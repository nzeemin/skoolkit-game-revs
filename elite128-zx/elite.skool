 $8A1E JR C,$8A30    ;
 $8A20 CP $78        ; 'x'
 $8A22 JR NC,$8A2C   ;
 $8A24 LD A,B        ;
 $8A25 CP $63        ; 'c'
 $8A27 RET Z         ;
 $8A28 LD A,$02      ;
 $8A2A JR $8A36      ;
*$8A2C LD A,$63      ; 'c'
 $8A2E JR $8A36      ;
*$8A30 LD A,B        ;
 $8A31 CP $04        ;
 $8A33 RET NZ        ;
 $8A34 LD A,$06      ;
*$8A36 LD ($7062),A  ; set IndDanger
 $8A39 RET           ;

