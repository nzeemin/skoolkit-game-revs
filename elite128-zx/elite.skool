; Data block at DA0B
@label=RadiusBlast
b$DA0B DEFB $00      ; circle radius when printing an explosion
@label=PilotMission2
 $DA0C DEFB $00,$00  ; =3 the Asp from mission 2 is destroyed / there is a
                     ; canister with the cloak in space =2 the Asp's
                     ; invisibility is off =1 mission 2 given =0 while moving
                     ; on the J-drive
@label=FrameCounter
 $DA0E DEFB $00      ; ship-appearance counter???? frame counter
@label=J_Drive_Ready4
 $DA0F DEFB $00      ; =1 an object nearby is blocking the J-drive <>0 J-drive
                     ; unavailable
@label=EnergyBombUsed
 $DA10 DEFB $00      ; <>0, =1, =$FF energy bomb exploded
@label=FlgObjNear
 $DA11 DEFB $00      ; <>0 there is some object nearby
@label=ObjInTarget
 $DA12 DEFB $00,$00  ; <>0 there is something in the crosshair (object
                     ; number???)
@label=PlayerPirate
 $DA14 DEFB $00      ; =1 the player attacked a peaceful trader/station/police.
                     ; enable aggression
@label=ManualDocking
 $DA15 DEFB $00      ; =0 when leaving the planet <>0 manual docking
                     ; started????
@label=TimeWorkECM
 $DA16 DEFB $00      ; remaining system runtime =0 ECM off
@label=DamageEnergyUnit
 $DA17 DEFB $00      ; damage to the energy units
@label=DamageFrontShield
 $DA18 DEFB $00      ; damage to the front shields
@label=DamageRearShield
 $DA19 DEFB $00      ; damage to the rear shields
@label=FlgCoriolisNear
 $DA1A DEFB $00      ; <>0 there is a station nearby
@label=nMissileObj
 $DA1B DEFB $00      ; number of missiles in space >=4, random ships don't
                     ; appear
@label=InverseNumSlotIX
 $DA1C DEFB $00      ; reverse slot number of the object whose slot address is
                     ; in IX (possibly targeted)

; MoveAllObjects
;
; Used by the routine at #R$7287.
;
; .
;
; Process all objects in space
; .
; In: ---
; .
; Out: ix,iy,hl,de,bc,a - undefined
c$DA1D LD A,($A871)   ; get PilotMission3
 $DA20 CP $04         ;
 $DA22 JR NZ,$DA29    ;
 $DA24 LD HL,$6069    ; 2,=1 Coriolis is hostile
 $DA27 SET 2,(HL)     ;
*$DA29 LD A,($707B)   ; get TypeOfPrint
 $DA2C AND A          ;
 $DA2D LD A,$B1       ; or c
 $DA2F JR Z,$DA33     ; adjust the line-printing routine
 $DA31 LD A,$A9       ; xor c
*$DA33 LD ($F203),A   ; adjust the line-printing routine
 $DA36 LD ($F231),A   ;
 $DA39 LD ($F27E),A   ;
 $DA3C LD ($F252),A   ;
 $DA3F LD A,($DA0E)   ; get FrameCounter
 $DA42 DEC A          ;
 $DA43 LD ($DA0E),A   ; set FrameCounter
 $DA46 LD B,A         ;
 $DA47 LD A,($7077)   ; get CoriolisNear
 $DA4A AND A          ;
 $DA4B JR NZ,$DA5F    ;
 $DA4D LD A,($7061)   ; get InFreeSpace
 $DA50 AND A          ;
 $DA51 JR NZ,$DA5F    ;
 $DA53 LD A,($DA1B)   ; get nMissileObj
 $DA56 CP $04         ;
 $DA58 JR NC,$DA5F    ;
 $DA5A LD A,B         ;
 $DA5B AND A          ;
 $DA5C CALL Z,$F2CA   ; set rnd ship
*$DA5F XOR A          ;
 $DA60 LD ($DA17),A   ; set DamageEnergyUnit
 $DA63 LD ($DA19),A   ; set DamageRearShield
 $DA66 LD ($DA18),A   ; set DamageFrontShield
 $DA69 LD ($DA12),A   ; set ObjInTarget
 $DA6C LD ($DA1A),A   ; set FlgCoriolisNear
 $DA6F LD ($DA11),A   ; set FlgObjNear
 $DA72 LD ($DA0F),A   ; set J_Drive_Ready4
 $DA75 LD C,A         ; c=0
 $DA76 LD IX,$6048    ; length 27h
 $DA7A LD DE,$0027    ; '''
 $DA7D LD B,$06       ; c=0
*$DA7F ADD IX,DE      ;
 $DA81 LD A,(IX+$22)  ;
 $DA84 AND A          ;
 $DA85 JR Z,$DA8E     ; next
 $DA87 BIT 6,(IX+$20) ;
 $DA8B JR Z,$DA8E     ; next (not a missile)
 $DA8D INC C          ;
*$DA8E DJNZ $DA7F     ;
 $DA90 LD A,C         ; a,c number of missiles
 $DA91 LD ($DA1B),A   ; set nMissileObj
 $DA94 LD IX,$6048    ; length 27h
 $DA98 LD A,$08       ;
*$DA9A PUSH AF        ;
 $DA9B LD B,A         ;
 $DA9C LD ($DA1C),A   ; set InverseNumSlotIX
 $DA9F LD A,(IX+$22)  ;
 $DAA2 AND A          ;
 $DAA3 JP Z,$DBBE     ; next object
 $DAA6 LD ($DA11),A   ; set FlgObjNear
 $DAA9 BIT 2,(IX+$26) ;
 $DAAD JR NZ,$DAB2    ;
 $DAAF LD ($DA1A),A   ; set FlgCoriolisNear
*$DAB2 LD A,($DA0E)   ; get FrameCounter
 $DAB5 LD C,A         ;
 $DAB6 BIT 3,(IX+$26) ;
 $DABA JR NZ,$DAC1    ;
 $DABC LD A,$01       ;
 $DABE LD ($DA0F),A   ; set J_Drive_Ready4
*$DAC1 LD A,($DA10)   ; get EnergyBombUsed
 $DAC4 AND A          ;
 $DAC5 JR Z,$DAD8     ;
 $DAC7 BIT 2,(IX+$26) ;
 $DACB JR NZ,$DAD8    ;
 $DACD LD A,(IY+$06)  ; iy - start address of the ship descriptor, the previous
                      ; one???
 $DAD0 CP $27         ; '''
 $DAD2 JR Z,$DAD8     ;
 $DAD4 SET 4,(IX+$20) ;
*$DAD8 BIT 2,(IX+$21) ;
 $DADC JR Z,$DAEA     ; object is not aggressive
 $DADE LD A,(IX+$21)  ;
 $DAE1 AND $60        ; '`'
 $DAE3 JR Z,$DAEA     ;
 $DAE5 LD A,$01       ;
 $DAE7 LD ($DA14),A   ; set PlayerPirate
*$DAEA LD A,($617B)   ; missile descriptor +$22
 $DAED AND A          ;
 $DAEE JR NZ,$DAF6    ; if there is at least one missile, enable aggression
 $DAF0 LD A,($DA14)   ; get PlayerPirate
 $DAF3 AND A          ; if the invisibility cloak is on, enable aggression
 $DAF4 JR Z,$DAFA     ;
*$DAF6 SET 2,(IX+$21) ;
*$DAFA LD H,(IX+$24)  ;
 $DAFD LD L,(IX+$23)  ;
 $DB00 PUSH HL        ;
 $DB01 POP IY         ; iy address of the object data
 $DB03 LD A,(IX+$20)  ;
 $DB06 AND $30        ; '0'
 $DB08 JR Z,$DB71     ; ????
 $DB0A SUB $20        ; ' '
 $DB0C JP NZ,$DBA3    ; ????
 $DB0F RES 5,(IX+$20) ;
 $DB13 LD (IX+$1E),A  ; =0
 $DB16 LD A,$C0       ;
 $DB18 LD (IX+$1D),A  ;
 $DB1B BIT 0,(IX+$26) ;
 $DB1F JR NZ,$DB43    ; branch if it's a missile
 $DB21 LD HL,$707D    ; which sound to play =$00 no sound (silent) 0,=1 energy
                      ; bomb exploded 1,=1 missile launched 2,=1 colliding with
                      ; an object/object destroyed 3,=1 laser fired 4,=1 laser
                      ; fired 5,=1 ECM working 6,=1 hit by laser on the
                      ; player/docking damage 7,=1
 $DB24 SET 2,(HL)     ;
 $DB26 LD A,($DA0C)   ; get PilotMission2
 $DB29 AND A          ;
 $DB2A JR Z,$DB43     ; destroy the object
 $DB2C CP $03         ;
 $DB2E JR Z,$DB38     ; the Asp from mission 2 was destroyed
 $DB30 BIT 6,(IX+$26) ;
 $DB34 JR Z,$DB43     ; destroy the object
 $DB36 JR $DB3F       ;
*$DB38 LD A,(IY+$01)  ; the Asp from mission 2 was destroyed
 $DB3B CP $1E         ;
 $DB3D JR NZ,$DB43    ; destroy the object
*$DB3F XOR A          ;
 $DB40 LD ($DA0C),A   ; set PilotMission2
*$DB43 XOR A          ; destroy the object
 $DB44 LD (IX+$22),A  ;
 $DB47 CALL $EB65     ; object has disappeared from space (destroyed/flown
                      ; off). Untarget the missile and destroy any missiles
                      ; fired at this object
 $DB4A LD D,(IY+$09)  ;
 $DB4D LD E,(IY+$08)  ;
 $DB50 CALL $A900     ; increase the money amount
 $DB53 LD D,(IY+$16)  ;
 $DB56 LD E,(IY+$15)  ;
 $DB59 SRL D          ;
 $DB5B RR E           ;
 $DB5D CALL $A8EE     ; increase combat rating
 $DB60 LD A,(IX+$21)  ;
 $DB63 AND $60        ; '`'
 $DB65 JR Z,$DBBE     ; next object
 $DB67 LD A,($A821)   ; pilot's legal status 0 - clean 1..31h offender 32h..FFh
                      ; fugitive
 $DB6A OR $40         ; '@'
 $DB6C LD ($A821),A   ; pilot's legal status 0 - clean 1..31h offender 32h..FFh
                      ; fugitive
 $DB6F JR $DBBE       ; next object
*$DB71 LD A,B         ; b - reverse slot number of the object whose slot
                      ; address is in IX c - ship-appearance counter????
 $DB72 XOR C          ;
 $DB73 AND $0F        ;
 $DB75 BIT 6,(IX+$20) ;
 $DB79 JR Z,$DB8B     ; object is not controlled
 $DB7B BIT 0,(IX+$26) ;
 $DB7F JR Z,$DB86     ; not a missile
 $DB81 CALL $F928     ; this is a missile
 $DB84 JR $DB8B       ;
*$DB86 AND $03        ;
 $DB88 CALL Z,$F733   ; object's reaction to the player. Launching missiles,
                      ; ships, escape capsule, etc.
*$DB8B CALL $DCE0     ; recalculate object coordinates
 $DB8E CALL $E791     ; align the Y axis to be orthogonal to the X axis
 $DB91 PUSH IX        ;
 $DB93 LD DE,$0009    ;
 $DB96 ADD IX,DE      ;
 $DB98 CALL $DCA3     ; x=x*l y=y*l z=z*l, ix=ix+6
 $DB9B CALL $DCA3     ; x=x*l y=y*l z=z*l, ix=ix+6
 $DB9E CALL $DCA3     ; x=x*l y=y*l z=z*l, ix=ix+6
 $DBA1 POP IX         ;
*$DBA3 CALL $EA51     ; check for collision of the object with the player, and
                      ; handle it
 $DBA6 CALL $E008     ; compute visibility and print the object
 $DBA9 RES 3,(IX+$20) ;
 $DBAD LD A,(IX+$20)  ;
 $DBB0 AND $30        ; '0'
 $DBB2 CP $10         ;
 $DBB4 JR NZ,$DBBE    ; next object
 $DBB6 SET 5,(IX+$20) ;
 $DBBA RES 4,(IX+$20) ;
*$DBBE POP AF         ; next object
 $DBBF LD DE,$0027    ; '''
 $DBC2 ADD IX,DE      ;
 $DBC4 DEC A          ;
 $DBC5 JP NZ,$DA9A    ;
 $DBC8 XOR A          ;
 $DBC9 LD ($DA10),A   ; set EnergyBombUsed
 $DBCC LD A,($DA0F)   ; get J_Drive_Ready4
 $DBCF AND A          ;
 $DBD0 RET NZ         ;
 $DBD1 LD ($DA14),A   ; set PlayerPirate
 $DBD4 RET            ;

; CalcLenVector
;
; Used by the routine at #R$F9FA.
;
; .
;
; Compute vector length and normalize the vector
; .
; In: ix - address of the vector's per-axis lengths
; .
; Out: de=sqrt(dX^2+dY^2+dZ^2) vector length
; .
; (ix) - normalized vector coordinates
; .
; a =$00
c$DBD5 PUSH IX       ;
 $DBD7 CALL $DBFA    ; squaring
 $DBDA PUSH HL       ;
 $DBDB CALL $DBFA    ; squaring
 $DBDE PUSH HL       ;
 $DBDF CALL $DBFA    ; squaring
 $DBE2 POP DE        ;
 $DBE3 ADD HL,DE     ;
 $DBE4 POP DE        ;
 $DBE5 ADD HL,DE     ;
 $DBE6 POP IX        ; hl=dX^2+dY^2+dZ^2
 $DBE8 CALL $DC53    ; extract the square root h=sqr(hl)
 $DBEB EX DE,HL      ; de=sqrt(dX^2+dY^2+dZ^2)
 $DBEC PUSH IX       ;
 $DBEE CALL $DC31    ; dX = dX / sqrt(dX^2+dY^2+dZ^2) / 2
 $DBF1 CALL $DC31    ; dY = dY / sqrt(dX^2+dY^2+dZ^2) / 2
 $DBF4 CALL $DC31    ; dZ = dZ / sqrt(dX^2+dY^2+dZ^2) / 2
 $DBF7 POP IX        ;
 $DBF9 RET           ;

; Sqr_HL_wordAdrIX
;
; Used by the routine at #R$DBD5.
;
; .
;
; Squaring
; .
; In: HL = high(word(ix+0/1)^2)
c$DBFA LD B,(IX+$01) ;
 $DBFD LD C,(IX+$00) ;
 $DC00 RES 7,B       ;
 $DC02 PUSH IX       ;
 $DC04 LD IX,$0000   ;
 $DC08 CALL $E45D    ; Approximate table-based multiplication HL=B*C
 $DC0B XOR A         ;
 $DC0C LD D,A        ;
 $DC0D ADD HL,HL     ;
 $DC0E RL D          ;
 $DC10 LD E,H        ;
 $DC11 ADD IX,DE     ;
 $DC13 LD H,L        ;
 $DC14 LD L,A        ;
 $DC15 PUSH HL       ;
 $DC16 LD H,$BE      ;
 $DC18 LD L,B        ;
 $DC19 LD E,(HL)     ;
 $DC1A INC H         ;
 $DC1B LD D,(HL)     ;
 $DC1C DEC H         ;
 $DC1D ADD IX,DE     ;
 $DC1F LD L,C        ;
 $DC20 LD E,(HL)     ;
 $DC21 INC H         ;
 $DC22 LD D,(HL)     ;
 $DC23 POP HL        ;
 $DC24 ADD HL,DE     ;
 $DC25 JR NC,$DC29   ;
 $DC27 INC IX        ;
*$DC29 EX (SP),IX    ;
 $DC2B POP HL        ;
 $DC2C INC IX        ;
 $DC2E INC IX        ;
 $DC30 RET           ;

; CaclNormalVector
;
; Used by the routine at #R$DBD5.
;
; .
;
; Normalize the vector
; .
; In: ix - address of the dX/dY/dZ variable
; .
; de - vector length (divisor)
; .
; a =$00
; .
; Out: (ix) - normalized vector coordinate
; .
; ix=ix+2
; .
; bc - undefined
; .
; a =$00
c$DC31 LD H,(IX+$01) ;
 $DC34 LD L,(IX+$00) ;
 $DC37 PUSH HL       ;
 $DC38 RES 7,H       ;
 $DC3A CALL $E8CF    ; fixed-point division hl.a/de
 $DC3D SRL B         ;
 $DC3F RR C          ; b.c = hl.a/de/2
 $DC41 POP HL        ;
 $DC42 BIT 7,H       ;
 $DC44 JR Z,$DC48    ;
 $DC46 SET 7,B       ;
*$DC48 LD (IX+$00),C ;
 $DC4B LD (IX+$01),B ;
 $DC4E INC IX        ;
 $DC50 INC IX        ;
 $DC52 RET           ;

; Sqrt_H_HL
;
; Used by the routines at #R$8A5A, #R$AD45 and #R$DBD5.
;
; .
;
; Extract the square root h=sqr(hl)
; .
; In: hl - number
; .
; Out: h - result
; .
; l - remainder
; .
; a=0
; .
; de,bc - undefined
c$DC53 LD A,H        ;
 $DC54 CP $10        ;
 $DC56 JR NC,$DC7A   ;
 $DC58 AND A         ;
 $DC59 JR Z,$DC6C    ;
 $DC5B LD B,$04      ;
*$DC5D ADD HL,HL     ;
 $DC5E DJNZ $DC5D    ;
 $DC60 CALL $DC7A    ;
 $DC63 SRL H         ;
 $DC65 RR L          ;
 $DC67 SRL H         ;
 $DC69 RR L          ;
 $DC6B RET           ;
*$DC6C LD H,L        ;
 $DC6D LD L,A        ;
 $DC6E CALL $DC7A    ;
 $DC71 LD B,$04      ;
*$DC73 SRL H         ;
 $DC75 RR L          ;
 $DC77 DJNZ $DC73    ;
 $DC79 RET           ;
*$DC7A XOR A         ;
 $DC7B PUSH HL       ;
 $DC7C PUSH HL       ;
 $DC7D SRL H         ;
 $DC7F RR L          ;
 $DC81 RRA           ;
 $DC82 LD DE,$8000   ;
 $DC85 CALL $DC97    ;
 $DC88 POP DE        ;
 $DC89 CALL $DC8D    ;
 $DC8C POP DE        ;
*$DC8D RR H          ;
 $DC8F RR L          ;
 $DC91 EX DE,HL      ;
 $DC92 SRL H         ;
 $DC94 RR L          ;
 $DC96 RRA           ;
*$DC97 PUSH DE       ;
 $DC98 CALL $E8CF    ; fixed-point division hl.a/de
 $DC9B SRL B         ;
 $DC9D RR C          ;
 $DC9F XOR A         ;
 $DCA0 POP HL        ;
 $DCA1 ADD HL,BC     ;
 $DCA2 RET           ;

; CorrAxisVector
;
; Used by the routines at #R$DA1D and #R$DFDD.
;
; .
;
; Normalize the vector (correcting small computation errors)
; .
; In: ix - vector start address
; .
; Out: ix=ix+6
; .
; hl,de,bc,a - undefined
c$DCA3 LD H,$BF      ;
 $DCA5 LD L,(IX+$01) ; hl address of the squares table (high bytes)
 $DCA8 SLA L         ;
 $DCAA LD A,(HL)     ;
 $DCAB LD L,(IX+$03) ;
 $DCAE SLA L         ;
 $DCB0 ADD A,(HL)    ;
 $DCB1 LD L,(IX+$05) ;
 $DCB4 SLA L         ;
 $DCB6 ADD A,(HL)    ;
 $DCB7 SRA A         ;
 $DCB9 SRA A         ; hi(dx)^2+hi(dy)^2+hi(dz)^2
 $DCBB NEG           ;
 $DCBD XOR $80       ;
 $DCBF LD B,A        ;
 $DCC0 CALL $DCC6    ;
 $DCC3 CALL $DCC6    ;

; Routine at DCC6
;
; Used by the routine at #R$DCA3.
c$DCC6 LD C,(IX+$01) ;
 $DCC9 SLA C         ;
 $DCCB CALL $E45D    ; Approximate table-based multiplication HL=B*C
 $DCCE SLA H         ;
 $DCD0 SLA (IX+$01)  ;
 $DCD4 RR H          ;
 $DCD6 LD (IX+$01),H ;
 $DCD9 INC IX        ;
 $DCDB INC IX        ;
 $DCDD RET           ;

