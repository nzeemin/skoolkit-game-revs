; KeyCtrl_Move
;
; Used by the routine at #R$FF25.
;
; .
;
; Handle control key presses: turning and speed
; .
; In: ----
; .
; Out: (AngleLeftRight), (AngleUpDown) new rotation angles
; .
; (DeltaSpeed) new speed
c$FE01 LD A,($7041)  ; get WhatOnScreen
 $FE04 CP $04        ;
 $FE06 RET NC        ;
 $FE07 LD A,($FC0F)  ; get ControlKeyMove
 $FE0A LD B,A        ;
 $FE0B LD A,($FC14)  ; get FlagsSetUp
