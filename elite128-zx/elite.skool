 $E38E XOR D         ;
 $E38F AND $80       ;
 $E391 LD D,A        ;
 $E392 LD (IY+$15),D ;
 $E395 CALL $E424    ; signed addition
 $E398 LD L,A        ;
 $E399 LD E,(IY+$16) ;
 $E39C LD D,(IY+$17) ;
 $E39F LD A,B        ;
 $E3A0 RLA           ;
 $E3A1 XOR D         ;
 $E3A2 AND $80       ;
 $E3A4 LD D,A        ;
 $E3A5 LD (IY+$17),D ;
 $E3A8 CALL $E424    ; signed addition
 $E3AB LD L,A        ;
 $E3AC LD DE,$0006   ;
 $E3AF ADD IY,DE     ;
 $E3B1 JP $E40C      ;
*$E3B4 LD B,(IX+$00) ;
 $E3B7 CALL $E447    ; multiply the coordinate by a matrix element, accounting
                     ; for the vertex coordinate scaling factor
 $E3BA LD A,(IX+$03) ;
 $E3BD XOR (IY+$01)  ;
 $E3C0 RLA           ;
 $E3C1 RR H          ;
 $E3C3 LD (IY+$12),L ;
 $E3C6 LD (IY+$13),H ;
 $E3C9 EX DE,HL      ;
 $E3CA INC IY        ;
 $E3CC INC IY        ;
 $E3CE LD B,(IX+$01) ;
 $E3D1 CALL $E447    ; multiply the coordinate by a matrix element, accounting
                     ; for the vertex coordinate scaling factor
 $E3D4 LD A,(IX+$03) ;
 $E3D7 RLA           ;
 $E3D8 XOR (IY+$01)  ;
 $E3DB RLA           ;
 $E3DC RR H          ;
 $E3DE LD (IY+$12),L ;
 $E3E1 LD (IY+$13),H ;
 $E3E4 CALL $E424    ; signed addition
 $E3E7 LD L,A        ;
 $E3E8 EX DE,HL      ;
 $E3E9 INC IY        ;
 $E3EB INC IY        ;
 $E3ED LD B,(IX+$02) ;
 $E3F0 CALL $E447    ; multiply the coordinate by a matrix element, accounting
                     ; for the vertex coordinate scaling factor
 $E3F3 LD A,(IX+$03) ;
 $E3F6 RLA           ;
 $E3F7 RLA           ;
 $E3F8 XOR (IY+$01)  ;
 $E3FB RLA           ;
 $E3FC RR H          ;
 $E3FE LD (IY+$12),L ;
 $E401 LD (IY+$13),H ;
 $E404 CALL $E424    ; signed addition
 $E407 LD L,A        ;
 $E408 INC IY        ;
 $E40A INC IY        ;
*$E40C LD A,($E2EF)  ; get VertexIncFactor
 $E40F LD B,A        ;
 $E410 XOR A         ;
 $E411 LD C,H        ;
 $E412 RES 7,H       ;
*$E414 SRL H         ;
 $E416 RR L          ;
 $E418 RRA           ;
