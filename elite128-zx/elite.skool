 $BD0F LD ($BCF9),A  ;
 $BD12 CP $1F        ;
 $BD14 RET C         ;
 $BD15 LD A,$20      ; ' '
 $BD17 CP B          ;
 $BD18 JP Z,$BD5D    ; print the built string
 $BD1B CALL $BDC6    ; find the first space from the end of the line
 $BD1E LD A,B        ;
 $BD1F LD ($BCF8),A  ;
 $BD22 AND A         ;
 $BD23 JR Z,$BD52    ;
 $BD25 LD HL,($BCF6) ;
 $BD28 INC HL        ;
 $BD29 LD C,B        ;
 $BD2A LD B,$00      ;
 $BD2C LD DE,$7023   ;
 $BD2F LDIR          ;
 $BD31 LD HL,$7003   ;
 $BD34 LD A,($BCF8)  ;
 $BD37 LD E,A        ;
 $BD38 LD D,$00      ;
 $BD3A ADD HL,DE     ;
 $BD3B LD ($BCFA),HL ;
 $BD3E LD A,($BCF8)  ;
 $BD41 CP $1F        ;
 $BD43 JP NC,$BD5D   ; print the built string
 $BD46 LD HL,($BCF6) ;
 $BD49 LD B,A        ;
*$BD4A LD (HL),$00   ;
 $BD4C INC HL        ;
 $BD4D DJNZ $BD4A    ;
 $BD4F LD A,($BCF8)  ;
*$BD52 PUSH AF       ;
 $BD53 CALL $BDC6    ; find the first space from the end of the line
 $BD56 CALL $D000    ; search for a zero starting from address (#R$BCF6)
 $BD59 POP AF        ;
 $BD5A DEC A         ;
 $BD5B JR NZ,$BD52   ;

; PrintMsgDescr
;
; Used by the routines at #R$BCFC and #R$BDB9.
;
; .
;
; Print the built string
; .
; In: ---
; .
; Out: bc =$0020
; .
; hl,de,a - undefined
c$BD5D LD HL,$7004   ;
 $BD60 LD B,$1E      ;
*$BD62 PUSH BC       ;
 $BD63 PUSH HL       ;
 $BD64 LD A,(HL)     ;
 $BD65 CALL $BB58    ; print one character
 $BD68 POP HL        ;
 $BD69 INC HL        ;
 $BD6A POP BC        ;
 $BD6B DJNZ $BD62    ;
 $BD6D CALL $AFFA    ; set the print-register flag, reset X coordinate,
                     ; increment Y coordinate
 $BD70 LD A,$00      ;
 $BD72 LD ($A892),A  ; set FlgPrnSym2
; This entry point is used by the routine at #R$BD9D.
*$BD75 LD HL,($BCFA) ;
 $BD78 LD ($BCF6),HL ;
 $BD7B LD HL,$7003   ;
 $BD7E LD ($BCFA),HL ;
 $BD81 LD A,($BCF8)  ;
 $BD84 LD ($BCF9),A  ;
 $BD87 XOR A         ;
 $BD88 LD ($BCF8),A  ;
 $BD8B LD B,$1E      ;
 $BD8D LD C,$20      ; ' '
 $BD8F LD HL,$7023   ;
 $BD92 LD DE,$7004   ;
*$BD95 LD A,(HL)     ;
 $BD96 LD (DE),A     ;
 $BD97 LD (HL),C     ;
 $BD98 INC HL        ;
 $BD99 INC DE        ;
 $BD9A DJNZ $BD95    ;
 $BD9C RET           ;

; ClearDescrMsg
;
; .
;
; .
;
; Clear the description lines and set variables
; .
; In: ---
; .
; Out: bc =$0020
; .
; hl,de,a - undefined
c$BD9D LD A,$01      ;
 $BD9F LD ($A894),A  ; set FlgPrnDescr
 $BDA2 LD B,$1F      ;
 $BDA4 LD A,$20      ; ' '
 $BDA6 LD HL,$7023   ;
*$BDA9 LD (HL),A     ;
 $BDAA INC HL        ;
 $BDAB DJNZ $BDA9    ;
 $BDAD LD HL,$7003   ;
 $BDB0 LD ($BCFA),HL ;
 $BDB3 XOR A         ;
 $BDB4 LD ($BCF8),A  ;
 $BDB7 JR $BD75      ;

; CloseDescrMsg
;
; .
;
; .
;
; Finish printing the planet description
; .
; In: ---
; .
; Out: hl,de,bc,a - undefined
c$BDB9 LD A,$00      ;
 $BDBB LD ($A894),A  ; set FlgPrnDescr
 $BDBE LD A,($BCF9)  ;
 $BDC1 AND A         ;
 $BDC2 CALL NZ,$BD5D ; print the built string
 $BDC5 RET           ;

; FindLastSpace
;
; Used by the routine at #R$BCFC.
;
; .
;
; Find the first space from the end of the line
; .
; In: (AdrInMsgDescr2) - address of the last character in the line
; .
; Out: b - number of characters from the end of the line to the space,
; including the space
; .
; (AdrInMsgDescr2) - address of the last space in the line
c$BDC6 LD HL,($BCF6) ;
 $BDC9 LD B,$00      ;
*$BDCB DEC HL        ;
 $BDCC LD A,(HL)     ;
 $BDCD INC B         ;
 $BDCE CP $20        ; ' '
 $BDD0 JR NZ,$BDCB   ;
 $BDD2 LD ($BCF6),HL ;
 $BDD5 LD DE,$7004   ;
 $BDD8 AND A         ;
 $BDD9 SBC HL,DE     ;
 $BDDB RET NC        ;
 $BDDC LD HL,$7022   ;
 $BDDF LD ($BCF6),HL ;
 $BDE2 JR $BDC6      ; find the first space from the end of the line

; ECM_On
;
; Used by the routine at #R$ED3F.
;
; .
;
; Turn on the ECM system, if available
c$BDE4 LD A,C        ;
 $BDE5 AND A         ;
 $BDE6 RET Z         ;
 $BDE7 BIT 4,B       ;
 $BDE9 RET Z         ;
 $BDEA OR $80        ;
 $BDEC LD ($A847),A  ; set PilotECMSystem
 $BDEF LD A,$0A      ;
 $BDF1 LD ($DA16),A  ; set TimeWorkECM
 $BDF4 RET           ;

; Unused
s$BDF5 DEFS $0B
