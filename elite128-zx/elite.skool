; Div_C_DEc_HLa
;
; Used by the routines at #R$E008 and #R$E5CB.
;
; .
;
; Division: 0.c=cde/ahl (if cde>ahl -> c=$FF)
; .
; In: de.c - dividend
; .
; hl.a - divisor
; .
; Out: 0.c=dec/hla
; .
; cde>ahl -> c=$FF
; .
; hl,de,b,a - undefined
c$E592 LD B,$09      ;
*$E594 DEC B         ;
 $E595 JR Z,$E5AD    ;
 $E597 RLA           ;
 $E598 ADC HL,HL     ;
 $E59A JR C,$E5A9    ;
 $E59C RL C          ;
 $E59E RL E          ;
 $E5A0 RL D          ;
 $E5A2 JR NC,$E594   ;
 $E5A4 RR D          ;
 $E5A6 RR E          ;
 $E5A8 SCF           ;
*$E5A9 RR H          ;
 $E5AB RR L          ;
*$E5AD LD A,D        ;
 $E5AE LD C,$FF      ;
 $E5B0 CP H          ;
 $E5B1 RET NC        ;
 $E5B2 LD B,H        ;
 $E5B3 DEC C         ;

; CalcDeltaCrdLine2
;
; Used by the routine at #R$F0CC.
;
; .
;
; Calculate the coordinate step coefficient when printing a line
; .
; In: a - smaller coordinate difference
; .
; b - larger coordinate difference
; .
; c=$FE
; .
; e=$00
; .
; Out: c - increment coefficient along the shorter axis
c$E5B4 SLA E         ;
 $E5B6 RLA           ;
 $E5B7 JR C,$E5C1    ;
 $E5B9 CP B          ;
 $E5BA JR NC,$E5C1   ;
 $E5BC SLA C         ;
 $E5BE RET NC        ;
 $E5BF JR $E5B4      ; calculate the coordinate step coefficient when printing
                     ; a line
*$E5C1 SUB B         ;
 $E5C2 SCF           ;
 $E5C3 RL C          ;
 $E5C5 RET NC        ;
 $E5C6 JR $E5B4      ; calculate the coordinate step coefficient when printing
                     ; a line

