; GenerateProductPrice
;
; Used by the routine at #R$D6B3.
;
; .
;
; Generate quantities and prices of goods at the station
; .
; In: ----
; .
; Called on arrival after every hyperspace jump, so the market re-rolls once
; per jump and then stays fixed while docked. Per good, with economy =
; PlanetEconomy (0-7) and rnd = PilotRnd: gradient = (economyFactor & $1F) *
; economy; quantity = (baseQty + (rnd & mask)) +/- gradient (sign from bit 7 of
; the economy factor byte), clamped to 0 and masked to 0-63; price = (basePrice
; + (rnd & mask)) +/- gradient with the OPPOSITE sign convention from quantity,
; then multiplied by 4 and stored in 0.1 Cr units (so an internal price of $13
; displays as 19*4/10 = 7.6 Cr). The same single random byte seasons every good
; on the station -- goods differ only via their own mask/base values/economy
; gradient.
; .
; GenerateAnotherPrice is an alternate entry point that skips drawing a fresh
; random byte and reuses the saved PilotRnd instead, used by InitGame so a
; loaded commander rebuilds the exact same market it had when saved.
c$AE96 LD A,($7063)  ; get RndWord
 $AE99 LD ($A82C),A  ; commander data offset +23 (PilotRnd)
; This entry point is used by the routine at #R$A976.
@label=GenerateAnotherPrice
*$AE9C LD HL,$A860   ; the same but without setting a new rnd
 $AE9F LD DE,$AF0E   ; goods prices at the station, in 0.1 Cr units
 $AEA2 EXX           ;
 $AEA3 LD HL,$91F2   ; table for generating goods quantities and prices at the
                     ; station: 17 x 4-byte templates in TableBasePrice (byte 0
                     ; = base price, byte 1 = economy factor: bits 0-4 gradient
                     ; multiplier, bit 7 gradient sign, byte 2 = base quantity,
                     ; byte 3 = random mask)
 $AEA6 LD B,$11      ;
*$AEA8 PUSH BC       ;
 $AEA9 LD E,(HL)     ;
 $AEAA INC HL        ;
 $AEAB LD A,(HL)     ;
 $AEAC LD D,A        ;
 $AEAD AND $1F       ;
 $AEAF JR Z,$AEBA    ;
 $AEB1 LD B,A        ;
 $AEB2 LD A,($AC4B)  ; Economy
 $AEB5 LD C,A        ;
 $AEB6 XOR A         ;
*$AEB7 ADD A,C       ;
 $AEB8 DJNZ $AEB7    ;
*$AEBA LD ($AE95),A  ;
 $AEBD INC HL        ;
 $AEBE LD B,(HL)     ;
 $AEBF INC HL        ;
 $AEC0 LD C,(HL)     ;
 $AEC1 INC HL        ;
 $AEC2 LD A,($A82C)  ; commander data offset +23 (PilotRnd)
 $AEC5 AND C         ;
 $AEC6 ADD A,B       ;
 $AEC7 LD B,A        ;
 $AEC8 LD A,($AE95)  ;
 $AECB BIT 7,D       ;
 $AECD JR NZ,$AED2   ;
 $AECF INC A         ;
 $AED0 NEG           ;
*$AED2 ADD A,B       ;
 $AED3 BIT 7,A       ;
 $AED5 JR Z,$AED8    ;
 $AED7 XOR A         ;
*$AED8 AND $3F       ; '?'
 $AEDA PUSH AF       ;
 $AEDB LD A,($A82C)  ; commander data offset +23 (PilotRnd)
 $AEDE AND C         ;
 $AEDF ADD A,E       ;
 $AEE0 LD B,A        ;
 $AEE1 LD A,($AE95)  ;
 $AEE4 BIT 7,D       ;
 $AEE6 JR Z,$AEEB    ;
 $AEE8 INC A         ;
 $AEE9 NEG           ;
*$AEEB ADD A,B       ;
 $AEEC LD C,A        ;
 $AEED LD B,$00      ;
 $AEEF SLA C         ;
 $AEF1 RL B          ;
 $AEF3 SLA C         ;
 $AEF5 RL B          ;
 $AEF7 PUSH BC       ;
 $AEF8 EXX           ;
 $AEF9 POP BC        ;
 $AEFA LD A,C        ;
 $AEFB LD (DE),A     ;
 $AEFC INC DE        ;
 $AEFD LD A,B        ;
 $AEFE LD (DE),A     ;
 $AEFF INC DE        ;
 $AF00 POP AF        ;
 $AF01 LD (HL),A     ;
 $AF02 INC HL        ;
 $AF03 EXX           ;
 $AF04 POP BC        ;
 $AF05 DJNZ $AEA8    ;
 $AF07 LD HL,$A870   ; +91 =0 the station was destroyed as part of the mission
 $AF0A LD (HL),B     ;
 $AF0B RET           ;

; Data block at AF0C
b$AF0C DEFB $00,$00
@label=ProductPrice
 $AF0E DEFB $BA,$3E,$20,$C3,$07,$BA,$CD,$07
 $AF16 DEFB $BA,$3E,$01,$32,$A7,$A7,$CD,$25
 $AF1E DEFB $AF,$3A,$23,$A7,$3C,$18,$11,$AF
 $AF26 DEFB $32,$22,$A7,$C9,$E1,$7E,$23,$E5
 $AF2E DEFB $32,$22
@label=CurrentGoodIndex
