; PrintCircleMap
;
; Used by the routines at #R$A9CA, #R$AB4E and #R$B27B.
;
; .
;
; Draw on the galaxy map a circle of the flight radius reachable with available
; fuel
; .
; In: (PrnCrdXCursor) - circle center coordinates
; .
; (RadiusCircleMap) - circle radius
; .
; Out: a =$00
; .
; hl,de,bc - undefined
; .
; After drawing the map marker, it immediately re-runs the same 32-byte patch
; loop using Data4CircleEngine instead of Data4CircleMap, repointing the shared
; circle engine at the 3D flight-view viewport constants before returning, so
; the very next PrnCircle_Fill call (for the sun/planet disc) draws correctly
; sized/positioned for that screen.
c$8461 LD B,$0C      ;
 $8463 LD A,($A813)  ; get PrnCrdXCursor
 $8466 LD C,A        ;
 $8467 SUB $80       ;
 $8469 JR C,$846F    ;
 $846B SET 0,B       ;
 $846D JR $8472      ;
*$846F LD A,$80      ;
 $8471 SUB C         ;
*$8472 LD ($7C3B),A  ; set CircleCrdX
 $8475 LD A,($A814)  ; get PrnCrdYCursor
 $8478 LD C,A        ;
 $8479 SUB $60       ; '`'
 $847B JR NC,$8482   ;
 $847D SET 1,B       ;
 $847F LD A,$60      ; '`'
 $8481 SUB C         ;
*$8482 LD ($7C3A),A  ; set CircleCrdY
 $8485 LD A,B        ;
 $8486 LD ($7C3C),A  ; set CircleFlg
 $8489 LD A,($A815)  ;
 $848C LD ($7C3D),A  ; set CircleRadius
 $848F DI            ;
 $8490 LD ($7C43),SP ;
 $8494 LD A,($7C4A)  ; number of bytes to modify in the circle-printing routine
 $8497 LD HL,$84C5   ; modify the routine
 $849A LD SP,$8505   ; addresses in the circle-printing routine to modify
*$849D POP DE        ;
 $849E LDI           ;
 $84A0 DEC A         ;
 $84A1 JR NZ,$849D   ;
 $84A3 LD SP,($7C43) ;
 $84A7 EI            ;
 $84A8 CALL $7CFE    ;
 $84AB DI            ;
 $84AC LD ($7C43),SP ;
 $84B0 LD A,($7C4A)  ; number of bytes to modify in the circle-printing routine
 $84B3 LD HL,$84E5   ; revert the routine modification
 $84B6 LD SP,$8505   ; addresses in the circle-printing routine to modify
*$84B9 POP DE        ;
 $84BA LDI           ;
 $84BC DEC A         ;
 $84BD JR NZ,$84B9   ;
 $84BF LD SP,($7C43) ;
 $84C3 EI            ;
 $84C4 RET           ;

