; BuyGoodCallback
;
; .
;
; .
;
; Transaction callback for the Buy screen, called by EnterQuantity after every
; digit. Snapshots state, then: stock -= qty (fail $B0 = quantity unavailable),
; pays qty x price via DecCASH in a loop (fail $C5 = insufficient cash), checks
; cargo-bay space via IsCargoBayGood and debits PilotFreeCargo if needed (fail
; $CE = no room), then PilotCargo[good] += qty (8-bit overflow also fails $CE),
; and finally calls SetLegalStatCargo. Any failure jumps to loc_B3E8 which
; prints the message and rolls the whole attempt back.
c$B3A1 CALL $B402    ;
 $B3A4 LD A,($B471)  ;
 $B3A7 LD B,A        ;
 $B3A8 LD HL,($AF35) ; address in the goods quantity table
 $B3AB LD A,(HL)     ;
 $B3AC SUB B         ;
 $B3AD JR C,$B3DE    ;
 $B3AF LD (HL),A     ;
*$B3B0 LD HL,($AF33) ; address in the goods price table
 $B3B3 LD E,(HL)     ;
 $B3B4 INC HL        ;
 $B3B5 LD D,(HL)     ;
 $B3B6 CALL $B877    ; decrease money (from 0 to 999.9)
 $B3B9 JR C,$B3E2    ;
 $B3BB DJNZ $B3B0    ;
 $B3BD CALL $B09D    ;
 $B3C0 LD A,($B471)  ;
 $B3C3 LD B,A        ;
 $B3C4 JR NC,$B3CE   ;
 $B3C6 LD HL,$A83E   ; remaining ship cargo capacity
 $B3C9 LD A,(HL)     ;
 $B3CA SUB B         ;
 $B3CB JR C,$B3E6    ;
 $B3CD LD (HL),A     ;
*$B3CE LD HL,($AF31) ; address in the goods quantity table
 $B3D1 LD A,(HL)     ;
 $B3D2 ADD A,B       ;
 $B3D3 JR C,$B3E6    ;
 $B3D5 LD (HL),A     ;
 $B3D6 LD A,($AF30)  ; good number
 $B3D9 CALL $A8D4    ; duplicate this routine
 $B3DC AND A         ;
 $B3DD RET           ;
; This entry point is used by the routine at #R$B501.
*$B3DE LD A,$B0      ;
 $B3E0 JR $B3E8      ;

; Routine at B3E2
;
; Used by the routines at #R$B3A1 and #R$B702.
c$B3E2 LD A,$C5      ;
 $B3E4 JR $B3E8      ;
; This entry point is used by the routine at #R$B3A1.
*$B3E6 LD A,$CE      ;
; Shared fail handler for both buy and sell: prints the message code left in A
; at print-column 3 followed by '?', then calls RollbackTradeState to undo the
; attempted transaction.
*$B3E8 PUSH AF       ;
 $B3E9 CALL $B00D    ; set the X print coordinate
 $B3EC INC BC        ;
 $B3ED POP AF        ;
 $B3EE CALL $BA9D    ; print a message from group 1 in the buffer/on screen
 $B3F1 CALL $BA99    ; print one character (print a message by number

; Data block at B3F4
b$B3F4 DEFB $3F

; Routine at B3F5
c$B3F5 CALL $B423    ;

; BeepPause24
;
; Used by the routines at #R$B39D and #R$D2E4.
;
; .
;
; Sound beep and a pause of $24
; .
; In: ----
; .
; Out: cy=1
; .
; a=$01
c$B3F8 CALL $AF39    ; sound beep
 $B3FB CALL $B0AF    ; Pause of the 24h interrupt
 $B3FE LD A,$01      ;
 $B400 SCF           ;
 $B401 RET           ;

; SnapshotTradeState
;
; Used by the routines at #R$B3A1, #R$B501 and #R$B5BB.
;
; .
;
; Saves PilotCash1, PilotCash2, the current good's stock byte, its hold byte,
; and PilotFreeCargo into word_B46A/word_B46C/byte_B46E/byte_B46F/byte_B470.
; Called first by every buy/sell transaction callback, so a later digit (or an
; abort) can cleanly undo a transaction already committed by a previous digit.
c$B402 LD HL,($A828) ; get PilotCash2
 $B405 LD ($B46C),HL ;
 $B408 LD HL,($A82A) ; get PilotCash1
 $B40B LD ($B46A),HL ;
 $B40E LD HL,($AF35) ; address in the goods quantity table
 $B411 LD A,(HL)     ;
 $B412 LD ($B46F),A  ;
 $B415 LD HL,($AF31) ; address in the goods quantity table
 $B418 LD A,(HL)     ;
 $B419 LD ($B46E),A  ;
 $B41C LD A,($A83E)  ; get PilotFreeCargo
 $B41F LD ($B470),A  ;
 $B422 RET           ;

; RollbackTradeState
;
; Used by the routines at #R$B324, #R$B333, #R$B3F5, #R$B6BB and #R$B71E.
;
; .
;
; Restores the five fields saved by SnapshotTradeState. Called by EnterQuantity
; between digits and on backspace, and by every transaction failure path.
c$B423 LD HL,($B46C) ;
 $B426 LD ($A828),HL ; set PilotCash2
 $B429 LD HL,($B46A) ;
 $B42C LD ($A82A),HL ; set PilotCash1
 $B42F LD HL,($AF35) ; address in the goods quantity table
 $B432 LD A,($B46F)  ;
 $B435 LD (HL),A     ;
 $B436 LD HL,($AF31) ; address in the goods quantity table
 $B439 LD A,($B46E)  ;
 $B43C LD (HL),A     ;
 $B43D LD A,($B470)  ;
 $B440 LD ($A83E),A  ; set PilotFreeCargo
 $B443 RET           ;

