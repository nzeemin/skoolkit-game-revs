; half_rClip_Down
;
; Used by the routines at #R$7E14, #R$7E60, #R$7EAE, #R$7ED8 and #R$85F4.
;
; .
;
; Print a half-circle by OR (circle extends past the right X boundary).
; .
; The midpoint/Bresenham error term and step deltas are kept in the alternate
; register set (hl', bc', e', reached via exx), freeing the primary registers
; for screen addressing.
; .
; In: b - left byte to print
; .
; c - right byte to print
; .
; hl - address to print the right byte
; .
; hl - address to print the left byte
; .
; e' =0
; .
; c' =0 minus radius
; .
; Out: hl,de,bc,hl',de',bc' - ????
c$7C4B PUSH AF       ;
 $7C4C EXX           ;
 $7C4D LD HL,$0000   ;
 $7C50 LD D,H        ;
 $7C51 LD B,$FF      ;
 $7C53 EXX           ;
 $7C54 LD A,$01      ;
 $7C56 LD ($7C48),A  ; set DirPrnCircle
 $7C59 LD A,($7C49)  ; get FillCircle
 $7C5C AND A         ;
 $7C5D JP NZ,$869C   ; print an unfilled half-circle by OR (circle extends past
                     ; the right X boundary)
 $7C60 JP $8331      ; print a filled half-circle by OR (circle extends past
                     ; the right X boundary)

