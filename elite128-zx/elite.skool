; Use_J_Drive
;
; Used by the routine at #R$7287.
;
; .
;
; Movement on the J-drive
c$9966 LD A,($FC10)  ; get ControlKey2
 $9969 BIT 6,A       ;
 $996B PUSH AF       ;
 $996C AND $BF       ;
 $996E LD ($FC10),A  ; set ControlKey2
 $9971 POP AF        ;
 $9972 RET Z         ;
 $9973 LD A,($88DC)  ; =1 J-drive unavailable (sun nearby)
 $9976 DEC A         ;
 $9977 RET Z         ;
 $9978 LD A,($88DD)  ; =1 J-drive unavailable (planet nearby)
 $997B DEC A         ;
 $997C RET Z         ;
