; ReCalcCrdObj
;
; Used by the routines at #R$779D and #R$DA1D.
;
; .
;
; Recalculate object coordinates
; .
; In: ix - start address of the object slot
; .
; (InverseNumSlotIX) - its reverse index in the slot list
; .
; Out: hl,de,bc,a - undefined
c$DCE0 CALL $DED1     ; update object coordinates from player movement
 $DCE3 BIT 2,(IX+$26) ;
 $DCE7 JR NZ,$DCEE    ; check the object's distance along Z
 $DCE9 LD A,L         ; check the object's distance along Z
 $DCEA CP $60         ; '`'
 $DCEC JR NC,$DCF3    ; the object has moved far away, remove it from space
*$DCEE LD A,H         ; check the object's distance along Z
 $DCEF AND $7F        ;
 $DCF1 JR Z,$DCFA     ; check the object's distance along X
*$DCF3 XOR A          ; the object has moved far away, remove it from space
 $DCF4 LD (IX+$22),A  ;
 $DCF7 JP $EB65       ; object has disappeared from space (destroyed/flown
                      ; off). Untarget the missile and destroy any missiles
                      ; fired at this object
*$DCFA LD A,(IX+$02)  ; check the object's distance along X
 $DCFD AND $7F        ;
 $DCFF JR NZ,$DCF3    ; the object has moved far away, remove it from space
 $DD01 LD A,(IX+$05)  ; check the object's distance along Y
 $DD04 AND $7F        ;
 $DD06 JR NZ,$DCF3    ; the object has moved far away, remove it from space
 $DD08 LD HL,($7042)  ; get HighAngleLR
 $DD0B LD ($DCDE),HL  ; ship rotation angle 7,n sign $00.$0F
 $DD0E PUSH IX        ;
 $DD10 LD DE,$0009    ;
 $DD13 ADD IX,DE      ; ix start address of the rotation angles
 $DD15 CALL $DE0B     ; rotate the OCS axis vector by the given angles
 $DD18 CALL $DE0B     ; rotate the OCS axis vector by the given angles
 $DD1B CALL $DE0B     ; rotate the OCS axis vector by the given angles
 $DD1E POP IX         ;
 $DD20 LD A,(IX+$1D)  ;
 $DD23 LD B,A         ;
 $DD24 BIT 7,A        ;
 $DD26 JR NZ,$DD33    ;
 $DD28 AND $0F        ;
 $DD2A LD A,$00       ;
 $DD2C JR Z,$DD3D     ;
 $DD2E LD A,B         ;
 $DD2F DEC A          ;
 $DD30 LD (IX+$1D),A  ;
*$DD33 LD A,$0C       ;
 $DD35 BIT 6,(IX+$1D) ;
 $DD39 JR Z,$DD3D     ;
 $DD3B ADD A,$80      ;
*$DD3D LD ($DCDE),A   ; ship rotation angle 7,n sign $00.$0F
 $DD40 LD A,(IX+$1E)  ;
 $DD43 LD B,A         ;
 $DD44 BIT 7,A        ;
 $DD46 JR NZ,$DD53    ;
 $DD48 AND $0F        ;
 $DD4A LD A,$00       ;
 $DD4C JR Z,$DD5D     ;
 $DD4E LD A,B         ;
 $DD4F DEC A          ;
 $DD50 LD (IX+$1E),A  ;
*$DD53 LD A,$08       ;
 $DD55 BIT 6,(IX+$1E) ;
 $DD59 JR Z,$DD5D     ;
 $DD5B ADD A,$80      ;
; This entry point is used by the routine at #R$DFDD.
*$DD5D LD ($DCDF),A   ; up/down rotation angle 7,n sign $00.$0F
 $DD60 PUSH IX        ;
 $DD62 CALL $DE88     ; rotate the like-named coordinates of the OCS axis
                      ; vectors by the given angles
 $DD65 CALL $DE88     ; rotate the like-named coordinates of the OCS axis
                      ; vectors by the given angles
 $DD68 CALL $DE88     ; rotate the like-named coordinates of the OCS axis
                      ; vectors by the given angles
 $DD6B POP IX         ;
 $DD6D LD A,(IX+$1C)  ;
 $DD70 AND A          ;
 $DD71 JR Z,$DD92     ;
 $DD73 LD B,(IX+$1B)  ;
 $DD76 ADD A,B        ;
 $DD77 BIT 7,A        ;
 $DD79 JR Z,$DD7E     ;
 $DD7B XOR A          ;
 $DD7C JR $DD8F       ;
*$DD7E LD C,(IY+$06)  ;
 $DD81 BIT 0,(IX+$21) ;
 $DD85 JR Z,$DD8B     ;
 $DD87 SLA C          ;
 $DD89 SLA C          ;
*$DD8B CP C           ;
 $DD8C JR C,$DD8F     ;
 $DD8E LD A,C         ;
*$DD8F LD (IX+$1B),A  ;
*$DD92 PUSH IX        ;
 $DD94 PUSH IY        ;
 $DD96 LD C,(IX+$1B)  ;
 $DD99 PUSH IX        ;
 $DD9B POP IY         ;
 $DD9D CALL $DDAB     ; update the object's global coordinates from its speed
 $DDA0 CALL $DDAB     ; update the object's global coordinates from its speed
 $DDA3 CALL $DDAB     ; update the object's global coordinates from its speed
 $DDA6 POP IY         ;
 $DDA8 POP IX         ;
 $DDAA RET            ;

; CalcNewCrdObjSpeed
;
; Used by the routine at #R$DCE0.
;
; .
;
; Update the object's global coordinates from its speed
; .
; In: ix=iy address of the object descriptor
; .
; c - object speed (ix+oSpeed)
; .
; Out: hl,de,a - undefined
c$DDAB PUSH BC       ;
 $DDAC LD D,(IX+$0A) ;
 $DDAF LD E,(IX+$09) ;
 $DDB2 CALL $DDD6    ; compute the increment for the object's global coordinate
                     ; high((d.e * speed*4)/$100+$FF) =34b =389/425t
 $DDB5 LD A,(IY+$02) ;
 $DDB8 LD H,(IY+$01) ;
 $DDBB LD L,(IY+$00) ;
 $DDBE CALL $DDF8    ; coordinate increment bh.l = ah.l + d.e
 $DDC1 LD (IY+$02),B ;
 $DDC4 LD (IY+$01),H ;
 $DDC7 LD (IY+$00),L ;
 $DDCA INC IY        ;
 $DDCC INC IY        ;
 $DDCE INC IY        ;
 $DDD0 INC IX        ;
 $DDD2 INC IX        ;
 $DDD4 POP BC        ;
 $DDD5 RET           ;

; CaclDeltaCrdObj
;
; Used by the routine at #R$DDAB.
;
; .
;
; Compute the increment for the object's global coordinate
; .
; high((d.e * speed*4)/$100+$FF)
; .
; =34b
; .
; =389/425t
; .
; In: de - coordinate n of the OCS X axis
; .
; c - object speed (ix+oSpeed)
; .
; Out: d.e - increment of the object's global coordinate
c$DDD6 SLA D         ;
 $DDD8 RL C          ;
 $DDDA RL C          ;
 $DDDC SRL D         ;
 $DDDE LD HL,$0000   ;
 $DDE1 LD B,$06      ;
*$DDE3 SRL D         ;
 $DDE5 RR E          ;
 $DDE7 SLA C         ;
 $DDE9 JR NC,$DDEC   ;
 $DDEB ADD HL,DE     ;
*$DDEC DJNZ $DDE3    ;
 $DDEE LD DE,$00FF   ;
 $DDF1 ADD HL,DE     ;
 $DDF2 LD E,H        ;
 $DDF3 SLA C         ;
 $DDF5 RR D          ;
 $DDF7 RET           ;

; CrdNAddDeltaCrd
;
; Used by the routine at #R$DDAB.
;
; .
;
; Coordinate increment bh.l = ah.l + d.e
; .
; In: ah.l - coordinate (7,a = sign)
; .
; d.e - coordinate increment (7,d = sign)
; .
; Out: bh.l - new coordinate (7,b - new sign)
c$DDF8 LD B,A        ;
 $DDF9 LD C,D        ;
 $DDFA XOR C         ;
 $DDFB RES 7,D       ;
 $DDFD JR NZ,$DE01   ;
 $DDFF ADD HL,DE     ;
 $DE00 RET           ;
*$DE01 SBC HL,DE     ;
 $DE03 RET NC        ;
 $DE04 ADD HL,DE     ;
 $DE05 EX DE,HL      ;
 $DE06 AND A         ;
 $DE07 SBC HL,DE     ;
 $DE09 LD B,C        ;
 $DE0A RET           ;

; RotateAxisSCO
;
; Used by the routine at #R$DCE0.
;
; .
;
; Rotate the OCS axis vector by the given angles
; .
; In: ix - address of the OCS axis vector
; .
; Out: ix=ix+6
; .
; de=$0006
; .
; bc,a - undefined
c$DE0B LD A,($DCDF)  ; up/down rotation angle 7,n sign $00.$0F
 $DE0E XOR $80       ;
 $DE10 SRA A         ;
 $DE12 RES 6,A       ;
 $DE14 LD C,A        ;
 $DE15 LD B,(IX+$03) ;
 $DE18 LD D,(IX+$05) ;
 $DE1B CALL $DE5D    ; compute the new coordinate of the object's
                     ; coordinate-system axis
 $DE1E LD (IX+$05),A ;
 $DE21 LD A,($DCDE)  ; ship rotation angle 7,n sign $00.$0F
 $DE24 XOR $80       ;
 $DE26 LD C,A        ;
 $DE27 LD B,(IX+$03) ;
 $DE2A LD D,(IX+$01) ;
 $DE2D CALL $DE5D    ; compute the new coordinate of the object's
                     ; coordinate-system axis
 $DE30 LD (IX+$01),A ;
 $DE33 LD A,($DCDE)  ; ship rotation angle 7,n sign $00.$0F
 $DE36 LD C,A        ;
 $DE37 LD B,(IX+$01) ;
 $DE3A LD D,(IX+$03) ;
 $DE3D CALL $DE5D    ; compute the new coordinate of the object's
                     ; coordinate-system axis
 $DE40 LD (IX+$03),A ;
 $DE43 LD A,($DCDF)  ; up/down rotation angle 7,n sign $00.$0F
 $DE46 SRA A         ;
 $DE48 RES 6,A       ;
 $DE4A LD C,A        ;
 $DE4B LD B,(IX+$05) ;
 $DE4E LD D,(IX+$03) ;
 $DE51 CALL $DE5D    ; compute the new coordinate of the object's
                     ; coordinate-system axis
 $DE54 LD (IX+$03),A ;
 $DE57 LD DE,$0006   ;
 $DE5A ADD IX,DE     ;
 $DE5C RET           ;

; CalcNewCrdNAxis
;
; Used by the routines at #R$DE0B and #R$DE88.
;
; .
;
; Compute the new coordinate of the object's coordinate-system axis
; .
; In: a,c - rotation angle
; .
; b - Y coordinate of the OCS axis
; .
; d - Z coordinate of the OCS axis
; .
; Out: a = crd(d) + crd(b) * angle(c)*2 (signs accounted for)
; .
; 7,a - sign
; .
; de,bc - undefined
c$DE5D PUSH DE       ;
 $DE5E XOR B         ;
 $DE5F SLA B         ;
 $DE61 RES 7,C       ;
 $DE63 LD E,A        ;
 $DE64 CALL $E434    ; A=((b+c)/2)^2-((b-c)/2)^2
 $DE67 POP BC        ;
 $DE68 LD C,A        ;
 $DE69 LD A,E        ;
 $DE6A XOR B         ;
 $DE6B SLA B         ;
 $DE6D RR E          ;
 $DE6F SLA C         ;
 $DE71 RLA           ;
 $DE72 LD A,B        ;
 $DE73 JR C,$DE7D    ;
 $DE75 ADD A,C       ;
 $DE76 JP NC,$DE84   ;
 $DE79 LD A,$FF      ;
 $DE7B JR $DE84      ;
*$DE7D SUB C         ;
 $DE7E JR NC,$DE84   ;
 $DE80 NEG           ;
 $DE82 RL E          ;
*$DE84 RL E          ;
 $DE86 RRA           ;
 $DE87 RET           ;

; RotateCrdNSCO
;
; Used by the routine at #R$DCE0.
;
; .
;
; Rotate the like-named coordinates of the OCS axis vectors by the given angles
; .
; In: ix - address of the first OCS axis vector's coordinate
; .
; Out: ix=ix+2
; .
; de,bc,a - undefined
c$DE88 LD A,($DCDF)  ; up/down rotation angle 7,n sign $00.$0F
 $DE8B XOR $80       ;
 $DE8D LD C,A        ;
 $DE8E LD B,(IX+$10) ;
 $DE91 LD D,(IX+$0A) ;
 $DE94 CALL $DE5D    ; compute the new coordinate of the object's
                     ; coordinate-system axis
 $DE97 LD (IX+$0A),A ;
 $DE9A LD A,($DCDE)  ; ship rotation angle 7,n sign $00.$0F
 $DE9D XOR $80       ;
 $DE9F LD C,A        ;
 $DEA0 LD B,(IX+$10) ;
 $DEA3 LD D,(IX+$16) ;
 $DEA6 CALL $DE5D    ; compute the new coordinate of the object's
                     ; coordinate-system axis
 $DEA9 LD (IX+$16),A ;
 $DEAC LD A,($DCDE)  ; ship rotation angle 7,n sign $00.$0F
 $DEAF LD C,A        ;
 $DEB0 LD B,(IX+$16) ;
 $DEB3 LD D,(IX+$10) ;
 $DEB6 CALL $DE5D    ; compute the new coordinate of the object's
                     ; coordinate-system axis
 $DEB9 LD (IX+$10),A ;
 $DEBC LD A,($DCDF)  ; up/down rotation angle 7,n sign $00.$0F
 $DEBF LD C,A        ;
 $DEC0 LD B,(IX+$0A) ;
 $DEC3 LD D,(IX+$10) ;
