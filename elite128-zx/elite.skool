                     ; Cloaking device 5,=1 - cannot buy goods (refugees in the
                     ; hold) 4 3 =1 mission 3 was completed 2 =1 - mission 3
                     ; completed 1 =1 - mission 2 completed 0 =1 - mission 1
                     ; completed
 $D7F8 LD A,(DE)     ;
