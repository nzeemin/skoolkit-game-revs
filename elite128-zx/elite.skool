*$A511 LD HL,$BBBF   ; menu displayed
 $A514 LD (HL),$00   ;
 $A516 LD HL,$011B   ;
 $A519 LD ($A80D),HL ; set CrdXPrnSymbol
 $A51C CP $09        ;
 $A51E JR NC,$A53C   ;
 $A520 LD A,D        ;
