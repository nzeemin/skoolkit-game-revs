@label=CircleDeltaY
 $7C42 DEFB $00      ; point where the circle intersects the left/right screen
                     ; edge, relative to the coordinate center
@label=SaveSPcircle
 $7C43 DEFW $0000
@label=SaveHL3
 $7C45 DEFW $0000
@label=SaveA7
 $7C47 DEFB $00      ; byte to print
@label=DirPrnCircle
 $7C48 DEFB $00      ; =0 print upward =1 print downward
@label=FillCircle
 $7C49 DEFB $00      ; =1 draw an unfilled circle =0 filled
