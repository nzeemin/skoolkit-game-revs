 $739B LD HL,$C000   ;
 $739E CALL $73BD    ; fast interlaced transfer of the screen buffer to 1/3 of
                     ; the screen
 $73A1 LD DE,$4800   ;
 $73A4 LD HL,$C800   ;
 $73A7 CALL $73BD    ; fast interlaced transfer of the screen buffer to 1/3 of
                     ; the screen
 $73AA LD DE,$4100   ;
 $73AD LD HL,$C100   ;
 $73B0 CALL $73BD    ; fast interlaced transfer of the screen buffer to 1/3 of
                     ; the screen
 $73B3 LD DE,$4900   ;
 $73B6 LD HL,$C900   ;
 $73B9 CALL $73BD    ; fast interlaced transfer of the screen buffer to 1/3 of
                     ; the screen
 $73BC RET           ;

