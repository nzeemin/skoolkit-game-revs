; CalcTempAltitude
;
; Used by the routine at #R$88E1.
;
; .
;
; Calculate temperature/altitude from proximity to the sun/planet and set the
; color
; .
; of the danger indicator
; .
; In: hl = 0 - distance (vector length)
; .
; Out: hl = hl*2.5
; .
; de,b,a - undefined
c$8A0F PUSH HL       ;
 $8A10 ADD HL,HL     ;
 $8A11 POP DE        ;
 $8A12 SRL D         ;
 $8A14 RR E          ;
 $8A16 ADD HL,DE     ; hl=hl*2.5
 $8A17 LD A,($7062)  ; get IndDanger
 $8A1A LD B,A        ;
 $8A1B LD A,H        ;
