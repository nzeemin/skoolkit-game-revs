; NextGalaxy
;
; .
;
; .
;
; Switch to the next galaxy
; .
; In: ----
; .
; Out: a - galaxy number
; .
; hl,de - ????
c$AC56 LD HL,$A827   ; galaxy number
 $AC59 LD A,(HL)     ;
 $AC5A INC A         ;
 $AC5B AND $07       ;
 $AC5D LD (HL),A     ;
 $AC5E LD HL,$A852   ; galaxy data
 $AC61 CALL $AC6D    ;
 $AC64 LD HL,$A854   ;
 $AC67 CALL $AC6D    ;
 $AC6A LD HL,$A856   ;

; Routine at AC6D
;
; Used by the routine at #R$AC56.
c$AC6D LD E,(HL)     ;
 $AC6E RLC E         ;
 $AC70 LD (HL),E     ;
 $AC71 INC HL        ;
 $AC72 LD D,(HL)     ;
 $AC73 RLC D         ;
 $AC75 LD (HL),D     ;
 $AC76 RET           ;

; FindPlanetByName
;
; Used by the routine at #R$B0E9.
;
; .
;
; Search for a planet in the galaxy by name
; .
; In: InputText - planet name
; .
; Out: DataOfPlanet - planet data, plus its info has been generated
; .
; cy =1 planet not found
; .
; =0 found
c$AC77 CALL $AE79    ; copy galaxy data into the working area
 $AC7A XOR A         ;
 $AC7B LD ($AC53),A  ;
*$AC7E CALL $AE81    ; save the working area with galaxy data
 $AC81 CALL $AD6F    ; generate the planet name and prepare data for generating
                     ; the next name
 $AC84 LD HL,$AC25   ; entered text (pilot name when saving/loading, planet
                     ; name when searching)
 $AC87 LD DE,$AC2E   ; for generating the planet name
*$AC8A LD B,(HL)     ;
 $AC8B LD A,(DE)     ;
 $AC8C CP B          ;
 $AC8D JR NZ,$AC96   ;
 $AC8F AND A         ;
 $AC90 JR Z,$AC9F    ;
 $AC92 INC HL        ;
 $AC93 INC DE        ;
 $AC94 JR $AC8A      ;
*$AC96 LD HL,$AC53   ;
 $AC99 INC (HL)      ;
 $AC9A JP NZ,$AC7E   ;
 $AC9D SCF           ;
 $AC9E RET           ;
*$AC9F CALL $AE89    ; restore the working area with galaxy data
 $ACA2 CALL $B1C0    ; print the small cursor on the global/local map
 $ACA5 CALL $ADDF    ; Build planet data (economy, government, tech level,
 $ACA8 CALL $B1C0    ; print the small cursor on the global/local map
 $ACAB CALL $ADD3    ; Copy the planet name into the working area
 $ACAE JP $AD08      ; calculate fuel consumption for the jump to the planet

; Unused
@label=SaveHL_1
s$ACB1 DEFS $02

; SearchNearPlanet
;
; Used by the routines at #R$B1AC, #R$B991, #R$D574 and #R$D5F5.
;
; .
;
; Find the planet nearest the cursor, build its data, set it as
; .
; the current target and draw the cursor if the map is displayed
c$ACB3 LD A,($7041)  ; get WhatOnScreen
 $ACB6 CP $07        ;
 $ACB8 JR C,$ACC7    ; find the planet nearest the cursor, build its data and
                     ; set it as the current target
 $ACBA CP $09        ;
 $ACBC JR NC,$ACC7   ; find the planet nearest the cursor, build its data and
                     ; set it as the current target
 $ACBE CALL $B1C0    ; print the small cursor on the global/local map
 $ACC1 CALL $ACC7    ; Find the planet nearest the cursor, build its data
 $ACC4 JP $B1C0      ; print the small cursor on the global/local map

; SearchPlanetNearCursor
;
; Used by the routines at #R$A976 and #R$ACB3.
;
; .
;
; Find the planet nearest the cursor, build its data
; .
; and set it as the current target
c$ACC7 CALL $AE79    ; copy galaxy data into the working area
 $ACCA LD HL,$FFFF   ;
 $ACCD LD ($ACB1),HL ; intermediate variable for calculating the distance from
                     ; the cursor to the nearest planet
 $ACD0 LD B,$00      ;
*$ACD2 PUSH BC       ;
 $ACD3 LD A,($AC18)  ;
 $ACD6 LD B,A        ;
 $ACD7 LD A,($AC16)  ; data for generating a planet
 $ACDA CALL $AD21    ; squared distance between the cursor and the planet
 $ACDD JR C,$ACEF    ;
 $ACDF EX DE,HL      ;
 $ACE0 LD HL,($ACB1) ; intermediate variable for calculating the distance from
                     ; the cursor to the nearest planet
 $ACE3 AND A         ;
 $ACE4 SBC HL,DE     ;
 $ACE6 JR C,$ACEF    ;
 $ACE8 LD ($ACB1),DE ; intermediate variable for calculating the distance from
                     ; the cursor to the nearest planet
 $ACEC CALL $AE81    ; save the working area with galaxy data
*$ACEF CALL $AD17    ; modify data for planet generation
 $ACF2 POP BC        ;
 $ACF3 DJNZ $ACD2    ;
 $ACF5 LD HL,($ACB1) ; intermediate variable for calculating the distance from
                     ; the cursor to the nearest planet
 $ACF8 AND A         ;
 $ACF9 CALL $AD45    ; calculate fuel to reach the planet
 $ACFC CALL $AE89    ; restore the working area with galaxy data
 $ACFF CALL $ADDF    ; Build planet data (economy, government, tech level,
 $AD02 CALL $AD6F    ; generate the planet name and prepare data for generating
                     ; the next name
 $AD05 CALL $ADD3    ; Copy the planet name into the working area
; This entry point is used by the routine at #R$AC77.
*$AD08 LD A,($A85B)  ; calculate fuel consumption for the jump to the planet
 $AD0B LD B,A        ;
 $AD0C LD A,($A859)  ; get Pilot_CrdYSystem
 $AD0F CALL $AD21    ; squared distance between the cursor and the planet
 $AD12 CALL $AD45    ; calculate fuel to reach the planet
 $AD15 AND A         ;
 $AD16 RET           ;

; NextPlanetData
;
; Used by the routines at #R$AA44, #R$AA96, #R$AB4E and #R$ACC7.
;
; .
;
; Modify data for planet generation
; .
; In: ----
; .
; Out: hl,de,b,a - ????
c$AD17 LD B,$04      ;
*$AD19 PUSH BC       ;
 $AD1A CALL $ADB6    ; modify data for planet generation
 $AD1D POP BC        ;
 $AD1E DJNZ $AD19    ;
 $AD20 RET           ;

; CalcDistanceToCursor
;
; Used by the routine at #R$ACC7.
;
; .
;
; Squared distance between the cursor and the planet
; .
; In: b - planet's Y coordinate
; .
; a - planet's X coordinate
; .
; Out: hl - result
; .
; cy=1 - sum greater than $FFFF
; .
; de,bc,a - ????
c$AD21 PUSH AF       ;
 $AD22 LD A,($A87D)  ; get Pilot_CrdXTarget
 $AD25 CALL $AD3D    ;
 $AD28 LD D,A        ;
 $AD29 CALL $AD5C    ; multiplication hl=d*a
 $AD2C POP BC        ;
 $AD2D PUSH HL       ;
 $AD2E LD A,($A87E)  ; get Pilot_CrdYTarget
 $AD31 CALL $AD3D    ;
 $AD34 SRL A         ;
 $AD36 LD D,A        ;
 $AD37 CALL $AD5C    ; multiplication hl=d*a
 $AD3A POP DE        ;
 $AD3B ADD HL,DE     ;
 $AD3C RET           ;
*$AD3D CP B          ;
 $AD3E JR NC,$AD43   ;
 $AD40 LD C,B        ;
 $AD41 LD B,A        ;
 $AD42 LD A,C        ;
*$AD43 SUB B         ;
 $AD44 RET           ;

; CalcFuelForDistance
;
; Used by the routine at #R$ACC7.
;
; .
;
; Calculate fuel to reach the planet
; .
; In: hl - squared distance from the planet to the cursor
; .
; cy=1 - hl > $FFFF
; .
; Out: hl,(FuelToPlanet) - fuel needed for the jump
c$AD45 JR C,$AD49    ;
 $AD47 JR $AD4C      ;
*$AD49 LD HL,$FFFF   ;
*$AD4C LD A,H        ;
 $AD4D OR L          ;
 $AD4E JR Z,$AD58    ;
 $AD50 CALL $DC53    ; extract the square root h=sqr(hl)
 $AD53 LD L,H        ;
 $AD54 LD H,$00      ;
 $AD56 ADD HL,HL     ;
 $AD57 ADD HL,HL     ;
*$AD58 LD ($AC49),HL ; fuel required to travel to the planet =distance*4
 $AD5B RET           ;

; Mult_HL_D_A
;
; Used by the routines at #R$AD21 and #R$ADDF.
;
; .
;
; Multiplication hl=d*a
; .
; In: d,a - factors
; .
; Out: hl - result
c$AD5C LD E,$00      ;
 $AD5E LD B,$08      ;
 $AD60 LD HL,$0000   ;
*$AD63 SRL D         ;
 $AD65 RR E          ;
 $AD67 RL A          ;
 $AD69 JR NC,$AD6C   ;
 $AD6B ADD HL,DE     ;
*$AD6C DJNZ $AD63    ;
 $AD6E RET           ;

; GeneratePlanetName
;
; Used by the routines at #R$AAE7, #R$AC77, #R$ACC7 and #R$B8E9.
;
; .
;
; Generate the planet name and prepare data for generating the next name
; .
; In: (DataOfPlanet) - planet data
; .
; Out: (TempName) - planet name
; .
; (DataOfPlanet) - data for the next planet
; .
; hl,de,bc,a - ????
c$AD6F LD HL,$AC2E   ; for generating the planet name
 $AD72 LD ($AC54),HL ; for storing a variable in the GeneratePlanetName routine
 $AD75 LD B,$08      ;
*$AD77 LD (HL),$00   ;
 $AD79 INC HL        ;
 $AD7A DJNZ $AD77    ;
 $AD7C LD HL,($AC15) ; data for generating a planet
 $AD7F LD A,L        ;
 $AD80 AND $40       ; '@'
 $AD82 AND A         ;
 $AD83 PUSH AF       ;
 $AD84 CALL $AD90    ;
 $AD87 CALL $AD90    ;
 $AD8A CALL $AD90    ;
 $AD8D POP AF        ;
 $AD8E JR Z,$ADB6    ; modify data for planet generation
*$AD90 LD HL,($AC19) ;
 $AD93 LD A,H        ;
 $AD94 AND $1F       ;
 $AD96 AND A         ;
 $AD97 JR Z,$ADB6    ; modify data for planet generation
 $AD99 LD HL,$FBC3   ; character pairs for generating the planet name
 $AD9C ADD A,A       ;
 $AD9D LD D,$00      ;
 $AD9F LD E,A        ;
 $ADA0 ADD HL,DE     ;
 $ADA1 LD A,(HL)     ;
 $ADA2 INC HL        ;
 $ADA3 PUSH HL       ;
 $ADA4 LD HL,($AC54) ; for storing a variable in the GeneratePlanetName routine
 $ADA7 LD (HL),A     ;
 $ADA8 INC HL        ;
 $ADA9 EX DE,HL      ;
 $ADAA POP HL        ;
 $ADAB LD A,(HL)     ;
 $ADAC EX DE,HL      ;
 $ADAD CP $3F        ; '?'
 $ADAF JR Z,$ADB3    ;
 $ADB1 LD (HL),A     ;
 $ADB2 INC HL        ;
*$ADB3 LD ($AC54),HL ; for storing a variable in the GeneratePlanetName routine
; This entry point is used by the routine at #R$AD17.
*$ADB6 LD HL,($AC15) ; modify data for planet generation
 $ADB9 LD DE,($AC17) ;
 $ADBD ADD HL,DE     ;
 $ADBE EX DE,HL      ;
 $ADBF LD HL,($AC17) ;
 $ADC2 LD ($AC15),HL ; data for generating a planet
 $ADC5 LD HL,($AC19) ;
 $ADC8 LD ($AC17),HL ;
 $ADCB LD HL,($AC17) ;
 $ADCE ADD HL,DE     ;
 $ADCF LD ($AC19),HL ;
 $ADD2 RET           ;

; CopyPlanetName
;
; Used by the routines at #R$AC77 and #R$ACC7.
;
; .
;
; Copy the planet name into the working area
; .
; (TempName)->(PlanetName)
c$ADD3 LD BC,$0008   ;
 $ADD6 LD HL,$AC2E   ; for generating the planet name
 $ADD9 LD DE,$AC40   ; name of the planet the ship is set to
 $ADDC LDIR          ;
 $ADDE RET           ;

; GenerateInfoPlanet
;
; Used by the routines at #R$AC77 and #R$ACC7.
;
; .
;
; Build planet data (economy, government, tech level,
; .
; population, gross income) and set the small-cursor coordinates
c$ADDF LD HL,($AC15) ; data for generating a planet
 $ADE2 LD ($AC0F),HL ; 6 bytes for generating planet data
 $ADE5 LD A,H        ;
 $ADE6 LD ($A87E),A  ; set Pilot_CrdYTarget
 $ADE9 AND $07       ;
 $ADEB LD ($AC4B),A  ; Economy
 $ADEE LD HL,($AC17) ;
 $ADF1 LD ($AC11),HL ;
 $ADF4 LD A,H        ;
 $ADF5 LD ($A87D),A  ; set Pilot_CrdXTarget
 $ADF8 LD A,L        ;
 $ADF9 SRL A         ;
 $ADFB SRL A         ;
 $ADFD SRL A         ;
 $ADFF AND $07       ;
 $AE01 LD ($AC4C),A  ; government (government type)
 $AE04 SRL A         ;
 $AE06 JR NZ,$AE10   ;
 $AE08 LD A,($AC4B)  ; Economy
 $AE0B OR $02        ;
 $AE0D LD ($AC4B),A  ; Economy
*$AE10 LD A,($AC4B)  ; Economy
 $AE13 XOR $07       ;
 $AE15 AND A         ;
 $AE16 LD B,A        ;
 $AE17 LD A,H        ;
 $AE18 AND $03       ;
 $AE1A ADD A,B       ;
 $AE1B LD B,A        ;
 $AE1C LD A,($AC4C)  ; government (government type)
