; Mult_C_hiAmulCadd80
;
; Used by the routine at #R$EE10.
;
; .
;
; Multiplication c=high(a*c+$80)
c$F0BE PUSH DE       ;
 $F0BF PUSH HL       ;
 $F0C0 LD B,A        ;
 $F0C1 CALL $E45D    ; computes: ((b+c)/2)^2 - ((b-c)/2)^2 should be: ((b+c)^2
                     ; - (b-c)^2)/4
 $F0C4 LD DE,$0080   ;
 $F0C7 ADD HL,DE     ;
 $F0C8 LD C,H        ;
 $F0C9 POP HL        ;
 $F0CA POP DE        ;
 $F0CB RET           ;

; CalcDeltaCrdLine
;
; Used by the routines at #R$EE10, #R$F130 and #R$F175.
;
; .
;
; Calculate the coordinate step coefficient when printing a line
; .
; In: a - smaller coordinate difference
; .
; b - larger coordinate difference
; .
; Out: c - increment coefficient along the shorter axis
c$F0CC LD C,$FE      ;
 $F0CE PUSH DE       ;
 $F0CF LD E,$00      ;
 $F0D1 CALL $E5B4    ; calculate the coordinate step coefficient when printing
                     ; a line
 $F0D4 POP DE        ;
 $F0D5 RET           ;

; CalcFirstAdr4Line
;
; Used by the routine at #R$EE10.
;
; .
;
; Compute the print address and data for setting the first point
; .
; In: de - coordinates of the second point (x2y2)
; .
; 7,b =1 line length along X > $FF
; .
; =0 line length along X =< $FF
; .
; 6,b =1 line length along Y > $FF
; .
; =0 line length along Y =< $FF
; .
; 4,b =1 dX >= dY
; .
; 4,b =0 dX < dY
; .
; 3,b =1 coordinate X2 is left of coordinate X1
; .
; =0 coordinate X2 is right of coordinate X1
; .
; 2,b =1 coordinate Y2 is below coordinate Y1
; .
; =0 coordinate Y2 is above coordinate Y1
; .
; c - coordinate increment coefficient along the shorter axis
; .
; Out: d' - byte for setting a point
; .
; e' - coordinate increment coefficient along the shorter axis
; .
; hl' - print address on screen/in buffer
; .
; b' - number of points in the first character cell along Y
; .
; a,c' - undefined
; .
; other registers are unchanged
; .
; The whole routine runs in the alternate register set (push, exx in, compute,
; exx back), so the caller's own bc/de are left completely undisturbed; the
; real results only become visible to the caller after it also does an exx. It
; recovers actual X/Y from the sign-coded deltas via X = $7F +/- dX and Y = $3F
; +/- dY (add if the sign bit is clear, subtract if set), i.e. reconstructing
; bitmap coordinates from a 127/63-centred reference point rather than from 0.
c$F0D6 PUSH BC       ;
 $F0D7 PUSH BC       ;
 $F0D8 PUSH DE       ;
 $F0D9 EXX           ;
 $F0DA POP BC        ;
 $F0DB POP DE        ;
 $F0DC BIT 1,D       ;
 $F0DE JR NZ,$F0E5   ;
 $F0E0 LD A,$7F      ;
 $F0E2 ADD A,B       ;
 $F0E3 JR $F0E8      ;
*$F0E5 LD A,$7F      ;
 $F0E7 SUB B         ;
*$F0E8 LD B,A        ;
 $F0E9 BIT 0,D       ;
 $F0EB JR Z,$F0F2    ;
 $F0ED LD A,$3F      ; '?'
 $F0EF ADD A,C       ;
 $F0F0 JR $F0F5      ;
*$F0F2 LD A,$3F      ; '?'
 $F0F4 SUB C         ;
*$F0F5 LD C,B        ;
 $F0F6 LD B,A        ;
 $F0F7 LD A,C        ;
 $F0F8 AND $07       ;
 $F0FA LD D,B        ;
 $F0FB LD B,A        ;
 $F0FC INC B         ;
 $F0FD LD A,$01      ;
*$F0FF RRCA          ;
 $F100 DJNZ $F0FF    ;
 $F102 LD B,D        ;
 $F103 LD D,A        ;
 $F104 SRL C         ;
 $F106 SRL C         ;
 $F108 SRL C         ;
 $F10A LD A,B        ;
 $F10B RRA           ;
 $F10C RRA           ;
 $F10D RRA           ;
 $F10E AND $18       ;
 $F110 LD H,A        ;
 $F111 LD A,B        ;
 $F112 AND $07       ;
 $F114 OR H          ;
; Self-modified operand: patched elsewhere to $40 or $C0 depending on whether
; the destination address being computed is the real screen or the off-screen
; buffer (bit 7 of the buffer's high byte selects the buffer, matching the
; third/row/column layout of the real screen but relocated into high memory).
 $F115 OR $C0        ;
 $F117 LD H,A        ;
 $F118 LD A,B        ;
 $F119 AND $38       ; '8'
 $F11B ADD A,A       ;
 $F11C ADD A,A       ;
 $F11D OR C          ;
 $F11E LD L,A        ;
 $F11F LD A,H        ;
 $F120 AND $07       ;
 $F122 INC A         ;
 $F123 LD B,A        ;
 $F124 LD C,D        ;
 $F125 POP AF        ;
 $F126 BIT 2,A       ;
 $F128 JR NZ,$F12E   ;
 $F12A LD A,$09      ;
 $F12C SUB B         ;
 $F12D LD B,A        ;
*$F12E EXX           ;
 $F12F RET           ;

; PrnLine_OneCrdClip
;
; Used by the routine at #R$EE10.
;
; .
;
; Print a line, clipped at the screen edge
; .
; In: de - coordinates of the second point (x2y2)
; .
; the on-screen point where printing starts
; .
; 4,b =1 dX >= dY
; .
; 4,b =0 dX < dY
; .
; 3,b =1 coordinate X2 is left of coordinate X1
; .
; =0 coordinate X2 is right of coordinate X1
; .
; 2,b =1 coordinate Y2 is below coordinate Y1
; .
; =0 coordinate Y2 is above coordinate Y1
; .
; 1,b - sign of x2
; .
; 0,b - sign of y2
; .
; c - coordinate increment coefficient along the shorter axis
; .
; hl' - print address on screen/in buffer
; .
; b' - number of points in the first character cell along Y
; .
; c' - byte for setting a point
; .
; e' - coordinate increment coefficient along the shorter axis
; .
; Out: line printed
c$F130 PUSH BC       ;
 $F131 LD HL,$8040   ;
 $F134 LD A,B        ;
 $F135 RRA           ;
 $F136 RRA           ;
 $F137 AND $03       ;
 $F139 SLA B         ;
 $F13B SLA B         ;
 $F13D OR B          ;
 $F13E XOR $03       ;
 $F140 AND $0F       ;
 $F142 LD B,A        ;
 $F143 CALL $F175    ; determine the coordinate difference and print direction
 $F146 POP DE        ;
 $F147 LD A,B        ;
 $F148 XOR D         ;
 $F149 AND $10       ;
 $F14B JR Z,$F14F    ;
 $F14D LD C,$FF      ;
*$F14F BIT 4,D       ;
 $F151 JR Z,$F15F    ;
 $F153 LD A,E        ;
 $F154 SUB C         ;
 $F155 LD A,H        ;
 $F156 JP C,$EEAC    ; modify the print routine and print the line
 $F159 JP Z,$EEAC    ; modify the print routine and print the line
 $F15C LD A,L        ;
 $F15D JR $F169      ;
*$F15F LD A,E        ;
 $F160 SUB C         ;
 $F161 LD A,L        ;
 $F162 JP C,$EEAC    ; modify the print routine and print the line
 $F165 JP Z,$EEAC    ; modify the print routine and print the line
 $F168 LD A,H        ;
*$F169 LD B,E        ;
 $F16A AND A         ;
 $F16B JR Z,$F16E    ;
 $F16D DEC A         ;
*$F16E CALL $F0CC    ; calculate the coordinate step coefficient when printing
                     ; a line
 $F171 LD A,C        ;
 $F172 JP $EEAC      ; modify the print routine and print the line

; CalcVars4Line
;
; Used by the routines at #R$EE10 and #R$F130.
;
; .
;
; Determine the coordinate difference and print direction
; .
; In: hl - coordinates of the first point (x1y1)
; .
; de - coordinates of the second point (x2y2)
; .
; 0,b - sign of y1
; .
; 1,b - sign of x1
; .
; 2,b - sign of y2
; .
; 3,b - sign of x2
; .
; Out: 7,b =1 line length along X > $FF
; .
; =0 line length along X =< $FF
; .
; 6,b =1 line length along Y > $FF
; .
; =0 line length along Y =< $FF
; .
; 4,b =1 dX >= dY
; .
; 4,b =0 dX < dY
; .
; 3,b =1 coordinate X2 is left of coordinate X1
; .
; =0 coordinate X2 is right of coordinate X1
; .
; 2,b =1 coordinate Y2 is below coordinate Y1
; .
; =0 coordinate Y2 is above coordinate Y1
; .
; 1,b - sign of x2
; .
; 0,b - sign of y2
; .
; c - coordinate increment coefficient along the shorter axis
; .
; h - coordinate difference along X
; .
; l - coordinate difference along Y
c$F175 LD A,B        ;
 $F176 SRL A         ;
 $F178 SRL A         ;
 $F17A XOR B         ;
 $F17B ADD A,A       ;
 $F17C ADD A,A       ;
 $F17D ADD A,A       ;
 $F17E ADD A,A       ;
 $F17F OR B          ;
 $F180 OR $03        ;
 $F182 LD B,A        ;
 $F183 RES 5,B       ;
 $F185 AND $20       ; ' '
 $F187 LD A,D        ;
 $F188 JR Z,$F195    ;
 $F18A BIT 3,B       ;
 $F18C JR Z,$F190    ;
 $F18E SET 5,B       ;
*$F190 ADD A,H       ;
 $F191 JR NC,$F1A8   ;
 $F193 JR $F1AA      ;
*$F195 SUB H         ;
 $F196 JR C,$F1A0    ;
 $F198 BIT 3,B       ;
 $F19A JR Z,$F1A8    ;
 $F19C SET 5,B       ;
 $F19E JR $F1A8      ;
*$F1A0 NEG           ;
 $F1A2 BIT 3,B       ;
 $F1A4 JR NZ,$F1A8   ;
 $F1A6 SET 5,B       ;
*$F1A8 RES 1,B       ;
*$F1AA LD H,A        ;
 $F1AB BIT 4,B       ;
 $F1AD LD A,E        ;
 $F1AE RES 4,B       ;
 $F1B0 JR Z,$F1BD    ;
 $F1B2 BIT 2,B       ;
 $F1B4 JR Z,$F1B8    ;
 $F1B6 SET 4,B       ;
*$F1B8 ADD A,L       ;
 $F1B9 JR NC,$F1D0   ;
 $F1BB JR $F1D2      ;
*$F1BD SUB L         ;
 $F1BE JR C,$F1C8    ;
 $F1C0 BIT 2,B       ;
 $F1C2 JR Z,$F1D0    ;
 $F1C4 SET 4,B       ;
 $F1C6 JR $F1D0      ;
*$F1C8 NEG           ;
 $F1CA BIT 2,B       ;
 $F1CC JR NZ,$F1D0   ;
 $F1CE SET 4,B       ;
*$F1D0 RES 0,B       ;
*$F1D2 LD L,A        ;
 $F1D3 LD C,L        ;
 $F1D4 RRC B         ;
 $F1D6 RR C          ;
 $F1D8 LD A,H        ;
 $F1D9 RRC B         ;
 $F1DB RRA           ;
 $F1DC CP C          ;
 $F1DD JR C,$F1EA    ;
 $F1DF SET 4,B       ;
 $F1E1 PUSH BC       ;
 $F1E2 BIT 7,B       ;
 $F1E4 JR Z,$F1F4    ;
 $F1E6 LD B,A        ;
 $F1E7 LD A,C        ;
 $F1E8 JR $F1FA      ;
*$F1EA RES 4,B       ;
 $F1EC PUSH BC       ;
 $F1ED BIT 6,B       ;
 $F1EF JR Z,$F1F8    ;
 $F1F1 LD B,C        ;
 $F1F2 JR $F1FA      ;
*$F1F4 LD A,L        ;
 $F1F5 LD B,H        ;
 $F1F6 JR $F1FA      ;
*$F1F8 LD A,H        ;
 $F1F9 LD B,L        ;
*$F1FA CALL $F0CC    ; calculate the coordinate step coefficient when printing
                     ; a line
 $F1FD LD A,C        ;
 $F1FE POP BC        ;
 $F1FF LD C,A        ;
 $F200 RET           ;

; Routine at F201
c$F201 DEC H         ;
; This entry point is used by the routine at #R$EE10.
@label=PrnLineDown2Up_vert
*$F202 LD A,(HL)     ;
 $F203 OR C          ;
 $F204 LD (HL),A     ;
 $F205 DEC D         ;
 $F206 RET Z         ;
 $F207 LD A,E        ;
 $F208 ADD A,$00     ;
 $F20A LD E,A        ;
 $F20B JR NC,$F211   ;
 $F20D RRC C         ;
 $F20F JR C,$F224    ;
; "boundary crossing" (every 8th row): because of the third-interleaved screen
; layout, advancing one pixel row is not a uniform +1/-1 to a linear address.
; Most of the time (within a character cell) it's just L +/- $20, but every 8th
; row this reloads b=8 and adjusts the high byte by +/-7 and the low byte by
; -/+$20 instead, with a further carry-driven -b correction to the high byte if
; that 8-row group also crosses a third boundary.
*$F211 DJNZ $F201    ;
 $F213 LD B,$08      ;
 $F215 LD A,H        ; DownScrAdr_HL
 $F216 ADD A,$07     ;
 $F218 LD H,A        ;
 $F219 LD A,L        ;
 $F21A SUB $20       ; ' '
 $F21C LD L,A        ;
 $F21D JR NC,$F202   ;
 $F21F LD A,H        ;
 $F220 SUB B         ;
 $F221 LD H,A        ;
 $F222 JR $F202      ;
; self-modified operand: PrnLineInBuf_clip pokes the literal byte $2C (inc l)
; or $2D (dec l) into this exact spot before jumping in, choosing the stepping
; direction once, before the loop starts, rather than branching on every pixel
; of the hot per-pixel loop.
*$F224 INC L         ;
 $F225 JP $F211      ;

; Routine at F228
;
; .
;
; .
;
; Print a line bottom-to-top, dY<dX
; .
; In: hl - address in buffer/on screen
; .
; d - line length
; .
; e - coordinate increment coefficient along the shorter axis
; .
; b - number of points in the first character cell along Y
; .
; c - byte for setting the first point
; .
; Out: d =$00
; .
; hl,e,bc,a - undefined
; .
; self-modified operand: PrnLineInBuf_clip pokes the literal byte $2C (inc l)
; or $2D (dec l) into this exact spot before jumping in, choosing the stepping
; direction once, before the loop starts, rather than branching on every pixel
; of the hot per-pixel loop.
c$F228 INC L         ;
 $F229 JP $F230      ;
*$F22C RRC C         ;
 $F22E JR C,$F228    ; print a line bottom-to-top, dY<dX
; This entry point is used by the routine at #R$EE10.
@label=PrnLineDown2Up_hor
*$F230 LD A,(HL)     ;
 $F231 OR C          ;
 $F232 LD (HL),A     ;
 $F233 DEC D         ;
 $F234 RET Z         ;
 $F235 LD A,E        ;
; "boundary crossing" (every 8th row): because of the third-interleaved screen
; layout, advancing one pixel row is not a uniform +1/-1 to a linear address.
; Most of the time (within a character cell) it's just L +/- $20, but every 8th
; row this reloads b=8 and adjusts the high byte by +/-7 and the low byte by
; -/+$20 instead, with a further carry-driven -b correction to the high byte if
; that 8-row group also crosses a third boundary.
 $F236 ADD A,$00     ;
 $F238 LD E,A        ;
 $F239 JR NC,$F22C   ;
 $F23B DEC H         ;
 $F23C DJNZ $F22C    ;
 $F23E LD B,$08      ;
 $F240 LD A,H        ;
 $F241 ADD A,B       ;
 $F242 LD H,A        ;
 $F243 LD A,L        ;
 $F244 SUB $20       ; ' '
 $F246 LD L,A        ;
 $F247 JP NC,$F22C   ;
 $F24A LD A,H        ;
 $F24B SUB B         ;
 $F24C LD H,A        ;
 $F24D JP $F22C      ;

; Routine at F250
c$F250 INC H         ;
; This entry point is used by the routine at #R$EE10.
@label=PrnLineUp2Down_vert
*$F251 LD A,(HL)     ; hl - address in the buffer c - data byte d - height e -
                     ; X increment b - height of the first character cell
 $F252 OR C          ;
 $F253 LD (HL),A     ;
 $F254 DEC D         ;
 $F255 RET Z         ;
 $F256 LD A,E        ;
 $F257 ADD A,$00     ;
 $F259 LD E,A        ;
 $F25A JR NC,$F260   ;
 $F25C RRC C         ; shift the data bit
 $F25E JR C,$F275    ;
; "boundary crossing" (every 8th row): because of the third-interleaved screen
; layout, advancing one pixel row is not a uniform +1/-1 to a linear address.
; Most of the time (within a character cell) it's just L +/- $20, but every 8th
; row this reloads b=8 and adjusts the high byte by +/-7 and the low byte by
; -/+$20 instead, with a further carry-driven -b correction to the high byte if
; that 8-row group also crosses a third boundary.
*$F260 DJNZ $F250    ;
 $F262 LD B,$08      ;
 $F264 LD A,H        ; DownScrAdr_HL
 $F265 SUB $07       ;
 $F267 LD H,A        ;
 $F268 LD A,L        ;
 $F269 ADD A,$20     ; ' '
 $F26B LD L,A        ;
 $F26C JP NC,$F251   ; hl - address in the buffer c - data byte d - height e -
                     ; X increment b - height of the first character cell
 $F26F LD A,H        ;
 $F270 ADD A,B       ;
 $F271 LD H,A        ;
 $F272 JP $F251      ; hl - address in the buffer c - data byte d - height e -
                     ; X increment b - height of the first character cell
; self-modified operand: PrnLineInBuf_clip pokes the literal byte $2C (inc l)
; or $2D (dec l) into this exact spot before jumping in, choosing the stepping
; direction once, before the loop starts, rather than branching on every pixel
; of the hot per-pixel loop.
*$F275 INC L         ;
 $F276 JP $F260      ;

; Routine at F279
;
; .
;
; .
;
; Print a line top-to-bottom, dY<dX
; .
; In: hl - address in buffer/on screen
; .
; d - line length
; .
; e - coordinate increment coefficient along the shorter axis
; .
; b - number of points in the first character cell along Y
; .
; c - byte for setting the first point
; .
; Out: d =$00
; .
; hl,e,bc,a - undefined
c$F279 RRC C         ;
 $F27B JR C,$F29D    ;
; This entry point is used by the routine at #R$EE10.
@label=PrnLineUp2Down_hor
*$F27D LD A,(HL)     ;
 $F27E OR C          ;
 $F27F LD (HL),A     ;
 $F280 DEC D         ;
 $F281 RET Z         ;
 $F282 LD A,E        ;
; "boundary crossing" (every 8th row): because of the third-interleaved screen
; layout, advancing one pixel row is not a uniform +1/-1 to a linear address.
; Most of the time (within a character cell) it's just L +/- $20, but every 8th
; row this reloads b=8 and adjusts the high byte by +/-7 and the low byte by
; -/+$20 instead, with a further carry-driven -b correction to the high byte if
; that 8-row group also crosses a third boundary.
 $F283 ADD A,$00     ;
 $F285 LD E,A        ;
 $F286 JR NC,$F279   ; print a line top-to-bottom, dY<dX
 $F288 INC H         ;
 $F289 DJNZ $F279    ; print a line top-to-bottom, dY<dX
 $F28B LD B,$08      ;
 $F28D LD A,H        ;
 $F28E SUB B         ;
 $F28F LD H,A        ;
 $F290 LD A,L        ;
 $F291 ADD A,$20     ; ' '
 $F293 LD L,A        ;
 $F294 JP NC,$F279   ; print a line top-to-bottom, dY<dX
 $F297 LD A,H        ;
 $F298 ADD A,B       ;
 $F299 LD H,A        ;
 $F29A JP $F279      ; print a line top-to-bottom, dY<dX
; self-modified operand: PrnLineInBuf_clip pokes the literal byte $2C (inc l)
; or $2D (dec l) into this exact spot before jumping in, choosing the stepping
; direction once, before the loop starts, rather than branching on every pixel
; of the hot per-pixel loop.
*$F29D INC L         ;
 $F29E JP $F27D      ;

; Data block at F2A1
@label=PatternObject
b$F2A1 DEFB $00,$32,$00,$00,$32,$00,$00,$32 ; {+0 template of an object's slot
 $F2A9 DEFB $00,$00,$00,$00,$00,$FF,$FF,$00 ; in space
 $F2B1 DEFB $00,$FF,$7F,$00,$00,$FF,$FF,$00 ;
 $F2B9 DEFB $00,$00,$00,$00,$00,$00,$00     ; }
@label=SKO4Intro
 $F2C0 DEFB $58,$44,$41,$98,$64,$CB,$5A,$A7
 $F2C8 DEFB $D1
 $F2C9 DEFB $00                             ; alternation

; CallFunctionObj
;
; Used by the routines at #R$716B, #R$79A3, #R$A706, #R$A77B, #R$DA1D, #R$EBA4,
; #R$EBC7 and #R$F876.
;
; .
;
; In: A - bits 3-0 handler function number?
; .
; =0 SetRndShip
; .
; =1 Set3_4Thargons
; .
; =2 SetObjMissile
; .
; =3 *not used
; .
; =4 ShipSetShip
; .
; =5 Set2Alloys
; .
; =6 SetCargo
; .
; =7 SetShipEscapePod
; .
; =8 Set2Minerals
; .
; =9 SetShip4Intro
; .
; bits 7-4 number =0 - slave
; .
; =1 - alloys
; .
; =2 - canister
; .
; =3 - alien items
; .
; =4 - asteroid
; .
; =5 - asteroid
; .
; =6 - policeman
; .
; =7 - cobra
; .
; =8 - python
; .
; =9 - python
; .
; =A - cobra
; .
; =B - asp
; .
; =C - fer-de-lance
; .
; =D - thargon
; .
; =E - sidewinder
; .
; =F - krait
c$F2CA LD C,A        ;
 $F2CB SRL C         ;
 $F2CD SRL C         ;
 $F2CF SRL C         ;
 $F2D1 SRL C         ;
 $F2D3 AND $0F       ;
 $F2D5 JP Z,$F61D    ; a = $x0
 $F2D8 DEC A         ;
 $F2D9 JP Z,$F3CE    ; 3-0 =1
 $F2DC DEC A         ;
 $F2DD JP Z,$F402    ; launch a missile a = $x2 x =0 launched by an enemy <>0
                     ; by the player
 $F2E0 DEC A         ;
 $F2E1 RET Z         ; 3-0 =3
 $F2E2 DEC A         ;
 $F2E3 JP Z,$F44A    ; a = $x4 x - ship number
 $F2E6 DEC A         ;
 $F2E7 JP Z,$F4F7    ; 3-0 =5
 $F2EA DEC A         ;
 $F2EB JP Z,$F555    ; 3-0 =6
 $F2EE DEC A         ;
 $F2EF JP Z,$F55D    ; 3-0 =7
 $F2F2 DEC A         ;
 $F2F3 JP Z,$F5B0    ; 3-0 =8
 $F2F6 DEC A         ;
 $F2F7 JP Z,$F5D8    ; 3-0 =9
 $F2FA RET           ; 3-0 =A..F

; SetObjInSlot
;
; Used by the routines at #R$F381, #R$F3B3, #R$F3CE, #R$F5D8 and #R$F61D.
;
; .
;
; Place an object into a slot
; .
; In: a - object number
; .
; ix address of the object slot
; .
; Out: a=$00
c$F2FB LD HL,$6180    ;
 $F2FE LD B,A         ;
 $F2FF AND $3F        ; '?'
 $F301 ADD A,A        ;
 $F302 ADD A,A        ;
 $F303 ADD A,L        ;
 $F304 LD L,A         ;
 $F305 JR NC,$F308    ;
 $F307 INC H          ;
*$F308 INC HL         ;
 $F309 LD E,(HL)      ;
 $F30A INC HL         ;
 $F30B LD D,(HL)      ;
 $F30C PUSH DE        ;
 $F30D POP IY         ; iy address of the object data
 $F30F LD (IX+$24),D  ;
 $F312 LD (IX+$23),E  ;
 $F315 PUSH IX        ;
 $F317 POP DE         ;
 $F318 LD BC,$001F    ;
 $F31B LD HL,$F2A1    ; +0 template of an object's slot in space
 $F31E LDIR           ;
 $F320 LD A,(IY+$07)  ;
 $F323 LD (IX+$22),A  ;
 $F326 LD A,(IY+$12)  ;
 $F329 LD C,A         ;
 $F32A AND $6F        ; 'o'
 $F32C LD (IX+$21),A  ;
 $F32F LD A,(IY+$0A)  ;
 $F332 AND $07        ;
 $F334 RLA            ;
 $F335 RL C           ;
 $F337 RRA            ;
 $F338 LD (IX+$20),A  ;
 $F33B LD A,(IY+$06)  ;
 $F33E SRL A          ;
 $F340 LD (IX+$1B),A  ;
 $F343 LD A,$7E       ; '~'
 $F345 LD (IX+$25),A  ;
 $F348 XOR A          ;
 $F349 LD (IX+$26),A  ;
 $F34C SET 6,(IX+$20) ;
 $F350 BIT 2,(IX+$21) ;
 $F354 JR NZ,$F366    ;
 $F356 CALL $ED24     ; Random number
 $F359 AND $07        ;
 $F35B LD (IX+$01),A  ;
 $F35E CALL $ED24     ; Random number
 $F361 AND $07        ;
 $F363 LD (IX+$04),A  ;
*$F366 CALL $ED24     ; Random number
 $F369 LD (IX+$00),A  ;
 $F36C CALL $ED24     ; Random number
 $F36F LD (IX+$03),A  ;
 $F372 CALL $ED24     ; Random number
 $F375 RRA            ;
 $F376 RR (IX+$02)    ;
 $F37A RRA            ;
 $F37B RR (IX+$05)    ;
 $F37F XOR A          ;
 $F380 RET            ;

; ShipSetObject
;
; Used by the routines at #R$F402, #R$F44A, #R$F592 and #R$F5B8.
;
; .
;
; Place an object into a slot at another object's coordinates (a ship
; .
; launching an enemy object, which inherits coordinates, OCS and speed from the
; parent)
; .
; In: a - object number
; .
; ix address of the object slot
; .
; Out: Z=1 success, -> ix - slot address of the placed object
; .
; bc =$0000
c$F381 LD C,A        ;
 $F382 PUSH IX       ;
 $F384 CALL $F399    ; find a free slot to place an object
 $F387 POP HL        ;
 $F388 RET NZ        ;
 $F389 PUSH HL       ;
 $F38A LD A,C        ;
 $F38B CALL $F2FB    ; place an object into a slot
 $F38E POP HL        ;
 $F38F PUSH IX       ;
 $F391 POP DE        ;
 $F392 LD BC,$001B   ;
 $F395 LDIR          ;
 $F397 XOR A         ;
 $F398 RET           ;

; FindSlot4Obj
;
; Used by the routines at #R$F381, #R$F3AD, #R$F3CE, #R$F402 and #R$F61D.
;
; .
;
; Find a free slot to place an object
; .
; In: ---
; .
; Out: z=1 free slot found -> ix - its address
; .
; de =LenSlotObj
; .
; b,a - undefined
c$F399 LD IX,$6048   ; length 27h
 $F39D LD DE,$0027   ; '''
 $F3A0 LD B,$06      ;
*$F3A2 ADD IX,DE     ;
 $F3A4 LD A,(IX+$22) ;
 $F3A7 AND A         ;
 $F3A8 RET Z         ;
 $F3A9 DJNZ $F3A2    ;
 $F3AB INC B         ;
 $F3AC RET           ;

; SetPlayerObj
;
; Used by the routine at #R$F4FF.
;
; .
;
; Place an object in space at the player's coordinates, into a free slot
; .
; In: a - object number
; .
; Out: z=1 free slot found -> ix - address
c$F3AD LD C,A        ;
 $F3AE CALL $F399    ; find a free slot to place an object
 $F3B1 RET NZ        ;
 $F3B2 LD A,C        ;

; SetPlayerObjSlot
;
; Used by the routines at #R$F402 and #R$F55D.
;
; .
;
; Place an object into a slot at the player's coordinates
; .
; In: a - object number
; .
; ix address of the object slot
; .
; Out: a=$00
c$F3B3 CALL $F2FB     ; place an object into a slot
 $F3B6 RES 7,(IX+$0E) ;
 $F3BA RES 7,(IX+$16) ;
 $F3BE LD (IX+$00),A  ;
 $F3C1 LD (IX+$01),A  ;
 $F3C4 LD (IX+$04),A  ;
 $F3C7 LD (IX+$06),A  ;
 $F3CA LD (IX+$07),A  ;
 $F3CD RET            ;

; Set3_4Thargons
;
; Used by the routine at #R$F2CA.
;
; .
;
; Place 3-4 Thargons
; .
; In: ---
; .
; Out: z=1 success
; .
; hl,de,bc,a - undefined
c$F3CE CALL $ED24     ; Random number
 $F3D1 AND $01        ;
 $F3D3 ADD A,$03      ; 3/4 thargon
 $F3D5 LD C,A         ;
*$F3D6 CALL $F399     ; find a free slot to place an object
 $F3D9 RET NZ         ;
 $F3DA LD A,$0F       ; thargon
 $F3DC PUSH BC        ;
 $F3DD CALL $F2FB     ; place an object into a slot
 $F3E0 SET 0,(IX+$25) ;
 $F3E4 CALL $ED24     ; Random number
 $F3E7 AND $0F        ;
 $F3E9 OR $04         ;
 $F3EB LD (IX+$07),A  ;
 $F3EE RRA            ;
 $F3EF RRA            ;
 $F3F0 RRA            ;
 $F3F1 AND $01        ;
 $F3F3 LD (IX+$01),A  ;
 $F3F6 XOR A          ;
 $F3F7 LD (IX+$04),A  ;
 $F3FA CALL $F4E6     ; generate a random movement direction for the object
 $F3FD POP BC         ;
 $F3FE DEC C          ;
 $F3FF JR NZ,$F3D6    ;
 $F401 RET            ;

; SetObjMissile
;
; Used by the routine at #R$F2CA.
;
; .
;
; Launch a missile
; .
; In: c - missile target
; .
; =0 player (launched by an enemy)
; .
; <>0 number of the object the player fired the missile at
; .
; Out: Z=1 success
c$F402 LD A,C         ;
 $F403 AND A          ;
 $F404 JR Z,$F432     ; =1 missile
 $F406 LD IX,$6048    ; length 27h
 $F40A LD DE,$0111    ; =$27*7
 $F40D ADD IX,DE      ; ix=#R$6159
 $F40F LD A,(IX+$22)  ;
 $F412 AND A          ;
 $F413 JR Z,$F419     ; =1 - missile
 $F415 CALL $F399     ; find a free slot to place an object
 $F418 RET NZ         ;
*$F419 LD A,$01       ; =1 - missile
 $F41B PUSH BC        ;
 $F41C CALL $F3B3     ; place an object into a slot at the player's coordinates
 $F41F POP BC         ;
 $F420 LD A,$6A       ; 'j'
 $F422 LD (IX+$06),A  ;
 $F425 LD A,$29       ; ')'
 $F427 LD (IX+$03),A  ;
 $F42A LD A,$80       ;
 $F42C LD (IX+$05),A  ;
 $F42F LD A,C         ;
 $F430 JR $F441       ;
*$F432 LD A,$01       ; =1 missile
 $F434 CALL $F381     ; place an object into a slot at another object's
                      ; coordinates (a ship launching an enemy object, which
                      ; inherits coordinates, OCS and speed from the parent)
 $F437 RET NZ         ;
 $F438 LD A,($7044)   ; get HighDeltaSpeed
 $F43B ADD A,(IX+$1B) ;
 $F43E LD (IX+$1B),A  ;
*$F441 LD (IX+$25),C  ;
 $F444 SET 0,(IX+$26) ;
 $F448 XOR A          ;
 $F449 RET            ;

; ShipSetShip
;
; Used by the routine at #R$F2CA.
;
; .
;
; Launch a ship from an object
; .
; In: c - number of the ship being placed
; .
; =1 Viper
; .
; =2 Cobra/Python
; .
; =3 Tharglet
; .
; =4 Thargon
; .
; =5 Sidewinder/Krait
; .
; >5 place nothing
; .
; ix - slot address of the parent object
; .
; Out: z=1 success
; .
; ix - slot address of the placed ship
; .
; iy - address of the parent slot
; .
; hl,de,bc,a - undefined
c$F44A LD A,$08       ;
 $F44C DEC C          ; A=8, viper
 $F44D JR Z,$F470     ; Set Viper
 $F44F CALL $ED24     ; Random number
 $F452 AND $01        ;
 $F454 ADD A,$09      ; a=9/10, cobra/python
 $F456 DEC C          ;
 $F457 JR Z,$F470     ; Set Cobra/Python
 $F459 LD A,$12       ; a=18, tharglet
 $F45B DEC C          ;
 $F45C JR Z,$F470     ; Set Tharglet
 $F45E LD A,$0F       ; a=15, thargon
 $F460 DEC C          ;
 $F461 JR Z,$F470     ; Set Thargon
 $F463 DEC C          ;
 $F464 RET NZ         ; >5, ships
 $F465 CALL $ED24     ; Random number
 $F468 BIT 0,A        ;
 $F46A LD A,$10       ; a=16, sidewinder
 $F46C JR Z,$F470     ; a - object number
 $F46E LD A,$11       ; a=17, krait
*$F470 PUSH IX        ; a - object number
 $F472 CALL $F381     ; place an object into a slot at another object's
                      ; coordinates (a ship launching an enemy object, which
                      ; inherits coordinates, OCS and speed from the parent)
 $F475 POP IY         ;
 $F477 RET NZ         ;
 $F478 BIT 2,(IY+$26) ;
 $F47C CALL Z,$F48A   ; rotate the object's OCS
 $F47F BIT 2,(IY+$21) ; inherit aggression
 $F483 RET Z          ;
 $F484 SET 2,(IX+$21) ;
 $F488 XOR A          ;
 $F489 RET            ;

; RotateSKOobj
;
; Used by the routines at #R$F44A and #R$F5B8.
;
; .
;
; Rotate the object's OCS
; .
; In: ix - address of the object slot
; .
; Out: b=$00
; .
; c,a - undefined
c$F48A LD A,($F2C9)  ; alternation
 $F48D XOR $01       ;
 $F48F LD ($F2C9),A  ; alternation
 $F492 JR Z,$F4BB    ;
 $F494 PUSH IX       ;
 $F496 CALL $F4A2    ;
 $F499 CALL $F4A2    ;
 $F49C CALL $F4A2    ;
 $F49F POP IX        ;
 $F4A1 RET           ;
*$F4A2 LD A,(IX+$0A) ;
 $F4A5 LD B,(IX+$10) ;
 $F4A8 LD (IX+$10),A ;
 $F4AB LD (IX+$0A),B ;
 $F4AE LD A,(IX+$16) ;
 $F4B1 XOR $80       ;
 $F4B3 LD (IX+$16),A ;
 $F4B6 INC IX        ;
 $F4B8 INC IX        ;
 $F4BA RET           ;
*$F4BB LD A,(IX+$10) ;
 $F4BE XOR $80       ;
 $F4C0 LD B,(IX+$0A) ;
 $F4C3 LD (IX+$0A),A ;
 $F4C6 LD (IX+$10),B ;
 $F4C9 LD A,(IX+$12) ;
 $F4CC XOR $80       ;
 $F4CE LD B,(IX+$0C) ;
 $F4D1 LD (IX+$0C),A ;
 $F4D4 LD (IX+$12),B ;
 $F4D7 LD A,(IX+$14) ;
 $F4DA XOR $80       ;
 $F4DC LD B,(IX+$0E) ;
 $F4DF LD (IX+$0E),A ;
 $F4E2 LD (IX+$14),B ;
 $F4E5 RET           ;

; RndDirectionObj
;
; Used by the routines at #R$F3CE, #R$F4FF and #R$F55D.
;
; .
;
; Generate a random movement direction for the object
; .
; In: ix - address of the object slot
; .
; Out: a - undefined
c$F4E6 CALL $ED24    ; Random number
 $F4E9 AND $87       ;
 $F4EB LD (IX+$0A),A ;
 $F4EE CALL $ED24    ; Random number
 $F4F1 AND $87       ;
 $F4F3 LD (IX+$0C),A ;
 $F4F6 RET           ;

; Set2Alloys
;
; Used by the routine at #R$F2CA.
;
; .
;
; Place two Alloys objects
; .
; In: c =$01 at the player's coordinates
; .
; $00 at the object's coordinates
; .
; Out: ix,hl,de,bc,a - undefined
c$F4F7 BIT 0,C       ;
 $F4F9 JR Z,$F54B    ; place an Alloys object in space at the object's
                     ; coordinates
 $F4FB CALL $F4FF    ; place an Alloys object in space at the player's
                     ; coordinates into a free slot; place a Cargo object in
                     ; space at the player's coordinates into a free slot
 $F4FE RET NZ        ;

; SetPlayerAlloys
;
; Used by the routine at #R$F4F7.
;
; .
;
; Place an Alloys object in space at the player's coordinates into a free slot
; .
; place a Cargo object in space at the player's coordinates into a free slot
; .
; In: ---
; .
; Out: ix,hl,de,bc,a - undefined
c$F4FF LD A,$03       ;
; This entry point is used by the routine at #R$F555.
*$F501 CALL $F3AD     ; place a Cargo object in space at the player's
                      ; coordinates into a free slot
 $F504 RET NZ         ;
 $F505 CALL $F4E6     ; generate a random movement direction for the object
 $F508 RES 6,(IX+$20) ;
 $F50C CALL $ED24     ; Random number
 $F50F AND $3F        ; '?'
 $F511 OR $10         ;
 $F513 LD (IX+$00),A  ;
 $F516 LD A,(IX+$0A)  ;
 $F519 AND $80        ;
 $F51B XOR $80        ;
 $F51D LD (IX+$02),A  ;
 $F520 CALL $ED24     ; Random number
 $F523 AND $3F        ; '?'
 $F525 OR $10         ;
 $F527 LD (IX+$03),A  ;
 $F52A LD A,(IX+$0C)  ;
 $F52D AND $80        ;
 $F52F XOR $80        ;
 $F531 LD (IX+$05),A  ;
 $F534 LD A,$19       ;
 $F536 LD (IX+$06),A  ;
 $F539 CALL $ED24     ; Random number
 $F53C LD (IX+$1D),A  ;
 $F53F CALL $ED24     ; Random number
 $F542 AND $1F        ;
 $F544 OR $08         ;
 $F546 LD (IX+$1B),A  ;
 $F549 XOR A          ;
 $F54A RET            ;

