 $8F6E LD HL,$FC14   ; 0-1,=00 SXNMA controls (LLFC0F)<>0 reset CS,F,c =01
                     ; Kempston controls =10 cursor controls 76850 =11 Sinclair
                     ; right controls 2,=1 realistic control approximation
                     ; (reaction) 3,=1 turn inertia on 4,=1 controls inverted
