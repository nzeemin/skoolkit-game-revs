 $DF6E POP DE        ;
 $DF6F LD B,E        ;
 $DF70 LD A,L        ;
 $DF71 LD L,H        ;
 $DF72 LD H,$00      ;
 $DF74 POP DE        ;
 $DF75 ADD HL,DE     ;
 $DF76 LD E,A        ;
 $DF77 PUSH HL       ;
 $DF78 CALL $E434    ; A=((b+c)/2)^2-((b-c)/2)^2
 $DF7B ADD A,E       ;
 $DF7C POP HL        ;
 $DF7D JR NC,$DF80   ;
 $DF7F INC HL        ;
*$DF80 LD B,A        ;
 $DF81 LD A,H        ;
 $DF82 LD H,L        ;
 $DF83 LD L,B        ;
 $DF84 POP BC        ;
 $DF85 LD C,B        ;
 $DF86 LD B,(IY+$02) ;
 $DF89 LD D,(IY+$01) ;
 $DF8C LD E,(IY+$00) ;
 $DF8F PUSH AF       ;
 $DF90 LD A,B        ;
 $DF91 XOR C         ;
 $DF92 RLC C         ;
 $DF94 RLC C         ;
 $DF96 RLA           ;
 $DF97 RR C          ;
 $DF99 RRC C         ;
 $DF9B SRL A         ;
 $DF9D LD B,A        ;
 $DF9E POP AF        ;
 $DF9F BIT 6,C       ;
 $DFA1 JR NZ,$DFAE   ;
 $DFA3 ADD A,A       ;
 $DFA4 SLA C         ;
 $DFA6 RRA           ;
 $DFA7 ADD A,B       ;
 $DFA8 ADD HL,DE     ;
 $DFA9 JR NC,$DFCF   ;
 $DFAB INC A         ;
 $DFAC JR $DFCF      ;
*$DFAE AND A         ;
 $DFAF EX DE,HL      ;
 $DFB0 SBC HL,DE     ;
 $DFB2 JR NC,$DFB5   ;
 $DFB4 INC A         ;
*$DFB5 LD D,A        ;
 $DFB6 LD A,B        ;
 $DFB7 SUB D         ;
 $DFB8 LD B,A        ;
 $DFB9 JR NC,$DFC8   ;
 $DFBB CPL           ;
 $DFBC LD B,A        ;
 $DFBD LD A,C        ;
 $DFBE XOR $80       ;
 $DFC0 LD C,A        ;
 $DFC1 EX DE,HL      ;
 $DFC2 AND A         ;
 $DFC3 LD HL,$0000   ;
 $DFC6 SBC HL,DE     ;
*$DFC8 LD A,B        ;
 $DFC9 RLA           ;
 $DFCA SLA C         ;
 $DFCC RRA           ;
 $DFCD XOR $80       ;
*$DFCF LD (IY+$02),A ;
 $DFD2 LD (IY+$01),H ;
 $DFD5 LD (IY+$00),L ;
 $DFD8 POP IY        ;
 $DFDA POP IX        ;
