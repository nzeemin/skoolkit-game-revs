; .
; In: c - crdY (circle center coordinate)
; .
; a - crdX-radius (left boundary coordinate of the circle)
; .
; Out: b - left byte to print
; .
; hl - print address
; .
; e - low byte of the left-byte print address
c$7FF4 LD B,C        ;
 $7FF5 LD C,A        ;
 $7FF6 LD A,B        ;
 $7FF7 CALL $22B0    ; hl - address
 $7FFA SET 7,H       ; print into the buffer
 $7FFC LD B,A        ; b - bit within the byte
 $7FFD LD A,($7C49)  ; get FillCircle
 $8000 AND A         ;
 $8001 LD A,B        ;
 $8002 JP NZ,$861F   ; continuation of CalcLeftAddrCircle
 $8005 LD B,$FF      ;
 $8007 INC A         ;
*$8008 SRL B         ;
 $800A DEC A         ;
 $800B JR NZ,$8008   ;
 $800D LD E,L        ;
 $800E RET           ;

; CalcRightAddrCircle
;
; Used by the routines at #R$7DF4, #R$7ED8, #R$7F5F and #R$7FC1.
;
; .
;
; Determine right byte data and print address
; .
; In: c - crdY (circle center coordinate)
; .
; a - crdX+radius (right boundary coordinate of the circle)
; .
; b - left byte to print
; .
; e - low byte of the left-byte print address
; .
; Out: b - left byte to print
; .
; c - right byte to print
; .
; hl - address to print the right byte
; .
; hl - address to print the left byte
c$800F PUSH AF       ;
 $8010 LD A,B        ;
 $8011 LD ($7C47),A  ; set SaveA7
 $8014 POP AF        ;
 $8015 LD B,C        ;
 $8016 LD C,A        ;
 $8017 LD A,B        ;
 $8018 CALL $22B0    ;
 $801B SET 7,H       ;
 $801D SUB $08       ;
 $801F NEG           ;
 $8021 LD C,A        ;
 $8022 LD A,($7C49)  ; get FillCircle
 $8025 AND A         ;
 $8026 LD A,C        ;
 $8027 JP NZ,$8629   ; continuation of CalcRightAddrCircle
 $802A LD C,$FF      ;
*$802C SLA C         ;
 $802E DEC A         ;
 $802F JR NZ,$802C   ;
 $8031 LD A,($7C47)  ; get SaveA7
 $8034 LD B,A        ;
 $8035 RET           ;

