 $893C CP $02        ;
 $893E JR NC,$89B2   ;
 $8940 LD B,A        ;
 $8941 LD A,(IX+$05) ;
 $8944 AND $7F       ;
 $8946 CP $02        ;
 $8948 JR NC,$89B2   ;
