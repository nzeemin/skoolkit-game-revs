*$ABCD LD SP,HL      ;
 $ABCE LD A,($ABE3)  ;
*$ABD1 LD B,$10      ;
*$ABD3 PUSH DE       ;
 $ABD4 DJNZ $ABD3    ;
 $ABD6 DEC A         ;
 $ABD7 JR NZ,$ABD1   ;
 $ABD9 INC H         ;
 $ABDA DEC C         ;
 $ABDB JR NZ,$ABCD   ;
 $ABDD LD SP,($ABE4) ;
 $ABE1 EI            ;
 $ABE2 RET           ;

