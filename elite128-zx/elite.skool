; CalcCatet
;
; Used by the routines at #R$7E14, #R$7E60, #R$7ED8 and #R$7F5F.
;
; .
;
; Calculate a leg using the Pythagorean theorem
; .
; In: d - hypotenuse length
; .
; a - leg length
; .
; Out: a - length of the other leg
c$80ED PUSH BC       ;
 $80EE PUSH DE       ;
 $80EF PUSH HL       ;
 $80F0 PUSH AF       ;
 $80F1 LD A,D        ;
 $80F2 CALL $7DDF    ; Squaring
 $80F5 LD H,D        ;
 $80F6 LD L,E        ;
 $80F7 POP AF        ;
 $80F8 CALL $7DDF    ; Squaring
 $80FB SBC HL,DE     ;
 $80FD LD B,$80      ;
 $80FF XOR A         ;
 $8100 LD ($7C45),HL ;
*$8103 LD HL,($7C45) ;
 $8106 ADD A,B       ;
 $8107 CALL $7DDF    ; Squaring
 $810A SBC HL,DE     ;
 $810C JR NC,$810F   ;
 $810E SUB B         ;
*$810F SRL B         ;
 $8111 JR NC,$8103   ;
 $8113 POP HL        ;
 $8114 POP DE        ;
 $8115 POP BC        ;
 $8116 RET           ;

