 $B761 PUSH HL       ;
 $B762 CALL $B7F7    ; print leading zeros or spaces before the number
 $B765 POP HL        ;
 $B766 LD A,$01      ;
 $B768 LD ($A88D),A  ; set FlgPrnNumber
 $B76B LD ($B757),HL ; for storing the number to print
 $B76E LD DE,$2710   ;
 $B771 CALL $B7D2    ; print the most-significant digit of a number
 $B774 LD DE,$03E8   ;
 $B777 CALL $B7D2    ; print the most-significant digit of a number
 $B77A LD DE,$0064   ;
 $B77D CALL $B7D2    ; print the most-significant digit of a number
 $B780 LD DE,$000A   ;
 $B783 CALL $B7D2    ; print the most-significant digit of a number
 $B786 POP AF        ;
 $B787 JR NC,$B798   ;
 $B789 LD A,($A88D)  ; get FlgPrnNumber
 $B78C AND A         ;
 $B78D JP Z,$B794    ;
 $B790 XOR A         ;
 $B791 CALL $B7EB    ; print one digit a - digit
*$B794 CALL $BA99    ; print one character (print a message by number

; Data block at B797
