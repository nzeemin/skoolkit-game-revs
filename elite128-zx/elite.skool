; In: (DataOfPlanet) - planet data
; .
; Out: (DataOfPlanet) - data for the next planet
; .
; hl,de,bc,a - ????
c$AA96 CALL $AA6F    ; calculate the star's print coordinates and the
                     ; display-file address
 $AA99 LD ($AAB6),A  ;
 $AA9C LD DE,$91D2   ; sprites for stars on the local map
 $AA9F LD A,($AC1A)  ;
 $AAA2 AND $18       ;
 $AAA4 ADD A,E       ;
 $AAA5 LD E,A        ;
 $AAA6 JR NC,$AAA9   ;
 $AAA8 INC D         ;
*$AAA9 LD B,$08      ;
*$AAAB PUSH BC       ;
 $AAAC LD A,($AAB6)  ;
 $AAAF AND A         ;
 $AAB0 LD A,(DE)     ;
 $AAB1 LD C,$00      ;
 $AAB3 JR Z,$AABD    ;
 $AAB5 LD B,$01      ;
*$AAB7 SRL A         ;
 $AAB9 RR C          ;
 $AABB DJNZ $AAB7    ;
*$AABD LD B,A        ;
 $AABE LD A,(HL)     ;
 $AABF XOR B         ;
 $AAC0 LD (HL),A     ;
 $AAC1 INC HL        ;
 $AAC2 LD A,(HL)     ;
 $AAC3 XOR C         ;
 $AAC4 LD (HL),A     ;
 $AAC5 DEC HL        ;
 $AAC6 LD A,H        ;
 $AAC7 INC A         ;
 $AAC8 AND $07       ;
 $AACA JR NZ,$AADC   ;
 $AACC LD A,H        ;
 $AACD AND $F8       ;
 $AACF LD H,A        ;
 $AAD0 LD A,$20      ; ' '
 $AAD2 ADD A,L       ;
 $AAD3 LD L,A        ;
 $AAD4 JR NC,$AADD   ;
 $AAD6 LD A,$08      ;
 $AAD8 ADD A,H       ;
 $AAD9 LD H,A        ;
 $AADA JR $AADD      ;
*$AADC INC H         ;
*$AADD INC DE        ;
 $AADE POP BC        ;
 $AADF DJNZ $AAAB    ;
 $AAE1 JP $AD17      ; modify data for planet generation

