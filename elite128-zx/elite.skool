                     ; coordinates, OCS and speed from the parent)
 $F550 RET NZ        ;
 $F551 LD A,$03      ;
 $F553 JR $F5B8      ; place Minerals/Alloys into a slot at another object's
                     ; coordinates (debris

; SetCargo
