 $E435 SUB C         ;
 $E436 JR NC,$E43A   ;
 $E438 NEG           ;
*$E43A SRL A         ;
 $E43C LD H,$BF      ;
 $E43E LD L,A        ;
 $E43F LD D,(HL)     ;
 $E440 LD A,B        ;
 $E441 ADD A,C       ;
 $E442 RRA           ;
 $E443 LD L,A        ;
 $E444 LD A,(HL)     ;
 $E445 SUB D         ;
 $E446 RET           ;

; MultCrdNMatrixEl
;
; Used by the routine at #R$E353.
;
; .
;
; Multiply the coordinate by a matrix element, accounting for the scaling
; factor
; .
; of vertex coordinates
; .
; In: b - abs(crd N) of the vertex
; .
; iy =MatrixRotate+n address of an element in the rotation matrix
; .
; (VertexIncFactor) - vertex coordinate scaling factor
; .
; Out: hl = 0.b*2^(VertexIncFactor) * 0.MatrixElement
; .
; bc,a - undefined
c$E447 LD A,($E2EF)  ; get VertexIncFactor
*$E44A SLA B         ;
 $E44C DEC A         ;
 $E44D JR NZ,$E44A   ;
 $E44F LD C,(IY+$01) ;
 $E452 RES 7,C       ;
 $E454 PUSH DE       ;
 $E455 CALL $E434    ; A=((b+c)/2)^2-((b-c)/2)^2
 $E458 LD L,A        ;
 $E459 LD H,$00      ;
 $E45B POP DE        ;
 $E45C RET           ;

; Mult_HL_B_C
;
; Used by the routines at #R$DBFA, #R$DCC6, #R$DF46, #R$E7F3, #R$E88B, #R$E9E4
; and #R$F0BE.
;
; .
;
; Approximate table-based multiplication HL=B*C
; .
; computes: ((b+c)/2)^2 - ((b-c)/2)^2
; .
; should be: ((b+c)^2 - (b-c)^2)/4
c$E45D LD A,B        ;
 $E45E SUB C         ;
 $E45F JR NC,$E463   ;
 $E461 NEG           ;
*$E463 SRL A         ;
 $E465 LD H,$BE      ;
 $E467 LD L,A        ;
 $E468 LD E,(HL)     ;
 $E469 INC H         ;
 $E46A LD D,(HL)     ;
 $E46B DEC H         ;
 $E46C LD A,B        ;
 $E46D ADD A,C       ;
 $E46E RRA           ;
 $E46F LD L,A        ;
 $E470 LD A,(HL)     ;
 $E471 INC H         ;
 $E472 LD H,(HL)     ;
 $E473 LD L,A        ;
 $E474 AND A         ;
 $E475 SBC HL,DE     ;
 $E477 RET           ;

; AddCrdNobj_CrdNvertex
