 $AAFA INC A         ;
 $AAFB LD ($AAE6),A  ;
 $AAFE POP BC        ;
 $AAFF LD A,C        ;
 $AB00 RRA           ;
 $AB01 RRA           ;
 $AB02 RRA           ;
 $AB03 AND $1F       ;
 $AB05 INC A         ;
 $AB06 LD ($A80D),A  ; set CrdXPrnSymbol
 $AB09 LD A,B        ;
 $AB0A SRL A         ;
 $AB0C SRL A         ;
