 $A5D5 LD B,$05      ;
*$A5D7 LD A,(HL)     ;
 $A5D8 SUB C         ;
 $A5D9 JR C,$A5DF    ;
 $A5DB LD (HL),A     ;
 $A5DC DJNZ $A5D7    ;
 $A5DE RET           ;
*$A5DF LD (HL),$00   ;
 $A5E1 DEC B         ;
 $A5E2 RET Z         ;
 $A5E3 CALL $A5A6    ; decrease ship energy energy=energy-(b*c)
 $A5E6 LD HL,$A639   ; damage intensity; if the damage empties the front/rear
                     ; shield, +5; if that makes it >=$0D, chance of destroying
                     ; cargo/equipment
 $A5E9 LD A,(HL)     ;
 $A5EA ADD A,$05     ;
 $A5EC LD (HL),A     ;
 $A5ED CP $0D        ;
 $A5EF RET C         ;
; This entry point is used by the routine at #R$A8A7.
*$A5F0 LD A,($D448)  ; heavy damage. destruction of something (fuel/cargo,
                     ; etc.)
 $A5F3 CP $FD        ;
 $A5F5 RET Z         ;
 $A5F6 LD A,($7063)  ; get RndWord
 $A5F9 RRCA          ;
 $A5FA RRCA          ;
 $A5FB AND $3F       ; '?'
 $A5FD JP Z,$D862    ; zero out fuel
 $A600 CP $11        ;
 $A602 RET NC        ;
 $A603 DEC A         ;
 $A604 CP $06        ;
 $A606 JR NC,$A626   ;
 $A608 LD HL,$A847   ; ECM System 7,=1 system on
 $A60B AND A         ;
 $A60C JR Z,$A610    ;
 $A60E ADD A,$02     ;
*$A610 CALL $B719    ;
 $A613 LD A,(HL)     ;
 $A614 AND A         ;
 $A615 RET Z         ;
 $A616 LD (HL),D     ;
 $A617 LD A,E        ;
 $A618 ADD A,$6C     ; 'l'
*$A61A LD ($D44B),A  ; message number for what got damaged in combat
 $A61D CALL $9A6E    ; Set cockpit attributes on screen/in buffer
 $A620 LD HL,$A885   ; 7,=1 some equipment/cargo destroyed -> message number
                     ; goes into nMsgDamage
 $A623 SET 7,(HL)    ;
 $A625 RET           ;
*$A626 LD HL,$A829   ; 19-20 pilot's money (whole thousands) CASH 0..65535 -
                     ; 0000..65535000
 $A629 CALL $B719    ;
 $A62C LD A,(HL)     ;
 $A62D AND A         ;
 $A62E RET Z         ;
 $A62F DEC (HL)      ;
 $A630 LD HL,$A83E   ; remaining ship cargo capacity
 $A633 INC (HL)      ;
 $A634 LD A,$CC      ;
 $A636 ADD A,E       ;
 $A637 JR $A61A      ;

