 $D7BA LD A,($A87E)  ; get Pilot_CrdYTarget
 $D7BD LD ($A859),A  ; set Pilot_CrdYSystem
 $D7C0 LD A,($A827)  ; get PilotNumGalaxy
 $D7C3 AND A         ;
 $D7C4 JR Z,$D814    ;
 $D7C6 LD HL,$606E   ; 7,=1 mission 3 completed
 $D7C9 BIT 7,(HL)    ;
 $D7CB RES 7,(HL)    ;
 $D7CD JR NZ,$D7AC   ;
 $D7CF LD HL,$A871   ; +92 >0 - mission 3 given =1 mission 3 will be given on
                     ; docking ( =1 time to give the mission, will become =2
                     ; after the jump) =2 mission 3 will be given on docking =3
                     ; mission 3 given (the station can be destroyed with a
                     ; missile) (Thargons launch from the station) =4 mission 3
                     ; given, the ship is in the target system (the station can
                     ; be destroyed with a missile) (Thargons launch from the
                     ; station) =5 mission 3 completed, there will be
                     ; congratulations on docking
 $D7D2 LD A,(HL)     ;
 $D7D3 AND A         ;
 $D7D4 JR Z,$D7EE    ;
 $D7D6 DEC A         ;
 $D7D7 JR NZ,$D7DC   ;
 $D7D9 INC (HL)      ;
 $D7DA JR $D7E1      ;
*$D7DC CP $03        ;
 $D7DE JR NZ,$D7E1   ;
 $D7E0 LD (HL),A     ;
*$D7E1 LD HL,$A858   ; ?????
 $D7E4 CALL $D06C    ; compare galaxy data with HL
 $D7E7 JR C,$D7EE    ;
 $D7E9 LD A,$04      ;
*$D7EB LD ($A871),A  ; set PilotMission3
*$D7EE LD HL,($A825) ; get JumpCounter
 $D7F1 INC HL        ;
 $D7F2 LD ($A825),HL ; set JumpCounter
