c$F55D BIT 0,C        ;
 $F55F LD A,$02       ;
 $F561 JR Z,$F592     ; place EscapePod/Cargo into a slot at another object's
                      ; coordinates (an enemy ship launching EscapePod/Cargo,
                      ; which inherits coordinates, OCS and speed from the
                      ; parent)
 $F563 LD A,$09       ;
 $F565 LD IX,$6132    ;
 $F569 CALL $F3B3     ; place an object into a slot at the player's coordinates
 $F56C CALL $F4E6     ; generate a random movement direction for the object
 $F56F LD A,$80       ;
 $F571 LD (IX+$05),A  ;
 $F574 LD A,$1C       ;
 $F576 LD (IX+$03),A  ;
 $F579 RES 6,(IX+$20) ;
 $F57D LD A,$4C       ; 'L'
 $F57F LD (IX+$06),A  ;
 $F582 LD A,$C0       ;
 $F584 LD (IX+$1E),A  ;
 $F587 LD A,($7044)   ; get HighDeltaSpeed
 $F58A ADD A,(IX+$1B) ;
 $F58D LD (IX+$1B),A  ;
 $F590 XOR A          ;
 $F591 RET            ;

; SetShipEPodCargo
;
; Used by the routines at #R$F555 and #R$F55D.
;
; .
;
; Place EscapePod/Cargo into a slot at another object's coordinates (an enemy
; .
; ship launching EscapePod/Cargo, which inherits coordinates, OCS and speed
; from
; .
; the parent)
; .
; In: a - object number
; .
; ix address of the object slot
; .
; Out: z=1 success
; .
; hl,de,bc,a - undefined
c$F592 PUSH IX        ; place an EscapePod at the enemy's coordinates
 $F594 CALL $F381     ; place an object into a slot at another object's
                      ; coordinates (a ship launching an enemy object, which
                      ; inherits coordinates, OCS and speed from the parent)
 $F597 EX (SP),IX     ;
 $F599 POP HL         ;
 $F59A RET NZ         ;
 $F59B PUSH HL        ;
 $F59C EX (SP),IX     ;
 $F59E RES 6,(IX+$20) ;
 $F5A2 LD A,$0A       ;
 $F5A4 LD (IX+$26),A  ;
 $F5A7 LD A,$80       ;
 $F5A9 LD (IX+$1D),A  ;
 $F5AC XOR A          ;
 $F5AD POP IX         ;
 $F5AF RET            ;

