 $D9D9 SUB D         ;
 $D9DA LD B,A        ;
 $D9DB LD A,($A813)  ; get PrnCrdXCursor
 $D9DE CALL $D97D    ; calculate the screen address
*$D9E1 LD A,($A813)  ; get PrnCrdXCursor
 $D9E4 AND $07       ;
 $D9E6 INC A         ;
 $D9E7 LD C,A        ;
 $D9E8 XOR A         ;
 $D9E9 SCF           ;
