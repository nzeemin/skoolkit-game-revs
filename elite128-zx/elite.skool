 $9A81 LD C,$1F      ;
*$9A83 LD DE,$001B   ;
 $9A86 PUSH HL       ;
 $9A87 CALL $9A8F    ; set cockpit indicator attributes C - Attribute HL -
                     ; address in the attribute area DE =1Bh
 $9A8A POP HL        ;
 $9A8B LD A,L        ;
 $9A8C ADD A,$15     ;
 $9A8E LD L,A        ;
*$9A8F LD B,$07      ; set cockpit indicator attributes C - Attribute HL -
                     ; address in the attribute area DE =1Bh
*$9A91 PUSH BC       ;
 $9A92 LD B,$05      ;
*$9A94 LD (HL),C     ;
 $9A95 INC HL        ;
 $9A96 DJNZ $9A94    ;
 $9A98 POP BC        ;
 $9A99 ADD HL,DE     ;
 $9A9A DJNZ $9A91    ;
 $9A9C RET           ;

