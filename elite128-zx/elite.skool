; SetShipMinAlloys
;
; Used by the routines at #R$F54B and #R$F5B0.
;
; .
;
; Place Minerals/Alloys into a slot at another object's coordinates (debris
; .
; of an asteroid/ship inherits coordinates, OCS and speed from the parent)
; .
; In: a - number of the object being placed
; .
; ix address of the parent object's slot
; .
; Out: z=1 success
; .
; hl,de,bc,a - undefined
c$F5B8 PUSH IX        ;
 $F5BA CALL $F381     ; place an object into a slot at another object's
                      ; coordinates (a ship launching an enemy object, which
                      ; inherits coordinates, OCS and speed from the parent)
 $F5BD EX (SP),IX     ;
 $F5BF POP HL         ;
 $F5C0 RET NZ         ;
 $F5C1 PUSH HL        ;
 $F5C2 EX (SP),IX     ;
 $F5C4 CALL $F48A     ; rotate the object's OCS
 $F5C7 LD A,$0A       ;
 $F5C9 LD (IX+$26),A  ;
 $F5CC RES 6,(IX+$20) ;
 $F5D0 SET 7,(IX+$1D) ;
 $F5D4 POP IX         ;
 $F5D6 XOR A          ;
 $F5D7 RET            ;

; SetShip4Intro
;
; Used by the routine at #R$F2CA.
;
; .
;
; Place an object into the missile slot for the intro screen
; .
; In: c - object number
; .
; Out: ix,hl,de,bc,a - undefined
c$F5D8 LD IX,$6159    ; slot for the missile +00
 $F5DC LD A,C         ;
 $F5DD ADD A,$02      ;
 $F5DF CALL $F2FB     ; place an object into a slot
 $F5E2 LD A,$C0       ;
 $F5E4 LD (IX+$1D),A  ;
 $F5E7 LD (IX+$1E),A  ;
 $F5EA XOR A          ;
 $F5EB LD (IX+$06),A  ;
 $F5EE LD (IX+$00),A  ; crd X =0
 $F5F1 LD (IX+$01),A  ;
 $F5F4 LD (IX+$03),A  ; crd y =0
 $F5F7 LD (IX+$04),A  ;
 $F5FA LD (IX+$08),A  ; crd z = 003200
 $F5FD LD (IX+$1B),A  ;
 $F600 RES 6,(IX+$20) ;
 $F604 INC A          ;
 $F605 INC A          ;
 $F606 LD (IX+$07),A  ; crd z = 000200
 $F609 PUSH IX        ;
 $F60B POP HL         ;
 $F60C LD DE,$0009    ;
 $F60F LD B,D         ;
 $F610 LD C,E         ;
 $F611 ADD HL,DE      ;
 $F612 EX DE,HL       ;
 $F613 LD HL,$F2C0    ; object's OCS for the intro
*$F616 INC DE         ;
 $F617 LDI            ;
 $F619 JP PE,$F616    ;
 $F61C RET            ;

; SetRndShip
;
; Used by the routine at #R$F2CA.
;
; .
;
; Place a random ship/group of ships
; .
; In: ---
; .
; Out: hl,de,bc,a - undefined
c$F61D LD A,($A830)   ; get cargoSlaves
 $F620 LD C,A         ; number of slaves
 $F621 LD A,($A833)   ; get cargoNarc
 $F624 ADD A,C        ;
 $F625 ADD A,A        ;
 $F626 LD C,A         ; c = (number of slaves + amount of narcotics) * 2
 $F627 LD A,($A837)   ; +0A Firearms
 $F62A ADD A,C        ;
 $F62B LD C,A         ; c = (number of slaves + amount of narcotics) * 2 +
                      ; amount of weapons
 $F62C LD A,($DA0C)   ; get PilotMission2
 $F62F AND A          ;
 $F630 JR NZ,$F660    ; c = (number of slaves + amount of narcotics) * 2 +
                      ; amount of weapons
 $F632 CALL $ED24     ; Random number
 $F635 CP $FF         ;
 $F637 JR NC,$F660    ; c = (number of slaves + amount of narcotics) * 2 +
                      ; amount of weapons
 $F639 LD A,($A872)   ; +93 extra equipment present 7,=1 - ECM Jammer 6,=1 -
                      ; Cloaking device 5,=1 - cannot buy goods (refugees in
                      ; the hold) 4 3 =1 mission 3 was completed 2 =1 - mission
                      ; 3 completed 1 =1 - mission 2 completed 0 =1 - mission 1
                      ; completed
 $F63C AND $42        ;
 $F63E CP $02         ;
 $F640 JR NZ,$F660    ; c = (number of slaves + amount of narcotics) * 2 +
                      ; amount of weapons
 $F642 DEC A          ;
 $F643 LD ($DA0C),A   ; set PilotMission2
 $F646 LD A,$0F       ;
 $F648 LD HL,$F655    ;
 $F64B PUSH HL        ;
 $F64C PUSH AF        ;
 $F64D CALL $F399     ; find a free slot to place an object
 $F650 RET NZ         ;
 $F651 LD A,$0D       ; asp
 $F653 JR $F6C8       ; set asp
 $F655 SET 6,(IX+$26) ;
 $F659 SET 2,(IX+$20) ;
 $F65D JP $F70E       ; place 2-4 Sidewinder/Krait
*$F660 CALL $ED24     ; c = (number of slaves + amount of narcotics) * 2 +
                      ; amount of weapons
 $F663 SUB C          ;
 $F664 JR C,$F684     ; rnd < banned cargo
 $F666 CP $5A         ; 'Z'
 $F668 RET NC         ; rnd >= banned cargo rnd >=$5A
 $F669 CP $50         ; 'P'
 $F66B JR C,$F684     ; rnd >= banned cargo rnd < $50
 $F66D CALL $F399     ; rnd >= banned cargo rnd >= $50 rnd < $5A rnd=$50..$59
 $F670 RET NZ         ;
 $F671 LD A,$06       ; set asteroid
 $F673 CALL $F2FB     ; place an object into a slot
 $F676 SET 7,(IX+$0E) ;
 $F67A RES 6,(IX+$20) ;
 $F67E LD A,$C0       ;
 $F680 LD (IX+$1D),A  ;
 $F683 RET            ;
*$F684 LD B,A         ;
 $F685 AND $07        ;
 $F687 LD E,A         ;
 $F688 LD A,($A871)   ; get PilotMission3
 $F68B CP $04         ;
 $F68D LD D,A         ;
 $F68E LD C,$0F       ;
 $F690 JR Z,$F6DB     ; set thargon, if the ship is captured by pirates
 $F692 LD A,D         ;
 $F693 CP $01         ;
 $F695 LD C,$0A       ;
 $F697 JR Z,$F6DB     ; set python, if it's time to give mission 3
 $F699 LD A,($A85F)   ; 74 ???
 $F69C AND $07        ;
 $F69E JR Z,$F6A3     ; if anarchy
 $F6A0 INC E          ;
 $F6A1 CP E           ;
 $F6A2 RET NC         ; exit if rnd >= the planet's government
*$F6A3 LD C,A         ;
 $F6A4 BIT 3,B        ;
 $F6A6 JP Z,$F6E2     ;
 $F6A9 CALL $F399     ; place a random ship
 $F6AC RET NZ         ;
 $F6AD CALL $ED24     ; Random number
 $F6B0 AND $3F        ; '?'
 $F6B2 LD B,$0F       ; thargon
 $F6B4 JR Z,$F6C6     ;
 $F6B6 DEC B          ; fer-de-lance
 $F6B7 SUB $0C        ;
 $F6B9 JR C,$F6C6     ;
 $F6BB DEC B          ; asp
 $F6BC SUB $12        ;
 $F6BE JR C,$F6C6     ;
 $F6C0 DEC B          ; cobra
 $F6C1 SUB $10        ;
 $F6C3 JR C,$F6C6     ;
 $F6C5 DEC B          ; python
*$F6C6 LD A,B         ;
*$F6C7 PUSH AF        ;
*$F6C8 CALL $F2FB     ; place an object into a slot
 $F6CB POP AF         ;
 $F6CC CP $0F         ;
 $F6CE JR Z,$F6D6     ;
 $F6D0 CALL $ED24     ; probability of aggression?
 $F6D3 CP $33         ; '3'
 $F6D5 RET NC         ;
*$F6D6 SET 0,(IX+$25) ;
 $F6DA RET            ;
*$F6DB CALL $F399     ; find a free slot to place an object
 $F6DE RET NZ         ;
 $F6DF LD A,C         ;
 $F6E0 JR $F6C7       ;
*$F6E2 CALL $ED24     ; Random number
 $F6E5 LD B,A         ;
 $F6E6 AND $07        ;
 $F6E8 CP E           ;
 $F6E9 JR NC,$F70E    ; place 2-4 Sidewinder/Krait
 $F6EB RLC B          ;
 $F6ED RLC B          ;
 $F6EF RLC B          ;
 $F6F1 LD C,B         ;
 $F6F2 CALL $F399     ; find a free slot to place an object
 $F6F5 RET NZ         ;
 $F6F6 LD A,C         ;
 $F6F7 AND $07        ;
 $F6F9 CP $02         ;
 $F6FB JR C,$F706     ;
 $F6FD DEC A          ;
 $F6FE SRL A          ;
 $F700 SRL A          ;
 $F702 ADD A,$09      ; cobra/python
 $F704 JR $F6C7       ;
*$F706 LD A,C         ;
 $F707 RLCA           ;
 $F708 AND $01        ;
 $F70A ADD A,$07      ; asteroid/viper
 $F70C JR $F6C7       ;
*$F70E CALL $ED24     ; place 2-4 Sidewinder/Krait
