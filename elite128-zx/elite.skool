 $B79B LD A,L        ;
 $B79C CALL $B7EB    ; print one digit a - digit
 $B79F XOR A         ;
 $B7A0 LD ($A88E),A  ; ; number of digits to print for the number (padded on
                     ; the left with spaces or zeros)
