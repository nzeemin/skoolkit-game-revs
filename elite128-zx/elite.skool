c$A8EE LD HL,$A822   ; 13 pilot's combat rating 0,0,0...255,8,0 Harmless
                     ; 0,9,0...255,8,0 M.Harmless 0,17,0...255,16,0 Poor
                     ; 0,33,0...255,32,0 Average 0,65,0...255,64,0 Above
                     ; Average 0,129,0...255,128,0 Competent 0,0,3...255,255,2
                     ; Dangerous 0,0,11...255,255,10 Deadly 0,0,26...255,255,25
                     ; Elite
 $A8F1 LD A,(HL)     ;
