 $D8F4 ADD A,B       ;
 $D8F5 LD C,A        ;
 $D8F6 AND $07       ;
 $D8F8 JR NZ,$D900   ;
 $D8FA LD D,$08      ;
 $D8FC LD A,C        ;
 $D8FD SUB D         ;
 $D8FE JR $D902      ;
*$D900 LD D,A        ;
 $D901 LD A,C        ;
*$D902 AND $F8       ;
 $D904 JR Z,$D922    ;
 $D906 SRL A         ;
 $D908 SRL A         ;
 $D90A SRL A         ;
