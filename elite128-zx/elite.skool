; Data block at F72B
@label=deltaCrdX
b$F72B DEFW $0000    ; distance along X / 4 7,=x sign
@label=deltaCrdY
 $F72D DEFW $0000    ; distance along Y / 4 7,=x sign
@label=deltaCrdZ
 $F72F DEFW $0000    ; distance along Z / 4 7,=z sign
@label=LenVector
 $F731 DEFW $0000    ; vector length

; ReactionObject
;
; Used by the routine at #R$DA1D.
;
; .
;
; Object's reaction to the player. Launching missiles, ships, escape capsule,
; etc.
; .
; In: ix - address of the object slot
; .
; iy - address of the object data
; .
; Out: hl,de,bc,a - undefined
c$F733 LD A,(IY+$07)  ; max energy of the object
 $F736 LD C,(IX+$22)  ; current energy
 $F739 INC C          ;
 $F73A CP $F0         ;
 $F73C JR C,$F741     ; max energy >=$F0 current energy +4 max energy <$F0
                      ; current energy +1
 $F73E INC C          ;
 $F73F INC C          ;
 $F740 INC C          ;
*$F741 CP C           ;
 $F742 JR C,$F745     ; current energy > max energy
 $F744 LD A,C         ; a=c(current energy) if current <= max energy
*$F745 LD B,A         ; b - the object's changed energy
 $F746 LD A,($A80C)   ; get CloakingDeviceOn
 $F749 AND A          ;
 $F74A RET NZ         ;
 $F74B LD HL,$DA0C    ; =3 the Asp from mission 2 is destroyed / there is a
                      ; canister with the cloak in space =2 the Asp's
                      ; invisibility is off =1 mission 2 given =0 while moving
                      ; on the J-drive
 $F74E LD A,B         ;
 $F74F CP $50         ; 'P'
 $F751 LD A,(HL)      ;
 $F752 JR C,$F759     ; energy <$50
 $F754 CP $02         ;
 $F756 JR NZ,$F759    ;
 $F758 DEC (HL)       ;
*$F759 CP $01         ;
 $F75B JR NZ,$F76A    ;
 $F75D LD A,B         ;
 $F75E CP $34         ; '4'
 $F760 JR NC,$F767    ; energy >=$34
 $F762 LD A,$02       ;
 $F764 LD (HL),A      ;
 $F765 JR $F76A       ;
*$F767 SUB $02        ;
 $F769 LD B,A         ;
*$F76A LD A,B         ;
 $F76B LD (IX+$22),A  ; new energy
 $F76E LD B,(IY+$07)  ;
 $F771 ADD A,A        ;
 $F772 JR C,$F7DF     ; energy is high
 $F774 CP B           ;
 $F775 JR NC,$F7DF    ; energy is more than half
 $F777 ADD A,A        ;
 $F778 JR C,$F780     ;
 $F77A ADD A,A        ;
 $F77B JR C,$F780     ;
 $F77D CP B           ;
 $F77E JR C,$F7B6     ; critically low energy
*$F780 LD A,(IX+$20)  ;
 $F783 AND $07        ;
 $F785 JR Z,$F7DF     ; no missiles and no ships
 $F787 CALL $ED24     ; determine the launch probability
 $F78A CP $80         ;
 $F78C JR NC,$F7DF    ;
 $F78E LD A,($DA16)   ; get TimeWorkECM
 $F791 AND A          ;
 $F792 JR NZ,$F7DF    ; while ECM is running, the enemy cannot launch anything
 $F794 LD A,(IY+$0A)  ;
 $F797 AND $F0        ;
 $F799 JR NZ,$F79D    ;
 $F79B OR $06         ;
*$F79D XOR $04        ;
 $F79F LD B,A         ;
 $F7A0 PUSH BC        ;
 $F7A1 CALL $F876     ; the enemy launches a missile or a ship
 $F7A4 POP BC         ;
 $F7A5 JR NZ,$F7DF    ;
 $F7A7 DEC (IX+$20)   ;
 $F7AA LD A,B         ;
 $F7AB CP $02         ; =2 launched a missile
 $F7AD JR NZ,$F7DF    ;
 $F7AF LD HL,$A881    ; 7,=1 the enemy fired a missile
 $F7B2 SET 7,(HL)     ;
 $F7B4 JR $F7DF       ;
*$F7B6 CALL $ED24     ; critically low energy
 $F7B9 CP (IX+$25)    ; probability of dropping cargo/pod
 $F7BC JR C,$F815     ; not aggressive by default???
 $F7BE BIT 7,(IX+$20) ;
 $F7C2 JR Z,$F7D4     ; drop the cargo hold
 $F7C4 LD A,$07       ; set the object's escape capsule
