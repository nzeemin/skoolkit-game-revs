 $D860 JR $D814      ;

; SetFuelZero
;
; Used by the routines at #R$A5C0, #R$A897 and #R$D6B3.
;
; .
;
; Zero out fuel
; .
; In: ---
; .
; Out: b,a - undefined
c$D862 LD A,($A844)  ; get Pilot_Fuel
 $D865 AND A         ;
 $D866 RET Z         ;
 $D867 LD HL,$A88F   ; 7,=1 - fuel was zeroed out
 $D86A SET 7,(HL)    ;
 $D86C XOR A         ;

; SetPilotFuel
