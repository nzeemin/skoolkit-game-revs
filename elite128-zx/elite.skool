 $D981 SRL A         ;
 $D983 LD L,A        ;
 $D984 LD A,C        ;
 $D985 AND $38       ; '8'
 $D987 ADD A,A       ;
 $D988 ADD A,A       ;
 $D989 OR L          ;
 $D98A LD L,A        ;
 $D98B LD A,C        ;
 $D98C AND $07       ;
 $D98E OR $40        ; '@'
 $D990 LD H,A        ;
