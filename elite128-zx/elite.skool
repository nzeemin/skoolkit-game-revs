*$D8C8 LD A,($A814)  ; cursor extends past the left boundary
 $D8CB LD C,A        ;
 $D8CC XOR A         ;
 $D8CD CALL $D97D    ; calculate the screen address
 $D8D0 LD A,($A813)  ; get PrnCrdXCursor
 $D8D3 ADD A,B       ;
 $D8D4 LD C,A        ;
 $D8D5 AND $07       ;
 $D8D7 JR NZ,$D8DF   ;
 $D8D9 LD E,$08      ;
 $D8DB LD A,C        ;
 $D8DC SUB E         ;
 $D8DD JR $D8E1      ;
