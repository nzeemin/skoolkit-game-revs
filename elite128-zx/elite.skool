 $E950 LD A,(IX+$03) ;
 $E953 AND $1F       ;
 $E955 CP $1F        ;
 $E957 JR Z,$E964    ;
 $E959 LD B,A        ;
 $E95A LD A,($E2E0)  ; get DistanceToObj
 $E95D CP B          ;
 $E95E JR C,$E964    ;
 $E960 POP DE        ;
 $E961 XOR A         ;
 $E962 JR $E99E      ; next face
*$E964 PUSH IY       ;
 $E966 LD HL,($E917) ; get AdrSlotObj
 $E969 PUSH HL       ;
 $E96A CALL $EA03    ;
 $E96D LD ($E920),A  ; set NormalCrdX
 $E970 LD ($E91A),HL ; set AddNormalCrdX
 $E973 CALL $EA03    ;
 $E976 LD ($E921),A  ;
 $E979 LD ($E91C),HL ;
 $E97C CALL $EA03    ;
 $E97F LD ($E922),A  ;
 $E982 LD ($E91E),HL ;
 $E985 POP HL        ;
 $E986 PUSH IX       ;
 $E988 LD IY,$E91A   ; sum of the normal vector and the object's vector
                     ; (coordinates)
 $E98C LD IX,$E920   ; normal vector after OCS rotation
 $E990 CALL $E9AE    ; dot product of vectors
 $E993 POP IX        ;
 $E995 POP IY        ;
 $E997 POP DE        ;
 $E998 XOR A         ;
 $E999 SLA H         ;
 $E99B JR NC,$E99E   ; next face
 $E99D INC A         ;
*$E99E LD (DE),A     ; next face
 $E99F INC DE        ;
 $E9A0 LD BC,$0004   ;
 $E9A3 ADD IX,BC     ;
 $E9A5 POP AF        ;
 $E9A6 DEC A         ;
 $E9A7 JR NZ,$E94E   ; a - number of normals de =#R$E2AC ix start address of
                     ; the normals iy =#R$E2BC
*$E9A9 POP IY        ; exit
 $E9AB POP IX        ;
 $E9AD RET           ;

