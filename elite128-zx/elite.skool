 $E577 LD A,(IX+$03) ;
 $E57A RLA           ;
 $E57B RLA           ;
 $E57C XOR (IY+$05)  ;
 $E57F AND $80       ;
 $E581 LD H,A        ;
 $E582 LD (IY+$16),L ;
