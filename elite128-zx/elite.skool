; CalcCrdSunPlanet
;
; Used by the routines at #R$7287 and #R$7AF8.
;
; .
;
; Update sun/planet coordinates as the player moves
c$778F LD IX,$7065   ; data for printing the sun, 9 bytes long, crd low x
                     ; planet
 $7793 CALL $DED1    ; update object coordinates from player movement
 $7796 LD IX,$706E   ; planet coordinates in space
 $779A JP $DED1      ; update object coordinates from player movement

; CalcCrdCoriolis
;
; Used by the routine at #R$7287.
;
; .
;
; Handle Coriolis station movement
c$779D LD A,($7078)   ; get J_Drive_Coriolis
 $77A0 AND A          ;
 $77A1 LD IX,$6048    ; length 27h
 $77A5 JR NZ,$77B0    ; update Coriolis coordinates from player movement
 $77A7 LD A,(IX+$22)  ;
 $77AA AND A          ;
 $77AB RET NZ         ;
 $77AC DEC A          ;
 $77AD LD ($7078),A   ; =$FF J-drive usable
*$77B0 CALL $DCE0     ; update Coriolis coordinates from player movement
 $77B3 LD A,(IX+$02)  ;
 $77B6 AND $7F        ;
 $77B8 RET NZ         ;
 $77B9 LD A,(IX+$05)  ;
 $77BC AND $7F        ;
 $77BE RET NZ         ;
 $77BF LD A,(IX+$08)  ;
 $77C2 AND $7F        ;
 $77C4 RET NZ         ;
 $77C5 BIT 7,(IX+$26) ;
 $77C9 RET NZ         ;
 $77CA XOR A          ; station is close, disable the J-drive
 $77CB LD ($7078),A   ; set J_Drive_Coriolis
 $77CE LD A,$F0       ;
 $77D0 LD (IX+$22),A  ;
 $77D3 RET            ;

; Data block at 77D4
b$77D4 DEFB $01

; Use_Y_Cloacking
;
; Used by the routine at #R$7287.
;
; .
;
; Use of the Cloaking Device
c$77D5 LD HL,$77D4   ;
 $77D8 DEC (HL)      ;
 $77D9 LD HL,$FC0E   ; 7,=1 - Y -- Cloaking Device 6,=1 - 0 -- ??? 5,=1 - I --
                     ; Global Map 4,=1 - O -- Local Map 3,=1 - P -- Planet Info
                     ; 2,=1 - K -- Planet Price 1,=1 - L -- Commander Info 0,=1
                     ; - Enter -- Inventory
 $77DC RES 7,(HL)    ;
 $77DE RET NZ        ;
 $77DF LD A,$02      ;
 $77E1 LD ($77D4),A  ;
 $77E4 HALT          ;
 $77E5 BIT 7,(HL)    ;
 $77E7 RET Z         ; if the key is still pressed, continue
 $77E8 LD HL,$A872   ; +93 extra equipment present 7,=1 - ECM Jammer 6,=1 -
                     ; Cloaking device 5,=1 - cannot buy goods (refugees in the
                     ; hold) 4 3 =1 mission 3 was completed 2 =1 - mission 3
                     ; completed 1 =1 - mission 2 completed 0 =1 - mission 1
                     ; completed
 $77EB BIT 6,(HL)    ;
 $77ED RET Z         ;
 $77EE LD HL,$A80C   ; =1 Cloaking Device on =1 energy drain while in use
 $77F1 DEC (HL)      ;
 $77F2 JR Z,$780A    ; paper 0, ink 7
 $77F4 LD A,($7058)  ; check energy
 $77F7 CP $28        ; '('
 $77F9 RET C         ;
 $77FA LD A,$01      ; energy is low
 $77FC LD (HL),A     ;
 $77FD LD HL,$6069   ; 2,=1 Coriolis is hostile
 $7800 RES 2,(HL)    ;
 $7802 XOR A         ;
 $7803 LD ($DA14),A  ; set PlayerPirate
*$7806 LD L,$0F      ; paper 1, ink 7
 $7808 JR $780C      ;
*$780A LD L,$07      ; paper 0, ink 7
*$780C JP $9287      ; print view-screen attributes
 $780F LD A,($A843)  ; get PilotMission1
 $7812 AND A         ;
; This entry point is used by the routine at #R$781F.
*$7813 LD L,$02      ; paper 0, ink 2 of the view screen
 $7815 JR NZ,$780C   ;
 $7817 RET           ;
 $7818 LD A,($A80C)  ; get CloakingDeviceOn
 $781B AND A         ;
 $781C JR NZ,$7806   ; paper 1, ink 7
 $781E RET           ;

