; ClearZnkLines
;
; Used by the routine at #R$AB4E.
;
; .
;
; Fast clear of several character rows within a screen segment
; .
; In: hl - end address of the screen area +2
; .
; a - number of rows
c$ABC0 DI            ;
 $ABC1 LD ($ABE4),SP ;
 $ABC5 LD ($ABE3),A  ;
