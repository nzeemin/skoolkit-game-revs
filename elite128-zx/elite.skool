 $FB22 LD A,(IY+$01) ;
 $FB25 CALL $FB10    ; (crdXv/2) * (cos(a)/2)
 $FB28 PUSH HL       ;
 $FB29 LD B,(IX+$03) ;
 $FB2C LD A,(IY+$03) ;
 $FB2F CALL $FB10    ; multiplication hl = -1 * high((a*2) * (b*2))
 $FB32 PUSH HL       ;
 $FB33 LD B,(IX+$05) ;
 $FB36 LD A,(IY+$05) ;
 $FB39 CALL $FB10    ; multiplication hl = -1 * high((a*2) * (b*2))
 $FB3C POP DE        ;
 $FB3D CALL $E424    ; signed addition
 $FB40 JR NC,$FB44   ;
 $FB42 LD A,$FF      ;
*$FB44 POP DE        ;
 $FB45 LD L,A        ;
 $FB46 CALL $E424    ; signed addition
 $FB49 JR NC,$FB4D   ;
 $FB4B LD A,$FF      ;
*$FB4D RL H          ;
 $FB4F RRA           ;
 $FB50 RET           ;

