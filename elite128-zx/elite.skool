 $A522 JR Z,$A536    ;
 $A524 CP $02        ;
 $A526 JR NZ,$A538   ;
 $A528 LD A,$21      ; '!'
 $A52A CALL $BA9D    ; print a message from group 1 in the buffer/on screen
 $A52D LD A,$22      ; '"'
 $A52F CALL $BA9D    ; print a message from group 1 in the buffer/on screen
 $A532 LD D,$17      ;
 $A534 JR $A548      ;
*$A536 LD D,$02      ;
*$A538 LD A,$10      ;
 $A53A ADD A,D       ;
 $A53B LD D,A        ;
*$A53C PUSH DE       ;
 $A53D LD A,$23      ; '$'
 $A53F CALL $BA9D    ; print a message from group 1 in the buffer/on screen
 $A542 LD A,$24      ; '$'
 $A544 CALL $BA9D    ; print a message from group 1 in the buffer/on screen
 $A547 POP DE        ;
