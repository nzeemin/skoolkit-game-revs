; Mult_HL_A2_B2
;
; Used by the routine at #R$FB1F.
;
; .
;
; Multiplication hl = -1 * high((a*2) * (b*2))
; .
; In: b - first factor, 7,b - sign
; .
; a - second factor, 7,a - sign
; .
; Out: l,a = high((a*2) * (b*2))
; .
; l,a = high((a*2) * (b*2))
; .
; 7,h - sign
c$FB10 LD C,A        ;
 $FB11 XOR B         ;
 $FB12 XOR $80       ;
 $FB14 SLA B         ;
 $FB16 SLA C         ;
 $FB18 PUSH AF       ;
 $FB19 CALL $E434    ; A=((b+c)/2)^2-((b-c)/2)^2
 $FB1C POP HL        ;
 $FB1D LD L,A        ;
 $FB1E RET           ;

; ScalarMultVectors
;
