; ClearScrBuffer
;
; Used by the routines at #R$716B, #R$7287, #R$79A3 and #R$7AF8.
;
; .
;
; Fast clear of the screen buffer
; .
; This is not a plain clear: the repeating byte pattern it writes already
; contains the 3D viewport border (a full horizontal line at the top and
; bottom, and a single vertical pixel down each edge column for every row in
; between), so the border is regenerated as a side effect of "clearing" every
; single frame, with no separate border-preserving or redrawing code needed.
c$745F DI            ;
 $7460 LD ($74B0),SP ;
 $7464 LD SP,$D000   ;
 $7467 LD HL,$0000   ;
 $746A LD DE,$00FF   ;
 $746D LD IX,$FF00   ;
 $7471 LD BC,$FFFF   ;
 $7474 PUSH DE       ;
 $7475 LD A,$0E      ;
*$7477 PUSH BC       ;
 $7478 DEC A         ;
 $7479 JR NZ,$7477   ;
 $747B PUSH IX       ;
 $747D LD E,$01      ;
 $747F LD IX,$8000   ;
 $7483 LD B,$7E      ; '~'
*$7485 PUSH DE       ;
 $7486 PUSH HL       ;
 $7487 PUSH HL       ;
 $7488 PUSH HL       ;
 $7489 PUSH HL       ;
 $748A PUSH HL       ;
 $748B PUSH HL       ;
 $748C PUSH HL       ;
 $748D PUSH HL       ;
 $748E PUSH HL       ;
 $748F PUSH HL       ;
 $7490 PUSH HL       ;
 $7491 PUSH HL       ;
 $7492 PUSH HL       ;
 $7493 PUSH HL       ;
 $7494 PUSH IX       ;
 $7496 DJNZ $7485    ;
 $7498 LD BC,$FFFF   ;
 $749B LD E,$FF      ;
 $749D LD IX,$FF00   ;
 $74A1 PUSH DE       ;
 $74A2 LD A,$0E      ;
*$74A4 PUSH BC       ;
 $74A5 DEC A         ;
 $74A6 JR NZ,$74A4   ;
 $74A8 PUSH IX       ;
 $74AA LD SP,($74B0) ;
 $74AE EI            ;
 $74AF RET           ;

