; UseMissile
;
; Used by the routine at #R$A559.
;
; .
;
; Use of a missile
c$A706 LD A,($A845)  ; get PilotMissiles
 $A709 AND A         ;
 $A70A RET Z         ;
 $A70B LD A,($A80F)  ; get Missile1
 $A70E CP $01        ;
 $A710 JR NZ,$A72E   ;
 $A712 LD HL,$A89A   ; =0 missile targeting was on <>0 reverse index of the
                     ; object the missile is targeting (8 - slot 0)
 $A715 LD A,(HL)     ;
 $A716 AND A         ;
 $A717 JR NZ,$A72E   ;
 $A719 LD A,($DA12)  ; get ObjInTarget
 $A71C AND A         ;
 $A71D JR Z,$A72E    ;
 $A71F LD (HL),A     ;
 $A720 LD HL,$A80F   ; =0 missile not targeted =1 missile ready to lock target
                     ; =2 missile targeted on something
 $A723 LD (HL),$02   ;
 $A725 LD HL,$0070   ; 'p' ; target-lock sound
 $A728 LD DE,$0060   ; '`'
 $A72B CALL $03B5    ;
*$A72E LD HL,$FC11   ; 7,=1 - C -- Docking Computer 6,=1 - Q -- Escape Capsule
                     ; 5,=1 - W -- Energy Bomb 4,=1 - E -- ECM System 3,=1 - U
                     ; -- UnTarget 2,=1 - F -- Fire Missile 1,=1 - T -- Target
                     ; Missile 0,=1 - A -- Fire Laser
 $A731 LD A,(HL)     ;
 $A732 LD HL,$A80F   ; =0 missile not targeted =1 missile ready to lock target
                     ; =2 missile targeted on something
 $A735 SRL A         ;
 $A737 SRL A         ;
 $A739 JR C,$A744    ; attempt to target the missile (T key)
 $A73B SRL A         ;
 $A73D JR C,$A752    ; attempt to launch the missile (F key)
 $A73F SRL A         ;
 $A741 JR C,$A74F    ; untarget the missile (U key)
 $A743 RET           ;
*$A744 LD A,(HL)     ; attempt to target the missile (T key)
 $A745 CP $02        ;
 $A747 RET Z         ;
 $A748 LD (HL),$01   ;
 $A74A XOR A         ;
 $A74B LD ($A89A),A  ; set nObjMissile
 $A74E RET           ;
*$A74F LD (HL),$00   ; untarget the missile (U key)
 $A751 RET           ;
*$A752 LD A,(HL)     ; attempt to launch the missile (F key)
 $A753 CP $02        ;
 $A755 RET NZ        ;
 $A756 LD A,($A89A)  ; get nObjMissile
 $A759 ADD A,A       ;
 $A75A ADD A,A       ;
 $A75B ADD A,A       ;
 $A75C ADD A,A       ;
 $A75D OR $02        ; a=xxxx0010=$x2
 $A75F PUSH HL       ;
 $A760 CALL $F2CA    ;
 $A763 POP HL        ;
 $A764 JR Z,$A76C    ; if successful
 $A766 LD HL,$A87F   ; 7,=1 missile launch failed 6-0,= Y print coordinate of
                     ; the message
 $A769 SET 7,(HL)    ;
 $A76B RET           ;
*$A76C LD (HL),$00   ;
 $A76E LD HL,$707D   ; which sound to play =$00 no sound (silent) 0,=1 energy
                     ; bomb exploded 1,=1 missile launched 2,=1 colliding with
                     ; an object/object destroyed 3,=1 laser fired 4,=1 laser
                     ; fired 5,=1 ECM working 6,=1 hit by laser on the
                     ; player/docking damage 7,=1
 $A771 SET 1,(HL)    ;
