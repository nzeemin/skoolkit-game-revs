 $A4F3 LD (HL),D     ;
 $A4F4 INC HL        ;
 $A4F5 LD (HL),D     ;
 $A4F6 LD HL,$5A48   ;
 $A4F9 LD (HL),D     ;
 $A4FA INC HL        ;
 $A4FB LD (HL),D     ;
 $A4FC CALL $A553    ;
 $A4FF LD A,($A80F)  ; get Missile1
 $A502 CP $01        ;
 $A504 JR NZ,$A508   ;
 $A506 LD A,$04      ; =1 -> paper 4
*$A508 ADD A,A       ;
