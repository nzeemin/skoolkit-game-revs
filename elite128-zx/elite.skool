                                            ; 3,=1 - S -- Up 2,=1 - X -- Down
                                            ; 1,=1 - M -- Right 0,=1 - N --
                                            ; Left
@label=ControlKey2
 $FC10 DEFB $00                             ; 7,=1 - CapsS -- Pause 6,=1 - J --
                                            ; Jump Drive 5,=1 - G -- Galactic
                                            ; Hyper Drive 4,=1 - H -- Hyper
                                            ; Drive 3,=1 - 4 -- Right
                                            ; View/Equip Ship 2,=1 - 3 -- Left
                                            ; View/Sell Cargo 1,=1 - 2 -- Rear
                                            ; View/Buy Cargo 0,=1 - 1 -- Front
                                            ; View/Launch
@label=ControlKey3
 $FC11 DEFB $00                             ; 7,=1 - C -- Docking Computer 6,=1
                                            ; - Q -- Escape Capsule 5,=1 - W --
                                            ; Energy Bomb 4,=1 - E -- ECM
                                            ; System 3,=1 - U -- UnTarget 2,=1
                                            ; - F -- Fire Missile 1,=1 - T --
                                            ; Target Missile 0,=1 - A -- Fire
                                            ; Laser
@label=ControlKeyInMap
 $FC12 DEFB $00                             ; 7, -- unused 6,=1 - R -- Find
                                            ; Planet 5,=1 - D -- Cursor to Near
                                            ; Planet 4,=1 - B -- Cursor to
                                            ; Present System 3-0, -- unused
@label=PressKeyPrnSymbol
 $FC13 DEFB $FF                             ; printable character of the
                                            ; pressed key =$FE - BackSpace =$FF
                                            ; - nothing pressed
@label=FlagsSetUp
 $FC14 DEFB $8C                             ; 0-1,=00 SXNMA controls
                                            ; (LLFC0F)<>0 reset CS,F,c =01
                                            ; Kempston controls =10 cursor
                                            ; controls 76850 =11 Sinclair right
                                            ; controls 2,=1 realistic control
                                            ; approximation (reaction) 3,=1
                                            ; turn inertia on 4,=1 controls
                                            ; inverted 5,=1 up/down inverted
                                            ; 6,=1 Thargon interception on 7,=1
                                            ; sound on
 $FC15 DEFB $00                             ; something related to cursor and
                                            ; Sinclair joystick, unused in this
                                            ; version

; ScanKeysContinue
;
; Used by the routine at #R$FB79.
;
; .
;
; Update the pressed-keys table
; .
; In: ----
; .
; Out: (LLFC0E...) - pressed keys
; .
; (LLFC13) - code of the pressed key
c$FC16 DEC D         ;
 $FC17 JP NZ,$FB86   ;
 $FC1A LD A,($FC0F)  ; get ControlKeyMove
 $FC1D AND $0F       ;
 $FC1F LD D,A        ;
 $FC20 LD A,($FC14)  ; get FlagsSetUp
 $FC23 LD E,A        ;
 $FC24 AND $03       ;
 $FC26 JR Z,$FC69    ;
 $FC28 DEC A         ;
 $FC29 JR NZ,$FC43   ;
 $FC2B LD BC,$FF1F   ;
 $FC2E IN A,(C)      ;
 $FC30 BIT 4,A       ;
 $FC32 JR Z,$FC39    ;
 $FC34 LD HL,$FC11   ; 7,=1 - C -- Docking Computer 6,=1 - Q -- Escape Capsule
                     ; 5,=1 - W -- Energy Bomb 4,=1 - E -- ECM System 3,=1 - U
                     ; -- UnTarget 2,=1 - F -- Fire Missile 1,=1 - T -- Target
                     ; Missile 0,=1 - A -- Fire Laser
 $FC37 SET 0,(HL)    ;
*$FC39 AND $0F       ;
 $FC3B LD D,A        ;
 $FC3C LD A,E        ;
 $FC3D XOR $30       ; '0'
 $FC3F LD E,A        ;
 $FC40 JP $FC69      ;
*$FC43 DEC A         ;
 $FC44 LD A,($FC15)  ; something related to cursor and Sinclair joystick,
                     ; unused in this version
 $FC47 RRA           ;
 $FC48 LD D,A        ;
 $FC49 JR Z,$FC5D    ;
 $FC4B LD D,$00      ;
 $FC4D RL D          ;
 $FC4F RRA           ;
 $FC50 RRA           ;
 $FC51 RL D          ;
 $FC53 SLA D         ;
 $FC55 RRA           ;
 $FC56 RR D          ;
 $FC58 RRA           ;
 $FC59 RL D          ;
 $FC5B RL D          ;
*$FC5D LD HL,$FC0E   ; 7,=1 - Y -- Cloaking Device 6,=1 - 0 -- ??? 5,=1 - I --
                     ; Global Map 4,=1 - O -- Local Map 3,=1 - P -- Planet Info
                     ; 2,=1 - K -- Planet Price 1,=1 - L -- Commander Info 0,=1
                     ; - Enter -- Inventory
 $FC60 BIT 6,(HL)    ;
 $FC62 JR Z,$FC69    ;
 $FC64 LD HL,$FC11   ; 7,=1 - C -- Docking Computer 6,=1 - Q -- Escape Capsule
                     ; 5,=1 - W -- Energy Bomb 4,=1 - E -- ECM System 3,=1 - U
                     ; -- UnTarget 2,=1 - F -- Fire Missile 1,=1 - T -- Target
                     ; Missile 0,=1 - A -- Fire Laser
 $FC67 SET 0,(HL)    ;
*$FC69 BIT 4,E       ;
 $FC6B JR Z,$FC7A    ;
 $FC6D LD A,D        ;
 $FC6E AND $05       ;
 $FC70 SLA A         ;
 $FC72 LD C,A        ;
 $FC73 LD A,D        ;
 $FC74 AND $0A       ;
 $FC76 SRL A         ;
 $FC78 OR C          ;
 $FC79 LD D,A        ;
*$FC7A BIT 5,E       ;
 $FC7C JR Z,$FC8F    ;
 $FC7E LD A,D        ;
 $FC7F AND $03       ;
 $FC81 LD B,A        ;
 $FC82 LD A,D        ;
 $FC83 AND $0C       ;
 $FC85 LD C,A        ;
 $FC86 SRL C         ;
 $FC88 SLA A         ;
 $FC8A OR C          ;
 $FC8B AND $0C       ;
 $FC8D OR B          ;
 $FC8E LD D,A        ;
*$FC8F LD HL,$FC0F   ; 7,=1 - -- unused 6,=1 - -- unused 5,=1 - SymbolS --
                     ; Decrease Speed 4,=1 - Space -- Increase Speed 3,=1 - S
                     ; -- Up 2,=1 - X -- Down 1,=1 - M -- Right 0,=1 - N --
                     ; Left
 $FC92 LD A,($FC14)  ; get FlagsSetUp
 $FC95 AND $03       ;
 $FC97 JR NZ,$FCA7   ;
 $FC99 LD A,(HL)     ;
 $FC9A AND A         ;
 $FC9B JR Z,$FCA7    ;
 $FC9D INC L         ;
 $FC9E RES 7,(HL)    ;
 $FCA0 INC L         ;
 $FCA1 RES 2,(HL)    ;
 $FCA3 RES 7,(HL)    ;
 $FCA5 DEC L         ;
 $FCA6 DEC L         ;
*$FCA7 LD A,(HL)     ;
 $FCA8 AND $F0       ;
 $FCAA OR D          ;
 $FCAB LD (HL),A     ;
 $FCAC LD HL,$FC0E   ; 7,=1 - Y -- Cloaking Device 6,=1 - 0 -- ??? 5,=1 - I --
                     ; Global Map 4,=1 - O -- Local Map 3,=1 - P -- Planet Info
                     ; 2,=1 - K -- Planet Price 1,=1 - L -- Commander Info 0,=1
                     ; - Enter -- Inventory
 $FCAF BIT 6,(HL)    ;
 $FCB1 RET Z         ;
 $FCB2 RES 6,(HL)    ;
 $FCB4 LD A,($FC10)  ; get ControlKey2
 $FCB7 AND $80       ;
 $FCB9 RET Z         ;
 $FCBA LD A,$FE      ;
 $FCBC LD ($FC13),A  ; set PressKeyPrnSymbol
 $FCBF RET           ;

; SetBitControlKey
;
; Used by the routine at #R$FB79.
;
; .
;
; Set the pressed key from the table
; .
; In: d - half-row number
; .
; e - reverse key index within the half-row
; .
; Out: (PressKeyPrnSymbol) - character of the pressed key
; .
; (ControlKeys) - the corresponding bit is set
c$FCC0 PUSH BC       ;
 $FCC1 PUSH AF       ;
 $FCC2 LD A,$05      ;
 $FCC4 SUB E         ;
 $FCC5 ADD A,A       ;
 $FCC6 ADD A,A       ;
 $FCC7 ADD A,A       ;
 $FCC8 ADD A,D       ;
 $FCC9 DEC A         ;
 $FCCA LD B,A        ;
 $FCCB SLA B         ;
 $FCCD LD HL,$FB51   ; key character table
 $FCD0 ADD A,L       ;
 $FCD1 JR NC,$FCD4   ;
 $FCD3 INC H         ;
*$FCD4 LD L,A        ;
 $FCD5 LD A,(HL)     ;
 $FCD6 LD ($FC13),A  ; set PressKeyPrnSymbol
 $FCD9 LD HL,$FF58   ; table mapping key codes to bits +0 byte number in the
                     ; control-key list +1 bit of the pressed key
 $FCDC LD A,L        ;
 $FCDD ADD A,B       ;
 $FCDE LD L,A        ;
 $FCDF LD A,(HL)     ;
 $FCE0 INC HL        ;
 $FCE1 LD B,(HL)     ;
 $FCE2 LD HL,$FC0E   ; 7,=1 - Y -- Cloaking Device 6,=1 - 0 -- ??? 5,=1 - I --
                     ; Global Map 4,=1 - O -- Local Map 3,=1 - P -- Planet Info
                     ; 2,=1 - K -- Planet Price 1,=1 - L -- Commander Info 0,=1
                     ; - Enter -- Inventory
 $FCE5 ADD A,L       ;
 $FCE6 LD L,A        ;
 $FCE7 LD A,(HL)     ;
 $FCE8 OR B          ;
 $FCE9 LD (HL),A     ;
 $FCEA POP AF        ;
 $FCEB POP BC        ;
 $FCEC RET           ;

