 $FE14 JR NZ,$FE41   ;
 $FE16 BIT 1,B       ;
 $FE18 JR NZ,$FE2E   ;
 $FE1A BIT 3,C       ;
 $FE1C JR Z,$FE7A    ;
 $FE1E LD DE,$003C   ; '<'
