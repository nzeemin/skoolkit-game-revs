 $E92F LD D,(IX+$11) ;
 $E932 LD E,(IX+$10) ; de offset to the normals
 $E935 ADD IX,DE     ; ix=start address of the normals
 $E937 LD DE,$E2AC   ; face visibility =0 not visible (normal points away from
                     ; the player)
 $E93A LD A,(IY+$13) ;
 $E93D LD ($E919),A  ; set IY_dFactor
 $E940 LD A,(IY+$05) ;
 $E943 AND A         ;
 $E944 LD IY,$E2BC   ;
 $E948 JR NZ,$E94E   ; a - number of normals de =#R$E2AC ix start address of
                     ; the normals iy =#R$E2BC
 $E94A INC A         ;
 $E94B LD (DE),A     ;
 $E94C JR $E9A9      ; exit
*$E94E PUSH AF       ; a - number of normals de =#R$E2AC ix start address of
                     ; the normals iy =#R$E2BC
