; IncCASH
;
; Used by the routines at #R$A900, #R$B501 and #R$B6BB.
;
; .
;
; Trading code never computes price x quantity as a single multiplication -- it
; calls this once per unit inside a djnz loop instead, sidestepping 16-bit
; overflow entirely (the priciest good at maximum quantity would overflow a
; 16-bit product) at the cost of a few hundred cycles nobody notices.
; .
; Add money
; .
; In: de - amount of money (from 0.1 to 6553.5)
; .
; Out: hl,de - undefined
c$B84D LD HL,($A82A) ; get PilotCash1
 $B850 ADD HL,DE     ;
 $B851 LD ($A82A),HL ; set PilotCash1
 $B854 AND A         ;
 $B855 LD DE,$2710   ;
 $B858 SBC HL,DE     ;
 $B85A RET C         ;
 $B85B LD ($A82A),HL ; set PilotCash1
 $B85E LD DE,$0001   ;
; Trading code never computes price x quantity as a single multiplication -- it
; calls this once per unit inside a djnz loop instead, sidestepping 16-bit
; overflow entirely (the priciest good at maximum quantity would overflow a
; 16-bit product) at the cost of a few hundred cycles nobody notices.
@label=IncCASH_1K
*$B861 LD HL,($A828) ; get PilotCash2
 $B864 ADD HL,DE     ;
 $B865 LD ($A828),HL ; set PilotCash2
 $B868 RET           ;

; DecCASH_1000
;
; Used by the routine at #R$B5BB.
;
; .
;
; Trading code never computes price x quantity as a single multiplication -- it
; calls this once per unit inside a djnz loop instead, sidestepping 16-bit
; overflow entirely (the priciest good at maximum quantity would overflow a
; 16-bit product) at the cost of a few hundred cycles nobody notices.
; .
; Decrease money (whole thousands)
; .
; In: de - amount of money (from 1000 to 65535000)
; .
; Out: cy=1 - not enough money
; .
; hl,de - ????
c$B869 LD HL,($A828) ; get PilotCash2
 $B86C SBC HL,DE     ;
 $B86E JR C,$B875    ;
 $B870 LD ($A828),HL ; set PilotCash2
 $B873 AND A         ;
 $B874 RET           ;
*$B875 SCF           ;
 $B876 RET           ;

; DecCASH
;
; Used by the routines at #R$B3A1 and #R$B5BB.
;
; .
;
; Trading code never computes price x quantity as a single multiplication -- it
; calls this once per unit inside a djnz loop instead, sidestepping 16-bit
; overflow entirely (the priciest good at maximum quantity would overflow a
; 16-bit product) at the cost of a few hundred cycles nobody notices.
; .
; Decrease money (from 0 to 999.9)
; .
; In: de - amount of money (from 0.1 to 6553.5)
; .
; Out: cy=1 - not enough money
; .
; hl,de,a - ????
c$B877 LD HL,($A82A) ; get PilotCash1
 $B87A AND A         ;
 $B87B SBC HL,DE     ;
 $B87D JR NC,$B895   ;
 $B87F LD HL,($A828) ; get PilotCash2
 $B882 LD A,L        ;
 $B883 OR H          ;
 $B884 SCF           ;
 $B885 RET Z         ;
 $B886 DEC HL        ;
 $B887 LD ($A828),HL ; set PilotCash2
 $B88A LD HL,$2710   ;
 $B88D AND A         ;
 $B88E SBC HL,DE     ;
 $B890 LD DE,($A82A) ; get PilotCash1
 $B894 ADD HL,DE     ;
*$B895 LD ($A82A),HL ; set PilotCash1
 $B898 AND A         ;
 $B899 RET           ;

