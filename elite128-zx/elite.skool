; PrnOneProduct
;
; Used by the routines at #R$B2CE and #R$D07D.
;
; .
;
; One Market Prices / Buy row: name, unit, price (4-digit nnn.n field), then
; stock as nn+unit, or a literal - when the stock byte is 0 (returns carry set
; = not traded here). The good's name is printed via message code $D0+index.
; The 17 goods, in index order: $00 Food(t) $01 Textiles(t) $02 Radioactives(t)
; $03 Slaves(t) $04 Liquor & Wines(t) $05 Luxuries(t) $06 Narcotics(t) $07
; Computers(t) $08 Machinery(t) $09 Alloys(t) $0A Firearms(t) $0B Furs(t) $0C
; Minerals(t) $0D Gold(kg) $0E Platinum(kg) $0F Gem-Stones(g) $10 Alien
; Items(t).
; .
; Print the name, price and quantity of a good
; .
; In: (LLAF30) - good number
; .
; (LLAF33) - address in the goods price table
; .
; (LLAF35) - address in the goods quantity table
; .
; Out: cy=1 - no such good
; .
; hl,de,bc,a - ????
c$AF63 LD A,($AF30)  ; good number
 $AF66 ADD A,$D0     ;
 $AF68 CALL $BA9D    ; print a message from group 1 in the buffer/on screen
 $AF6B CALL $B00D    ; set the X print coordinate

; Data block at AF6E
b$AF6E DEFB $0D

; Routine at AF6F
c$AF6F CALL $B06F    ; print in lowercase t/kg/g/km
 $AF72 CALL $B00D    ; set the X print coordinate

; Data block at AF75
b$AF75 DEFB $0F

; Routine at AF76
c$AF76 LD HL,($AF33) ; address in the goods price table
 $AF79 INC HL        ;
 $AF7A INC HL        ;
 $AF7B LD ($AF33),HL ; address in the goods price table
 $AF7E LD E,(HL)     ;
 $AF7F INC HL        ;
 $AF80 LD D,(HL)     ;
 $AF81 EX DE,HL      ;
 $AF82 SCF           ;
 $AF83 LD A,$04      ;
 $AF85 LD ($A88E),A  ; ; number of digits to print for the number (padded on
                     ; the left with spaces or zeros)
 $AF88 CALL $B760    ; print a number
 $AF8B CALL $B00D    ; set the X print coordinate

; Data block at AF8E
b$AF8E DEFB $17

; Routine at AF8F
c$AF8F LD HL,($AF35) ; address in the goods quantity table
 $AF92 INC HL        ;
 $AF93 LD A,(HL)     ;
 $AF94 LD ($AF35),HL ; address in the goods quantity table
 $AF97 AND A         ;
 $AF98 JR NZ,$AFA5   ;
 $AF9A CALL $BA99    ; print one character (print a message by number

; Data block at AF9D
b$AF9D DEFB $20

; Routine at AF9E
c$AF9E LD A,$2D      ; '-'
 $AFA0 CALL $AFF7    ; print a message, with LF/CR at the end
 $AFA3 SCF           ;
 $AFA4 RET           ;
; This entry point is used by the routine at #R$AF8F.
*$AFA5 LD A,$02      ;
 $AFA7 LD ($A88E),A  ; ; number of digits to print for the number (padded on
                     ; the left with spaces or zeros)
 $AFAA LD HL,($AF35) ; address in the goods quantity table
 $AFAD LD A,(HL)     ;
 $AFAE CALL $B75C    ; Print a number
 $AFB1 CALL $B06F    ; print in lowercase t/kg/g/km
 $AFB4 CALL $AFFA    ; set the print-register flag, reset X coordinate,
                     ; increment Y coordinate
 $AFB7 AND A         ;
 $AFB8 RET           ;

