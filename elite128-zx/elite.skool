; CollisionWithObj
;
; Used by the routine at #R$DA1D.
;
; .
;
; Check for collision of the object with the player, and handle it
; .
; In: ix - address of the object slot
; .
; iy - address of the object data
; .
; Out: hl,de,bc,a - undefined
c$EA51 LD A,($707A)   ; get PlayerGameOver
 $EA54 AND A          ;
 $EA55 RET NZ         ;
 $EA56 LD D,$00       ;
 $EA58 LD E,(IY+$01)  ;
 $EA5B BIT 0,(IX+$26) ;
 $EA5F JR Z,$EA69     ;
 $EA61 LD A,(IX+$25)  ;
 $EA64 AND A          ;
 $EA65 JR NZ,$EA69    ;
 $EA67 LD D,$01       ; d=1, this is a missile and it was fired at the player
*$EA69 BIT 1,(IX+$26) ;
 $EA6D JR Z,$EA71     ;
 $EA6F LD E,$B4       ;
*$EA71 LD L,(IX+$00)  ;
 $EA74 LD H,(IX+$01)  ;
 $EA77 SBC HL,DE      ;
 $EA79 RET NC         ; along the X axis, far from collision
 $EA7A AND A          ;
 $EA7B LD L,(IX+$03)  ;
 $EA7E LD H,(IX+$04)  ;
 $EA81 SBC HL,DE      ;
 $EA83 RET NC         ; along the Y axis, far from collision
 $EA84 AND A          ;
 $EA85 LD L,(IX+$06)  ;
 $EA88 LD H,(IX+$07)  ;
 $EA8B SBC HL,DE      ;
 $EA8D RET NC         ; along the Z axis, far from collision
 $EA8E LD A,(IX+$08)  ;
 $EA91 AND $7F        ;
 $EA93 RET NZ         ;
 $EA94 BIT 1,(IX+$26) ;
 $EA98 JR Z,$EAD8     ; collision with the object???
 $EA9A BIT 7,(IX+$05) ; object is above the Y axis
 $EA9E JP Z,$EB23     ; destroy the object (we collide)
 $EAA1 LD A,($A84A)   ; object is below the Y axis, we pick up cargo
 $EAA4 AND A          ;
 $EAA5 JP Z,$EB23     ; destroy the object (we collide)
 $EAA8 XOR A          ; we pick up the canister
 $EAA9 LD (IX+$22),A  ;
 $EAAC CALL $EB65     ; object has disappeared from space (destroyed/flown
                      ; off). Untarget the missile and destroy any missiles
                      ; fired at this object
 $EAAF LD A,($A83E)   ; get PilotFreeCargo
 $EAB2 AND A          ;
 $EAB3 JR Z,$EB23     ; destroy the object (we collide)
 $EAB5 LD A,(IY+$00)  ;
 $EAB8 AND $F0        ;
 $EABA JR Z,$EAC3     ;
 $EABC RRCA           ;
 $EABD RRCA           ;
 $EABE RRCA           ;
 $EABF RRCA           ;
 $EAC0 INC A          ;
 $EAC1 JR $EAD5       ;
*$EAC3 LD A,($DA0C)   ; get PilotMission2
 $EAC6 SUB $03        ;
 $EAC8 JR NZ,$EAD0    ;
 $EACA LD ($DA0C),A   ; set PilotMission2
 $EACD DEC A          ; A=$FF picked up the Cloaking device
 $EACE JR $EAD5       ;
*$EAD0 CALL $ED24     ; Random number
 $EAD3 AND $07        ;
*$EAD5 JP $A8B7       ; add a found canister to the cargo
*$EAD8 BIT 2,(IX+$26) ; collision with the object???
 $EADC JR Z,$EB23     ; destroy the object (we collide)
 $EADE BIT 7,(IX+$0E) ;
 $EAE2 JR Z,$EB58     ; player destroyed
 $EAE4 BIT 7,(IX+$08) ;
 $EAE8 JR NZ,$EB58    ; player destroyed
