; RenewCompass
;
; Used by the routine at #R$89B2.
;
; .
;
; Draw the compass with pointer on screen
; .
; In: ---
; .
; Out: b=$00
; .
; hl,de,c,a - undefined
c$8AC7 LD A,($7041)  ; get WhatOnScreen
 $8ACA CP $04        ;
 $8ACC RET NC        ; exit if not in flight
 $8ACD LD HL,$8BC0   ; the compass pointer, filled
 $8AD0 LD A,($88E0)  ; =0 print the compass filled
 $8AD3 AND A         ;
 $8AD4 JR Z,$8AD9    ;
 $8AD6 LD HL,$8BB8   ; the compass pointer, empty
*$8AD9 LD DE,$8BB0   ; buffer for preparing to print the pointer
 $8ADC LD BC,$0008   ;
 $8ADF LDIR          ;
 $8AE1 LD HL,$5156   ;
 $8AE4 LD A,($88DF)  ; 88DF 7,=1 DownScrAdr 7,=0 UpScrAdr 0-6 =Y coordinate
                     ; increment
 $8AE7 LD B,A        ;
 $8AE8 AND $7F       ; %01111111
 $8AEA JR Z,$8B07    ;
 $8AEC LD A,B        ;
 $8AED AND $80       ;
 $8AEF JR NZ,$8AFC   ;
*$8AF1 LD A,H        ;
 $8AF2 DEC H         ;
 $8AF3 AND $07       ;
 $8AF5 CALL Z,$8B86  ; continue calculating the display-file address one pixel
                     ; above
 $8AF8 DJNZ $8AF1    ;
 $8AFA JR $8B07      ;
*$8AFC RES 7,B       ;
*$8AFE INC H         ;
 $8AFF LD A,H        ;
 $8B00 AND $07       ;
 $8B02 CALL Z,$8B7C  ; continue calculating the display-file address one pixel
                     ; below
 $8B05 DJNZ $8AFE    ;
*$8B07 LD ($8BAE),HL ; set TempAdrPrnScr
 $8B0A CALL $8B90    ; draw an empty compass on screen
 $8B0D LD A,($88DE)  ; 88DE 7,=1 left 7,=0 right 0-6 =X coordinate increment
 $8B10 LD B,A        ;
 $8B11 AND $7F       ;
 $8B13 LD C,A        ;
 $8B14 JR Z,$8B2C    ;
 $8B16 LD A,B        ;
 $8B17 AND $80       ;
 $8B19 LD B,C        ;
 $8B1A JR NZ,$8B4C   ;
*$8B1C LD HL,$8BB0   ; buffer for preparing to print the pointer
 $8B1F LD A,$04      ;
*$8B21 SRL (HL)      ; shift the compass indicator right
 $8B23 INC HL        ;
 $8B24 RR (HL)       ;
 $8B26 INC HL        ;
 $8B27 DEC A         ;
 $8B28 JR NZ,$8B21   ; shift the compass indicator right
 $8B2A DJNZ $8B1C    ;
*$8B2C LD DE,($8BAE) ; get TempAdrPrnScr
 $8B30 LD HL,$8BB0   ; buffer for preparing to print the pointer
 $8B33 LD BC,$04FF   ;
*$8B36 LD A,(DE)     ; print the indicator
 $8B37 OR (HL)       ;
 $8B38 LD (DE),A     ;
 $8B39 INC E         ;
 $8B3A INC L         ;
 $8B3B LD A,(DE)     ;
 $8B3C OR (HL)       ;
 $8B3D LD (DE),A     ;
 $8B3E EX DE,HL      ;
 $8B3F INC H         ;
 $8B40 LD A,H        ;
 $8B41 AND $07       ;
 $8B43 CALL Z,$8B7C  ; continue calculating the display-file address one pixel
                     ; below
 $8B46 EX DE,HL      ;
 $8B47 DEC E         ;
 $8B48 INC HL        ;
 $8B49 DJNZ $8B36    ; print the indicator
 $8B4B RET           ;
*$8B4C LD HL,$8BB0   ; buffer for preparing to print the pointer
 $8B4F LD A,$04      ;
*$8B51 SLA (HL)      ; shift the compass indicator left
 $8B53 INC HL        ;
 $8B54 RL (HL)       ;
 $8B56 INC HL        ;
 $8B57 DEC A         ;
 $8B58 JR NZ,$8B51   ; shift the compass indicator left
 $8B5A DJNZ $8B4C    ;
 $8B5C LD DE,($8BAE) ; get TempAdrPrnScr
 $8B60 LD HL,$8BB0   ; buffer for preparing to print the pointer
 $8B63 LD BC,$04FF   ;
*$8B66 LD A,(DE)     ; print the indicator
 $8B67 OR (HL)       ;
 $8B68 LD (DE),A     ;
 $8B69 INC HL        ;
 $8B6A DEC E         ;
 $8B6B LD A,(DE)     ;
 $8B6C OR (HL)       ;
 $8B6D LD (DE),A     ;
 $8B6E EX DE,HL      ;
 $8B6F INC H         ;
 $8B70 LD A,H        ;
 $8B71 AND $07       ;
 $8B73 CALL Z,$8B7C  ; continue calculating the display-file address one pixel
                     ; below
 $8B76 EX DE,HL      ;
 $8B77 INC E         ;
 $8B78 INC HL        ;
 $8B79 DJNZ $8B66    ; print the indicator
 $8B7B RET           ;

