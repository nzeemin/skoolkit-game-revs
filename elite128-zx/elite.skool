; PrnStarOnGalaxyMap
;
; Used by the routine at #R$AB4E.
;
; .
;
; Calculate coordinates and print one star (dot) on the galaxy map
; .
; In: (DataOfPlanet) - planet data
c$ABE6 LD A,($AC16)  ; data for generating a planet
 $ABE9 SRL A         ;
 $ABEB XOR $7F       ;
 $ABED ADD A,$18     ;
 $ABEF LD B,A        ;
 $ABF0 LD A,($AC18)  ;
 $ABF3 LD C,A        ;
 $ABF4 CALL $22AA    ; calculate the screen address In: B - crdY, C - crdX Out:
                     ; hl - address A - offset of this point from the byte's
                     ; left edge
 $ABF7 XOR $07       ;
 $ABF9 ADD A,A       ;
 $ABFA ADD A,A       ;
 $ABFB ADD A,A       ;
 $ABFC OR $C0        ;
 $ABFE LD DE,$AC05   ;
 $AC01 LD (DE),A     ; adjust the instruction used to set the point
 $AC02 LD B,$00      ;
 $AC04 SET 1,B       ;
 $AC06 LD A,(HL)     ;
 $AC07 XOR B         ;
 $AC08 LD (HL),A     ;
 $AC09 RET           ;

