 $E41B JR NC,$E41E   ;
 $E41D INC HL        ;
*$E41E BIT 7,C       ;
 $E420 RET Z         ;
 $E421 SET 7,H       ;
 $E423 RET           ;

; AddSign_L_E
;
; Used by the routines at #R$E353, #R$E4E9, #R$E52A and #R$FB1F.
;
; .
;
; Signed addition
; .
; In: hl - first addend $00..$FF (7,h sign)
; .
; de - second addend $00..$FF (7,d sign)
; .
; Out: a - sum
; .
; 7,h - sign
; .
; cy =1 sum overflow
c$E424 LD A,H        ;
 $E425 XOR D         ;
 $E426 RLA           ;
 $E427 JR C,$E42C    ;
 $E429 LD A,L        ;
 $E42A ADD A,E       ;
 $E42B RET           ;
*$E42C LD A,L        ;
 $E42D SUB E         ;
 $E42E RET NC        ;
 $E42F NEG           ;
 $E431 AND A         ;
 $E432 LD H,D        ;
 $E433 RET           ;

; Mult_A_hiB_C
;
; Used by the routines at #R$DE5D, #R$DF46, #R$E447, #R$E52A, #R$E7B2, #R$E9E4
; and #R$FB10.
;
