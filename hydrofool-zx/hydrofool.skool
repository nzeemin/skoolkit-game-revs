                     ; (row $A4)
 $8519 POP HL        ;
 $851A LD A,(HL)     ;
 $851B LD ($618A),A  ;
 $851E INC HL        ;
 $851F CALL $7D68    ; Print string: inline message text embedded after the
                     ; call to #R$8513
 $8522 JP (HL)       ;

