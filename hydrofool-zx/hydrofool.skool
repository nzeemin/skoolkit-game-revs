; Menu tune + key-wait driver
;
; Used by the routine at #R$85A1.
;
; .
;
; Sets up the melody-table pointers ($FBAB=$FC99, $FBAF=$FE33), then loops:
; disable interrupts, play one note via #R$FBD7 (which reads/advances through
; the melody-index table and produces the tone), scan the keyboard via the ROM
; KEY-SCAN routine at $028E, and repeat until a key is pressed; then re-enable
; interrupts and return.
c$FB90 LD HL,$FC99   ; {point $FBAB at the start of the melody-index table
 $FB93 LD ($FBAB),HL ; (#R$FC9A, aliased as code for a rare branch -- see its
                     ; note)}
 $FB96 LD HL,$FE33   ; {point $FBAF at $FE33 (a second/loop-restart table
 $FB99 LD ($FBAF),HL ; pointer, not yet explored)}
 $FB9C DI            ; disable interrupts while bit-banging the tone (precise
                     ; timing)
*$FB9D CALL $FBD7    ; play one note (advances the melody-index pointer
                     ; internally via #R$FBB4/#R$FBC1)
 $FBA0 CALL $028E    ; ROM KEY-SCAN: scans the keyboard, returns no-key-found
                     ; as E=$FF
 $FBA3 INC E         ; {if no key was found (E wraps to 0), loop back and play
 $FBA4 JR Z,$FB9D    ; the next note}
 $FBA6 EI            ; {re-enable interrupts and return (a key was pressed)
 $FBA7 RET           ; }

; Data block at FBA8
b$FBA8 DEFB $00,$00,$00
 $FBAB DEFW $EA60
 $FBAD DEFW $FC9A
 $FBAF DEFW $EE48
 $FBB1 DEFW $FE34
 $FBB3 DEFB $EE

; Melody-index table reader/advancer, used by #R$FBD7
;
; Used by the routine at #R$FBD7.
;
; .
;
; Reads the next byte of the melody-index table (via the pointer at (HL)),
; advances the pointer, and returns it in A. If the byte is $40 (end-of-tune
; marker), jumps to #R$FBCF to reload the pointer from a loop-restart address
; instead.
c$FBB4 LD E,(HL)     ;
 $FBB5 INC HL        ;
 $FBB6 LD D,(HL)     ;
 $FBB7 INC DE        ;
; This entry point is used by the routine at #R$FBCF.
*$FBB8 LD A,(DE)     ;
 $FBB9 CP $40        ;
 $FBBB JR Z,$FBCF    ;
 $FBBD LD (HL),D     ;
 $FBBE DEC HL        ;
 $FBBF LD (HL),E     ;
 $FBC0 RET           ;

; Melody-index to period lookup, used by #R$FBD7
;
; Used by the routine at #R$FBD7.
;
; .
;
; Converts a melody-index byte (from #R$FBB4, at (HL)) into an actual tone
; period by adding $0C and indexing into the period table at #R$FC64; returns
; the period in H, with L fixed at $01. E.g. index $29 (+$0C=$35) ->
; #R$FC64+$35 = $FC99 = $01.
c$FBC1 LD A,(HL)     ;
 $FBC2 ADD A,$0C     ;
 $FBC4 LD E,A        ;
 $FBC5 LD D,$00      ;
 $FBC7 LD HL,$FC64   ;
 $FBCA ADD HL,DE     ;
 $FBCB LD H,(HL)     ;
 $FBCC LD L,$01      ;
 $FBCE RET           ;

; Continuation of #R$FBB4
;
; Used by the routine at #R$FBB4.
c$FBCF INC HL        ;
 $FBD0 LD E,(HL)     ;
 $FBD1 INC HL        ;
 $FBD2 LD D,(HL)     ;
 $FBD3 DEC HL        ;
 $FBD4 DEC HL        ;
 $FBD5 JR $FBB8      ;

; Play one note / check key selection
;
; Used by the routine at #R$FB90.
;
; .
;
; Calls #R$FBB4 twice (storing results at $FBA8/$FBA9), then #R$FBC1 twice to
; check them; if neither matches, falls into the tone-generator loop at $FC04,
; continuing through $FC15/$FC17/$FC25 into #R$FC34, which toggles the
; speaker/border via OUT ($FE),A (bit 4 = speaker) in a tight DJNZ-timed
; square-wave loop -- this is the music heard while the menu waits for input.
; If both checks match, jumps to the plain delay loop at #R$FC46 instead.
c$FBD7 LD HL,$FBAB   ;
 $FBDA CALL $FBB4    ; Melody-index table reader/advancer, used by #R$FBD7
 $FBDD LD ($FBA8),A  ;
 $FBE0 LD HL,$FBAF   ;
 $FBE3 CALL $FBB4    ; Melody-index table reader/advancer, used by #R$FBD7
 $FBE6 LD ($FBA9),A  ;
 $FBE9 LD HL,$FBA8   ;
 $FBEC CALL $FBC1    ; Melody-index to period lookup, used by #R$FBD7
 $FBEF RL E          ;
 $FBF1 JP C,$FC9A    ;
 $FBF4 PUSH HL       ;
 $FBF5 LD HL,$FBA9   ;
 $FBF8 CALL $FBC1    ; Melody-index to period lookup, used by #R$FBD7
 $FBFB POP DE        ;
 $FBFC LD A,H        ;
 $FBFD DEC A         ;
 $FBFE JR NZ,$FC04   ;
 $FC00 LD A,D        ;
 $FC01 DEC A         ;
 $FC02 JR Z,$FC46    ;
*$FC04 LD A,($FBB3)  ; {setup: C=note duration count (from $FBB3), B=0, load
 $FC07 LD C,A        ; key-state twice into both AF register banks, D=$10
 $FC08 LD B,$00      ; (initial half-period)
 $FC0A LD A,($FBAA)  ;
 $FC0D EX AF,AF'     ;
 $FC0E LD A,($FBAA)  ;
 $FC11 LD IXh,D      ;
 $FC13 LD D,$10      ; }
; This entry point is used by the routine at #R$FC34.
*$FC15 NOP           ;
 $FC16 NOP           ;
; This entry point is used by the routine at #R$FC34.
*$FC17 EX AF,AF'     ;
 $FC18 DEC E         ;
 $FC19 OUT ($FE),A   ; toggle speaker/border bit 4 -- produces the audible tone
 $FC1B JR NZ,$FC34   ;
 $FC1D LD E,IXh      ;
 $FC1F XOR D         ;
 $FC20 EX AF,AF'     ;
 $FC21 DEC L         ;
 $FC22 JP NZ,$FC3B   ;
; This entry point is used by the routine at #R$FC34.
*$FC25 OUT ($FE),A   ; toggle speaker/border bit 4 -- produces the audible tone
 $FC27 LD L,H        ;
 $FC28 XOR D         ;
 $FC29 DJNZ $FC15    ;
 $FC2B INC C         ;
 $FC2C JP NZ,$FC17   ;
 $FC2F RET           ;

; NOTE: not a real string
;
; .
;
; .
;
; Literal ASCII "adam" embedded as data/padding between code paths; possibly a
; programmer's signature.
t$FC30 DEFM "adam"

; Tone generator loop (continued)
;
; Used by the routine at #R$FBD7.
;
; .
;
; Toggles the speaker bit via OUT ($FE),A, timed by DJNZ.
c$FC34 JR Z,$FC34    ;
 $FC36 EX AF,AF'     ;
 $FC37 DEC L         ;
 $FC38 JP Z,$FC25    ;
; This entry point is used by the routine at #R$FBD7.
*$FC3B OUT ($FE),A   ; toggle speaker/border bit 4 -- produces the audible tone
 $FC3D NOP           ;
 $FC3E NOP           ;
 $FC3F DJNZ $FC15    ;
 $FC41 INC C         ;
 $FC42 JP NZ,$FC17   ;
 $FC45 RET           ;

; Plain delay loop (no sound)
;
; Used by the routine at #R$FBD7.
;
; .
;
; Decrements a counter via $FBB3, with no OUT ($FE) calls.
c$FC46 LD A,($FBB3)  ;
 $FC49 CPL           ;
 $FC4A LD C,A        ;
 $FC4B PUSH BC       ;
 $FC4C PUSH AF       ;
 $FC4D LD B,$00      ;
*$FC4F PUSH HL       ;
 $FC50 LD HL,$0000   ;
 $FC53 SRA (HL)      ; {shift a (self-modified) pointer's byte right 3 times
 $FC55 SRA (HL)      ; (divide by 8) -- pure delay, no sound
 $FC57 SRA (HL)      ; }
 $FC59 NOP           ;
 $FC5A POP HL        ;
 $FC5B DJNZ $FC4F    ;
 $FC5D DEC C         ;
 $FC5E JP NZ,$FC4F   ;
 $FC61 POP AF        ;
 $FC62 POP BC        ;
 $FC63 RET           ;

