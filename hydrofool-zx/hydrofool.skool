; Per-frame dynamic object dispatcher (walks the active object list from the
; head at #R$610E)
;
; Used by the routine at #R$9808.
;
; IX ???
;
; For each object record (IX) in the list (record +0/+1 links to the next; the
; list includes the pool records at #R$A900, the PLAYER record at #R$8DB6, and
; the room's creature), checks if its room number (offset $02) matches the
; current room ($6126); if so, loads a function pointer from offset $03/$04 and
; CALLs #R$61A7 (a JP (HL) trampoline) to invoke the object's own per-frame
; behaviour handler (e.g. #R$9684 for a snake, #R$8968 for the player). Also
; checks bit 7 of offset $0D and computes into offset $0C from offsets $10/$11
; -- purpose not yet confirmed.
c$983C LD L,(IX+$00)  ;
 $983F LD H,(IX+$01)  ;
*$9842 LD A,L         ;
 $9843 OR H           ;
 $9844 RET Z          ;
 $9845 PUSH HL        ;
 $9846 EX (SP),IX     ;
 $9848 LD A,(IX+$02)  ;
 $984B INC A          ;
 $984C JR NZ,$986C    ;
 $984E LD L,(IX+$00)  ;
 $9851 LD H,(IX+$01)  ;
 $9854 LD DE,($618B)  ;
 $9858 LD (IX+$00),E  ;
 $985B LD (IX+$01),D  ;
 $985E LD ($618B),IX  ;
 $9862 POP IX         ;
 $9864 LD (IX+$00),L  ;
 $9867 LD (IX+$01),H  ;
 $986A JR $9842       ;
*$986C LD A,($6126)   ; get room number
 $986F CP (IX+$02)    ;
 $9872 JP NZ,$98FC    ;
 $9875 LD L,(IX+$03)  ;
 $9878 LD H,(IX+$04)  ;
 $987B CALL $61A7     ; JP (HL)
 $987E LD A,($6126)   ; get room number
 $9881 CP (IX+$02)    ;
 $9884 JR NZ,$98FC    ;
 $9886 BIT 7,(IX+$0D) ;
 $988A JR NZ,$98FC    ;
 $988C LD A,$5E       ;
 $988E ADD A,(IX+$10) ;
 $9891 ADD A,(IX+$11) ;
 $9894 LD (IX+$0C),A  ;
 $9897 LD HL,$60EC    ;
 $989A LD A,($60EB)   ;
 $989D AND A          ;
 $989E JR Z,$98F2     ;
 $98A0 LD B,A         ;
 $98A1 LD A,(IX+$0C)  ;
*$98A4 LD E,(HL)      ;
 $98A5 INC HL         ;
 $98A6 LD D,(HL)      ;
 $98A7 PUSH HL        ;
 $98A8 LD HL,$0010    ;
 $98AB ADD HL,DE      ;
 $98AC LD A,(IX+$12)  ;
 $98AF CP (HL)        ;
 $98B0 JR C,$98D4     ;
 $98B2 INC HL         ;
 $98B3 LD A,(IX+$13)  ;
 $98B6 CP (HL)        ;
 $98B7 JR C,$98D4     ;
 $98B9 INC HL         ;
 $98BA LD A,(HL)      ;
 $98BB CP (IX+$10)    ;
 $98BE JR C,$98D4     ;
 $98C0 INC HL         ;
 $98C1 LD A,(HL)      ;
 $98C2 CP (IX+$11)    ;
 $98C5 JR C,$98D4     ;
 $98C7 LD HL,$0007    ;
 $98CA ADD HL,DE      ;
 $98CB LD A,(HL)      ;
 $98CC POP HL         ;
 $98CD CP (IX+$07)    ;
 $98D0 JR NC,$98E4    ;
 $98D2 JR $98DF       ;
*$98D4 LD HL,$000C    ;
 $98D7 ADD HL,DE      ;
 $98D8 LD A,(IX+$0C)  ;
 $98DB CP (HL)        ;
 $98DC POP HL         ;
 $98DD JR C,$98E4     ;
*$98DF INC HL         ;
 $98E0 DJNZ $98A4     ;
 $98E2 JR $98F2       ;
*$98E4 DEC HL         ;
 $98E5 LD A,B         ;
 $98E6 ADD A,A        ;
 $98E7 LD C,A         ;
 $98E8 LD B,$00       ;
 $98EA ADD HL,BC      ;
 $98EB LD E,L         ;
 $98EC LD D,H         ;
 $98ED INC DE         ;
 $98EE DEC HL         ;
 $98EF LDDR           ;
 $98F1 INC HL         ;
*$98F2 PUSH IX        ;
 $98F4 POP DE         ;
 $98F5 LD (HL),E      ;
 $98F6 INC HL         ;
 $98F7 LD (HL),D      ;
 $98F8 LD HL,$60EB    ;
 $98FB INC (HL)       ;
*$98FC POP HL         ;
