 $6399 LD A,$02      ;
 $639B LD D,$CC      ;
 $639D LD E,$E8      ;
 $639F LD BC,$BFBF   ;
 $63A2 CALL $8128    ; Draw sprite C with its mask at screen position DE
 $63A5 LD A,($612B)  ;
*$63A8 BIT 2,A       ;
 $63AA RET Z         ;
 $63AB LD A,$02      ;
 $63AD LD D,$CC      ;
 $63AF LD E,$18      ;
 $63B1 LD BC,$BCBC   ;
 $63B4 CALL $8128    ; Draw sprite C with its mask at screen position DE
 $63B7 LD A,$02      ;
 $63B9 LD D,$D4      ;
 $63BB LD E,$28      ;
 $63BD LD BC,$C0C0   ;
