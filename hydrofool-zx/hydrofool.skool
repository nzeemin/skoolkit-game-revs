; Print engine entry point
;
; Used by the routines at #R$8501, #R$854C, #R$854F, #R$85A1, #R$86CC and
; #R$885A.
;
; A char to print, or a control code ($14/$16)
;
; Prints the char/control code in A by jumping through the vector at (#R$7CE8).
c$7CEC PUSH HL       ; {save registers
 $7CED PUSH DE       ;
 $7CEE PUSH BC       ;
 $7CEF PUSH AF       ; }
 $7CF0 LD HL,$61A6   ; disable interrupt-driven redraw flag at #R$61A6 while
                     ; printing
 $7CF3 LD (HL),$01   ;
 $7CF5 LD HL,($7CE8) ; get Print char routine address
 $7CF8 JP (HL)       ; jump to current print-engine mode handler

; Print char routine (default mode)
;
; .
;
; A char to print, or a control code ($14/$16)
;
; Prints char A as a font glyph at (#R$7CEA), or switches mode for control
; codes $14/$16.
c$7CF9 CP $20        ; control codes (<$20) are handled separately; printable
                     ; chars fall through
 $7CFB JR C,$7D26    ;
 $7CFD LD L,A        ; {convert char code to font glyph offset (glyph =
 $7CFE LD H,$00      ; (A-$20)*8, using codes starting at font base -$20*8)
 $7D00 ADD HL,HL     ;
 $7D01 ADD HL,HL     ;
 $7D02 ADD HL,HL     ; }
 $7D03 LD DE,$A300   ; Font base address
 $7D06 ADD HL,DE     ;
 $7D07 EX DE,HL      ;
 $7D08 LD HL,($7CEA) ; {copy 8 rows of the glyph to the shadow screen at
 $7D0B LD BC,$0020   ; (#R$7CEA), stepping by 32 bytes/row}
 $7D0E LD A,$08      ;
*$7D10 PUSH AF       ;
 $7D11 LD A,(DE)     ;
 $7D12 NOP           ;
 $7D13 LD (HL),A     ;
 $7D14 INC DE        ;
 $7D15 ADD HL,BC     ; next line
 $7D16 POP AF        ;
 $7D17 DEC A         ;
 $7D18 JR NZ,$7D10   ;
 $7D1A LD HL,($7CEA) ; {advance print cursor (#R$7CEA) to the next character
 $7D1D INC HL        ; column
 $7D1E LD ($7CEA),HL ; }
; This entry point is used by the routine at #R$7D3F.
*$7D21 POP AF        ;
 $7D22 POP BC        ;
 $7D23 POP DE        ;
 $7D24 POP HL        ;
 $7D25 RET           ;
*$7D26 CP $14        ; {control code $14: switch mode to #R$7D32 (set
 $7D28 JR NZ,$7D3F   ; inverse/highlight flag)
 $7D2A LD HL,$7D32   ; }
; This entry point is used by the routines at #R$7D32, #R$7D3F and #R$7D48.
*$7D2D LD ($7CE8),HL ;
 $7D30 JR $7D21      ;

; Print engine mode: set inverse video flag
;
; .
;
; A flag: zero sets inverse video (CPL), non-zero sets normal video (NOP)
;
; Self-modifies the LD A at #R$7D12 to CPL/NOP for subsequent chars.
c$7D32 AND A         ;
 $7D33 JR Z,$7D37    ;
 $7D35 LD A,$2F      ;
*$7D37 LD ($7D12),A  ;
; This entry point is used by the routine at #R$7D57.
*$7D3A LD HL,$7CF9   ;
 $7D3D JR $7D2D      ;

; Print engine mode: dispatch control code $16
;
; Used by the routine at #R$7CF9.
;
; A char to test against control code $16
;
; Control code $16 switches mode to #R$7D48 (set cursor row); else return.
c$7D3F CP $16        ;
 $7D41 JR NZ,$7D21   ;
 $7D43 LD HL,$7D48   ;
 $7D46 JR $7D2D      ;

; Print engine mode: set cursor row
;
; .
;
; A cursor row
;
; Sets print cursor row from A (row*256 + shadow screen base).
c$7D48 LD H,A        ;
 $7D49 LD L,$00      ;
 $7D4B LD DE,$E390   ; Shadow screen address
 $7D4E ADD HL,DE     ;
 $7D4F LD ($7CEA),HL ;
 $7D52 LD HL,$7D57   ;
 $7D55 JR $7D2D      ;

; Print engine mode: set cursor column
;
; .
;
; A cursor column offset
;
; Sets print cursor column from A, then switches back to default char-printing
; mode.
c$7D57 LD HL,($7CEA) ;
 $7D5A LD E,A        ;
 $7D5B LD D,$00      ;
 $7D5D ADD HL,DE     ;
 $7D5E LD ($7CEA),HL ;
 $7D61 JR $7D3A      ;

