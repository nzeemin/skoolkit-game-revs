; Jump-arc step, right: room change when Joe reaches X=$E6
;
; Used by the routines at #R$7E32 and #R$7FD2.
;
; .
;
; Called every frame during a rightward jump-arc (#R$7FD2, triggered by
; UP+RIGHT). X increases by 2/frame; once it reaches $E6 (right edge), room++
; ($8203, wraps 0-7) and X resets to $00 - i.e. this is where horizontal ROOM
; (column) transitions actually happen, as a side effect of completing a jump
; off the edge. Blocked (no room change, X still clamped) if $820C bit0 is set
; - see that variable's bit map.
@label=JumpStepRight
c$7F6E LD A,$00      ;
 $7F70 LD ($820B),A  ; set Joe's facing direction
 $7F73 LD A,($820C)  ;
 $7F76 AND $01       ;
 $7F78 LD C,A        ;
 $7F79 LD A,($8201)  ; get Joe X
 $7F7C CP $E6        ;
 $7F7E JR NZ,$7F95   ;
 $7F80 LD A,C        ;
 $7F81 OR A          ;
 $7F82 RET NZ        ;
 $7F83 LD A,$00      ;
 $7F85 LD ($8201),A  ; set Joe X
 $7F88 LD A,($8203)  ; get room number
 $7F8B INC A         ;
 $7F8C AND $07       ;
 $7F8E LD ($8203),A  ; set room number
 $7F91 POP BC        ;
 $7F92 JP $8114      ; => Per-frame room-tile lookup, then hand off to game
                     ; loop
*$7F95 LD A,($8201)  ; get Joe X
 $7F98 INC A         ;
 $7F99 INC A         ;
 $7F9A LD ($8201),A  ; set Joe X
 $7F9D RET           ;

; Data block at 7F9E
b$7F9E DEFB $59,$58

; Jump-arc step, left: room change when Joe reaches X=$00
;
; Used by the routines at #R$7E32 and #R$7FDC.
;
; .
;
; Mirror of #R$7F6E for a leftward jump-arc (#R$7FDC, triggered by UP+LEFT): X
; decreases by 2/frame; once it reaches $00 (left edge), room-- ($8203, wraps
; 0-7) and X resets to $E6. Blocked if $820C bit1 is set.
@label=JumpStepLeft
c$7FA0 LD A,$01      ;
 $7FA2 LD ($820B),A  ; set Joe's facing direction
 $7FA5 LD A,($8201)  ; get Joe X
 $7FA8 CP $00        ;
 $7FAA JR NZ,$7FC4   ;
 $7FAC LD A,($820C)  ;
 $7FAF AND $02       ;
 $7FB1 RET NZ        ;
 $7FB2 LD A,$E6      ;
 $7FB4 LD ($8201),A  ; set Joe X
 $7FB7 LD A,($8203)  ; get room number
 $7FBA DEC A         ;
 $7FBB AND $07       ;
 $7FBD LD ($8203),A  ; set room number
 $7FC0 POP BC        ;
 $7FC1 JP $8114      ; => Per-frame room-tile lookup, then hand off to game
                     ; loop
*$7FC4 LD A,($8201)  ; get Joe X
 $7FC7 DEC A         ;
 $7FC8 DEC A         ;
 $7FC9 LD ($8201),A  ; set Joe X
 $7FCC RET           ;

; Data block at 7FCD
b$7FCD DEFB $5A,$11,$20,$00,$06

