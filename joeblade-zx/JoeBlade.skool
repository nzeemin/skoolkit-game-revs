; Soldier pattern 1: chase Joe's X; shared screen/sprite-address builder
;
; Used by the routines at #R$7D64, #R$7D82 and #R$96CC.
;
; .
;
; Compares Joe's X against the soldier's X (IX+1); moves the soldier one step
; toward Joe (INC/DEC), picking a left/right-facing sprite (DE=#R$A800/$AA00)
; accordingly. Falls into #R$9028 (also entered directly by #R$8164/#R$9464)
; which turns the soldier's X (C) into a screen address (HL, $8F93) and
; sprite/mask address (DE, $8F90/$8F8D) - bit1 of X selects sprite half, bit2
; selects sprite row.
@label=SoldierPattern1
c$900A LD A,($8201)  ; {Compare Joe X vs soldier X (IX+1)
 $900D SUB (IX+$01)  ;
 $9010 JR Z,$9017    ; }
 $9012 JR C,$901C    ; {Step toward Joe
 $9014 INC (IX+$01)  ; }
*$9017 LD DE,$AA00   ; {Moving right: DE = $AA00 (right-facing sprite)
 $901A JR $9022      ; }
*$901C DEC (IX+$01)  ; {Moving left: DE = #R$A800 (left-facing sprite)
 $901F LD DE,$A800   ; }
*$9022 LD C,(IX+$01) ; C = soldier X
 $9025 NOP           ;
 $9026 NOP           ;
 $9027 NOP           ;
; This entry point is used by the routines at #R$8164 and #R$9464.
*$9028 LD HL,$4880   ; {HL = screen address from soldier X (HL = screen row 12
 $902B LD A,C        ; col 0)
 $902C AND $F8       ;
 $902E RRCA          ;
 $902F RRCA          ;
 $9030 RRCA          ;
 $9031 ADD A,L       ;
 $9032 LD L,A        ; }
 $9033 LD A,C        ; {Bit1 of X: E = $80 (sprite half)
 $9034 AND $02       ;
 $9036 JR Z,$903A    ;
 $9038 LD E,$80      ; }
*$903A LD A,C        ; {Bit2 of X: D += 1 (sprite row)
 $903B AND $04       ;
 $903D JR Z,$9041    ;
 $903F INC D         ;
 $9040 NOP           ; }
*$9041 LD ($8F90),DE ; {Store $8F90 = DE, $8F93 = HL
 $9045 LD ($8F93),HL ; }
 $9048 INC D         ; {D += 4
 $9049 INC D         ;
 $904A INC D         ;
 $904B INC D         ; }
 $904C LD ($8F8D),DE ; {Store $8F8D = DE
 $9050 RET           ; }

; Unused
s$9051 DEFS $09

; Running line of symbols
;
; Used by the routine at #R$8F00.
;
; .
;
; Called every frame from #R$8F00. Bit-rotates 5 rows of pixels at $407F left
; through carry (a scrolling decorative border effect), then advances a slower
; secondary animation frame ($821F/$8220-gated) sourced from a table at
; #R$9E00.
@label=RunningLine
c$905A LD HL,$407F   ; Screen row 3 col 31
 $905D LD C,$05      ; C = 5 rows
*$905F PUSH HL       ;
 $9060 LD B,$20      ;
*$9062 RL (HL)       ;
 $9064 DEC HL        ;
 $9065 DJNZ $9062    ;
 $9067 POP HL        ;
 $9068 INC H         ;
 $9069 DEC C         ;
 $906A JR NZ,$905F   ;
 $906C LD A,($821F)  ; {Advance frame counter $821F
 $906F INC A         ;
 $9070 LD ($821F),A  ;
 $9073 AND $07       ;
 $9075 RET NZ        ; }
 $9076 LD HL,$8220   ; {Advance secondary frame counter $8220, wrap at 0
 $9079 INC (HL)      ;
 $907A LD A,(HL)     ;
 $907B CP $00        ;
 $907D JR NZ,$9084   ; }
 $907F LD A,$00      ;
 $9081 LD ($8220),A  ;
*$9084 LD H,$9E      ; #R$9E00 block
 $9086 LD L,A        ;
 $9087 LD A,(HL)     ; get symbol code
 $9088 AND $E0       ;
 $908A RRCA          ;
 $908B RRCA          ;
 $908C RRCA          ;
 $908D RRCA          ;
 $908E RRCA          ;
 $908F ADD A,$A6     ;
 $9091 LD D,A        ;
 $9092 NOP           ;
 $9093 LD A,(HL)     ;
 $9094 NOP           ;
 $9095 AND $1F       ;
 $9097 RLCA          ;
 $9098 RLCA          ;
 $9099 RLCA          ;
 $909A LD E,A        ;
 $909B LD HL,$3E7F   ;
 $909E LD B,$08      ;
*$90A0 LD A,(DE)     ; read character pixels
 $90A1 INC DE        ;
 $90A2 LD (HL),A     ; write character pixels
 $90A3 INC H         ;
 $90A4 DJNZ $90A0    ;
 $90A6 RET           ;

; Unused
s$90A7 DEFS $03

; Draw door graphic column 1 (animated, via $8206)
;
; Used by the routine at #R$9602.
;
; .
;
; Picks an animation frame from $8600+ using $8206 bits1-2 (4 frames), then
; copies that frame's two 8x4-byte columns (via #R$90C8) into the shadow buffer
; at $B884/$B890 - the two halves of door-graphic column 1. Sibling routines
; #R$85DC/#R$95E6 draw columns 2/3 the same way; all three are gated by
; #R$9500's per-tile event flags (bits 2/3/4).
c$90AA LD A,($8206)  ; {DE = $8600 + frame*16 (animation source)
 $90AD AND $06       ;
 $90AF RLCA          ;
 $90B0 RLCA          ;
 $90B1 RLCA          ;
 $90B2 RLCA          ;
 $90B3 LD L,A        ;
 $90B4 LD H,$86      ; }
 $90B6 PUSH HL       ; {Save DE, swap to source
 $90B7 EX DE,HL      ; }
 $90B8 LD HL,$B884   ; Dest column 1 (shadow buffer)
 $90BB CALL $90C8    ; Copy an 8x4-byte column (DE->HL), used by the
                     ; door-drawing routines
 $90BE POP DE        ; Restore DE
 $90BF LD HL,$B890   ; Dest column 2 (shadow buffer)
 $90C2 JP $90C8      ; => Copy an 8x4-byte column (DE->HL), used by the
                     ; door-drawing routines

; Unused
s$90C5 DEFS $03

; Copy an 8x4-byte column (DE->HL), used by the door-drawing routines
;
; Used by the routines at #R$85DC, #R$90AA and #R$95E6.
;
; .
;
; Shared column-copy primitive for #R$85DC/#R$90AA/#R$95E6 (the 3 door-graphic
; columns in #R$9602).
@label=CopyColumn
c$90C8 LD B,$08      ; B = 8 lines
*$90CA LD A,(DE)     ; {Copy 4 bytes (DE->HL)
 $90CB INC DE        ;
 $90CC LD (HL),A     ;
 $90CD INC HL        ;
 $90CE LD A,(DE)     ;
 $90CF INC DE        ;
 $90D0 LD (HL),A     ;
 $90D1 INC HL        ;
 $90D2 LD A,(DE)     ;
 $90D3 INC DE        ;
 $90D4 LD (HL),A     ;
 $90D5 INC HL        ;
 $90D6 LD A,(DE)     ;
 $90D7 INC DE        ;
 $90D8 LD (HL),A     ; }
 $90D9 DEC HL        ; {HL -= 3 (net +1 after the 4-byte copy)
 $90DA DEC HL        ;
 $90DB DEC HL        ; }
 $90DC INC H         ; next line
 $90DD DJNZ $90CA    ; Loop 8 lines
 $90DF RET           ;

