 $825C PUSH BC       ;
 $825D PUSH HL       ;
 $825E LD B,$08      ;
*$8260 PUSH BC       ;
 $8261 PUSH HL       ;
 $8262 LD B,$04      ;
*$8264 LD A,(DE)     ; {Copy a 4-byte strip
 $8265 LD (HL),A     ;
 $8266 INC DE        ;
 $8267 INC HL        ;
 $8268 DJNZ $8264    ; }
 $826A POP HL        ; {Restore HL/BC
 $826B POP BC        ; }
 $826C INC H         ; {Advance to next screen row (INC H)
 $826D DJNZ $8260    ; }
 $826F POP HL        ; {Restore HL/BC
 $8270 POP BC        ; }
 $8271 LD A,L        ; {Advance column X by $20
 $8272 ADD A,$20     ;
 $8274 LD L,A        ;
 $8275 DJNZ $825B    ; }
 $8277 POP HL        ; {Restore HL/BC
 $8278 POP BC        ; }
 $8279 INC HL        ; {Advance source HL by 4
 $827A INC HL        ;
 $827B INC HL        ;
 $827C INC HL        ;
 $827D DJNZ $8254    ; }
 $827F RET           ;

