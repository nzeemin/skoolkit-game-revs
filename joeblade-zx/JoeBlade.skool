; Win screen: redraw title, congratulations text, wait, return to menu
;
; Used by the routine at #R$FF14.
;
; .
;
; Triggered by #R$FF14 on game completion. Redraws the "JOE BLADE" sign and
; several congratulation strings, pauses (28 iterations of #R$A77C), then falls
; into a HL-countdown delay before JP #R$8EB4 (back to the menu/hi-score flow).
@label=WinScreen
c$FEB4 CALL $83C0    ; Clear screen, border to black
 $FEB7 NOP           ;
 $FEB8 NOP           ;
 $FEB9 NOP           ;
 $FEBA NOP           ;
 $FEBB NOP           ;
 $FEBC NOP           ;
 $FEBD NOP           ;
 $FEBE NOP           ;
 $FEBF NOP           ;
 $FEC0 NOP           ;
 $FEC1 CALL $8B02    ; Show "JOE BLADE" big sign on the screen
 $FEC4 LD IX,$FE00   ;
 $FEC8 LD HL,$4809   ; HL = screen row 8 col 9
 $FECB CALL $9196    ; Draw string IX
 $FECE LD HL,$5908   ;
 $FED1 LD B,$11      ;
*$FED3 LD (HL),$57   ;
 $FED5 INC HL        ;
 $FED6 DJNZ $FED3    ;
 $FED8 LD HL,$4866   ; HL = screen row 11 col 6
 $FEDB CALL $9196    ; Draw string IX
 $FEDE LD HL,$48A5   ; HL = screen row 13 col 5
 $FEE1 CALL $9196    ; Draw string IX
 $FEE4 LD HL,$48E4   ; HL = screen row 15 col 4
 $FEE7 CALL $9196    ; Draw string IX
 $FEEA LD HL,$5042   ; HL = screen row 18 col 2
 $FEED CALL $9196    ; Draw string IX
 $FEF0 LD HL,$5082   ; HL = screen row 20 col 2
 $FEF3 CALL $9196    ; Draw string IX
 $FEF6 LD A,$28      ;
*$FEF8 PUSH AF       ;
 $FEF9 CALL $A77C    ; Fast-forward the rolling-digit counter
 $FEFC POP AF        ;
 $FEFD DEC A         ;
 $FEFE JR NZ,$FEF8   ;
 $FF00 LD HL,$0000   ;
 $FF03 LD B,$20      ;
*$FF05 DJNZ $FF05    ;
 $FF07 DEC HL        ;
 $FF08 LD A,H        ;
 $FF09 OR L          ;
 $FF0A JR NZ,$FF02   ;
 $FF0C JP $8EB4      ; => Post-game hub

; Unused
s$FF0F DEFS $05

; Win-condition check: back at the start room, all hostages+bombs
;
; Used by the routine at #R$8F00.
;
; .
;
; Called every frame from #R$8F00. Wins the game when the current tile ($8202)
; is $7B (the same tile as Joe's starting room), the hostage counter $8214=6,
; and the bomb counter $8216=6 - i.e. rescue all hostages, defuse all bombs,
; and return to the start. On match, calls #R$FEB4 (win screen) and waits for
; all keys to release before returning to the menu (#R$8EB4).
@label=CheckWin
c$FF14 LD A,($8202)  ; {Current tile = starting room ($7B)?
 $FF17 CP $7B        ;
 $FF19 RET NZ        ; }
 $FF1A LD A,($8214)  ; {Hostages ($8214) = 6?
 $FF1D CP $06        ;
 $FF1F RET NZ        ; }
 $FF20 LD A,($8216)  ; {Bombs ($8216) = 6?
 $FF23 CP $06        ;
 $FF25 RET NZ        ; }
 $FF26 POP BC        ;
 $FF27 CALL $FEB4    ; Win screen
 $FF2A LD HL,$C800   ;
 $FF2D LD B,$00      ;
*$FF2F DJNZ $FF2F    ;
*$FF31 DEC HL        ;
 $FF32 LD A,H        ;
 $FF33 OR L          ;
 $FF34 JR NZ,$FF31   ;
*$FF36 CALL $91FA    ; Wait until every key on the keyboard is released
 $FF39 JR Z,$FF36    ;
 $FF3B JP $8EB4      ; => Post-game hub

; Kill-sparkle animation, 2nd slot (gated on $8226)
;
; Used by the routine at #R$8E64.
;
; .
;
; Byte-for-byte the same pattern as #R$789D, gated on $8226 instead of $7B10
; (anchor $8217/$8227 instead of $7B11/$7B12, clears $8F94 instead of $8FA8
; when done). A second, independent sparkle-effect slot - resolves $8226's
; purpose (set by #R$A798/#R$7869 on a hit): it's the same kill-sparkle
; mechanism as $7B10, letting two kills animate at once.
@label=KillSparkle2
c$FF3E LD A,($8226)  ; {Check $8226
 $FF41 OR A          ; }
 $FF42 RET Z         ; Return if inactive
 $FF43 NOP           ;
 $FF44 NOP           ;
 $FF45 NOP           ;
 $FF46 NOP           ;
 $FF47 NOP           ;
 $FF48 NOP           ;
 $FF49 NOP           ;
 $FF4A NOP           ;
 $FF4B NOP           ;
 $FF4C NOP           ;
 $FF4D NOP           ;
 $FF4E NOP           ;
 $FF4F LD A,($8226)  ; get kill-sparkle animation counter
 $FF52 CP $01        ;
 $FF54 JR NZ,$FF62   ;
 $FF56 LD A,($8F93)  ;
 $FF59 LD ($8227),A  ; set kill-sparkle anchor byte
 $FF5C LD HL,($8F90) ;
 $FF5F LD ($8217),HL ;
*$FF62 LD A,($8227)  ; get kill-sparkle anchor byte
 $FF65 LD ($8F93),A  ;
 $FF68 LD HL,($8217) ;
 $FF6B LD A,H        ;
 $FF6C AND $01       ;
 $FF6E ADD A,$64     ;
 $FF70 LD H,A        ;
 $FF71 LD A,($8206)  ;
 $FF74 AND $04       ;
 $FF76 NOP           ;
 $FF77 NOP           ;
 $FF78 ADD A,H       ;
 $FF79 LD H,A        ;
 $FF7A LD ($8F90),HL ;
 $FF7D INC H         ;
 $FF7E INC H         ;
 $FF7F LD ($8F8D),HL ;
 $FF82 LD A,($8226)  ; {Advance $8226
 $FF85 INC A         ;
 $FF86 LD ($8226),A  ; }
 $FF89 CP $1E        ; Done at $1E?
 $FF8B RET NZ        ;
 $FF8C DEC A         ;
 $FF8D LD ($8226),A  ; set kill-sparkle animation counter
 $FF90 LD A,$00      ;
 $FF92 LD ($8F94),A  ;
 $FF95 RET           ;

; Per-frame soldier update (redirect)
;
; Used by the routine at #R$8F00.
@label=jp_ProcessSoldier
@label=jp_ProcessSoldier
c$FF96 JP $8E64      ; => Per-frame soldier update

