 $80A9 LD A,($820D)  ; get jump counter
 $80AC LD D,$80      ;
 $80AE LD E,A        ;
 $80AF LD A,(DE)     ;
 $80B0 LD C,A        ;
 $80B1 NOP           ;
 $80B2 NOP           ;
 $80B3 NOP           ;
 $80B4 NOP           ;
 $80B5 NOP           ;
 $80B6 AND $07       ;
 $80B8 ADD A,$48     ;
 $80BA LD H,A        ;
 $80BB NOP           ;
 $80BC LD A,C        ;
 $80BD AND $38       ;
 $80BF RLCA          ;
 $80C0 RLCA          ;
 $80C1 ADD A,L       ;
 $80C2 LD L,A        ;
 $80C3 NOP           ;
 $80C4 LD A,C        ;
 $80C5 AND $C0       ;
 $80C7 RRCA          ;
 $80C8 RRCA          ;
 $80C9 RRCA          ;
 $80CA ADD A,H       ;
 $80CB LD H,A        ;
; HL = destination addr
 $80CC NOP           ;
 $80CD LD BC,$D800   ; !!MUT-ARG!! Joe sprites base address
 $80D0 LD A,($8209)  ; {$8209 bits0/1/7: use alt sprite bank $D0 (climbing
 $80D3 AND $83       ; costume)}
 $80D5 JR Z,$80D9    ;
 $80D7 LD B,$D0      ;
*$80D9 LD A,($820B)  ; {C = $820B (Joe's facing direction: 0/1)
 $80DC LD C,A        ; }
 $80DD LD A,($8209)  ; {$8209 bit5: flip facing (C ^= 1) - dead code, nothing
 $80E0 AND $20       ; ever sets this bit}
 $80E2 JR Z,$80E8    ;
 $80E4 LD A,C        ;
 $80E5 XOR $01       ;
 $80E7 LD C,A        ;
*$80E8 LD A,C        ;
 $80E9 OR A          ;
 $80EA JR NZ,$80EE   ;
 $80EC INC B         ;
 $80ED INC B         ;
*$80EE LD C,$00      ;
 $80F0 LD A,($8201)  ; get Joe X
 $80F3 AND $02       ;
 $80F5 JR Z,$80F9    ;
 $80F7 LD C,$80      ;
*$80F9 LD A,($8201)  ; get Joe X
 $80FC AND $04       ;
 $80FE JR Z,$8101    ;
 $8100 INC B         ;
