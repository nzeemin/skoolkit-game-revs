; Bomb minigame - access-code swap cursor input handler
;
; Used by the routine at #R$7800.
;
; .
;
; Edge-detects new key presses ($7B0F). Right/left move cursor 1 ($7B09, wraps
; 1-5); some other input moves cursor 2 ($7B0A, wraps 1-5); a third input swaps
; the access-code letters at $7B00+cursor1 and $7B00+cursor2 - the two cursor
; positions are the "green, exchangeable" letters.
@label=BombGameSwap
c$7A28 CALL $8032    ; Read input into $820A
 $7A2B LD A,($820A)  ; get input state
 $7A2E LD HL,$7B0F   ; {Edge-detect new key press ($7B0F)
 $7A31 CP (HL)       ;
 $7A32 RET Z         ;
 $7A33 LD (HL),A     ; }
 $7A34 LD HL,$7B09   ; HL = cursor1 addr $7B09
 $7A37 LD A,($820A)  ; get input state
 $7A3A AND $01       ;
 $7A3C JR Z,$7A4E    ;
 $7A3E INC (HL)      ; {cursor1++, wrap 6->1
 $7A3F LD A,$06      ;
 $7A41 CP (HL)       ;
 $7A42 JR NZ,$7A46   ; }
 $7A44 LD (HL),$01   ;
*$7A46 INC HL        ;
 $7A47 INC (HL)      ;
 $7A48 CP (HL)       ;
 $7A49 JR NZ,$7A4D   ;
 $7A4B LD (HL),$01   ;
*$7A4D RET           ;
*$7A4E LD A,($820A)  ; get input state
 $7A51 AND $02       ;
 $7A53 JR Z,$7A65    ;
 $7A55 LD A,$00      ; {cursor2--, wrap 0->5
 $7A57 DEC (HL)      ;
 $7A58 CP (HL)       ;
 $7A59 JR NZ,$7A5D   ; }
 $7A5B LD (HL),$05   ;
*$7A5D INC HL        ;
 $7A5E DEC (HL)      ;
 $7A5F CP (HL)       ;
 $7A60 JR NZ,$7A64   ;
 $7A62 LD (HL),$05   ;
*$7A64 RET           ;
*$7A65 LD A,($820A)  ; get input state
 $7A68 AND $1C       ;
 $7A6A RET Z         ;
 $7A6B LD E,(HL)     ; {Swap access-code letters at cursor1/cursor2
 $7A6C LD D,$7B      ;
 $7A6E LD A,(DE)     ;
 $7A6F LD C,A        ;
 $7A70 INC HL        ;
 $7A71 LD L,(HL)     ;
 $7A72 LD H,D        ;
 $7A73 LD A,(HL)     ;
 $7A74 NOP           ;
 $7A75 LD (DE),A     ;
 $7A76 LD (HL),C     ;
 $7A77 RET           ; }

; Bomb minigame - highlight the two swap-cursor access-code letters (green)
;
; Used by the routine at #R$7800.
;
; .
;
; Part of the bomb-deactivation minigame (#R$7800/#R$7A28): clears an attribute
; row, then highlights the two access-code letters currently selected for
; swapping (green), using cursor positions $7B09/$7B0A.
@label=BombGameHighlt
c$7A78 LD HL,$5960   ; {Clear attribute row $5960
 $7A7B LD A,$42      ;
 $7A7D LD B,L        ; }
*$7A7E LD (HL),A     ;
 $7A7F INC HL        ;
 $7A80 DJNZ $7A7E    ;
 $7A82 LD A,($7B09)  ; {HL = highlight position from cursor row $7B09
 $7A85 LD B,A        ;
 $7A86 ADD A,B       ;
 $7A87 ADD A,B       ;
 $7A88 ADD A,A       ;
 $7A89 ADD A,$5C     ;
 $7A8B LD L,A        ;
 $7A8C LD H,$59      ; }
 $7A8E LD B,$03      ; {B = 3 rows, DE = row stride
 $7A90 LD DE,$001E   ; }
*$7A93 LD (HL),$44   ; {Fill 3 cells per row with attribute $44
 $7A95 INC HL        ;
 $7A96 LD (HL),$44   ;
 $7A98 INC HL        ;
 $7A99 LD (HL),$44   ;
 $7A9B ADD HL,DE     ;
 $7A9C DJNZ $7A93    ; }
 $7A9E LD A,($7B0A)  ; {HL = highlight position from cursor row $7B0A
 $7AA1 LD B,A        ;
 $7AA2 ADD A,B       ;
 $7AA3 ADD A,B       ;
 $7AA4 ADD A,A       ;
 $7AA5 ADD A,$5C     ;
 $7AA7 LD L,A        ; }
 $7AA8 LD B,$03      ; B = 3 rows
*$7AAA LD (HL),$44   ; {Fill 3 cells per row with attribute $44
 $7AAC INC HL        ;
 $7AAD LD (HL),$44   ;
 $7AAF INC HL        ;
 $7AB0 LD (HL),$44   ;
 $7AB2 ADD HL,DE     ;
 $7AB3 DJNZ $7AAA    ; }
 $7AB5 RET           ;

