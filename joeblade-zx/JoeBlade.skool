 $9330 CP (HL)       ;
 $9331 JR NZ,$934C   ; }
 $9333 LD A,($820C)  ; {$820C bits4-5: pick which edge to check
 $9336 AND $30       ; }
 $9338 JR NZ,$9343   ;
 $933A LD A,($8201)  ; get Joe X
 $933D CP $20        ;
 $933F JP Z,$9350    ;
 $9342 RET           ;
*$9343 LD A,($8201)  ; get Joe X
 $9346 CP $C0        ;
 $9348 JP Z,$9350    ;
 $934B RET           ;
*$934C INC HL        ;
 $934D DJNZ $932D    ;
 $934F RET           ;
; Pickup the food
@label=PickupFood
*$9350 LD (HL),$FF   ; Mark tile visited ($FF)
 $9352 CALL $8C00    ; Build room background into shadow buffer $B800
 $9355 LD C,$03      ;
 $9357 CALL $86C0    ; Show pickup message popup
 $935A CALL $9456    ; Refill energy gauge
 $935D RET           ;

; "YOU ARE DEAD" message and finalize the game
;
; Used by the routines at #R$93A0 and #R$9650.
;
; .
;
; Called from #R$93A0 once the energy gauge is fully depleted. Draws a black
; popup box and the "YOU ARE DEAD" message, polls the main menu state and waits
; for all keys released, then falls into #R$8EB4 (post-game hub - menu or
; high-score entry).
@label=JoeDead
c$935E POP BC        ;
 $935F CALL $923C    ; Draw black box on the screen
 $9362 LD IX,$9382   ; '  YOU ARE DEAD'
 $9366 LD HL,$4868   ; HL = screen row 11 col 8
 $9369 CALL $9196    ; Draw string IX
 $936C CALL $8A09    ; Poll main menu state
 $936F CALL $91FA    ; Wait until every key on the keyboard is released
 $9372 NOP           ;
 $9373 NOP           ;
 $9374 JP $8EB4      ; => Post-game hub

; Data block at 9377
b$9377 DEFB $00,$00,$00,$00,$00,$00,$00,$00
 $937F DEFB $00,$00,$00
 $9382 DEFB $1F,$1F,$18,$0E,$14,$1F,$00,$11 ; {'  YOU ARE DEAD'
 $938A DEFB $04,$1F,$03,$04,$00,$03         ; }
 $9390 DEFB $FF
 $9391 DEFB $00,$00,$00,$00,$00

; Set Joe's screen address HL and sprite mask DE
;
; Used by the routine at #R$80A0.
;
; .
;
; DE = mask addr, HL = destination addr
@label=SetJoeAddrMask
c$9396 LD ($8221),HL ;
 $9399 LD ($8223),DE ; set current Joe sprite mask address
 $939D RET           ;

; Unused
s$939E DEFS $02

; Reduce energy
;
; Used by the routine at #R$7CF7.
;
; .
;
; Called whenever contact damage is due (e.g. #R$93DC). Decrements one segment
; of the 18-byte energy-gauge array ($A228+), rippling the borrow into earlier
; segments as each one empties ($FF wraps to $00, decrement continues into the
; previous segment). Redraws the gauge via #R$FFB5, then falls into #R$935E
; ("YOU ARE DEAD") once the gauge byte at $A228 itself reaches 0.
@label=ReduceEnergy
c$93A0 LD HL,$A239   ; Energy gauge tail
 $93A3 LD B,$12      ; B = $12
*$93A5 DEC (HL)      ; {Deplete one gauge segment, carry borrow to next
 $93A6 LD A,(HL)     ;
 $93A7 CP $FF        ;
 $93A9 JR NZ,$93B0   ;
 $93AB LD (HL),$00   ;
 $93AD DEC HL        ;
 $93AE DJNZ $93A5    ; }
*$93B0 LD IX,$A228   ; Glyph string
 $93B4 LD HL,$50A1   ; Screen row 21 col 1
 $93B7 CALL $FFB5    ; Draw a string of 8x8 glyphs
 $93BA LD A,($A228)  ;
 $93BD OR A          ;
 $93BE JP Z,$935E    ; => "YOU ARE DEAD" message and finalize the game
 $93C1 RET           ;

; Data block at 93C2
b$93C2 DEFB $00,$00,$00,$00,$19,$19,$19,$19
 $93CA DEFB $19,$EB,$E1,$CD,$4C,$94,$00,$21
 $93D2 DEFB $05,$82,$34,$7E,$FE,$40,$CA,$5E
 $93DA DEFB $93,$C9

; Contact check: Joe sprite vs screen pixels -> reduce energy
;
; Used by the routine at #R$8F00.
;
; .
;
; Compares Joe's sprite bytes ($8221/$8223) against what's already on the live
; screen (NOT mask AND screen byte) row by row, 29 scanlines (standard Spectrum
; row-advance with wraparound). Any mismatch means a solid pixel (e.g. the
; just-drawn soldier) sits under Joe's own sprite -> #R$7CF7 (reduce energy).
; Called once per frame right after DrawJoe/DrawSoldier - pixel-perfect touch
; detection, not a coordinate-box test.
@label=CheckContact
c$93DC LD HL,($8221) ;
 $93DF LD DE,($8223) ; get current Joe sprite mask address
 $93E3 CALL $9446    ; B = D - 4
 $93E6 LD C,E        ; now BC = Joe sprite addr, DE = mask addr, HL = screen
                     ; addr
 $93E7 LD A,$1D      ;
*$93E9 EX AF,AF'     ;
 $93EA LD A,(DE)     ;
 $93EB CPL           ;
 $93EC AND (HL)      ;
 $93ED LD E,A        ;
 $93EE LD A,(BC)     ;
 $93EF CP E          ;
 $93F0 JP NZ,$7CF7   ; => Reduce energy, if allowed
 $93F3 INC BC        ; {Row1: advance sprite/screen pointers
 $93F4 LD E,C        ;
 $93F5 INC HL        ; }
 $93F6 LD A,(DE)     ;
 $93F7 CPL           ;
 $93F8 AND (HL)      ;
 $93F9 LD E,A        ;
 $93FA LD A,(BC)     ;
 $93FB CP E          ;
 $93FC JP NZ,$7CF7   ; => Reduce energy, if allowed
 $93FF INC BC        ;
 $9400 LD E,C        ;
 $9401 INC HL        ;
 $9402 LD A,(DE)     ;
 $9403 CPL           ;
 $9404 AND (HL)      ;
 $9405 LD E,A        ;
 $9406 LD A,(BC)     ;
 $9407 CP E          ;
 $9408 JP NZ,$7CF7   ; => Reduce energy, if allowed
 $940B INC BC        ; {Row2: advance sprite/screen pointers
 $940C LD E,C        ;
 $940D INC HL        ; }
 $940E LD A,(DE)     ;
 $940F CPL           ;
 $9410 AND (HL)      ;
 $9411 LD E,A        ;
 $9412 LD A,(BC)     ;
 $9413 CP E          ;
 $9414 JP NZ,$7CF7   ; => Reduce energy, if allowed
 $9417 INC BC        ; {Row3 done: advance pointers, bump column
 $9418 LD E,C        ;
 $9419 INC HL        ;
 $941A INC H         ; }
 $941B NOP           ; {Unused padding (NOP + 4x DEC HL)
 $941C DEC HL        ;
 $941D DEC HL        ;
 $941E DEC HL        ;
 $941F DEC HL        ; }
 $9420 NOP           ; {Unused padding (8x NOP)
 $9421 NOP           ;
 $9422 NOP           ;
 $9423 NOP           ;
 $9424 NOP           ;
 $9425 NOP           ;
 $9426 NOP           ;
 $9427 NOP           ; }
 $9428 LD A,H        ; {Row wrapped past 8 lines? advance to next block
 $9429 AND $07       ;
 $942B JR NZ,$943D   ; }
 $942D LD A,H        ;
 $942E SUB $08       ;
 $9430 LD H,A        ;
 $9431 LD A,L        ;
 $9432 ADD A,$20     ;
 $9434 LD L,A        ;
 $9435 AND $E0       ;
 $9437 JR NZ,$943D   ;
 $9439 LD A,H        ;
 $943A ADD A,$08     ;
 $943C LD H,A        ;
*$943D EX AF,AF'     ;
 $943E DEC A         ;
 $943F JR NZ,$93E9   ;
 $9441 RET           ;

; Unused
s$9442 DEFS $04

; B = D - 4
;
; Used by the routine at #R$93DC.
c$9446 LD B,D        ;
 $9447 DEC B         ;
 $9448 DEC B         ;
 $9449 DEC B         ;
 $944A DEC B         ;
 $944B RET           ;

; Data block at 944C
b$944C DEFB $06,$08,$1A,$77,$13,$23,$10,$FA
 $9454 DEFB $C9,$00

; Refill energy gauge (food pickup effect)
;
; Used by the routine at #R$9328.
;
; .
;
; Calls #R$A23C to refill the energy gauge $A228-$A239 back to full, then
; clears $8205.
@label=ConsumeFood
