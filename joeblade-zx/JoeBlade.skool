; Key-gated door: consume a key to open, or block the UP input
;
; Used by the routine at #R$FFE8.
;
; .
;
; Called (via #R$FFE8) whenever Joe isn't mid-jump ($8209=0) and the current
; tile has an up-door flag set in $820C (bit4=left side, bit2=right side). If
; Joe is standing at that door's screen edge with UP pressed: with keys in
; stock ($8215), consumes one and redraws the key-count digit (#R$925C); with
; none, clears the UP bit in $820A before #R$7E32 processes it - blocking the
; level transition outright. Confirms $8215's "key" role extends beyond a
; simple pickup counter: keys are also the toll for certain doors. Left-edge
; and right-edge halves are otherwise identical.
@label=KeyDoorGate
c$9880 LD A,($820A)  ; {UP pressed?
 $9883 AND $08       ;
 $9885 JR Z,$98B4    ; }
 $9887 LD A,($8201)  ; {Joe at left edge (X&$E0=$20)?
 $988A ADD A,$10     ;
 $988C AND $E0       ;
 $988E CP $20        ;
 $9890 JR NZ,$98B4   ; }
 $9892 LD A,($820C)  ; {$820C bit4 (up-door-left) set?
 $9895 AND $10       ;
 $9897 JR Z,$98B4    ; }
 $9899 LD A,($8215)  ; {Have keys ($8215)?
 $989C OR A          ;
 $989D JR NZ,$98A9   ; }
 $989F LD A,($820A)  ; get input state
 $98A2 AND $F7       ;
 $98A4 LD ($820A),A  ; set input state
 $98A7 JR $98B4      ;
; Open left-side door: decrement $8215, redraw digit
*$98A9 LD HL,$8215   ; {Decrement $8215
 $98AC DEC (HL)      ;
 $98AD LD C,(HL)     ; }
 $98AE LD HL,$50BE   ; {Redraw digit, screen row 21 col 30
 $98B1 JP $925C      ; }
*$98B4 LD A,($820A)  ; get input state
 $98B7 AND $08       ;
 $98B9 RET Z         ;
 $98BA LD A,($8201)  ; get Joe X
 $98BD ADD A,$10     ;
 $98BF AND $E0       ;
 $98C1 CP $C0        ;
 $98C3 RET NZ        ;
 $98C4 LD A,($820C)  ; {$820C bit2 (up-door-right) set?
 $98C7 AND $04       ;
 $98C9 RET Z         ; }
 $98CA LD A,($8215)  ; {Have keys ($8215)?
 $98CD OR A          ;
 $98CE JR NZ,$98DA   ; }
 $98D0 LD A,($820A)  ; get input state
 $98D3 AND $F7       ;
 $98D5 LD ($820A),A  ; set input state
 $98D8 RET           ;
 $98D9 NOP           ;
; Open right-side door: decrement $8215, redraw digit
*$98DA LD HL,$8215   ;
 $98DD DEC (HL)      ;
 $98DE LD C,(HL)     ;
 $98DF LD HL,$50BE   ; HL = screen row 21 col 30
 $98E2 JP $925C      ; => Draw one digit/character glyph

