s$945F DEFS $05

; Soldier pattern 2: synchronized left-right patrol (group A)
;
; Used by the routine at #R$96CC.
;
; .
;
; Byte-identical to #R$8164 but uses $8213 as the shared direction step instead
; of $8212 - a second, independent synchronized patrol group.
@label=SoldierPattern2
c$9464 LD A,($8213)   ; {X += $8213 (shared step)
 $9467 ADD A,(IX+$01) ;
 $946A LD (IX+$01),A  ; }
 $946D CP $02         ; {Hit X=2 or $E6?
 $946F JR Z,$9475     ;
 $9471 CP $E6         ;
 $9473 JR NZ,$947D    ; }
*$9475 LD A,($8213)   ; {Flip $8213's sign
 $9478 XOR $FE        ;
 $947A LD ($8213),A   ; }
*$947D LD C,(IX+$01)  ; C = soldier X
 $9480 LD A,($8213)   ; {Pick sprite by $8213 sign, continue at #R$9028
 $9483 AND $80        ;
 $9485 JR NZ,$948D    ; }
 $9487 LD DE,$AA00    ;
 $948A JP $9028       ;
*$948D LD DE,$A800    ;
 $9490 JP $9028       ;

; Data block at 9493
b$9493 DEFB $B2,$C3,$28,$90,$00

; Set initial values
;
; Used by the routine at #R$7D00.
;
; .
;
; Also rotates the item-placement scratch table #R$9D80 by 5 bytes in place
; (backs up 5 bytes to $9DE4, shifts the rest down, copies the result into
; #R$9D00) - live-confirmed deterministic, no RNG: repeated "Start Game"
; presses within one power-on session drift the item layout further each time,
; but a cold restart always reproduces the same starting phase (see
; docs/Actors.md).
@label=SetInitialValues
c$9498 LD BC,$0028   ;
 $949B LD HL,$8228   ;
 $949E LD DE,$8200   ;
 $94A1 LDIR          ; set variables initial values
 $94A3 NOP           ;
 $94A4 LD BC,$0005   ; BC = 5 (rotate amount)
 $94A7 LD HL,$9D80   ; {HL=#R$9D80, DE=$9DE4 (backup src/dst)
 $94AA LD DE,$9DE4   ; }
 $94AD LDIR          ; => backup first 5 bytes of #R$9D80
 $94AF CALL $8A06    ; Poll main menu state
 $94B2 LD DE,$9D80   ; {DE=#R$9D80, HL=$9D85, BC=$69 (shift setup)
 $94B5 LD HL,$9D85   ;
 $94B8 LD BC,$0069   ; }
 $94BB LDIR          ; => shift remaining 105 bytes down by 5
 $94BD CALL $A23C    ; Energy gauge initial fill
 $94C0 LD BC,$0080   ; {BC=$80, HL=#R$9D80, DE=#R$9D00 (final copy setup)
 $94C3 LD HL,$9D80   ;
 $94C6 LD DE,$9D00   ; }
 $94C9 LDIR          ; => copy rotated buffer into #R$9D00
 $94CB LD DE,$8950   ;
 $94CE LD HL,$FDBE   ;
 $94D1 LD BC,$0010   ;
 $94D4 LDIR          ;
 $94D6 NOP           ;
 $94D7 NOP           ;
 $94D8 LD HL,$85F9   ;
 $94DB LD (HL),$FF   ;
 $94DD INC HL        ;
 $94DE LD (HL),$22   ; {"20" -> #R$85FA/$85B
 $94E0 INC HL        ;
 $94E1 LD (HL),$20   ;
 $94E3 INC HL        ; }
 $94E4 LD (HL),$1D   ; ":"
 $94E6 INC HL        ;
 $94E7 LD (HL),$20   ; {"00"
 $94E9 INC HL        ;
 $94EA LD (HL),$20   ;
 $94EC INC HL        ; }
 $94ED LD (HL),$FF   ;
 $94EF NOP           ;
 $94F0 LD A,($FFFF)  ;
 $94F3 LD ($820E),A  ;
 $94F6 NOP           ;
 $94F7 NOP           ;
 $94F8 NOP           ;
 $94F9 NOP           ;
 $94FA NOP           ;
 $94FB NOP           ;
 $94FC NOP           ;
 $94FD NOP           ;
 $94FE NOP           ;
 $94FF RET           ;

; Per-room event/object flags, indexed by $8202
;
; .
;
; .
;
; One byte per room-tile ($8202, 0-127). Read by #R$9602 each frame; each bit
; conditionally draws a door/object graphic (see #R$9602 for the bit map).
b$9500 DEFB $00,$00,$08,$20,$08,$08,$00,$00
 $9508 DEFB $00,$00,$00,$00,$00,$00,$00,$00
 $9510 DEFB $00,$00,$00,$00,$00,$00,$00,$00
 $9518 DEFB $00,$00,$20,$20,$00,$00,$00,$00
 $9520 DEFB $00,$00,$00,$00,$00,$00,$00,$00
 $9528 DEFB $00,$08,$04,$30,$24,$00,$00,$00
 $9530 DEFB $00,$20,$00,$00,$00,$00,$00,$00
 $9538 DEFB $00,$00,$00,$00,$00,$00,$00,$00
 $9540 DEFB $20,$00,$00,$00,$00,$20,$00,$00
 $9548 DEFB $00,$20,$08,$10,$00,$00,$00,$00
 $9550 DEFB $08,$04,$00,$08,$04,$00,$00,$20
 $9558 DEFB $10,$08,$08,$00,$00,$00,$00,$00
 $9560 DEFB $20,$00,$08,$10,$00,$00,$00,$00
 $9568 DEFB $20,$20,$00,$00,$00,$00,$00,$00
 $9570 DEFB $30,$08,$00,$00,$20,$00,$00,$00
 $9578 DEFB $08,$04,$00,$00,$00,$00,$00,$00

; High-score name entry: cursor loop
;
; Used by the routine at #R$8EB4.
;
; .
;
; Repurposes $8201 as the cursor column and $8202 as the selected character for
; entering initials into a new high-score row. Up/down cycles the character
; (#R$8964 stores it), left/right likely moves the cursor (unconfirmed in
; detail) - reached from #R$8EB4 when $8210=5.
@label=HiScoreNameEntry
c$9580 LD A,$00      ;
 $9582 LD ($8201),A  ; set Joe X
 $9585 LD ($8202),A  ; set current room-tile index = room + 8*subtile
*$9588 CALL $8032    ; Read input into $820A
 $958B LD A,($820A)  ; get input state
 $958E AND $10       ;
 $9590 JR Z,$959F    ;
 $9592 CALL $8964    ; High-score name entry
 $9595 LD HL,$8201   ;
 $9598 INC (HL)      ;
 $9599 LD A,(HL)     ;
 $959A CP $05        ;
 $959C JP Z,$8DBE    ; => High scores screen
*$959F LD A,($820A)  ; get input state
 $95A2 AND $01       ;
 $95A4 JR Z,$95B1    ;
 $95A6 LD HL,$8202   ;
 $95A9 INC (HL)      ;
 $95AA LD A,(HL)     ;
 $95AB CP $1B        ;
 $95AD JR NZ,$95B1   ;
 $95AF LD (HL),$00   ;
*$95B1 LD A,($820A)  ; get input state
 $95B4 AND $02       ;
 $95B6 JR Z,$95C3    ;
 $95B8 LD HL,$8202   ;
 $95BB DEC (HL)      ;
 $95BC LD A,(HL)     ;
 $95BD CP $FF        ;
 $95BF JR NZ,$95C3   ;
 $95C1 LD (HL),$1A   ;
*$95C3 LD HL,$8202   ;
 $95C6 LD C,(HL)     ;
 $95C7 DEC HL        ;
 $95C8 LD A,(HL)     ;
 $95C9 LD H,$48      ;
 $95CB ADD A,$71     ;
 $95CD LD L,A        ;
 $95CE LD D,$A6      ;
 $95D0 LD A,($8202)  ; get current room-tile index = room + 8*subtile
 $95D3 CALL $925F    ;
 $95D6 LD BC,$3200   ;
*$95D9 DEC BC        ;
 $95DA LD A,B        ;
 $95DB OR C          ;
 $95DC JR NZ,$95D9   ;
 $95DE JP $9588      ;

; Unused
s$95E1 DEFS $05

; Draw door graphic column 3 (animated, via $8206)
;
; Used by the routine at #R$9602.
;
; .
;
; Same pattern as #R$90AA/#R$85DC (the 3rd of #R$9602's door-graphic columns):
; animation frame from $8206, source table at #R$8600+, drawn at $B88C/$B898.
c$95E6 LD A,($8206)  ; {HL = #R$8600 + frame*16 (animation source)
 $95E9 AND $06       ;
 $95EB RLCA          ;
 $95EC RLCA          ;
 $95ED RLCA          ;
 $95EE RLCA          ;
 $95EF LD L,A        ;
 $95F0 LD H,$86      ; }
 $95F2 PUSH HL       ;
 $95F3 EX DE,HL      ;
 $95F4 LD HL,$B88C   ;
 $95F7 CALL $90C8    ; Copy an 8x4-byte column (DE->HL), used by the
                     ; door-drawing routines
 $95FA LD HL,$B898   ;
 $95FD POP DE        ;
 $95FE JP $90C8      ; => Copy an 8x4-byte column (DE->HL), used by the
                     ; door-drawing routines

; Unused
s$9601 DEFS $01

; Draw per-room door/object graphics from event-flags table
;
; Used by the routine at #R$8F00.
;
; .
;
; Draws animated door/object graphics for the current room-tile (not
; room-transition code - that lives in #R$7E32/#R$7F6E/#R$7FA0). IX = #R$9500 +
; $8202 (the current room-tile's event-flags byte). Bits 0,1,6,7 are NOPed out
; in this build (disabled/unused). Bits 2,3,4 each draw a different column of a
; door graphic (#R$90AA, #R$85DC, #R$95E6 - all index the same per-frame
; animation table at #R$8600+ via counter $8206, just at different destination
; columns in the shadow buffer: $B884/$B890, $B888/$B894, $B88C/$B898). Bit 5
; (#R$FFE8) is gated on $8209==0 and leads into #R$9880: a key-gated door check
; - marks this tile as requiring a key to open.
@label=DrawDoor
c$9602 LD A,($8202)  ; {IX = #R$9500 + $8202 (this room's event-flags byte)
 $9605 LD L,A        ;
 $9606 LD H,$95      ; }
 $9608 PUSH HL       ;
 $9609 POP IX        ;
 $960B LD A,(IX+$00) ; {Bit0: unused (NOPed out)
 $960E AND $01       ; }
 $9610 NOP           ;
 $9611 NOP           ;
 $9612 NOP           ;
 $9613 LD A,(IX+$00) ; {Bit1: unused (NOPed out)
 $9616 AND $02       ; }
 $9618 NOP           ;
 $9619 NOP           ;
 $961A NOP           ;
 $961B LD A,(IX+$00) ; {Bit2: draw door column 1 (#R$90AA)
 $961E AND $04       ;
 $9620 CALL NZ,$90AA ; }
 $9623 LD A,(IX+$00) ; {Bit3: draw door column 2 (#R$85DC)
 $9626 AND $08       ;
 $9628 CALL NZ,$85DC ; }
 $962B LD A,(IX+$00) ; {Bit4: draw door column 3 (#R$95E6)
 $962E AND $10       ;
 $9630 CALL NZ,$95E6 ; }
 $9633 LD A,(IX+$00) ; {Bit5: key-gated door check (#R$FFE8)
 $9636 AND $20       ;
 $9638 CALL NZ,$FFE8 ; }
 $963B LD A,(IX+$00) ; {Bit6: unused (NOPed out)
 $963E AND $40       ; }
 $9640 NOP           ;
 $9641 NOP           ;
 $9642 NOP           ;
 $9643 LD A,(IX+$00) ; {Bit7: unused (NOPed out)
 $9646 AND $80       ; }
 $9648 NOP           ;
 $9649 NOP           ;
 $964A NOP           ;
 $964B RET           ;

; Unused
s$964C DEFS $04

; Countdown timer tick, MM:SS-style display at $85FA
;
; Used by the routine at #R$8F00.
;
; .
;
; Called every frame from #R$8F00. No-op while the gate byte $85F9 is $FF (see
; #R$92DE, which releases it on first bomb contact). Otherwise decrements $85F9
; each frame, and once it wraps past 0 (every 25 frames), decrements the
; "MM:SS"-style digit string at $85FA-$85FE (seconds ones, seconds tens with a
; 0-5 wrap, minutes with a 0-1 wrap), redrawing it via #R$9196 unless it's
; already at "00:00".
@label=CountdownTick
c$9650 LD HL,$85F9   ;
 $9653 LD A,(HL)     ;
 $9654 CP $FF        ;
 $9656 RET Z         ;
 $9657 INC (HL)      ;
 $9658 LD A,(HL)     ;
 $9659 CP $19        ;
 $965B RET C         ;
 $965C LD (HL),$00   ;
 $965E LD HL,$85FE   ;
 $9661 DEC (HL)      ;
 $9662 LD A,(HL)     ;
 $9663 CP $1F        ;
 $9665 JR NZ,$967E   ;
 $9667 LD (HL),$29   ;
 $9669 DEC HL        ;
 $966A DEC (HL)      ;
 $966B LD A,(HL)     ;
 $966C CP $1F        ;
 $966E JR NZ,$967E   ;
 $9670 LD (HL),$25   ;
 $9672 DEC HL        ;
 $9673 DEC HL        ;
 $9674 DEC (HL)      ;
