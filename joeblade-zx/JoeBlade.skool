; Detect collectible tile under Joe, draw its icon
;
; Used by the routine at #R$8114.
;
; .
;
; Scans the same 4 tile-ID tables used by #R$926E/#R$92A0/#R$9300/#R$9328 for a
; match against the current tile ($8202): #R$9D00 (15 entries, keys), $9D0F (6
; entries, food), $9D18 (6 entries, bombs - also checked by #R$8D3C's
; bomb-minigame trigger), $9D24 (6 entries, hostages). On a match, sets up the
; item's sprite/mask data and draws it via #R$9118. No match in any table ->
; falls through to #R$A2F6, which checks ammo ($9D20) and uniform ($9D2B - see
; #R$A328/#R$7B1E).
@label=DetectItem
c$912C LD HL,$9D00   ;
 $912F LD DE,$9A80   ;
 $9132 LD B,$0F      ;
*$9134 LD A,($8202)  ; get current room-tile index = room + 8*subtile
 $9137 CP (HL)       ;
 $9138 JR NZ,$9140   ;
 $913A LD B,D        ;
 $913B LD C,$00      ;
 $913D JP $9118      ; => Draw a collectible-item sprite, left or right variant
*$9140 INC HL        ;
 $9141 DJNZ $9134    ;
 $9143 NOP           ;
 $9144 LD HL,$9D0F   ;
 $9147 LD DE,$9B80   ;
 $914A LD B,$06      ;
*$914C LD A,($8202)  ; get current room-tile index = room + 8*subtile
 $914F CP (HL)       ;
 $9150 JR NZ,$9158   ;
 $9152 LD B,D        ;
 $9153 LD C,$00      ;
 $9155 JP $9118      ; => Draw a collectible-item sprite, left or right variant
*$9158 INC HL        ;
 $9159 DJNZ $914C    ;
 $915B LD HL,$9D18   ;
 $915E LD DE,$9980   ;
 $9161 LD B,$06      ;
*$9163 LD A,($8202)  ; get current room-tile index = room + 8*subtile
 $9166 LD C,A        ;
 $9167 LD A,(HL)     ;
 $9168 AND $7F       ;
 $916A CP C          ;
 $916B JR NZ,$9173   ;
 $916D LD B,D        ;
 $916E LD C,$00      ;
 $9170 JP $9118      ; => Draw a collectible-item sprite, left or right variant
*$9173 INC HL        ;
 $9174 DJNZ $9163    ;
 $9176 NOP           ;
 $9177 LD HL,$9D24   ;
 $917A LD DE,$9C80   ;
 $917D LD B,$06      ;
*$917F LD A,($8202)  ; get current room-tile index = room + 8*subtile
 $9182 CP (HL)       ;
 $9183 JR NZ,$918B   ;
 $9185 LD B,D        ;
 $9186 LD C,$00      ;
 $9188 JP $9118      ; => Draw a collectible-item sprite, left or right variant
*$918B INC HL        ;
 $918C DJNZ $917F    ;
 $918E JP $A2F6      ; => Detect ammo or uniform tile under Joe, draw its icon

