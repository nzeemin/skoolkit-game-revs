 $9247 LD B,$14      ; B = $14 (20)
*$9249 LD (HL),$00   ; {Clear a byte strip
 $924B INC HL        ;
 $924C DJNZ $9249    ; }
 $924E POP HL        ;
 $924F POP BC        ;
 $9250 INC H         ;
 $9251 DJNZ $9245    ;
 $9253 POP HL        ;
 $9254 LD BC,$0020   ;
 $9257 ADD HL,BC     ;
 $9258 POP BC        ;
 $9259 DJNZ $9241    ;
