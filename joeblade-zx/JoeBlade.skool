; Hostage pickup: check $9D24 tile at screen edge
;
; Used by the routine at #R$A3BA.
;
; .
;
; Scans the 6-entry hostage tile table $9D24; on a match, checks $820C bits4-5
; to pick which screen edge to test Joe's X against ($20 or $C0), and if Joe is
; there, collects it via #R$86E4.
@label=CheckHostage
c$926E LD HL,$9D24   ; Hostage tile table
 $9271 LD B,$06      ; B = 6
*$9273 LD A,($8202)  ; {Compare current tile ($8202) against table entry
 $9276 CP (HL)       ;
 $9277 JR NZ,$9292   ; }
 $9279 LD A,($820C)  ; {$820C bits4-5: pick which edge to check
 $927C AND $30       ; }
 $927E JR NZ,$9289   ;
 $9280 LD A,($8201)  ; get Joe X
 $9283 CP $20        ;
 $9285 JP Z,$86E4    ; => Collect a hostage tile
 $9288 RET           ;
*$9289 LD A,($8201)  ; get Joe X
 $928C CP $C0        ;
 $928E JP Z,$86E4    ; => Collect a hostage tile
 $9291 RET           ;
*$9292 INC HL        ;
 $9293 DJNZ $9273    ;
 $9295 RET           ;

