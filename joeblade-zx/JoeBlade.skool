; Draw Joe sprite 32x32 with mask
;
; Used by the routine at #R$80A0.
;
; .
;
; BC = sprite addr, DE = mask addr, HL = destination
@label=DrawJoeSprite
c$8D6E LD A,$20      ; {A = $20 (loop counter, 32 rows)
*$8D70 PUSH AF       ; }
 $8D71 LD A,(DE)     ; 0: get mask byte
 $8D72 AND (HL)      ; apply mask
 $8D73 LD (HL),A     ;
 $8D74 LD A,(BC)     ; get pixels byte
 $8D75 OR (HL)       ; apply pixels
 $8D76 LD (HL),A     ;
 $8D77 INC BC        ;
 $8D78 INC DE        ;
 $8D79 INC HL        ;
 $8D7A LD A,(DE)     ; 1
 $8D7B AND (HL)      ;
 $8D7C LD (HL),A     ;
 $8D7D LD A,(BC)     ;
 $8D7E OR (HL)       ;
 $8D7F LD (HL),A     ;
 $8D80 INC BC        ;
 $8D81 INC DE        ;
 $8D82 INC HL        ;
 $8D83 LD A,(DE)     ; 2
 $8D84 AND (HL)      ;
 $8D85 LD (HL),A     ;
 $8D86 LD A,(BC)     ;
 $8D87 OR (HL)       ;
 $8D88 LD (HL),A     ;
 $8D89 INC BC        ;
 $8D8A INC DE        ;
 $8D8B INC HL        ;
 $8D8C LD A,(DE)     ; 3
 $8D8D AND (HL)      ;
 $8D8E LD (HL),A     ;
 $8D8F LD A,(BC)     ;
 $8D90 OR (HL)       ;
 $8D91 LD (HL),A     ;
 $8D92 INC BC        ;
 $8D93 INC DE        ;
 $8D94 NOP           ; {Advance to next screen row
 $8D95 NOP           ;
 $8D96 DEC HL        ;
 $8D97 DEC HL        ;
 $8D98 DEC HL        ;
 $8D99 INC H         ; }
 $8D9A LD A,H        ; {Row wrapped past 8 lines?
 $8D9B AND $07       ;
 $8D9D JR NZ,$8DAF   ; }
 $8D9F LD A,H        ;
 $8DA0 SUB $08       ;
 $8DA2 LD H,A        ;
 $8DA3 LD A,L        ;
 $8DA4 ADD A,$20     ;
 $8DA6 LD L,A        ;
 $8DA7 AND $E0       ;
 $8DA9 JR NZ,$8DAF   ;
 $8DAB LD A,H        ;
 $8DAC ADD A,$08     ;
 $8DAE LD H,A        ;
*$8DAF POP AF        ;
 $8DB0 DEC A         ;
 $8DB1 JR NZ,$8D70   ;
 $8DB3 RET           ;

