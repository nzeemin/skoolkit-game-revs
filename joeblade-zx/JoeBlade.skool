; Draw string IX
;
; Used by the routines at #R$7800, #R$7B1E, #R$7BE8, #R$7D00, #R$8546, #R$8596,
; #R$86C0, #R$89B4, #R$8BB4, #R$8DBE, #R$8E16, #R$8EB4, #R$935E, #R$9650,
; #R$A328, #R$A7DC and #R$FEB4.
;
; .
;
; IX = string address ($FF-terminated char codes), HL = screen address. Draws
; one 8x8 glyph per call and re-enters itself (via #R$91BE) for the next
; character until it hits the $FF terminator - the game's general-purpose
; text-drawing primitive, used throughout menus, HUD counters, and message
; screens.
@label=DrawStringIX
c$9196 LD C,(IX+$00) ; {C = char code (IX+0)
 $9199 LD A,(IX+$00) ;
 $919C INC IX        ; }
 $919E CP $FF        ; {Terminate at $FF
 $91A0 RET Z         ; }
 $91A1 LD A,C        ; {Decode char row (D = $A6 + code>>5)
 $91A2 AND $E0       ;
 $91A4 RRA           ;
 $91A5 RRA           ;
 $91A6 RRA           ;
 $91A7 RRA           ;
 $91A8 RRA           ;
 $91A9 ADD A,$A6     ;
 $91AB LD D,A        ; }
 $91AC LD A,C        ; {Decode char column (E = (code&$1F)*8)
 $91AD AND $1F       ;
 $91AF RLA           ;
 $91B0 RLA           ;
 $91B1 RLA           ;
 $91B2 LD E,A        ; }
 $91B3 LD B,$08      ; B = 8 rows
 $91B5 PUSH HL       ; Save HL
*$91B6 LD A,(DE)     ; read character pixels
 $91B7 LD (HL),A     ; write character pixels
 $91B8 INC H         ; {Advance dest row/source ptr
 $91B9 INC DE        ; }
 $91BA DJNZ $91B6    ; Loop 8
 $91BC POP HL        ; Restore HL
 $91BD INC HL        ; Advance to next char
 $91BE JP $9196      ; => Draw string IX

; Unused
s$91C1 DEFS $07

; Sound effect (descending pitch sweep), used at a room edge
;
; Used by the routine at #R$7F64.
;
; .
;
; Called from #R$7F64 (a jump-arc edge case in #R$7E32). Same border-toggle
; (`OUT ($FE)`) sweep pattern as #R$856E/#R$A2BE, from $3800 down to $28xx.
@label=SFX_roomedge
c$91C8 NOP           ; {HL/E = sweep start/rate
 $91C9 LD HL,$3800   ;
 $91CC LD E,$12      ; }
*$91CE LD A,$10      ;
 $91D0 OUT ($FE),A   ;
 $91D2 LD B,E        ;
*$91D3 DJNZ $91D3    ;
 $91D5 XOR A         ;
 $91D6 OUT ($FE),A   ;
 $91D8 LD B,(HL)     ; {Toggle border, delay
 $91D9 RES 7,B       ;
*$91DB DJNZ $91DB    ; }
 $91DD DEC HL        ; {HL -= 16
 $91DE DEC HL        ;
 $91DF DEC HL        ;
 $91E0 DEC HL        ;
 $91E1 DEC HL        ;
 $91E2 DEC HL        ;
 $91E3 DEC HL        ;
 $91E4 DEC HL        ;
 $91E5 DEC HL        ; }
 $91E6 DEC HL        ;
 $91E7 DEC HL        ;
 $91E8 DEC HL        ;
 $91E9 DEC HL        ;
 $91EA DEC HL        ;
 $91EB DEC HL        ;
 $91EC DEC HL        ;
 $91ED LD A,L        ; {L = 0 ?
 $91EE OR A          ; }
 $91EF JR NZ,$91F3   ; {Wrap column? skip if not, else dec sweep-rate E
 $91F1 NOP           ;
 $91F2 DEC E         ; }
*$91F3 LD A,H        ; {HL reached $28xx? loop or return
 $91F4 CP $28        ;
 $91F6 JR NZ,$91CE   ;
 $91F8 NOP           ;
 $91F9 RET           ; }

; Wait until every key on the keyboard is released
;
; Used by the routines at #R$8DBE, #R$8E16, #R$8EB4, #R$935E and #R$FF14.
;
; .
;
; Reads and ANDs all 8 keyboard half-rows together, returning non-zero only
; when nothing at all is pressed - a full-keyboard version of the single-row
; "no key pressed" checks used elsewhere.
@label=WaitKeyUp
c$91FA LD BC,$FEFE   ; {Read row $FEFE (CAPS,Z-V)
 $91FD IN A,(C)      ; }
 $91FF LD BC,$FDFE   ; {Read row $FDFE (A-G)
 $9202 IN D,(C)      ; }
 $9204 AND D         ;
 $9205 LD BC,$FBFE   ; {Read row $FBFE (Q-T)
 $9208 IN D,(C)      ; }
 $920A AND D         ;
 $920B LD BC,$F7FE   ; {Read row $F7FE (1-5)
 $920E IN D,(C)      ; }
 $9210 AND D         ;
 $9211 LD BC,$EFFE   ; {Read row $EFFE (6-0)
 $9214 IN D,(C)      ; }
 $9216 AND D         ;
 $9217 LD BC,$DFFE   ; {Read row $DFFE (O-Y)
 $921A IN D,(C)      ; }
 $921C AND D         ;
 $921D LD BC,$BFFE   ; {Read row $BFFE (Enter,L-H)
 $9220 IN D,(C)      ; }
 $9222 AND D         ;
 $9223 LD BC,$7FFE   ; {Read row $7FFE (Space,Sym,M-B)
 $9226 IN D,(C)      ; }
 $9228 AND D         ;
 $9229 CPL           ; {Invert and mask result
 $922A AND $1F       ; }
 $922C OR A          ;
 $922D RET           ;

; Unused
s$922E DEFS $0E

