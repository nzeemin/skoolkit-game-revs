; Menu idle: variable-duration border-flash effect
;
; Used by the routine at #R$8A3C.
;
; .
;
; Reached every frame via #R$8A3C once the menu has settled (waiting for 'S').
; Advances the counter $8207 by 2 (wrapping at $FC), reads a (HL,BC) duration
; pair from a table at #R$9F00 indexed by it, and calls #R$8680 to wait that
; long - since #R$8680 flashes the border while waiting, this drives a
; decorative twinkle effect that cycles through a preset sequence of
; wait-durations instead of a fixed rate.
; .
; Reached via #R$8A3C (JP #R$8E96) once the main menu is done.
@label=MenuIdleFlash
c$8E96 LD A,($8207)  ; {Advance $8207
 $8E99 INC A         ;
 $8E9A INC A         ;
 $8E9B LD ($8207),A  ; }
 $8E9E CP $FC        ; Wrap at $FC
 $8EA0 JR NZ,$8EA7   ;
 $8EA2 LD A,$00      ;
 $8EA4 LD ($8207),A  ;
*$8EA7 LD H,$9F      ; #R$9F00 table
 $8EA9 LD L,A        ;
 $8EAA LD C,(HL)     ;
 $8EAB INC L         ;
 $8EAC LD L,(HL)     ;
 $8EAD LD H,$00      ;
 $8EAF LD B,H        ;
 $8EB0 JP $8680      ; => Wait for a key or timeout
 $8EB3 NOP           ;

; Post-game hub: menu, or high-score name entry
;
; Used by the routines at #R$7800, #R$8F00, #R$935E, #R$FEB4 and #R$FF14.
;
; .
;
; Reached after death, winning, or a bomb-minigame timeout
; (#R$7800/#R$8F00/#R$935E/#R$FF14/#R$FEB4). If $8210=5 (no new high score in
; progress), returns straight to the main menu; otherwise shows "GOOD SCORING"
; text, beeps out a status line, waits for all keys released, then drops into
; #R$9580 for high-score name entry.
@label=FinalizeGame
c$8EB4 CALL $83C0    ; Clear screen, border to black
 $8EB7 LD A,($8210)  ;
 $8EBA CP $05        ;
 $8EBC JP Z,$8B37    ; => Main menu loop
 $8EBF LD IX,$85A0   ; 'GOOD SCORING'
 $8EC3 LD HL,$480A   ; HL = screen row 8 col 10
 $8EC6 CALL $9196    ; Draw string IX
 $8EC9 LD HL,$486C   ; HL = screen row 11 col 12
 $8ECC CALL $9196    ; Draw string IX
 $8ECF LD HL,$5022   ; HL = screen row 17 col 2
 $8ED2 CALL $9196    ; Draw string IX
 $8ED5 LD HL,$5909   ;
 $8ED8 LD B,$0E      ;
*$8EDA LD (HL),$57   ;
 $8EDC INC HL        ;
 $8EDD DJNZ $8EDA    ;
 $8EDF CALL $91FA    ; Wait until every key on the keyboard is released
 $8EE2 JR Z,$8EE4    ;
*$8EE4 JP $9580      ; => High-score name entry

