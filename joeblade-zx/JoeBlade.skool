; Jump sound effect, gated on jump counter $820D
;
; Used by the routine at #R$8F00.
;
; .
;
; While Joe is jumping ($820D <> 0), looks up a tone period from the table at
; $8000+ (indexed by $820D) and toggles the border 3 times at that pitch.
@label=SFX_jump
c$A750 LD A,($820D)  ; {Check jump counter $820D
 $A753 OR A          ; }
 $A754 RET Z         ; Return if not jumping
 $A755 LD L,A        ; {Look up tone period from table at $8000
 $A756 LD H,$80      ;
 $A758 LD A,(HL)     ;
 $A759 AND $1C       ;
 $A75B RRCA          ;
 $A75C ADD A,$0A     ; }
 $A75E NOP           ; {D = tone period
 $A75F LD D,A        ; }
 $A760 LD E,$03      ; E = 3 (repeat count)
*$A762 LD A,$10      ;
 $A764 OUT ($FE),A   ;
 $A766 LD B,$0E      ;
*$A768 DJNZ $A768    ;
 $A76A ADD A,$10     ;
 $A76C OUT ($FE),A   ;
 $A76E LD B,D        ;
*$A76F DJNZ $A76F    ;
 $A771 DEC E         ;
 $A772 JR NZ,$A762   ;
 $A774 RET           ;

; Data block at A775
b$A775 DEFB $00,$00,$00,$00,$00,$7F,$FE

; Fast-forward the rolling-digit counter (score tally animation)
;
; Used by the routine at #R$FEB4.
;
; .
;
; Sets the pending-tick countdown $820F to $FA (250) and runs #R$850E 250 times
; in a tight loop, instead of once per frame - forces the counter to roll all
; the way up immediately. Called 40 times in a row by #R$FEB4's win screen,
; giving a rapid score-tally-up effect.
@label=ScoreCountFast
c$A77C LD A,$FA      ; {$820F = $FA (250 ticks)
 $A77E LD ($820F),A  ; }
*$A781 PUSH AF       ;
 $A782 CALL $850E    ; Rolling-digit counter increment
 $A785 POP AF        ;
 $A786 DEC A         ; {Loop until A (tick count) reaches 0
 $A787 JR NZ,$A781   ; }
 $A789 RET           ;

; Delay
;
; Used by the routines at #R$9296 and #R$A7DC.
@label=Delay
c$A78A LD HL,$8000   ;
*$A78D LD B,$0A      ;
*$A78F DJNZ $A78F    ;
 $A791 DEC HL        ;
 $A792 LD A,H        ;
 $A793 OR L          ;
 $A794 JR NZ,$A78D   ;
 $A796 RET           ;

; Unused
s$A797 DEFS $01

; Shoot: fire button consumes one round of ammo ($8225)
;
; Used by the routine at #R$8F5A.
;
; .
;
; Checked from #R$8F5A (called from #R$8E64). If fire is pressed ($820A bit4)
; and $8225 (ammo count) is non-zero, consumes one round, calls #R$FFF0 and
; #R$7869 (soldier hit/reaction logic), then sets $8226 based on Joe's X
; relative to a #R$9700-table entry for the current tile (bullet
; range/collision against the current room?). Out of ammo -> #R$A7DC (draw an
; "out of ammo" message, #R$A7EC).
@label=Shoot
c$A798 LD A,($820A)  ; {Check fire button ($820A bit4)
 $A79B AND $10       ; }
 $A79D RET Z         ;
 $A79E LD A,($8225)  ; {$8225 (ammo count): none left -> #R$A7DC
 $A7A1 OR A          ;
 $A7A2 JR Z,$A7DC    ; }
 $A7A4 DEC A         ; {Consume one round
 $A7A5 LD ($8225),A  ; }
 $A7A8 CALL $FFF0    ; Play gunshot sound effect
 $A7AB CALL $7869    ; Shot hit check
 $A7AE LD H,$97      ;
 $A7B0 LD A,($8202)  ; get current room-tile index = room + 8*subtile
 $A7B3 RLCA          ;
 $A7B4 LD L,A        ;
 $A7B5 INC HL        ;
 $A7B6 CALL $FFA0    ; Shot reentry guard
 $A7B9 LD A,$01      ; {Set $8226=1
 $A7BB LD ($8226),A  ; }
 $A7BE NOP           ;
 $A7BF LD A,($820B)  ; get Joe's facing direction
 $A7C2 OR A          ;
 $A7C3 JR NZ,$A7D0   ;
 $A7C5 LD A,($8201)  ; get Joe X
 $A7C8 SUB (HL)      ;
 $A7C9 RET C         ;
 $A7CA LD A,$00      ;
 $A7CC LD ($8226),A  ; set kill-sparkle animation counter
 $A7CF RET           ;
*$A7D0 LD A,($8201)  ; get Joe X
 $A7D3 SUB (HL)      ;
 $A7D4 RET NC        ;
 $A7D5 LD A,$00      ;
 $A7D7 LD ($8226),A  ; set kill-sparkle animation counter
 $A7DA RET           ;

; Unused
s$A7DB DEFS $01

; Out of ammo
;
; Used by the routine at #R$A798.
@label=OutOfAmmo
c$A7DC CALL $923C    ; Draw black box on the screen
 $A7DF LD IX,$A7EC   ; "YOUR GUN'S EMPTY"
 $A7E3 LD HL,$4868   ; HL = screen row 11 col 8
 $A7E6 CALL $9196    ; Draw string IX
 $A7E9 JP $A78A      ; => Delay

; "YOUR GUN'S EMPTY" (out-of-ammo message)
b$A7EC DEFB $18,$0E,$14,$11,$1F,$06,$14,$0D
 $A7F4 DEFB $1B,$12,$1F,$04,$0C,$0F,$13,$18
 $A7FC DEFB $FF,$FF,$FF,$FF

