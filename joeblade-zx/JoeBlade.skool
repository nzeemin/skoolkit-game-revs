*$8B0E PUSH BC       ;
 $8B0F PUSH HL       ;
 $8B10 LD B,$20      ;
*$8B12 LD A,(DE)     ; {Copy a 32-byte column (DE->HL)
 $8B13 LD (HL),A     ;
 $8B14 INC DE        ;
 $8B15 INC HL        ;
 $8B16 DJNZ $8B12    ; }
 $8B18 POP HL        ; {Restore HL/BC
 $8B19 POP BC        ; }
