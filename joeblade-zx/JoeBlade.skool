; Main menu loop: poll keys, dispatch to Control/Start/High-scores
;
; Used by the routines at #R$83E1, #R$8DBE, #R$8E16 and #R$8EB4.
;
; .
;
; Draws the menu once, then polls C/S/H each frame (matches the "C FOR CONTROL
; OPTIONS", "S TO START", "H FOR HIGH SCORES" prompts): C enters #R$8BB4
; (control options), S jumps into #R$7D00 (start the game), H jumps into
; #R$8DBE (high scores).
@label=MainMenu
c$8B37 CALL $8A00    ; Show main menu
*$8B3A CALL $8A03    ; Poll main menu state
 $8B3D LD BC,$FEFE   ; {Read keyboard row $FEFE (CAPS,Z,X,C,V)
 $8B40 IN A,(C)      ; }
 $8B42 CPL           ;
 $8B43 AND $08       ;
 $8B45 JP NZ,$8BB4   ; => Control-options screen entry
 $8B48 LD BC,$FDFE   ; {Read keyboard row $FDFE (A,S,D,F,G)
 $8B4B IN A,(C)      ; }
 $8B4D CPL           ;
 $8B4E AND $02       ;
 $8B50 JP NZ,$7D00   ; => Start game
 $8B53 LD BC,$BFFE   ; {Read keyboard row $BFFE (B,N,M,SS,SPACE)
 $8B56 IN A,(C)      ; }
 $8B58 CPL           ;
 $8B59 AND $10       ;
 $8B5B JP NZ,$8DBE   ; => High scores screen
 $8B5E JP $8B3A      ; Loop back and poll again

; Data block at 8B61
b$8B61 DEFB $00,$0C,$07

; Control-options screen: J/S/K input method selector
;
; Used by the routine at #R$8BB4.
;
; .
;
; Part of the control-options screen (#R$8BB4). Polls J (Kempston), S
; (Sinclair), K (keyboard) and highlights the chosen option, setting $FFFF as a
; persisted "input method" flag (read back into $820E at init - see #R$8032).
@label=ControlOptionsScreen
c$8B64 LD BC,$BFFE   ; {Read row $BFFE bit3 (J = Kempston)
 $8B67 IN A,(C)      ;
 $8B69 CPL           ;
 $8B6A AND $08       ;
 $8B6C JR Z,$8B86    ; }
 $8B6E LD A,$01      ; {Set input-method flag $FFFF=1
 $8B70 LD ($FFFF),A  ; }
 $8B73 LD HL,$5964   ; Highlight row
 $8B76 LD B,$19      ; B = $19
*$8B78 LD (HL),$57   ; {Highlight 'J' row
 $8B7A INC HL        ;
 $8B7B DJNZ $8B78    ; }
 $8B7D NOP           ; {Unused padding (6x NOP)
 $8B7E NOP           ;
 $8B7F NOP           ;
 $8B80 NOP           ;
 $8B81 NOP           ;
 $8B82 NOP           ; }
 $8B83 JP $83E1      ; => 'J' (Kempston) chosen
*$8B86 LD A,$00      ; {Clear input-method flag $FFFF=0
 $8B88 LD ($FFFF),A  ; }
 $8B8B LD B,$FD      ; {Read row $FDFE bit1 (S = Sinclair)
 $8B8D IN A,(C)      ;
 $8B8F CPL           ;
 $8B90 AND $02       ;
 $8B92 JR Z,$8B9C    ; }
 $8B94 LD HL,$59A8   ; {'S' chosen: HL=$59A8, B=$10, reuse 'J' highlight loop
 $8B97 LD B,$10      ;
 $8B99 JP $8B78      ; }
*$8B9C LD B,$BF      ; {Read row $BFFE bit2 (K = keyboard)
 $8B9E IN A,(C)      ;
 $8BA0 CPL           ;
 $8BA1 AND $04       ;
 $8BA3 JP Z,$8B64    ; }
 $8BA6 LD HL,$5928   ; Highlight row
 $8BA9 LD B,$10      ; B = $10
*$8BAB LD (HL),$57   ; {Highlight 'K' row
 $8BAD INC HL        ;
 $8BAE DJNZ $8BAB    ; }
 $8BB0 JP $81E6      ; => 'K' (keyboard) chosen

