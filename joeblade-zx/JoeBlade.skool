; Rolling-digit counter increment (pending tick from $820F)
;
; Used by the routines at #R$8F00 and #R$A77C.
;
; .
;
; Called every frame from #R$8F00. If $820F (a pending-increment countdown,
; scheduled by #R$855B) is non-zero, decrements it and increments the counter
; selected by $8210 (row of 16 bytes at $89xx: a 16-bit value plus its ASCII
; digit string), carrying '9'->'0' through the digits, then continues into
; #R$8982 for the redraw if $8210's counter is active.
@label=DigitTick
c$850E LD A,($820F)  ; {Check pending tick $820F
 $8511 OR A          ; }
 $8512 RET Z         ; Return if none
 $8513 DEC A         ; {Decrement $820F
 $8514 LD ($820F),A  ; }
 $8517 LD H,$89      ; {HL = counter row at $89xx (selected by $8210)
 $8519 LD A,($8210)  ;
 $851C AND A         ;
 $851D RLCA          ;
 $851E RLCA          ;
 $851F RLCA          ;
 $8520 RLCA          ;
 $8521 LD L,A        ; }
 $8522 PUSH HL       ; {Increment the 16-bit counter value
 $8523 LD E,(HL)     ;
 $8524 INC HL        ;
 $8525 LD D,(HL)     ;
 $8526 INC DE        ;
 $8527 LD (HL),D     ;
 $8528 DEC HL        ;
 $8529 LD (HL),E     ; }
 $852A LD BC,$0007   ; {Roll the ASCII digit string ('9'->'0' carry)
 $852D ADD HL,BC     ;
 $852E LD B,$06      ;
*$8530 INC (HL)      ;
 $8531 LD A,(HL)     ;
 $8532 CP $2A        ;
 $8534 JR NZ,$853B   ;
 $8536 LD (HL),$20   ;
 $8538 DEC HL        ;
 $8539 DJNZ $8530    ; }
*$853B LD A,($8210)  ;
 $853E OR A          ;
 $853F POP HL        ;
 $8540 RET Z         ;
 $8541 JP $8982      ; => High-score table

; Unused
s$8544 DEFS $02

; Redraw the current score/counter digit string on screen
;
; Used by the routine at #R$8F00.
;
; .
;
; Called every frame from #R$8F00. IX = $8900 + $8210*16 + 2 (the digit-string
; field of the current high-score row - same row addressing as #R$850E), drawn
; at $5068. Keeps the on-screen counter for the active row up to date every
; frame.
@label=RedrawScore
c$8546 LD A,($8210)  ; {IX = high-score row digit field ($8210-selected)
 $8549 RLCA          ;
 $854A RLCA          ;
 $854B RLCA          ;
 $854C RLCA          ;
 $854D ADD A,$02     ;
 $854F LD L,A        ;
 $8550 LD H,$89      ;
 $8552 PUSH HL       ;
 $8553 POP IX        ; }
 $8555 LD HL,$5068   ; Screen dest, row 19 col 8
 $8558 JP $9196      ; => Draw string IX

; Glyph-draw preamble: schedule tick, set glyph table high byte
;
; Used by the routine at #R$925C.
;
; .
;
; Called first thing by #R$925C. Bumps $820F by $87 (schedules a delayed
; effect/tick), and sets D=$A7 - the fixed high byte of the $A700+ glyph tables
; used by #R$7CA4 and friends.
c$855B LD A,($820F)  ; {$820F += $87
 $855E ADD A,$87     ;
 $8560 LD ($820F),A  ; }
 $8563 LD D,$A7      ; D = $A7 (glyph table high byte)
 $8565 LD A,C        ; A = C
 $8566 RET           ;

