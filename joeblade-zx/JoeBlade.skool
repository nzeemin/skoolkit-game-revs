b$FF99 DEFB $CD,$98,$A7,$C3,$3E,$FF,$00

; Shot reentry guard: skip #R$A798's caller if mid-jump or sparkle busy
;
; Used by the routine at #R$A798.
;
; .
;
; Called from #R$A798 mid-shot. If Joe is mid-jump ($8209<>0) or the 2nd
; kill-sparkle slot is still playing ($8226<>0), pops its own return address
; and returns - a double-return that aborts the rest of #R$A798 too (skips
; setting $8226 and the facing-direction/range logic), preventing a new shot
; from stomping the still-active sparkle.
@label=ShotGuard
c$FFA0 LD A,($8209)  ; {Check $8209 (mid-jump)
 $FFA3 OR A          ;
 $FFA4 JR NZ,$FFAB   ; }
 $FFA6 LD A,($8226)  ; get kill-sparkle animation counter
 $FFA9 OR A          ;
 $FFAA RET Z         ;
*$FFAB POP BC        ; {Double-return: abort #R$A798 too
 $FFAC RET           ; }

; Clear $8226, hand off to $7D96
;
; Used by the routine at #R$8114.
c$FFAD LD A,$00      ; {Clear $8226 flag
 $FFAF LD ($8226),A  ; }
 $FFB2 JP $7D96      ; => Clamp room-tile pointers, hand off to game loop $8F00

; Draw a string of 8x8 glyphs (energy gauge segments)
;
; Used by the routines at #R$93A0 and #R$A23C.
;
; .
;
; IX = byte string (each byte a glyph index, $FF-terminated), HL = destination.
; Each glyph is an 8-byte (8x8 1bpp) block at #R$A200+index*8. Used by #R$93A0
; (energy loss) and #R$A23C (gauge fill) to draw the energy-gauge bar.
@label=DrawStringGlyphs
c$FFB5 LD C,(IX+$00) ; {C = glyph index
 $FFB8 LD A,C        ;
 $FFB9 INC IX        ; }
 $FFBB CP $FF        ; {$FF terminates
 $FFBD RET Z         ; }
 $FFBE LD E,C        ; {DE = #R$A200 + index*8 (glyph source)
 $FFBF LD D,$00      ;
 $FFC1 EX DE,HL      ;
 $FFC2 ADD HL,HL     ;
 $FFC3 ADD HL,HL     ;
 $FFC4 ADD HL,HL     ;
 $FFC5 EX DE,HL      ;
 $FFC6 LD D,$A2      ; }
 $FFC8 LD B,$08      ;
 $FFCA PUSH HL       ; {Draw 8-byte glyph column
*$FFCB LD A,(DE)     ;
 $FFCC LD (HL),A     ;
 $FFCD INC H         ;
 $FFCE INC DE        ;
 $FFCF DJNZ $FFCB    ; }
 $FFD1 POP HL        ;
 $FFD2 INC HL        ;
 $FFD3 JR $FFB5      ;

; Menu-done delay, then wait for a key or timeout
;
; Used by the routine at #R$8A5E.
;
; .
;
; Reached from #R$8A5E once the menu is done (`JP NZ,$FFD5`) - not ROM code,
; despite an earlier pass's uncertainty. Sets HL=BC=$0200 (512) and falls into
; #R$8680 (WaitKeyTimeout).
@label=MenuDoneWait
c$FFD5 LD HL,$0200   ;
 $FFD8 LD BC,$0200   ;
 $FFDB JP $8680      ; => Wait for a key or timeout

