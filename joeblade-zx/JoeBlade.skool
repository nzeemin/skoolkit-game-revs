; Bomb deactivation minigame: sort access code, "SELF DESTRUCT IN 30 SECONDS"
;
; Used by the routine at #R$8D3C.
;
; .
;
; Reached only from #R$8D3C's edge-tile check on a bomb tile ($9D18) - NOT a
; room-to-room flip or level-exit. Clears the screen, plays the "SELF DESTRUCT
; IN 30 SECONDS" message (#R$78E7 scrolling text + #R$7BA8/#R$7BE8 setup), then
; loops #R$7A28 (access-code letter-swap cursor input) while checking the
; 5-letter access code at $7B01-$7B05 against sorted order ($7B05 down to
; $7B01, comparing against B=5..1), and the 16-bit timer at $7B0C/$7B0D for
; expiry - fails back to #R$780C to keep playing until either the access code
; (2 of its letters swappable via the two cursors $7B09/$7B0A) is in
; alphabetical order (success, falls through to #R$7AE5 - back to normal
; gameplay), or the timer hits zero (failure, falls into #R$783F - "SELF
; DESTRUCT ACTIVATED" message, then #R$8EB4 - post-game hub, i.e. game over).
@label=BombGame
c$7800 CALL $7CE1    ; Bomb minigame entry
 $7803 LD HL,$00C8   ;
 $7806 LD BC,$00C8   ;
 $7809 CALL $8680    ; Wait for a key or timeout
*$780C NOP           ;
 $780D NOP           ;
 $780E NOP           ;
 $780F NOP           ;
 $7810 NOP           ;
 $7811 EI            ;
 $7812 HALT          ;
 $7813 NOP           ;
 $7814 NOP           ;
 $7815 NOP           ;
 $7816 NOP           ;
 $7817 NOP           ;
 $7818 NOP           ;
 $7819 NOP           ;
 $781A NOP           ;
 $781B CALL $7A28    ; Bomb minigame - access-code swap cursor input handler
 $781E CALL $7C65    ; Bomb minigame - cursor blink
 $7821 CALL $7C3F    ; Bomb minigame - draw the access code
 $7824 CALL $7A78    ; Bomb minigame - highlight the two swap-cursor
                     ; access-code letters
 $7827 LD HL,$7B0C   ; {Timer $7B0C/$7B0D expired? -> #R$783F (timeout/failure)
 $782A LD A,(HL)     ;
 $782B INC HL        ;
 $782C OR (HL)       ;
 $782D JR Z,$783F    ; }
 $782F LD HL,$7B05   ;
 $7832 LD B,$05      ;
*$7834 LD A,B        ;
 $7835 CP (HL)       ;
 $7836 JP NZ,$780C   ;
 $7839 DEC HL        ;
 $783A DJNZ $7834    ;
 $783C JP $7AE5      ; => Restore normal gameplay view (attrs + shadow flush +
                     ; sprites) after Bomb minigame
*$783F CALL $78E7    ; Bomb minigame
 $7842 NOP           ;
 $7843 LD HL,$4800   ; HL = screen row 8 col 0
 $7846 LD DE,$4801   ;
 $7849 LD BC,$07FF   ;
 $784C LD (HL),$00   ;
 $784E LDIR          ;
 $7850 LD HL,$4864   ; HL = screen row 11 col 4
 $7853 CALL $9196    ; Draw string IX
 $7856 LD HL,$48A7   ; HL = screen row 13 col 7
 $7859 CALL $9196    ; Draw string IX
 $785C LD HL,$01FA   ;
 $785F LD BC,$01FA   ;
 $7862 CALL $8680    ; Wait for a key or timeout
 $7865 POP BC        ;
 $7866 JP $8EB4      ; => Post-game hub

; Shot hit check: compare Joe X against #R$7900 threshold, set $7B10
;
; Used by the routine at #R$A798.
;
; .
;
; Called by #R$A798 when Joe fires. Looks up the #R$7900 entry for the current
; tile ($8202) and compares it against Joe's X (not a Y value, despite
; #R$7900's "ceiling" label - see that table's note) to decide which side of
; the threshold Joe is on, setting $7B10 accordingly (also gated by $8209 and
; $820B). $7B10 is read back by #R$789D to trigger a soldier hit/reaction
; animation - likely "is a soldier within range of this shot".
@label=ShotHitTest
c$7869 LD H,$79      ; {HL = #R$7900 entry for current tile ($8202)
 $786B LD A,($8202)  ;
 $786E RLCA          ;
 $786F LD L,A        ; }
 $7870 INC HL        ; {$8209 non-zero? skip the $7B10 idle-check
 $7871 LD A,($8209)  ;
 $7874 OR A          ;
 $7875 JR NZ,$787C   ; }
 $7877 LD A,($7B10)  ; {Not mid-shot: bail unless $7B10 already set
 $787A OR A          ;
 $787B RET NZ        ; }
*$787C LD A,$01      ; {Mark $7B10 active
 $787E LD ($7B10),A  ; }
 $7881 LD A,($820B)  ; {Check $820B direction, branch
 $7884 OR A          ;
 $7885 JR NZ,$7892   ; }
 $7887 LD A,($8201)  ; get Joe X
 $788A SUB (HL)      ;
 $788B RET C         ;
 $788C LD A,$00      ;
 $788E LD ($7B10),A  ;
 $7891 RET           ;
*$7892 LD A,($8201)  ; get Joe X
 $7895 SUB (HL)      ;
 $7896 RET NC        ;
 $7897 LD A,$00      ;
 $7899 LD ($7B10),A  ;
 $789C RET           ;

; Kill-sparkle animation, gated on $7B10
;
; Used by the routine at #R$8E64.
;
; .
;
; Called from #R$8E64 (per-frame soldier update). While $7B10 is non-zero (set
; by #R$7869 on a hit): first hit ($7B10=1) snapshots the soldier's screen/mask
; address into $7B11/$7B12 as the sparkle anchor; each following frame picks a
; sparkle sprite frame (the #R$6400+ bank) from that anchor plus the $8206
; counter, and $7B10 counts up to $1E (~30 frames) before resetting to 0.
@label=SparkleAnim
c$789D LD A,($7B10)  ; {Check $7B10
 $78A0 OR A          ; }
 $78A1 RET Z         ; Return if inactive
 $78A2 LD A,($7B10)  ; {First tick ($7B10=1)?
 $78A5 CP $01        ;
 $78A7 JR NZ,$78B5   ; }
 $78A9 LD A,($8FA7)  ; {Snapshot $8FA7/$8FA4 into $7B11/$7B12 (sparkle anchor)
 $78AC LD ($7B11),A  ;
 $78AF LD HL,($8FA4) ;
 $78B2 LD ($7B12),HL ; }
*$78B5 LD A,($7B11)  ; {Pick sparkle sprite frame from anchor + $8206 counter
 $78B8 LD ($8FA7),A  ;
 $78BB LD HL,($7B12) ;
 $78BE LD A,H        ;
 $78BF AND $01       ;
 $78C1 ADD A,$64     ;
 $78C3 LD H,A        ;
 $78C4 LD A,($8206)  ;
 $78C7 AND $04       ;
 $78C9 ADD A,H       ;
 $78CA LD H,A        ;
 $78CB LD ($8FA4),HL ;
 $78CE INC H         ;
 $78CF INC H         ;
 $78D0 LD ($8FA1),HL ; }
 $78D3 LD A,($7B10)  ; {Advance $7B10
 $78D6 INC A         ;
 $78D7 LD ($7B10),A  ; }
 $78DA CP $1E        ; Done at $1E?
 $78DC RET NZ        ;
 $78DD DEC A         ; {Freeze at $1D, clear done-flag $8FA8
 $78DE LD ($7B10),A  ;
 $78E1 LD A,$00      ;
 $78E3 LD ($8FA8),A  ;
 $78E6 RET           ; }

; Bomb minigame: fill screen attributes, set text pointer
;
; Used by the routine at #R$7800.
;
; .
;
; Called from #R$7800. Fills 256 bytes at $5900 (8 attribute rows) with $47
; (bright white-on-black), then sets IX=#R$7AB6 - likely the scrolling "SELF
; DESTRUCT..." text source.
@label=BombGamePrepAttr
c$78E7 LD HL,$5900   ; HL = $5900
 $78EA LD B,$00      ; B = 0 (256 iterations)
*$78EC LD (HL),$47   ;
 $78EE INC HL        ;
 $78EF DJNZ $78EC    ;
 $78F1 LD IX,$7AB6   ; IX = #R$7AB6
 $78F5 RET           ;

; Data block at 78F6
b$78F6 DEFB $00,$00,$00,$00,$00,$00,$00,$00
 $78FE DEFB $00,$00

; Per-tile threshold table, indexed by $8202
;
; .
;
; .
;
; Word pairs indexed by 2*$8202 (current room-tile index, see #R$8114). #R$7D96
; clamps the odd (high) byte of each pair into $4E-$9D each frame; the even
; (low) byte is a second soldier movement-pattern selector sharing #R$96CC's
; dispatch code via #R$8E53 (see docs/Actors.md). $8202 ranges 0-127 (room 0-7
; + 8*level 0-15), so the array proper is 128 words (256 bytes); the trailing
; 40 bytes are unaccounted for.
; .
; Originally guessed as a per-tile ceiling Y-bound. #R$7869 (the shot-hit
; check, called from #R$A798 when firing) compares this table's entry against
; Joe's X, not Y - so it may instead (or also) be a per-tile X threshold, e.g.
; a soldier post/wall position used for hit detection. The two uses aren't
; necessarily contradictory (same stored value reused as a generic "boundary
; coordinate" by different consumers) but the "ceiling" label is now uncertain
; - needs live tracing to settle.
b$7900 DEFW $6602,$1203,$6903,$2002
 $7908 DEFW $8000,$9D00,$9D00,$4E00
 $7910 DEFW $4E00,$4E00,$4E00,$4E00
