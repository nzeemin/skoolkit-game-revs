; Jump timer tick; clears $8209 on wrap
;
; Used by the routines at #R$7E32, #R$7FD2 and #R$7FDC.
;
; .
;
; Increments the jump timer $820D; when it wraps at $30 (48), resets both $820D
; and $8209 to 0. Called from #R$7E32 and the jump-arc routines
; #R$7FD2/#R$7FDC.
@label=JumpTimerTick
c$7FE6 LD A,($820D)  ; {Increment jump timer $820D
 $7FE9 INC A         ; }
 $7FEA LD ($820D),A  ; set jump counter
 $7FED CP $30        ; {Wrap at 48? branch
 $7FEF JR NZ,$7FF9   ; }
 $7FF1 LD A,$00      ; A = 0
 $7FF3 LD ($8209),A  ; Clear $8209
 $7FF6 LD ($820D),A  ; set jump counter
*$7FF9 NOP           ; {Unused padding (3x NOP)
 $7FFA NOP           ;
 $7FFB NOP           ; }
 $7FFC RET           ;

