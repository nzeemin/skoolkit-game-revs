; Read input into $820A: Kempston, digit-key, or redefinable-key scheme
;
; Used by the routines at #R$7A28, #R$8F00 and #R$9580.
;
; .
;
; Writes a 5-bit direction/fire mask to #R$820A. If $820E==1, reads Kempston
; joystick (port $1F) and uses it directly if non-zero, skipping the keyboard
; entirely. Otherwise tries a fixed digit-key scheme (row $F7FE, keys 1-5)
; first; if that row is idle, falls back to the redefinable keyboard scheme
; matching the control-options text (#R$8400 signs): row $FDFE (A-G) = down,
; row $FBFE (Q-T) = up, row $7FFE (B/space) = fire, row $DFFE bits0-1 (O/P) =
; left/right.
@label=ReadInput
c$8032 LD A,($820E)  ; {$820E==1? (Kempston mode selected)
 $8035 CP $01        ; }
 $8037 NOP           ;
 $8038 NOP           ;
 $8039 NOP           ;
 $803A NOP           ;
 $803B NOP           ;
 $803C NOP           ;
 $803D NOP           ;
 $803E JR NZ,$804B   ;
 $8040 NOP           ;
 $8041 IN A,($1F)    ; {Read Kempston joystick (port $1F)
 $8043 AND $1F       ; }
 $8045 JR Z,$804B    ; {Use directly if non-zero
 $8047 LD ($820A),A  ; }
 $804A RET           ;
*$804B LD BC,$F7FE   ; {Read digit-key row $F7FE (keys 1-5)
 $804E IN A,(C)      ; }
 $8050 CPL           ;
 $8051 AND $1F       ;
 $8053 JR Z,$806C    ;
 $8055 LD C,A        ; {Remap digit-row bits into result: bits2-4 passthrough,
 $8056 AND $1C       ; bit1->bit0, bit0->bit1
 $8058 LD B,A        ;
 $8059 LD A,C        ;
 $805A AND $02       ;
 $805C JR Z,$8060    ; }
 $805E SET 0,B       ;
*$8060 LD A,C        ;
 $8061 AND $01       ;
 $8063 JR Z,$8067    ;
 $8065 SET 1,B       ;
*$8067 LD A,B        ;
