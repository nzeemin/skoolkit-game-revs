; Wait for a key or timeout
;
; Used by the routines at #R$7800, #R$81E6, #R$83E1, #R$8E96 and #R$FFD5.
;
; .
;
; Busy-waits for HL*BC ticks (both caller-supplied), flashing the border on two
; independent countdowns (BC = fast, DE = slow) as a "waiting" indicator. Does
; not itself poll the keyboard - callers check for a keypress separately and
; just use this for the timed pause/flash.
@label=WaitKeyTimeout
c$8680 DI            ; {Save BC and BC+1 as two independent countdowns
 $8681 LD A,$00      ;
 $8683 EX AF,AF'     ;
 $8684 LD ($8696),BC ;
 $8688 INC BC        ;
 $8689 LD D,B        ;
 $868A LD E,C        ;
 $868B LD ($86A5),DE ; }
 $868F DEC BC        ;
*$8690 DEC BC        ; {Fast tick: flash border when BC reaches 0
 $8691 LD A,B        ;
 $8692 OR C          ;
 $8693 JR NZ,$869F   ; }
 $8695 LD BC,$00A0   ;
 $8698 EX AF,AF'     ;
 $8699 ADD A,$10     ;
 $869B OUT ($FE),A   ;
 $869D EX AF,AF'     ;
 $869E DEC HL        ;
*$869F DEC DE        ; {Slow tick: flash border when DE reaches 0
 $86A0 LD A,D        ;
 $86A1 OR E          ;
 $86A2 JR NZ,$86AD   ;
 $86A4 LD DE,$00A1   ;
 $86A7 EX AF,AF'     ;
 $86A8 ADD A,$10     ;
 $86AA OUT ($FE),A   ;
 $86AC EX AF,AF'     ; }
*$86AD LD A,H        ; {HL reached 0? loop or return (EI)
 $86AE OR L          ;
 $86AF JR NZ,$8690   ;
 $86B1 EI            ;
 $86B2 RET           ; }

