b$9299 DEFB $0B,$78,$B1,$20,$F9,$C9,$00

; Key pickup: check $9D00 tile at screen edge
;
; Used by the routine at #R$A3BA.
;
; .
;
; Same pattern as #R$926E but for the 15-entry key tile table #R$9D00; collects
; directly inline at #R$92C8 (mark tile $FF, increment key counter $8215,
; redraw digit, rebuild background).
@label=CheckKey
c$92A0 LD HL,$9D00   ; HL = #R$9D00 (key tile table)
 $92A3 LD B,$0F      ; B = 15
*$92A5 LD A,($8202)  ; {Compare current tile ($8202) against table entry
 $92A8 CP (HL)       ;
 $92A9 JR NZ,$92C4   ; }
 $92AB LD A,($820C)  ; {$820C bits4-5: pick which edge to check
 $92AE AND $30       ; }
 $92B0 JR NZ,$92BB   ;
 $92B2 LD A,($8201)  ; get Joe X
 $92B5 CP $20        ;
 $92B7 JP Z,$92C8    ;
 $92BA RET           ;
*$92BB LD A,($8201)  ; get Joe X
 $92BE CP $C0        ;
 $92C0 JP Z,$92C8    ;
 $92C3 RET           ;
*$92C4 INC HL        ;
 $92C5 DJNZ $92A5    ;
 $92C7 RET           ;
; Pickup the key
@label=PickupKey
*$92C8 LD (HL),$FF   ; {Mark tile visited ($FF)
 $92CA LD HL,$8215   ; }
 $92CD INC (HL)      ; {Increment key counter $8215
 $92CE LD C,(HL)     ; }
 $92CF LD HL,$50BE   ; HL = screen row 21 col 30
 $92D2 CALL $925C    ; Draw one digit/character glyph
 $92D5 CALL $8C00    ; Build room background into shadow buffer $B800
 $92D8 LD C,$00      ;
 $92DA CALL $86C0    ; Show pickup message popup
 $92DD RET           ;

; Bomb pickup: mark tile, count, rebuild
;
; Used by the routine at #R$9300.
;
; .
;
; Called by #R$9300 when Joe touches a $9D18-table tile at the screen edge.
; Sets bit7 on the tile's byte (rather than $FF like the other 3 pickups),
; increments the bomb counter $8216, redraws the digit, and does an extra
; countdown-timer tick at $85F9 (shared with #R$9650) before rebuilding.
@label=PickupBomb
c$92DE LD A,(HL)     ; {Set bit7 on tile byte
 $92DF ADD A,$80     ;
 $92E1 LD (HL),A     ;
 $92E2 LD HL,$8216   ; }
 $92E5 INC (HL)      ; {Increment bomb counter $8216
 $92E6 LD C,(HL)     ; }
 $92E7 LD HL,$50FE   ; HL = screen row 23 col 30
 $92EA CALL $925C    ; Draw one digit/character glyph
 $92ED LD C,$02      ;
 $92EF CALL $86C0    ; Show pickup message popup
 $92F2 LD HL,$85F9   ;
 $92F5 LD A,(HL)     ;
 $92F6 INC A         ;
 $92F7 RET C         ;
 $92F8 INC (HL)      ;
 $92F9 RET           ;

; Data block at 92FA
b$92FA DEFB $FF,$C0,$AF,$32,$F9,$85

; Bomb pickup: check $9D18 tile at screen edge
;
; Used by the routine at #R$A3BA.
;
; .
;
; Same pattern as #R$926E, for the 6-entry bomb tile table $9D18 (also scanned
; by #R$8D3C, which routes edge-touches into the bomb minigame instead). On
