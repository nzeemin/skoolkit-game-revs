; Soldier presence/movement-pattern dispatch for the current tile
;
; Used by the routine at #R$8E64.
;
; .
;
; The even (low) byte of #R$9700's word pair for the current tile ($8202) is a
; soldier movement-pattern selector, not unused padding: 0 = no soldier (clears
; the soldier screen address $8F93 and returns), 1-6 select one of 6 movement
; routines (#R$900A/#R$9464/#R$8164/#R$7D64/#R$7D82/#R$7D8C). Confirmed 4/4
; against known room layout: tiles $71/$7A (have a soldier) hold pattern 2/1;
; tiles $72/$7B (no soldier) hold pattern 0 - see docs/Actors.md.
@label=SoldierDispatch
c$96CC LD H,$97      ; {IX = #R$9700 entry for current tile ($8202)
; This entry point is used by the routine at #R$8E53.
*$96CE LD A,($8202)  ;
 $96D1 RLCA          ;
 $96D2 LD L,A        ;
 $96D3 PUSH HL       ;
 $96D4 POP IX        ; }
 $96D6 LD A,(IX+$00) ; A = movement-pattern byte (0 = no soldier)
 $96D9 CP $01        ;
 $96DB JP Z,$900A    ; => Soldier pattern 1
 $96DE CP $02        ;
 $96E0 JP Z,$9464    ; => Soldier pattern 2
 $96E3 CP $03        ;
 $96E5 JP Z,$8164    ; => Soldier pattern 3
 $96E8 CP $04        ;
 $96EA JP Z,$7D64    ; => Soldier pattern 4
 $96ED CP $05        ;
 $96EF JP Z,$7D82    ; => Soldier pattern 5
 $96F2 CP $06        ;
 $96F4 JP Z,$7D8C    ; => Soldier pattern 6
 $96F7 LD HL,$0000   ; {No/unknown pattern: clear soldier screen address $8F93
 $96FA LD ($8F93),HL ; }
 $96FD RET           ;

; Data block at 96FE
b$96FE DEFB $00,$00

