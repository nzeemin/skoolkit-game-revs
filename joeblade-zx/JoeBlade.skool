 $86C4 RLCA          ;
 $86C5 RLCA          ;
 $86C6 RLCA          ;
 $86C7 RLCA          ;
 $86C8 RLCA          ;
 $86C9 LD L,A        ; }
 $86CA LD H,$98      ;
 $86CC PUSH HL       ;
 $86CD POP IX        ;
 $86CF LD HL,$4869   ; HL = screen row 11 col 9
 $86D2 CALL $9196    ; Draw string IX
 $86D5 LD HL,$4889   ; HL = screen row 12 col 9
 $86D8 CALL $9196    ; Draw string IX
 $86DB CALL $856E    ; Pickup/beep sound effect
 $86DE JP $9296      ; => Delay

