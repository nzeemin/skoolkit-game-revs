; High-score table: bubble the current row into sorted order
;
; Used by the routine at #R$850E.
;
; .
;
; Called from #R$850E after a digit increment. Compares the current 16-byte
; table row (HL, at $89xx) against the previous row (HL-$10); if their first 2
; bytes match(?) swaps the two 16-byte rows, decrements $8210 (row index) and
; repeats - i.e. bubbles an updated entry up through the table until it's back
; in sorted order. The $8900+ data itself looks like a name+score table: name
; text (same encoding as HUD strings, $1F-padded) terminated by $FF, followed
; by a numeric score field - not yet given clean ctl boundaries (still
; fragmented by the same text-heuristic issue fixed elsewhere for
; #R$9D00/#R$6C00).
@label=HiScoreSort
c$8982 LD D,H        ; {DE = HL - $10 (previous table row)
 $8983 LD A,L        ;
 $8984 SUB $10       ;
 $8986 LD E,A        ; }
 $8987 LD A,(DE)     ; {Compare leading bytes of both rows; return if different
 $8988 CP (HL)       ;
 $8989 RET NZ        ;
 $898A INC DE        ;
 $898B INC HL        ;
 $898C LD A,(DE)     ;
 $898D CP (HL)       ;
 $898E RET NZ        ; }
 $898F DEC DE        ; {Swap the two 16-byte rows
 $8990 DEC HL        ;
 $8991 PUSH HL       ;
 $8992 LD B,$10      ;
*$8994 LD A,(DE)     ;
