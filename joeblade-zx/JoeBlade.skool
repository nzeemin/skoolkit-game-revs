; Per-frame room-tile lookup, then hand off to game loop
;
; Used by the routines at #R$7D00, #R$7E32, #R$7F6E and #R$7FA0.
;
; .
;
; Bridges #R$7D00 into the game loop: computes the current room-tile offset
; from $8203/$8204, looks it up in the table at #R$8300, stores it as the
; terrain-flags byte $820C (bit map documented at that variable), redraws the
; status bar from bits6-7 of it (LDIR to $5880), then falls through #R$FFAD,
; #R$7D96 into #R$8F00.
@label=RoomFrame
c$8114 LD A,($8204)  ; {Look up current room tile from table at #R$8300
 $8117 RLCA          ;
 $8118 RLCA          ;
 $8119 RLCA          ;
 $811A LD B,A        ;
 $811B LD A,($8203)  ;
 $811E ADD A,B       ;
 $811F LD ($8202),A  ; }
 $8122 ADD A,$00     ;
 $8124 LD H,$83      ;
 $8126 LD L,A        ;
 $8127 LD A,(HL)     ; {Store tile byte in $820C
 $8128 LD ($820C),A  ; }
 $812B CALL $8C00    ; Build room background into shadow buffer $B800
 $812E LD A,($820C)  ; {Attribute byte = (($820C>>6)&3) + $44: bright
 $8131 AND $C0       ; green/cyan/yellow/white ink on black, by room zone
 $8133 RRCA          ;
 $8134 RRCA          ;
 $8135 RRCA          ;
 $8136 RRCA          ;
 $8137 RRCA          ;
 $8138 RRCA          ;
 $8139 ADD A,$44     ; }
 $813B LD HL,$5880   ; {Fill 14 attribute rows at $5880 (0x1C0 bytes) - most of
 $813E LD (HL),A     ; the play area, not just a status bar
 $813F LD DE,$5881   ;
 $8142 LD BC,$01C0   ;
 $8145 LDIR          ; }
 $8147 CALL $912C    ; Detect collectible tile under Joe, draw its icon
 $814A CALL $828C    ; Draw bottom-door graphics
 $814D LD A,$00      ; {Clear $587F and $5860
 $814F LD ($587F),A  ;
 $8152 LD ($5860),A  ; }
 $8155 NOP           ;
 $8156 NOP           ;
 $8157 JP $FFAD      ; => Clear $8226, hand off to $7D96

; Unused code?
b$815A DEFB $48,$CD,$96,$91,$CD,$C8,$91,$C3
 $8162 DEFB $00,$7D

; Soldier pattern 3: synchronized left-right patrol (group B)
;
; Used by the routines at #R$7D8C and #R$96CC.
;
; .
;
; Adds a shared direction step ($8212, +2 or -2) to the soldier's X (IX+1); on
; hitting X=2 or X=$E6, flips $8212's sign - so every soldier using this
; pattern shares one direction byte and turns around in lockstep. Picks
; left/right-facing sprite from the sign of $8212, then builds the
; screen/sprite address via #R$9028 (shared with #R$900A/#R$9464).
@label=SoldierPattern3
c$8164 LD A,($8212)   ; {X += $8212 (shared step)
 $8167 ADD A,(IX+$01) ;
 $816A LD (IX+$01),A  ; }
 $816D CP $02         ; {Hit X=2 or $E6?
 $816F JR Z,$8175     ;
 $8171 CP $E6         ;
 $8173 JR NZ,$817D    ; }
*$8175 LD A,($8212)   ; {Flip $8212's sign
 $8178 XOR $FE        ;
 $817A LD ($8212),A   ; }
*$817D LD C,(IX+$01)  ; C = soldier X
 $8180 LD A,($8212)   ; {Pick sprite by $8212 sign, continue at #R$9028
 $8183 AND $80        ;
 $8185 JR NZ,$818D    ; }
 $8187 LD DE,$AA00    ;
 $818A JP $9028       ;
*$818D LD DE,$A800    ;
 $8190 JP $9028       ;

