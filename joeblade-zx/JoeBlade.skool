; Energy gauge initial fill
;
; Used by the routines at #R$9456 and #R$9498.
;
; .
;
; Refills the 18-byte gauge array $A228-$A239 to full ($04 each), redraws its
; attribute/border strips, then draws the gauge via #R$FFB5. Used both at
; game-start init and by the food pickup (#R$9456).
@label=EnergyFill
c$A23C LD HL,$A228   ; Energy gauge
 $A23F LD B,$12      ; B = 18
*$A241 LD (HL),$04   ; {Fill gauge segments to $04
 $A243 INC HL        ;
 $A244 DJNZ $A241    ; }
 $A246 LD HL,$5AA1   ; {Fill gauge attribute strip $5AA1
 $A249 LD B,$06      ; }
*$A24B LD (HL),$42   ;
 $A24D INC HL        ;
 $A24E DJNZ $A24B    ;
 $A250 LD B,$06      ; {Fill attribute strip with $06
*$A252 LD (HL),$06   ;
 $A254 INC HL        ;
 $A255 DJNZ $A252    ; }
 $A257 LD B,$06      ; {Fill attribute strip with $44
*$A259 LD (HL),$44   ;
 $A25B INC HL        ;
 $A25C DJNZ $A259    ; }
 $A25E LD HL,$5800   ; {Fill 64 screen-attribute bytes at $5800 with $42
 $A261 LD B,$40      ;
*$A263 LD (HL),$42   ;
 $A265 INC HL        ;
 $A266 DJNZ $A263    ; }
 $A268 LD IX,$A228   ; Energy gauge string address
 $A26C LD HL,$50A1   ; HL = screen row 21 col 1
 $A26F CALL $FFB5    ; Draw a string of 8x8 glyphs
 $A272 LD HL,$5840   ; {Fill 64 bytes at $5840 with $46
 $A275 LD B,$40      ;
*$A277 LD (HL),$46   ;
 $A279 INC HL        ;
 $A27A DJNZ $A277    ; }
 $A27C LD A,$00      ; {Clear 4 border/status flag bytes
 $A27E LD ($5840),A  ;
 $A281 LD ($5860),A  ;
 $A284 LD ($585F),A  ;
 $A287 LD ($587F),A  ; }
 $A28A RET           ;

; Unused
s$A28B DEFS $01

; Descending-pitch beeper sweep (2nd stage)
;
; Used by the routine at #R$A2BE.
;
; .
;
; Border/speaker OUT ($FE) sweep, shorter duration (E=5) than #R$A2BE - second
; stage of the gunshot sound played by #R$FFF0.
@label=SFX_descent2
c$A28C NOP           ; {HL = $3200, E = 5 (short sweep)
 $A28D LD HL,$3200   ;
 $A290 LD E,$05      ; }
*$A292 LD A,$10      ; {Toggle border on, delay
 $A294 OUT ($FE),A   ;
 $A296 LD B,E        ;
*$A297 DJNZ $A297    ; }
 $A299 XOR A         ; {Toggle border off, delay
 $A29A OUT ($FE),A   ;
 $A29C LD B,(HL)     ;
 $A29D RES 7,B       ;
*$A29F DJNZ $A29F    ; }
 $A2A1 DEC HL        ; {HL -= 16 (pitch step)
 $A2A2 DEC HL        ;
 $A2A3 DEC HL        ;
 $A2A4 DEC HL        ;
 $A2A5 DEC HL        ;
 $A2A6 DEC HL        ;
 $A2A7 DEC HL        ;
 $A2A8 DEC HL        ;
 $A2A9 DEC HL        ;
 $A2AA DEC HL        ;
 $A2AB DEC HL        ;
 $A2AC DEC HL        ;
 $A2AD DEC HL        ;
 $A2AE DEC HL        ;
 $A2AF DEC HL        ;
 $A2B0 DEC HL        ; }
 $A2B1 LD A,L        ; {L reached 0? adjust E
 $A2B2 OR A          ;
 $A2B3 JR NZ,$A2B7   ; }
 $A2B5 NOP           ;
 $A2B6 NOP           ;
*$A2B7 LD A,H        ; {H reached $28? loop or return
 $A2B8 CP $28        ;
 $A2BA JR NZ,$A292   ;
 $A2BC RET           ; }

; Unused
s$A2BD DEFS $01

; Descending-pitch beeper sweep (1st stage), falls into #R$A28C
;
; Used by the routine at #R$FFF0.
;
; .
;
; First stage of the gunshot sound: OUT ($FE) sweep from $3200 down to $2Exx,
; then falls into #R$A28C for a second, shorter sweep.
@label=SFX_descent1
c$A2BE NOP           ; {HL = $3200, E = $1E (long sweep)
 $A2BF LD HL,$3200   ;
 $A2C2 LD E,$1E      ; }
*$A2C4 LD A,$10      ; {Toggle border on, delay
 $A2C6 OUT ($FE),A   ;
 $A2C8 LD B,E        ;
*$A2C9 DJNZ $A2C9    ; }
 $A2CB XOR A         ; {Toggle border off, delay
 $A2CC OUT ($FE),A   ;
 $A2CE LD B,(HL)     ;
 $A2CF RES 7,B       ;
*$A2D1 DJNZ $A2D1    ; }
 $A2D3 DEC HL        ; {HL -= 16 (pitch step)
 $A2D4 DEC HL        ;
 $A2D5 DEC HL        ;
 $A2D6 DEC HL        ;
 $A2D7 DEC HL        ;
 $A2D8 DEC HL        ;
 $A2D9 DEC HL        ;
 $A2DA DEC HL        ;
 $A2DB DEC HL        ;
 $A2DC DEC HL        ;
 $A2DD DEC HL        ;
 $A2DE DEC HL        ;
 $A2DF DEC HL        ;
 $A2E0 DEC HL        ;
 $A2E1 DEC HL        ;
 $A2E2 DEC HL        ; }
 $A2E3 LD A,L        ; {L reached 0? adjust E
 $A2E4 OR A          ;
 $A2E5 JR NZ,$A2E9   ; }
 $A2E7 DEC E         ;
 $A2E8 DEC E         ;
*$A2E9 LD A,H        ; {H reached $2E? loop, else continue into #R$A28C
 $A2EA CP $2E        ;
 $A2EC JR NZ,$A2C4   ;
 $A2EE JP $A28C      ; }

; Data block at A2F1
b$A2F1 DEFB $3C,$06,$0F,$C0,$C0

; Detect ammo or uniform tile under Joe, draw its icon
;
; Used by the routine at #R$912C.
;
; .
;
; Same pattern as #R$912C but for two more collectibles: ammo (table $9D20,
; sprite/mask $A500/$A580) and uniform (table $9D2B, sprite/mask
; #R$A400/$A480). Pickup is handled separately by #R$A328 (ammo) and #R$7B1E
; (uniform).
@label=DetectAmmoUniform
c$A2F6 LD HL,$9D20   ; Ammo table
 $A2F9 LD DE,$A580   ; Mask
 $A2FC LD B,$02      ; B = 2
*$A2FE LD A,($8202)  ; get current room-tile index = room + 8*subtile
 $A301 CP (HL)       ;
 $A302 JR NZ,$A30A   ;
 $A304 LD B,D        ; {B = D (sprite/mask row), C = 0
 $A305 LD C,$00      ; }
 $A307 JP $9118      ; => Draw a collectible-item sprite, left or right variant
*$A30A INC HL        ; {No match: next entry
 $A30B DJNZ $A2FE    ; }
 $A30D LD HL,$9D2B   ; Uniform table
 $A310 LD DE,$A480   ; Mask
 $A313 LD B,$02      ; B = 2
*$A315 LD A,($8202)  ; get current room-tile index = room + 8*subtile
 $A318 CP (HL)       ;
 $A319 JR NZ,$A321   ;
 $A31B LD B,D        ; {B = D (sprite/mask row), C = 0
 $A31C LD C,$00      ; }
 $A31E JP $9118      ; => Draw a collectible-item sprite, left or right variant
*$A321 INC HL        ; {No match: next entry
 $A322 DJNZ $A315    ; }
 $A324 RET           ;
 $A325 XOR D         ;
 $A326 AND E         ;
 $A327 NOP           ;

; Ammo pickup: check $9D20 tile at screen edge
;
; Used by the routine at #R$A3BA.
;
; .
;
; Same edge-triggered pattern as #R$926E, for the ammo tile table $9D20. On
; match: marks the tile visited, rebuilds the background, shows a message
; (#R$A370, "SOME AMMUNITION") and a black-box popup, adds 10 to the ammo count
; $8225, then continues at #R$9296.
@label=CheckAmmo
c$A328 LD HL,$9D20   ; Ammo tile table
 $A32B LD B,$02      ; B = 2
*$A32D LD A,($8202)  ; {Compare current tile ($8202) against table entry
 $A330 CP (HL)       ;
 $A331 JR NZ,$A34C   ; }
 $A333 LD A,($820C)  ; {$820C bits4-5: pick which edge to check
 $A336 AND $30       ; }
 $A338 JR NZ,$A343   ;
 $A33A LD A,($8201)  ; get Joe X
 $A33D CP $20        ;
 $A33F JP Z,$A350    ;
 $A342 RET           ;
*$A343 LD A,($8201)  ; get Joe X
 $A346 CP $C0        ;
 $A348 JP Z,$A350    ;
 $A34B RET           ;
*$A34C INC HL        ;
 $A34D DJNZ $A32D    ;
 $A34F RET           ;
; Pickup the ammo
@label=PickupAmmo
*$A350 LD (HL),$FF   ; Mark tile visited ($FF)
 $A352 CALL $8C00    ; Build room background into shadow buffer $B800
 $A355 CALL $923C    ; Draw black box on the screen
 $A358 LD IX,$A370   ;
 $A35C LD HL,$4868   ; HL = screen row 11 col 8
 $A35F CALL $9196    ; Draw string IX
 $A362 CALL $856E    ; Pickup/beep sound effect
 $A365 LD A,($8225)  ; {$8225 += 10 (ammo)
 $A368 ADD A,$0A     ; }
