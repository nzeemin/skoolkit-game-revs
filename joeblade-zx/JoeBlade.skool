*$8DD0 LD (HL),$57   ;
 $8DD2 INC HL        ;
 $8DD3 DJNZ $8DD0    ;
 $8DD5 LD IX,$8902   ;
 $8DD9 LD HL,$482A   ; HL = screen row 9 col 10
 $8DDC CALL $8596    ; Draw string IX and play sound
 $8DDF LD HL,$486A   ; HL = screen row 11 col 10
 $8DE2 CALL $8DB4    ; Advance IX to the next high-score message row, draw +
                     ; beep
 $8DE5 LD HL,$48AA   ; HL = screen row 13 col 10
 $8DE8 CALL $8DB4    ; Advance IX to the next high-score message row, draw +
                     ; beep
 $8DEB LD HL,$48EA   ; HL = screen row 15 col 10
 $8DEE CALL $8DB4    ; Advance IX to the next high-score message row, draw +
                     ; beep
 $8DF1 LD HL,$502A   ; HL = screen row 17 col 10
 $8DF4 CALL $8DB4    ; Advance IX to the next high-score message row, draw +
                     ; beep
 $8DF7 CALL $8A0C    ; Poll main menu state
 $8DFA NOP           ;
*$8DFB CALL $8A0F    ; Poll main menu state
 $8DFE NOP           ;
 $8DFF CALL $91FA    ; Wait until every key on the keyboard is released
 $8E02 JR Z,$8DFB    ;
 $8E04 JP $8B37      ; => Main menu loop

