; Fill HUD attribute strip, then room attribute
;
; Used by the routine at #R$7AE5.
;
; .
;
; Fills 30 bytes at $5861 with attribute $46, then falls into #R$A3AA to fill
; the rest with the current room's attribute.
@label=FillHudAttr
c$FDB0 LD HL,$5861   ;
 $FDB3 LD B,$1E      ;
*$FDB5 LD (HL),$46   ;
 $FDB7 INC L         ;
 $FDB8 DJNZ $FDB5    ;
 $FDBA JP $A3AA      ; => Fill screen attributes with room attribute

; Data block at FDBD
b$FDBD DEFB $00,$00,$00,$20,$20,$20,$20,$20
 $FDC5 DEFB $20,$20,$1F,$1F,$1F,$1F,$1F,$1F
 $FDCD DEFB $FF

; Advance IX to the next high-score message row, draw + beep
;
; Used by the routine at #R$8DB4.
;
; .
;
; Rounds IX's low byte up to the next 16-byte row boundary (+2), then jumps
; into #R$8596 to draw that row's string and play the pickup beep. Called
; repeatedly by #R$8DB4/#R$8DBE to reveal the high-score table row by row.
@label=HiScoreNextIX
c$FDCE LD A,IXl      ;
 $FDD0 ADD A,$04     ;
 $FDD2 AND $F0       ;
 $FDD4 ADD A,$02     ;
 $FDD6 LD IXl,A      ;
 $FDD8 JP $8596      ; => Draw string IX and play sound

