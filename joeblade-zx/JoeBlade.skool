; Build room background into shadow buffer $B800
;
; Used by the routines at #R$7B1E, #R$8114, #R$86E4, #R$92A0, #R$9328 and
; #R$A328.
;
; .
;
; Reads room-layout selector bytes from the paged RAM bank at #R$C000+offset
; (offset from room number $8203 and subtile $8204 - same 128K bank paged in
; around #R$8A12). Each selector byte is decoded into the source address of a
; pre-made 32x32 "back sprite" (#R$8C5A) and a 2x8 grid of them is stamped into
; the shadow buffer at #R$B800. Falls through to #R$8CF0 for one more row. The
; shadow buffer is later copied to the real screen by #R$8C78.
; .
; Offset = level*128 + room*16 (level=$8204&$0F, room=$8203&$07). Selector
; byte: bit0 = tile variant, bits1-5 = tile index; decodes to source addr
; $E0+((byte>>1)&$1F) : (bit0?$80:0) - tiles live at #R$E000-$FFFF, 64 tiles x
; 128 bytes (32x32 1bpp). Full details and confirmation method in
; joeblade-zx/docs/Room-Format.md - in short: live-confirmed a flat 16-level x
; 8-room x 16-byte table filling $C000-$C7FF in bank0, the only RAM bank the
; game ever pages in at $C000 (no per-level bank switching exists).
@label=BuildRoom
c$8C00 LD IX,$C000   ; IX = #R$C000 (paged-bank tile-selector table)
 $8C04 LD A,($8203)  ; {E = (room $8203 & 7) * 16
 $8C07 AND $07       ;
 $8C09 RLCA          ;
 $8C0A RLCA          ;
 $8C0B RLCA          ;
 $8C0C RLCA          ; }
 $8C0D LD E,A        ;
 $8C0E LD A,($8204)  ; {D = (subtile $8204 & $0E) >> 1
 $8C11 AND $0E       ;
 $8C13 RRA           ;
 $8C14 LD D,A        ; }
 $8C15 LD A,($8204)  ; {If subtile bit0 set, E += $80
 $8C18 AND $01       ;
 $8C1A JR Z,$8C20    ;
 $8C1C LD A,E        ;
 $8C1D ADD A,$80     ; }
 $8C1F LD E,A        ;
*$8C20 ADD IX,DE     ; IX += DE (selector-table offset for this room/subtile)
 $8C22 LD HL,$B800   ; HL = #R$B800 (shadow buffer)
 $8C25 LD B,$02      ; Outer loop, 2 rows
*$8C27 PUSH BC       ;
 $8C28 PUSH HL       ;
 $8C29 LD B,$08      ; {Inner loop, 8 columns
*$8C2B PUSH BC       ;
 $8C2C PUSH HL       ; }
 $8C2D LD DE,$0000   ; DE = 0
 $8C30 LD A,(IX+$00) ; {If selector byte bit0 set, E = $80
 $8C33 AND $01       ;
 $8C35 JR Z,$8C39    ; }
 $8C37 LD E,$80      ;
*$8C39 LD A,(IX+$00) ; {D = $E0 + ((selector byte >> 1) & $1F): back-sprite
 $8C3C AND $3E       ; source address
 $8C3E RRA           ;
 $8C3F ADD A,$E0     ; }
 $8C41 LD D,A        ;
 $8C42 INC IX        ; Advance to next selector byte
 $8C44 CALL $8C5A    ; Draw back sprite 32x32
 $8C47 POP HL        ; {HL += 4 (advance dest column)
 $8C48 INC HL        ;
 $8C49 INC HL        ;
 $8C4A INC HL        ;
 $8C4B INC HL        ; }
 $8C4C POP BC        ;
 $8C4D DJNZ $8C2B    ;
 $8C4F POP HL        ; {Restore HL row start, advance to next row (L += $80)
 $8C50 POP BC        ;
 $8C51 LD L,$80      ; }
 $8C53 DJNZ $8C27    ;
 $8C55 JP $8CF0      ; => Draw one more background row directly onto the real
                     ; screen

; Unused
s$8C58 DEFS $02

; Draw back sprite 32x32
;
; Used by the routines at #R$8C00 and #R$8CF0.
;
; .
;
; Stamps one 32x32 "back sprite" (a pre-made room-background block) into the
; shadow/real screen. DE = back sprite source addr, HL = destination addr.
@label=DrawBackTile
c$8C5A LD B,$04      ; Outer loop: 4 column-groups
*$8C5C PUSH BC       ;
 $8C5D PUSH HL       ;
 $8C5E LD B,$08      ; Inner loop: 8 rows
*$8C60 PUSH BC       ;
