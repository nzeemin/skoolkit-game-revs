b$7AF2 DEFB $D7,$88,$25,$83,$8B,$EF,$FF,$FF
 $7AFA DEFB $FE,$BA,$2D,$65,$F7,$87
 $7B00 DEFB $02
 $7B01 DEFB $01,$02,$03,$04,$05             ; Bomb minigame access code (5
                                            ; letters)
 $7B06 DEFB $00,$00
 $7B08 DEFB $00                             ; uniform/disguise active flag
                                            ; ($00=normal, $01=disguised -
                                            ; suspends energy loss);
                                            ; auto-cleared by #R$7B84's timer
 $7B09 DEFB $04
 $7B0A DEFB $02
 $7B0B DEFB $2E,$02,$02
 $7B0E DEFB $47
 $7B0F DEFB $08,$00,$00,$80,$AA,$8B,$C5,$BF
 $7B17 DEFB $8B,$A5,$BD,$8A,$25,$81,$88

; Uniform pickup: check $9D2B tile at screen edge
;
; Used by the routine at #R$8F00.
;
; .
;
; Same edge-triggered pattern as #R$926E, for the uniform tile table $9D2B. On
; match: marks the tile visited, swaps Joe's sprite to the soldier costume
; ($80CF/$80D8 -> $A8/$70), sets the disguise flag $7B08=1, shows a message
; (#R$7B73, "AN ENEMY UNIFORM"), resets the duration timer $7B06, and rebuilds
; the background. Disguise is time-limited, not fire-consumed - see #R$7B84.
@label=PickupUniform
c$7B1E LD HL,$9D2B   ; Uniform tile table
 $7B21 LD B,$02      ; B = 2
*$7B23 LD A,($8202)  ; {Compare current tile ($8202) against table entry
 $7B26 CP (HL)       ;
 $7B27 JR NZ,$7B42   ; }
 $7B29 LD A,($820C)  ; {$820C bits4-5: pick which edge to check
 $7B2C AND $30       ; }
 $7B2E JR NZ,$7B39   ;
 $7B30 LD A,($8201)  ; get Joe X
 $7B33 CP $20        ;
 $7B35 JP Z,$7B46    ;
 $7B38 RET           ;
*$7B39 LD A,($8201)  ; get Joe X
 $7B3C CP $C0        ;
 $7B3E JP Z,$7B46    ;
 $7B41 RET           ;
*$7B42 INC HL        ;
 $7B43 DJNZ $7B23    ;
 $7B45 RET           ;
*$7B46 LD (HL),$FF   ; Mark tile visited ($FF)
 $7B48 LD A,$70      ; {Swap Joe's sprite to the soldier costume
 $7B4A LD ($80D8),A  ;
 $7B4D LD A,$A8      ;
 $7B4F LD ($80CF),A  ; }
 $7B52 LD A,$01      ;
 $7B54 LD ($7B08),A  ; disguise active
 $7B57 CALL $923C    ; Draw black box on the screen
 $7B5A LD IX,$7B73   ;
 $7B5E LD HL,$4868   ; HL = screen row 11 col 8
 $7B61 CALL $9196    ; Draw string IX
 $7B64 CALL $856E    ; Pickup/beep sound effect
 $7B67 CALL $9296    ; Delay
 $7B6A LD HL,$0000   ; {Reset disguise duration timer $7B06
 $7B6D LD ($7B06),HL ; }
 $7B70 JP $8C00      ; => Build room background into shadow buffer $B800

; "AN ENEMY UNIFORM" (disguise pickup message)
b$7B73 DEFB $00,$0D,$1F,$04,$0D,$04,$0C,$18 ; {"AN ENEMY UNIFORM" (disguise
 $7B7B DEFB $1F,$14,$0D,$08,$05,$0E,$11,$0C ; pickup message)
 $7B83 DEFB $FF                             ; }

; Disguise duration timer: auto-expire and revert
;
; Used by the routine at #R$8F00.
;
; .
;
; Called every frame from #R$8F00. While disguised ($7B08<>0), increments the
; 16-bit timer $7B06; once its high byte reaches 5 (~1280 frames), clears $7B08
; and restores Joe's normal sprite ($80CF/$80D8 -> $D8/$D0). No player input
; involved - the disguise just runs out.
@label=UniformTime
c$7B84 LD A,($7B08)  ; {Check disguise flag $7B08
 $7B87 OR A          ; }
 $7B88 RET Z         ; Return if not disguised
 $7B89 LD HL,($7B06) ; {Increment timer $7B06
 $7B8C INC HL        ;
 $7B8D LD A,H        ;
 $7B8E LD ($7B06),HL ; }
 $7B91 CP $05        ; Not yet expired? (CP $05)
 $7B93 RET NZ        ;
 $7B94 XOR A         ; {Expired: clear $7B08, restore normal sprite
 $7B95 LD H,A        ;
 $7B96 LD L,A        ;
 $7B97 LD ($7B08),A  ;
 $7B9A LD ($7B06),HL ;
 $7B9D LD A,$D8      ;
 $7B9F LD ($80CF),A  ; }
 $7BA2 LD A,$D0      ;
 $7BA4 LD ($80D8),A  ;
 $7BA7 RET           ;

; "SELF DESTRUCT IN 30 SECONDS" (bomb minigame message)
b$7BA8 DEFB $12,$04,$0B,$05,$1F,$03,$04,$12
 $7BB0 DEFB $13,$11,$14,$02,$13,$1F,$08,$0D
 $7BB8 DEFB $1F,$23,$20,$1F,$12,$04,$02,$0E
 $7BC0 DEFB $0D,$03,$12,$FF

; Draw a small 3x3-block icon (used by the bomb-deactivation minigame)
;
; Used by the routine at #R$7C3F.
;
; .
;
; DE=source, HL=destination (both caller-supplied). Blits a 24x24 block as 3
; columns of 8 rows x 3 bytes, advancing HL by one screen-row per pixel row and
; shifting to the next column after each. Only caller is #R$7C3F (draw the
; access code) - draws each of the 5 access-code letter icons (see #R$6298's
; confirmed letter-icon set: $6250 + key_code*72 with codes 1-5).
@label=BombGameDrawLetter
c$7BC4 PUSH HL       ; {Outer loop: 3 columns
 $7BC5 LD B,$03      ; }
*$7BC7 PUSH BC       ; {Inner loop: 8 pixel rows
 $7BC8 PUSH HL       ;
 $7BC9 LD B,$08      ;
 $7BCB NOP           ; }
*$7BCC LD A,(DE)     ; {Copy 3 bytes/row (DE->HL)
 $7BCD LD (HL),A     ;
 $7BCE INC DE        ;
 $7BCF INC HL        ;
 $7BD0 LD A,(DE)     ;
 $7BD1 LD (HL),A     ;
 $7BD2 INC DE        ;
 $7BD3 INC HL        ;
 $7BD4 LD A,(DE)     ;
 $7BD5 LD (HL),A     ;
 $7BD6 INC DE        ;
 $7BD7 DEC HL        ;
 $7BD8 DEC HL        ;
 $7BD9 INC H         ;
 $7BDA DJNZ $7BCC    ; }
 $7BDC POP HL        ;
 $7BDD LD C,$20      ;
 $7BDF ADD HL,BC     ;
 $7BE0 POP BC        ;
 $7BE1 DJNZ $7BC7    ;
 $7BE3 POP HL        ; {HL += 6 (advance past icon)
 $7BE4 LD C,$06      ;
 $7BE6 ADD HL,BC     ;
 $7BE7 RET           ; }

; Bomb minigame: clear/redraw, scramble the access code
;
; Used by the routine at #R$7CE1.
;
; .
;
; Clears the bitmap third at $4800, fills the top/bottom attribute strips,
; draws the "SELF DESTRUCT IN 30 SECONDS" instructions text, resets the cursor
; state ($7B00/$7B0B), then picks one of 8 access-code scrambles from the table
; at #R$7A00 using the R register as a pseudo-random index, copying it into
; $7B01-$7B05 as the access code to sort.
@label=BombGameSetup
c$7BE8 LD HL,$4800   ; {Clear bitmap third at $4800 (HL = screen row 8 col 0)
 $7BEB LD DE,$4801   ;
 $7BEE LD BC,$07FF   ;
 $7BF1 LD (HL),L     ;
 $7BF2 LDIR          ; }
 $7BF4 LD HL,$5900   ; {Fill 64 bytes at $5900 with attribute $45
 $7BF7 LD B,$40      ;
*$7BF9 LD (HL),$45   ;
 $7BFB INC HL        ;
 $7BFC DJNZ $7BF9    ; }
 $7BFE LD B,$C0      ; {Fill 192 bytes with attribute $41
*$7C00 LD (HL),$41   ;
 $7C02 INC HL        ;
 $7C03 DJNZ $7C00    ; }
 $7C05 LD IX,$7BA8   ; "SELF DESTRUCT IN 30 SECONDS"
 $7C09 LD HL,$4801   ; HL = screen row 8 col 1
 $7C0C CALL $9196    ; Draw string IX
 $7C0F LD A,$12      ;
 $7C11 LD ($7B00),A  ;
 $7C14 XOR A         ;
 $7C15 LD HL,$7B0B   ;
 $7C18 LD (HL),A     ;
 $7C19 CALL $7CDA    ; Set bomb-minigame timer to $0300
 $7C1C NOP           ;
 $7C1D LD A,R        ; {E = R register & 7 (pseudo-random 0-7)
 $7C1F AND $07       ;
 $7C21 LD E,A        ;
 $7C22 LD D,$00      ; }
 $7C24 LD HL,$7A00   ; {HL = #R$7A00 + E*5 (random 5-byte preset)
 $7C27 ADD HL,DE     ;
 $7C28 ADD HL,DE     ;
 $7C29 ADD HL,DE     ;
 $7C2A ADD HL,DE     ;
 $7C2B ADD HL,DE     ; }
 $7C2C LD DE,$7B01   ;
 $7C2F LD B,$05      ;
*$7C31 LD A,(HL)     ; {Copy 5 bytes into $7B01 (current key assignment)
 $7C32 LD (DE),A     ;
 $7C33 INC DE        ;
 $7C34 INC HL        ;
 $7C35 DJNZ $7C31    ; }
 $7C37 NOP           ;
 $7C38 LD HL,$0103   ; {$7B09 = $0103 (init cursor position)
 $7C3B LD ($7B09),HL ;
 $7C3E RET           ; }

; Bomb minigame - draw the access code (5 big letters)
;
; Used by the routine at #R$7800.
;
; .
;
; For each of the access code's 5 letter slots ($7B01-$7B05), looks up a glyph
; in a 72-byte-stride table at $6250 by letter code and draws it via #R$7BC4.
@label=BombGameDrawLetters
c$7C3F LD IX,$7B01   ; IX = $7B01 (key assignment slots)
 $7C43 LD HL,$4862   ; HL = screen row 11 col 2
 $7C46 LD B,$05      ; B = 5
*$7C48 PUSH BC       ;
 $7C49 PUSH HL       ;
 $7C4A LD B,(IX+$00) ; {HL = $6250 + key_code*72 (symbol lookup)
 $7C4D LD HL,$6250   ;
 $7C50 LD DE,$0048   ;
 $7C53 XOR A         ; }
 $7C54 OR B          ;
 $7C55 JR Z,$7C5A    ;
*$7C57 ADD HL,DE     ;
 $7C58 DJNZ $7C57    ;
*$7C5A EX DE,HL      ;
 $7C5B POP HL        ;
 $7C5C CALL $7BC4    ; Draw a small 3x3-block icon
 $7C5F INC IX        ;
 $7C61 POP BC        ;
 $7C62 DJNZ $7C48    ;
 $7C64 RET           ;

; Bomb minigame - cursor blink; drives the 30s timer $7B0C/$7B0D
;
; Used by the routine at #R$7800.
;
; .
;
; Per-frame tick for the bomb-deactivation minigame. Increments the blink timer
; $7B0B, and every 48 frames (wrap at $30) advances a displayed symbol AND
; decrements the countdown $7B0C/$7B0D (a base-10 digit pair: low byte cycles
; 9-0 repeating, high byte drops once per full low-digit cycle), redrawing the
; symbol preview via #R$7CA4. Live-confirmed: starting from $7B0C=0/$7B0D=3
; (set by #R$7CDA), it takes exactly 30 ticks (30*48=1440 frames, ~28.8s @50Hz)
; to reach 0/0 - matching the "30 SECONDS" message and the exact value #R$7800
; checks for timeout. Then runs a 6-column left-rotate ("running line") effect
; over the block at $491F, independent of the blink timer.
@label=BombGameTick
c$7C65 LD HL,$7B0B   ; {Increment blink timer $7B0B
 $7C68 INC (HL)      ; }
 $7C69 LD A,(HL)     ; {Wrap at 48 frames? branch
 $7C6A CP $30        ;
 $7C6C JR NZ,$7C86   ; }
 $7C6E LD (HL),$00   ; {Advance displayed key index ($7B00)
 $7C70 LD A,($7B00)  ;
 $7C73 SUB $06       ; }
 $7C75 CALL $7CD4    ; Wrap displayed key index into $7B00
 $7C78 INC HL        ;
 $7C79 DEC (HL)      ;
 $7C7A LD A,(HL)     ;
 $7C7B CP $FF        ;
 $7C7D JR NZ,$7C83   ;
 $7C7F LD (HL),$09   ;
 $7C81 INC HL        ;
 $7C82 DEC (HL)      ;
*$7C83 CALL $7CA4    ; Bomb minigame - draw the two symbol-preview columns
*$7C86 LD HL,$491F   ; Screen row 8 col 31
 $7C89 LD B,$06      ; B = 6 columns (scanline effect)
*$7C8B PUSH BC       ;
 $7C8C LD D,H        ;
 $7C8D LD E,$00      ;
 $7C8F LD A,(DE)     ;
 $7C90 RL A          ;
 $7C92 PUSH HL       ;
 $7C93 LD B,$20      ;
*$7C95 RL (HL)       ;
 $7C97 DEC HL        ;
 $7C98 DJNZ $7C95    ;
 $7C9A POP HL        ;
 $7C9B INC H         ;
 $7C9C POP BC        ;
 $7C9D DJNZ $7C8B    ;
 $7C9F RET           ;

; Unused
s$7CA0 DEFS $04

; Bomb minigame - draw the two symbol-preview columns
;
; Used by the routine at #R$7C65.
;
; .
;
; Draws two 7-byte columns onto the screen (at $48xx, column from $7B00) from
; two lookup tables at $A700+ (indexed by $7B0C) and a second at $48xx-1
; (indexed by $7B0D) - split across two source tables.
c$7CA4 LD D,$A7      ; {DE = $A700 + $7B0C*8 (symbol source, column 1)
 $7CA6 LD A,($7B0C)  ;
 $7CA9 RLCA          ;
 $7CAA RLCA          ;
 $7CAB RLCA          ;
 $7CAC LD E,A        ;
 $7CAD LD H,$48      ;
 $7CAF LD A,($7B00)  ; }
 $7CB2 ADD A,$01     ;
 $7CB4 LD L,A        ;
 $7CB5 LD B,$07      ; {Draw 7-byte column 1
*$7CB7 LD A,(DE)     ;
 $7CB8 LD (HL),A     ;
 $7CB9 INC DE        ;
 $7CBA INC H         ; }
 $7CBB DJNZ $7CB7    ;
 $7CBD LD H,$48      ; {DE = $7B0D*8 (symbol source, column 2)
 $7CBF DEC HL        ;
 $7CC0 LD A,($7B0D)  ;
 $7CC3 RLCA          ;
 $7CC4 RLCA          ;
 $7CC5 RLCA          ;
 $7CC6 LD E,A        ; }
 $7CC7 LD B,$07      ; {Draw 7-byte column 2
*$7CC9 LD A,(DE)     ;
 $7CCA LD (HL),A     ;
 $7CCB INC H         ;
 $7CCC INC DE        ; }
 $7CCD DJNZ $7CC9    ;
 $7CCF NOP           ; {Unused padding (4x NOP)
 $7CD0 NOP           ;
 $7CD1 NOP           ;
 $7CD2 NOP           ; }
 $7CD3 RET           ;

; Wrap displayed key index into $7B00
;
; Used by the routine at #R$7C65.
;
; .
;
; Masks A to 0-31 (AND $1F) and stores it back into $7B00 - called only from
; #R$7C65's blink-timer tick (A = $7B00-6 beforehand) to keep the "displayed
; key index" wrapped in range as it cycles.
@label=WrapKeyIndex
c$7CD4 AND $1F       ;
 $7CD6 LD ($7B00),A  ;
 $7CD9 RET           ;

; Set bomb-minigame timer to $0300
;
; Used by the routine at #R$7BE8.
;
; .
;
; Called from #R$7BE8 (bomb minigame setup). Sets $7B0C/$7B0D = $0300 - the
; starting value for the 30-second countdown driven by #R$7C65 (live-confirmed
; to take ~28.8s to expire, see docs/Actors.md).
@label=SetBombTimer
c$7CDA LD HL,$0300   ;
 $7CDD LD ($7B0C),HL ;
 $7CE0 RET           ;

; Bomb minigame entry: save screen state, clear status area
;
; Used by the routine at #R$7800.
;
; .
;
; Called only from #R$7800, right at the start. Saves the current attribute
; byte at $5900 into $7B0E (for later restoration), clears 480 bytes of
; status-bar attributes at $5860, then hands off to #R$7BE8 to set up the
; access-code sort puzzle.
@label=BombGameEntry
c$7CE1 LD A,($5900)  ; {Save current attribute ($5900) to $7B0E
 $7CE4 LD ($7B0E),A  ; }
 $7CE7 LD HL,$5860   ; {Clear 480 bytes at $5860
 $7CEA LD DE,$5861   ;
 $7CED LD (HL),$00   ; }
 $7CEF LD BC,$01E0   ;
 $7CF2 LDIR          ;
 $7CF4 JP $7BE8      ; => Bomb minigame

; Reduce energy, if allowed
;
; Used by the routine at #R$93DC.
@label=TryReduceEnergy
c$7CF7 LD A,($7B08)  ;
 $7CFA OR A          ;
 $7CFB RET NZ        ;
 $7CFC JP $93A0      ; => Reduce energy

; Data block at 7CFF
b$7CFF DEFB $3E

; Start game: draw sign, reset variables, drop into game loop
;
; Used by the routine at #R$8B37.
;
; .
;
; Entered from #R$8B37 when 'S' is pressed on the main menu. Redraws the "JOE
; BLADE" sign and title strings, resets game variables to their initial values,
; then re-enables energy loss ($7D45) before falling into the main game loop.
@label=StartGame
c$7D00 CALL $A3CB    ; Entry-point trampoline
 $7D03 NOP           ;
 $7D04 NOP           ;
 $7D05 NOP           ;
 $7D06 CALL $83C0    ; Clear screen, border to black
 $7D09 NOP           ;
 $7D0A NOP           ;
 $7D0B NOP           ;
 $7D0C LD HL,$4000   ; Address on the screen (HL = screen row 0 col 0)
 $7D0F CALL $8B05    ; Show "JOE BLADE" big sign; HL = screen address
 $7D12 LD IX,$90E0   ;
 $7D16 LD HL,$5074   ; HL = screen row 19 col 20
 $7D19 CALL $9196    ; Draw string IX
 $7D1C LD HL,$50B9   ; HL = screen row 21 col 25
 $7D1F CALL $9196    ; Draw string IX
 $7D22 LD HL,$50F8   ; HL = screen row 23 col 24
 $7D25 CALL $9196    ; Draw string IX
 $7D28 LD HL,$5061   ; HL = screen row 19 col 1
 $7D2B CALL $9196    ; Draw string IX
 $7D2E LD HL,$0000   ;
 $7D31 CALL $9196    ; Draw string IX
 $7D34 LD HL,$50E1   ; HL = screen row 23 col 1
 $7D37 CALL $9196    ; Draw string IX
 $7D3A LD HL,$50E8   ; HL = screen row 23 col 8
 $7D3D CALL $9196    ; Draw string IX
 $7D40 CALL $9498    ; Set initial values
 $7D43 LD A,$00      ;
 $7D45 LD ($7B08),A  ; allow to reduce energy
 $7D48 LD HL,$0000   ;
 $7D4B LD HL,($7B06) ;
 $7D4E LD A,$D8      ;
 $7D50 LD ($80CF),A  ;
 $7D53 LD A,$D0      ;
 $7D55 LD ($80D8),A  ;
 $7D58 NOP           ;
 $7D59 NOP           ;
 $7D5A NOP           ;
 $7D5B NOP           ;
 $7D5C NOP           ;
 $7D5D NOP           ;
 $7D5E NOP           ;
 $7D5F NOP           ;
 $7D60 NOP           ;
 $7D61 JP $8114      ; => Per-frame room-tile lookup, then hand off to game
                     ; loop

; Soldier pattern 4: chase + slow vertical drift
;
; Used by the routine at #R$96CC.
;
; .
;
; #R$900A (horizontal chase of Joe's X) plus a fixed vertical drift: adds $0800
; to the 16-bit fine-position accumulator $8F8D every frame, deriving the
; coarse row address $8F90 from it (H-4). Shared tail #R$7D6A also used by
; patterns 5/6.
@label=SoldierPattern4
c$7D64 CALL $900A    ; Soldier pattern 1
 $7D67 LD BC,$0800   ; BC = $0800 (slow drift rate)
; This entry point is used by the routines at #R$7D82 and #R$7D8C.
*$7D6A LD HL,($8F8D) ; {$8F8D += BC
 $7D6D ADD HL,BC     ;
 $7D6E LD ($8F8D),HL ; }
 $7D71 DEC H         ; {Derive coarse row $8F90 from it
 $7D72 DEC H         ;
 $7D73 DEC H         ;
 $7D74 DEC H         ;
 $7D75 LD ($8F90),HL ; }
 $7D78 RET           ;

; Data block at 7D79
b$7D79 DEFB $40,$59,$11,$FF,$00,$00,$00,$00
 $7D81 DEFB $00

; Soldier pattern 5: chase + fast vertical drift
;
; Used by the routine at #R$96CC.
;
; .
;
; Same as #R$7D64 but BC=$2000 (4x the drift rate).
@label=SoldierPattern5
c$7D82 CALL $900A    ; Soldier pattern 1
 $7D85 LD BC,$2000   ;
 $7D88 JP $7D6A      ;

; Unused
s$7D8B DEFS $01

; Soldier pattern 6: patrol (group B) + slow vertical drift
;
; Used by the routine at #R$96CC.
;
; .
;
; #R$8164 (synchronized left-right patrol, group B) plus the same slow vertical
; drift as pattern 4.
@label=SoldierPattern6
c$7D8C CALL $8164    ; Soldier pattern 3
 $7D8F LD BC,$0800   ; BC = $0800 (slow drift rate)
 $7D92 JP $7D6A      ;

; Unused
s$7D95 DEFS $01

; Clamp room-tile pointers, hand off to game loop $8F00
;
; Used by the routine at #R$FFAD.
;
; .
;
; Called from #R$FFAD every time the room-tile ($8202) changes. Checks the
; current tile's high byte in #R$9700 against $40/$A5 and clamps out-of-range
; values to $46/$A5, then does the same check for #R$7900 but clamps to $4E/$9D
; instead - so the two threshold tables always hold sane, table-specific values
; for the new tile even if the raw data byte was out of range. Also clears the
; shot-hit flag $7B10 before falling into #R$8F00, the main game loop.
@label=ClampTilePtrs
c$7D96 LD A,($8202)  ; {Clamp tile pointer at #R$9700+ to range $40-$A5
 $7D99 LD H,$97      ;
 $7D9B RLCA          ;
 $7D9C INC A         ;
 $7D9D LD L,A        ;
 $7D9E LD A,(HL)     ;
 $7D9F SUB $40       ;
 $7DA1 JR NC,$7DA5   ; }
 $7DA3 LD (HL),$46   ; {Clamp low bound, check/clamp high bound
*$7DA5 LD A,(HL)     ;
 $7DA6 SUB $A5       ;
 $7DA8 JR C,$7DAC    ;
 $7DAA LD (HL),$A5   ;
*$7DAC NOP           ; }
 $7DAD LD A,($8202)  ; {Clamp tile pointer at #R$7900+ to range $40-$A5
 $7DB0 LD H,$79      ;
 $7DB2 RLCA          ;
 $7DB3 INC A         ;
 $7DB4 LD L,A        ;
 $7DB5 LD A,(HL)     ;
 $7DB6 SUB $40       ;
 $7DB8 JR NC,$7DBC   ; }
 $7DBA LD (HL),$4E   ; {Clamp low bound, check/clamp high bound
*$7DBC LD A,(HL)     ;
 $7DBD SUB $A5       ;
 $7DBF JR C,$7DC3    ;
 $7DC1 LD (HL),$9D   ; }
*$7DC3 XOR A         ; {Clear $7B10 flag
 $7DC4 LD ($7B10),A  ; }
 $7DC7 NOP           ; {Continue at #R$8F00
 $7DC8 NOP           ;
 $7DC9 JP $8F00      ; }

; Footstep sound effect
;
; Used by the routine at #R$8F00.
;
; .
;
; Called every frame from #R$8F00. If Joe is grid-aligned (X&$07==4), not
; mid-jump ($8209=0), and left/right is pressed, plays a 6-step
; alternating-pitch border click - the walking footstep sound.
@label=SFX_footstep
c$7DCC LD A,($8201)  ; {Grid-aligned (X&$07==4)?
 $7DCF AND $07       ;
 $7DD1 CP $04        ;
 $7DD3 RET NZ        ; }
 $7DD4 LD A,($8209)  ; {Not mid-jump ($8209=0)?
 $7DD7 OR A          ;
 $7DD8 RET NZ        ; }
 $7DD9 LD A,($820A)  ; get input state
 $7DDC AND $03       ;
 $7DDE RET Z         ;
 $7DDF LD A,($8201)  ; get Joe X
 $7DE2 AND $07       ;
 $7DE4 ADD A,$05     ;
 $7DE6 LD B,$06      ;
 $7DE8 LD C,A        ;
*$7DE9 PUSH BC       ;
 $7DEA XOR A         ;
 $7DEB OUT ($FE),A   ;
 $7DED LD B,C        ;
*$7DEE DJNZ $7DEE    ;
 $7DF0 ADD A,$10     ;
 $7DF2 OUT ($FE),A   ;
 $7DF4 LD B,C        ;
*$7DF5 DJNZ $7DF5    ;
 $7DF7 POP BC        ;
 $7DF8 DJNZ $7DE9    ;
 $7DFA RET           ;

; Data block at 7DFB
b$7DFB DEFB $00,$00,$00,$00,$00,$F3,$11,$01
 $7E03 DEFB $05,$21,$00,$40,$06,$00,$C5,$06
 $7E0B DEFB $00,$1A,$E6,$3C,$F6,$C6,$32,$15
 $7E13 DEFB $7E,$CB,$CE,$23,$13,$7C,$FE,$48
 $7E1B DEFB $20,$02,$26,$40,$7A,$FE,$3D,$20
 $7E23 DEFB $02,$16,$00,$10,$E4,$C1,$10,$DE
 $7E2B DEFB $FB,$C9,$00,$00,$00,$00,$00

; Movement/collision: jump dispatch, then level (row) edge transitions
;
; Used by the routine at #R$8F00.
;
; .
;
; Dispatches on $8209 first (bit0 -> #R$7FD2 -> #R$7F6E, a rightward jump-arc;
; bit1 -> #R$7FDC -> #R$7FA0, a leftward jump-arc - these handle horizontal
; room changes; bit7 -> jump timer #R$7FE6), then checks the 4 up/down x
; left/right edge combos below to change the current level/row ($8204). Room
; (column, $8203) changes are not handled here directly - they happen inside
; the jump-arc routines when a jump carries Joe past the screen edge.
@label=MoveJoe
c$7E32 LD A,($8209)  ; {Dispatch: $8209 bit0 -> #R$7FD2 (jump right), bit1 ->
 $7E35 LD C,A        ; #R$7FDC (jump left)
 $7E36 AND $01       ; }
 $7E38 JP NZ,$7FD2   ; => Jump timer tick + Jump-arc step, right
 $7E3B LD A,C        ;
 $7E3C AND $02       ;
 $7E3E JP NZ,$7FDC   ; => Jump timer tick + Jump-arc step, left
 $7E41 LD A,C        ; {Dispatch: $8209 bit7 -> #R$7FE6 (jump timer)
 $7E42 AND $80       ;
 $7E44 JP NZ,$7FE6   ; }
 $7E47 NOP           ;
 $7E48 NOP           ;
 $7E49 NOP           ;
 $7E4A NOP           ;
 $7E4B NOP           ;
 $7E4C NOP           ;
 $7E4D NOP           ;
 $7E4E NOP           ;
 $7E4F NOP           ;
 $7E50 NOP           ;
 $7E51 NOP           ;
 $7E52 NOP           ;
 $7E53 NOP           ;
 $7E54 LD A,($820A)  ; {UP input + 'door' tile ($820C bit4)?
 $7E57 LD C,A        ;
 $7E58 AND $08       ;
 $7E5A JR Z,$7E7E    ;
 $7E5C LD A,($820C)  ;
 $7E5F AND $10       ;
 $7E61 JR Z,$7E7E    ; }
 $7E63 LD A,($8201)  ; {At left edge (X&$E0=$20)?
 $7E66 ADD A,$10     ;
 $7E68 AND $E0       ;
 $7E6A CP $20        ;
 $7E6C JR NZ,$7E7E   ; }
 $7E6E LD A,($8204)  ; {level++ ($8204, wraps 0-15)
 $7E71 INC A         ;
 $7E72 AND $0F       ;
 $7E74 LD ($8204),A  ; }
 $7E77 POP BC        ;
 $7E78 CALL $7F64    ; Sound effect - descending pitch sweep
 $7E7B JP $8114      ; => Per-frame room-tile lookup, then hand off to game
                     ; loop
*$7E7E NOP           ;
 $7E7F NOP           ;
 $7E80 NOP           ;
 $7E81 NOP           ;
 $7E82 NOP           ;
 $7E83 LD A,C        ; {DOWN input + 'door' tile ($820C bit5)?
 $7E84 AND $04       ;
 $7E86 JR Z,$7EAA    ;
 $7E88 LD A,($820C)  ;
 $7E8B AND $20       ;
 $7E8D JR Z,$7EAA    ; }
 $7E8F LD A,($8201)  ; {At left edge (X&$E0=$20)?
 $7E92 ADD A,$10     ;
 $7E94 AND $E0       ;
 $7E96 CP $20        ;
 $7E98 JR NZ,$7EAA   ; }
 $7E9A LD A,($8204)  ; {level-- ($8204, wraps 0-15)
 $7E9D DEC A         ;
 $7E9E AND $0F       ;
 $7EA0 LD ($8204),A  ; }
 $7EA3 POP BC        ;
 $7EA4 CALL $7F64    ; Sound effect - descending pitch sweep
 $7EA7 JP $8114      ; => Per-frame room-tile lookup, then hand off to game
                     ; loop
*$7EAA NOP           ;
 $7EAB NOP           ;
 $7EAC NOP           ;
 $7EAD NOP           ;
 $7EAE NOP           ;
 $7EAF LD A,C        ; {UP input + 'door' tile ($820C bit2)?
 $7EB0 AND $08       ;
 $7EB2 JR Z,$7ED6    ;
 $7EB4 LD A,($820C)  ;
 $7EB7 AND $04       ;
 $7EB9 JR Z,$7ED6    ; }
 $7EBB LD A,($8201)  ; {At right edge (X&$E0=$C0)?
 $7EBE ADD A,$10     ;
 $7EC0 AND $E0       ;
 $7EC2 CP $C0        ;
 $7EC4 JR NZ,$7ED6   ; }
 $7EC6 LD A,($8204)  ; {level++ ($8204, wraps 0-15)
 $7EC9 INC A         ;
 $7ECA AND $0F       ;
 $7ECC LD ($8204),A  ; }
 $7ECF POP BC        ;
 $7ED0 CALL $7F64    ; Sound effect - descending pitch sweep
 $7ED3 JP $8114      ; => Per-frame room-tile lookup, then hand off to game
                     ; loop
*$7ED6 NOP           ;
 $7ED7 NOP           ;
 $7ED8 NOP           ;
 $7ED9 NOP           ;
 $7EDA NOP           ;
 $7EDB LD A,C        ; {DOWN input + 'door' tile ($820C bit3)?
 $7EDC AND $04       ;
 $7EDE JR Z,$7F02    ;
 $7EE0 LD A,($820C)  ;
 $7EE3 AND $08       ;
 $7EE5 JR Z,$7F02    ; }
 $7EE7 LD A,($8201)  ; {At right edge (X&$E0=$C0)?
 $7EEA ADD A,$10     ;
 $7EEC AND $E0       ;
 $7EEE CP $C0        ;
 $7EF0 JR NZ,$7F02   ; }
 $7EF2 LD A,($8204)  ; {level-- ($8204, wraps 0-15)
 $7EF5 DEC A         ;
 $7EF6 AND $0F       ;
 $7EF8 LD ($8204),A  ; }
 $7EFB POP BC        ;
 $7EFC CALL $7F64    ; Sound effect - descending pitch sweep
 $7EFF JP $8114      ; => Per-frame room-tile lookup, then hand off to game
                     ; loop
*$7F02 NOP           ;
 $7F03 NOP           ;
 $7F04 NOP           ;
 $7F05 LD A,($820A)  ; {UP+RIGHT combo ($820A&$0B=$09, bit0=right/bit3=up) ->
 $7F08 LD C,A        ; $8209=1, retry #R$7E32
 $7F09 AND $0B       ;
 $7F0B CP $09        ;
 $7F0D JR NZ,$7F17   ;
 $7F0F LD A,$01      ;
 $7F11 LD ($8209),A  ; }
 $7F14 JP $7E32      ; => Movement/collision
*$7F17 CP $0A        ; {UP+LEFT combo (else &$0B=$0A, bit1=left/bit3=up) ->
 $7F19 JR NZ,$7F23   ; $8209=2, retry #R$7E32
 $7F1B LD A,$02      ;
 $7F1D LD ($8209),A  ; }
 $7F20 JP $7E32      ; => Movement/collision
*$7F23 AND $08       ;
 $7F25 JR Z,$7F2F    ;
 $7F27 LD A,$80      ;
 $7F29 LD ($8209),A  ;
 $7F2C JP $7E32      ; => Movement/collision
*$7F2F NOP           ;
 $7F30 NOP           ;
 $7F31 NOP           ;
 $7F32 NOP           ;
 $7F33 LD A,C        ;
 $7F34 AND $01       ;
 $7F36 JP NZ,$7F6E   ; => Jump-arc step, right
 $7F39 LD A,C        ;
 $7F3A AND $02       ;
 $7F3C JP NZ,$7FA0   ; => Jump-arc step, left
 $7F3F NOP           ;
 $7F40 NOP           ;
 $7F41 NOP           ;
 $7F42 NOP           ;
 $7F43 RET           ;

