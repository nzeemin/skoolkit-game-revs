; Draw sprite 32x32 with mask (masked blit)
;
; Used by the routines at #R$8F8C and #R$9118.
;
; .
;
; BC=sprite addr, DE=mask addr, HL=dest. Standard AND-mask/OR-pixels blit, 4
; rows x 8 rows x 4 bytes = 32x32. Used by #R$8F8C (draw soldier) and #R$9118
; (draw collectible icon).
@label=DrawSpriteMasked
c$81AA LD A,$04      ; Outer loop: 4 column-groups
*$81AC PUSH AF       ;
 $81AD PUSH HL       ;
 $81AE LD A,$08      ; Inner loop: 8 rows
*$81B0 PUSH AF       ;
 $81B1 PUSH HL       ;
 $81B2 LD A,(DE)     ; {0: AND mask, OR pixels, write (one 8-pixel strip)
 $81B3 AND (HL)      ;
 $81B4 LD (HL),A     ;
 $81B5 LD A,(BC)     ;
 $81B6 OR (HL)       ;
 $81B7 LD (HL),A     ; }
 $81B8 INC BC        ;
 $81B9 INC DE        ;
 $81BA INC HL        ;
 $81BB LD A,(DE)     ; {1
 $81BC AND (HL)      ;
 $81BD LD (HL),A     ;
 $81BE LD A,(BC)     ;
 $81BF OR (HL)       ;
 $81C0 LD (HL),A     ; }
 $81C1 INC BC        ;
 $81C2 INC DE        ;
 $81C3 INC HL        ;
 $81C4 LD A,(DE)     ; {2
 $81C5 AND (HL)      ;
 $81C6 LD (HL),A     ;
 $81C7 LD A,(BC)     ;
 $81C8 OR (HL)       ;
 $81C9 LD (HL),A     ; }
 $81CA INC BC        ;
 $81CB INC DE        ;
 $81CC INC HL        ;
 $81CD LD A,(DE)     ; {3
 $81CE AND (HL)      ;
 $81CF LD (HL),A     ;
 $81D0 LD A,(BC)     ;
 $81D1 OR (HL)       ;
 $81D2 LD (HL),A     ; }
 $81D3 INC BC        ; {Advance strip pointers, loop 8 rows
 $81D4 INC DE        ;
 $81D5 NOP           ; }
 $81D6 POP HL        ; {Restore row group, loop 4 groups
 $81D7 POP AF        ;
 $81D8 INC H         ;
 $81D9 DEC A         ;
 $81DA JR NZ,$81B0   ; }
 $81DC POP HL        ; Restore HL
 $81DD LD A,L        ; {Advance X by $20
 $81DE ADD A,$20     ;
 $81E0 LD L,A        ; }
 $81E1 POP AF        ; {Restore AF, loop 2 rows
 $81E2 DEC A         ;
 $81E3 JR NZ,$81AC   ; }
 $81E5 RET           ;

