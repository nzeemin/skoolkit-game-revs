; Main game loop
;
; Used by the routine at #R$7D96.
;
; .
;
; Reached from #R$7D00 via #R$8114/#R$FFAD/#R$7D96 when 'S' starts the game.
; One iteration per HALT: runs room/collision/energy/door subsystems, redraws
; Joe and the soldier, then polls the '0' key on row $EFFE - loop back to
; itself while not pressed, otherwise reset the stack and jump to #R$8EB4 (back
; to the menu/game-over flow).
@label=GameLoop
c$8F00 CALL $8D3C    ; Check for bomb tile at screen edge, trigger bomb
                     ; minigame
 $8F03 CALL $A750    ; Jump sound effect, gated on jump counter $820D
 $8F06 CALL $9650    ; Countdown timer tick, MM:SS-style display at $85FA
 $8F09 CALL $7B1E    ; Uniform pickup
 $8F0C CALL $FF96    ; Per-frame soldier update
 $8F0F CALL $850E    ; Rolling-digit counter increment
 $8F12 CALL $7B84    ; Disguise duration timer
 $8F15 CALL $A3BA    ; Per-frame collectible items scan
 $8F18 CALL $7DCC    ; Footstep sound effect
 $8F1B CALL $8032    ; Read input into $820A
 $8F1E CALL $9602    ; Draw per-room door/object graphics from event-flags
                     ; table
 $8F21 LD HL,$8206   ; {Increment room counter at $8206
 $8F24 INC (HL)      ; }
 $8F25 CALL $7E32    ; Movement/collision
 $8F28 NOP           ;
 $8F29 EI            ; {Wait a frame (EI; HALT)
 $8F2A HALT          ; }
 $8F2B CALL $905A    ; Running line of symbols
 $8F2E CALL $FF14    ; Win-condition check
 $8F31 CALL $8546    ; Redraw the current score/counter digit string on screen
 $8F34 CALL $8F78    ; Pause
 $8F37 CALL $905A    ; Running line of symbols
 $8F3A CALL $8C78    ; Copy shadow screen to real screen
 $8F3D NOP           ;
 $8F3E CALL $80A0    ; Draw Joe sprite
 $8F41 CALL $8F8C    ; Draw soldier
 $8F44 CALL $93DC    ; Contact check
 $8F47 NOP           ;
 $8F48 EI            ; {Poll '0' key (row $EFFE)
 $8F49 LD BC,$EFFE   ;
 $8F4C IN A,(C)      ;
 $8F4E AND $01       ; }
 $8F50 JP NZ,$8F00   ; => Main game loop
 $8F53 LD SP,$6200   ; {'0' pressed: reset stack, jump to #R$8EB4
 $8F56 JP $8EB4      ; }

