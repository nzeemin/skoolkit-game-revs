; Set interrupt-vector page register I=$8A
;
; Used by the routine at #R$A3CB.
;
; .
;
; Called once at game start via #R$A3CB. Sets I=$8A - would only matter under
; IM2, but no `IM 2` instruction exists anywhere in the currently-disassembled
; 64K, so this may be vestigial/defensive rather than load-bearing.
@label=SetIntVector
c$8FB4 NOP           ; {Unused padding (8x NOP)
 $8FB5 NOP           ;
 $8FB6 NOP           ;
 $8FB7 NOP           ;
 $8FB8 NOP           ;
 $8FB9 NOP           ;
 $8FBA NOP           ;
 $8FBB NOP           ; }
 $8FBC LD A,$8A      ; A = $8A
 $8FBE LD I,A        ; Set I register
 $8FC0 RET           ;

