; Draw one more background row directly onto the real screen
;
; Used by the routine at #R$8C00.
;
; .
;
; Unlike #R$8C00, this draws straight to the live screen at $4080 instead of
; the shadow buffer, using a separate per-column selector table at #R$6C00
; indexed by $8202. Reason for the split: the shadow buffer only covers the
; 2-tile-tall band that changes frame-to-frame (Joe/soldier movement + jump
; height); this row is static per-room, so it's drawn once directly to the
; screen.
@label=DrawTopRow
c$8CF0 LD A,($8202)  ; {HL = $8202 * 8 (byte offset into table at #R$6C00)
 $8CF3 LD H,$00      ;
 $8CF5 LD L,A        ;
 $8CF6 ADD HL,HL     ;
 $8CF7 ADD HL,HL     ;
 $8CF8 ADD HL,HL     ; }
 $8CF9 LD IX,$6C00   ; {IX = #R$6C00 + offset (one selector byte per screen
 $8CFD EX DE,HL      ; column)
 $8CFE ADD IX,DE     ; }
 $8D00 NOP           ;
 $8D01 NOP           ;
 $8D02 NOP           ;
 $8D03 NOP           ;
 $8D04 NOP           ;
 $8D05 NOP           ;
 $8D06 NOP           ;
 $8D07 NOP           ;
 $8D08 NOP           ;
 $8D09 NOP           ;
 $8D0A NOP           ;
 $8D0B NOP           ;
 $8D0C NOP           ;
 $8D0D NOP           ;
 $8D0E NOP           ;
 $8D0F NOP           ;
 $8D10 NOP           ;
 $8D11 NOP           ;
 $8D12 LD HL,$4080   ; Top strip of the real screen, row 4 col 0
 $8D15 LD B,$08      ; B = 8 columns
*$8D17 PUSH BC       ;
 $8D18 PUSH HL       ;
 $8D19 LD DE,$0000   ; DE = 0
 $8D1C LD A,(IX+$00) ; {If selector byte bit0 set, E = $80
 $8D1F AND $01       ;
 $8D21 JR Z,$8D25    ; }
 $8D23 LD E,$80      ;
*$8D25 LD A,(IX+$00) ; {D = $E0 + ((selector byte >> 1) & $1F): back-sprite
 $8D28 AND $3E       ; source address
 $8D2A RRA           ;
 $8D2B ADD A,$E0     ; }
 $8D2D LD D,A        ;
 $8D2E INC IX        ; Advance to next selector byte
 $8D30 CALL $8C5A    ; Draw back sprite 32x32
 $8D33 POP HL        ; {HL += 4 (advance dest column)
 $8D34 INC HL        ;
 $8D35 INC HL        ;
 $8D36 INC HL        ;
 $8D37 INC HL        ; }
 $8D38 POP BC        ;
 $8D39 DJNZ $8D17    ;
 $8D3B RET           ;

; Check for bomb tile at screen edge, trigger bomb minigame
;
; Used by the routine at #R$8F00.
;
; .
;
; Scans the bomb tile table $9D18 (same table used for bomb pickup, see
; docs/Actors.md); if the current room-tile ($8202) matches one of them AND
; $820C bits 4-5 are clear AND Joe's X is at the screen edge ($20 or $C0),
; jumps to #R$7800 - the bomb-deactivation minigame ("SELF DESTRUCT IN 30
; SECONDS", sort the access code). Not a room-to-room transition.
@label=CheckRoomEdge
c$8D3C LD HL,$9D18   ; Table of 6 edge-tile IDs
 $8D3F LD B,$06      ; B = 6
*$8D41 LD A,($8202)  ; {Compare current tile ($8202) against table entry
 $8D44 CP (HL)       ;
 $8D45 JR NZ,$8D60   ; }
 $8D47 LD A,($820C)  ; {Check $820C bits 4-5 (tile flags)
 $8D4A AND $30       ;
 $8D4C JR NZ,$8D57   ; }
 $8D4E LD A,($8201)  ; {Joe at left edge (X=$20)? => #R$7800
 $8D51 CP $20        ; }
 $8D53 JP Z,$7800    ; => Bomb deactivation minigame
 $8D56 RET           ;
*$8D57 LD A,($8201)  ; {Joe at right edge (X=$C0)? => #R$7800
 $8D5A CP $C0        ; }
 $8D5C JP Z,$7800    ; => Bomb deactivation minigame
 $8D5F RET           ;
*$8D60 INC HL        ;
 $8D61 DJNZ $8D41    ;
 $8D63 RET           ;

