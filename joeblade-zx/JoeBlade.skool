; Draw a collectible-item sprite, left or right variant
;
; Used by the routines at #R$912C and #R$A2F6.
;
; .
;
; Called by #R$912C once a collectible tile has been matched (DE/other regs
; already set up by the caller for #R$81AA). Picks between two destination
; columns in the shadow buffer ($B898 or $B884) based on $820C bits4-5, then
; draws via #R$81AA.
@label=DrawItemSprite
c$9118 LD A,($820C)  ;
 $911B AND $30       ;
 $911D JR Z,$9125    ;
 $911F LD HL,$B898   ;
 $9122 JP $81AA      ; => Draw sprite 32x32 with mask
*$9125 LD HL,$B884   ;
 $9128 JP $81AA      ; => Draw sprite 32x32 with mask

