; (#R$8A3C-#R$8AD0). #R$C000/$C003/$C006 in bank 1 look like a 3-entry vector
; table (init/step/finish) for code resident in that bank; not yet identified
; further.
@label=MenuWait
c$8A12 XOR A         ; {Clear $8AFF menu-done flag
 $8A13 LD ($8AFF),A  ; }
