 $9606 SUB (IY+$06)   ;
 $9609 LD L,A         ; }
 $960A LD A,(IX+$0C)  ; {vertical delta high byte (+12) &3
 $960D SBC A,(IY+$0C) ;
 $9610 AND $03        ; }
 $9612 JR NZ,$961B    ; {same page: within 8 rows?
 $9614 LD A,L         ;
 $9615 CP $08         ;
 $9617 JR C,$9624     ; }
 $9619 JR $9648       ;
*$961B CP $03         ; {one-page-back wrap: within -7 rows?
