; MAIN_TICK -- one frame of the game.
;
; Used by the routine at #R$8064.
;
; .
;
; Called from main_loop.
; .
; Order: read input (unless frozen) -> run game-state machine (player move,
; tower rotation, enemies) -> redraw widgets -> HALT to sync to the 50Hz frame
; interrupt.
; .
; State: game_state ($60D9): 3=level transition, 4=finished,
; .
; else = normal play.
; .
; demo_pause ($60D8) skips logic.
; .
; freeze_ctr ($8004) freezes input for N frames.
; .
; Clobbers: most regs.
; .
; Returns once per frame.
; .
; i8080 PORT:
@label=main_tick
c$8240 LD HL,$8004   ; HL -> freeze_ctr (in code padding at $8004)
 $8243 LD A,(HL)     ; A = freeze counter
 $8244 OR A          ;
 $8245 JR Z,$8254    ; 0 = not frozen -> read input normally
 $8247 DEC (HL)      ; frozen: count down one frame
 $8248 XOR A         ;
 $8249 LD ($601D),A  ; zero the three input vars while frozen
 $824C LD ($601E),A  ;
 $824F LD ($601C),A  ;
 $8252 JR $8257      ;
*$8254 CALL $A700    ; proc_table[0] -> read keyboard/joystick
*$8257 LD A,($60D8)  ; A = demo_pause flag
 $825A OR A          ;
 $825B JR NZ,$8291   ; set -> skip all game logic (attract/demo), just redraw
 $825D LD A,($60D9)  ; A = game_state
 $8260 CP $03        ; state 3 = level transition?
 $8262 JR NZ,$8270   ;
 $8264 CALL $8482    ; run transition step
 $8267 LD A,($60D9)  ;
 $826A CP $04        ;
 $826C RET Z         ; state 4 = finished -> done this frame
 $826D JP $8291      ;
*$8270 CALL $A769    ; --- normal play: update one frame ---
 $8273 CALL $96E9    ; update actor position around/along the tower
                     ; (update_actor_pos)
 $8276 CALL $8482    ; advance level logic
 $8279 LD A,($60A4)  ; A = player column before move
 $827C PUSH AF       ;
 $827D CALL $A76F    ; move player (proc_table slot)
 $8280 POP AF        ;
 $8281 LD B,A        ;
 $8282 LD A,($60A4)  ; compare new vs old player column
 $8285 CP B          ;
 $8286 LD A,$00      ;
 $8288 CALL NZ,$A3DE ; column changed -> CALL $A3DE (redraw player cell)
 $828B CALL $90DA    ; update enemies/hazards
 $828E CALL $89C5    ; collision + scoring
*$8291 LD A,$24      ; --- redraw HUD: A = $24 (36 rows) ---
 $8293 LD HL,$60B9   ;
 $8296 SUB (HL)      ; subtract tower_height ($60B9)
 $8297 AND $7F       ;
 $8299 LD ($6032),A  ; store display height ($6032)
 $829C CALL $A751    ; draw widgets (proc_table slots)
 $829F CALL $A75A    ;
 $82A2 CALL $A75D    ;
 $82A5 CALL $A757    ;
 $82A8 PUSH AF       ;
 $82A9 CALL $8FC7    ; draw the player sprite
 $82AC HALT          ; HALT: wait for the 50Hz frame IRQ (Z80
 $82AD CALL $A41C    ; post-frame: flip buffers / housekeeping
 $82B0 CALL $A760    ;
 $82B3 CALL $A790    ;
 $82B6 CALL $8FFA    ;
 $82B9 CALL $A787    ;
 $82BC CALL $A796    ;
 $82BF POP AF        ;
 $82C0 CALL $A793    ;
 $82C3 CALL $A754    ;
 $82C6 CALL $A79C    ;
 $82C9 LD A,($60D9)  ;
 $82CC CP $03        ;
 $82CE JR Z,$82D9    ;
 $82D0 CALL $82DA    ;
 $82D3 CALL $A724    ;
 $82D6 CALL $A736    ;
*$82D9 RET           ;

; TALLY_SCORE_TO -- count $60BC up toward $60BA, awarding $10 (BCD) points per
; step via add_bcd_score, until the two 16-bit values meet.
;
; Used by the routine at #R$8240.
;
; .
;
; Used to animate an end-of-section bonus tally.
; .
