; READ_INPUT -- proc_table[0]: sample controls into the signed
; input_x/input_y/input_fire vars.
;
; Used by the routine at #R$A700.
;
; .
;
; Only active when game_mode ($6017) == 4 (in play) otherwise returns.
; .
; Reads the Kempston joystick and converts each axis to -1/0/+1 via bit tests +
; SBC/NEG.
; .
; i8080 PORT: input comes from IN A,($1F) (Kempston).
; .
; The Specialist has no Kempston port -- replace read_joystick with the
; target's keyboard/joystick scan, keeping the -1/0/+1 result.
@label=read_input
c$A79F LD A,($6017)  ; A = game_mode ($6017)
 $A7A2 CP $04        ;
 $A7A4 JR NZ,$A7ED   ; only read controls while in play (mode 4)
 $A7A6 CALL $A7C8    ; A = raw joystick bits
 $A7A9 LD B,A        ;
 $A7AA AND $01       ;
 $A7AC SRL B         ;
 $A7AE SRL B         ;
 $A7B0 SBC A,$00     ;
 $A7B2 LD ($601D),A  ; input_y = -1/0/+1
 $A7B5 LD A,B        ;
 $A7B6 AND $01       ;
 $A7B8 SRL B         ;
 $A7BA SRL B         ;
 $A7BC SBC A,$00     ;
 $A7BE NEG           ;
 $A7C0 LD ($601E),A  ; input_fire = -1/0/+1 (negated)
 $A7C3 LD A,B        ;
 $A7C4 LD ($601C),A  ; input_x = -1/0/+1
 $A7C7 RET           ;

; Routine at A7C8
;
; Used by the routine at #R$A79F.
@label=read_joystick
c$A7C8 IN A,($1F)    ; read Kempston joystick port $1F (Z80 IN
 $A7CA AND $1F       ;
 $A7CC CP $1F        ; all 5 bits = nothing pressed
 $A7CE RET NZ        ;
 $A7CF XOR A         ;
 $A7D0 RET           ;

; Data block at A7D1
b$A7D1 DEFB $1D,$15,$19,$22,$0F,$12,$1A,$1E
 $A7D9 DEFB $25,$08,$24,$1C,$14,$0C,$04,$04
 $A7E1 DEFB $13,$03,$0B,$23,$D1,$A7,$D6,$A7
 $A7E9 DEFB $DB,$A7,$E0,$A7

; SCAN_CONTROL_KEYS -- read one 5-key control set into the flag array at $6018.
;
; Used by the routine at #R$A79F.
;
; .
;
; A selects the set: index a word-pointer table at $A7E5 (A*2) to a 5-byte
; key-id list, then test_key each one, storing 0/1 into $6018..$601C.
; .
; Used to read the redefinable keys.
; .
; In: A=set index.
; .
; Out: $6018[0..4] flags.
; .
; Clobbers: A,B,DE,HL.
@label=scan_control_keys
c$A7ED ADD A,A       ;
 $A7EE LD L,A        ;
 $A7EF LD H,$00      ;
 $A7F1 LD DE,$A7E5   ;
 $A7F4 ADD HL,DE     ;
 $A7F5 LD E,(HL)     ;
 $A7F6 INC HL        ;
 $A7F7 LD D,(HL)     ;
 $A7F8 LD HL,$6018   ;
 $A7FB LD B,$05      ;
*$A7FD LD A,(DE)     ;
 $A7FE CALL $A81F    ;
 $A801 LD (HL),$00   ;
 $A803 JR Z,$A806    ;
 $A805 INC (HL)      ;
*$A806 INC HL        ;
 $A807 INC DE        ;
 $A808 DJNZ $A7FD    ;
 $A80A LD HL,$6018   ;
 $A80D LD A,(HL)     ;
 $A80E INC HL        ;
 $A80F SUB (HL)      ;
 $A810 INC HL        ;
 $A811 NEG           ;
 $A813 LD ($601D),A  ;
 $A816 LD A,(HL)     ;
 $A817 INC HL        ;
 $A818 SUB (HL)      ;
 $A819 NEG           ;
 $A81B LD ($601E),A  ;
 $A81E RET           ;

; TEST_KEY -- is a specific key down?
;
; Used by the routines at #R$A706 and #R$A7ED.
;
; .
;
; (proc_table slot $A706.) In:  A = key id, encoded (row<<3 | column) into the
; ZX keyboard matrix.
; .
; Out: Z set (A=0) if the key is pressed.
; .
; Builds the half-row select on the address bus (A=$FE rotated <row> times so
; one of A8..A15 is low) and reads ULA port $FE rotates out <column> bits and
; tests the active-low key bit.
; .
; i8080 PORT: this is the ZX keyboard hardware scan (IN $FE with address-line
; row select).
@label=test_key
c$A81F PUSH BC       ;
 $A820 LD C,A        ; C = key id
 $A821 AND $07       ; low 3 bits = column -> bit count
 $A823 INC A         ;
 $A824 LD B,A        ;
 $A825 SRL C         ; C >>= 3 -> row index
 $A827 SRL C         ;
 $A829 SRL C         ;
 $A82B LD A,$05      ;
 $A82D SUB C         ; 5 - row -> number of rotates for the row select
 $A82E LD C,A        ;
 $A82F LD A,$FE      ; A = $FE: one address line low selects a keyboard
                     ; half-row
*$A831 RRCA          ; rotate the low bit into the row position (DJNZ)
 $A832 DJNZ $A831    ;
 $A834 IN A,($FE)    ; read ULA keyboard port $FE (Z80 IN
*$A836 RRA           ; shift out columns
 $A837 DEC C         ;
 $A838 JR NZ,$A836   ;
 $A83A LD A,C        ;
 $A83B JR C,$A83E    ; carry set = not pressed -> A=1
 $A83D INC A         ;
*$A83E POP BC        ;
 $A83F RET           ;

; POLL_ANY_KEY -- return NZ if ANY input is active: scans the five keyboard
; half-rows via IN ($FE) (CPL+AND $1F), and if none, tests the Kempston fire
; bit ($10).
;
; .
;
; .
;
; Out: A/flags NZ = pressed.
; .
; i8080: replace IN ($FE)/Kempston with the target's key/fire scan.
@label=poll_any_key
b$A840 DEFB $AF,$DB,$FE,$2F,$E6,$1F,$C0,$CD
 $A848 DEFB $C8,$A7,$E6,$10,$C9,$CD,$40,$A8
 $A850 DEFB $20,$FB,$C9

; TEST_BREAK_KEY -- test the BREAK combination (CAPS SHIFT + SPACE) via two IN
; ($FE) row reads.
;
; Used by the routine at #R$A70F.
;
; .
;
; Returns with CARRY CLEAR only when both are held (used to abort).
; .
; Clobbers: A.
@label=test_break_key
c$A853 LD A,$7F      ;
 $A855 IN A,($FE)    ;
 $A857 RRA           ;
 $A858 RET C         ;
 $A859 LD A,$FE      ;
 $A85B IN A,($FE)    ;
 $A85D RRA           ;
 $A85E RET           ;

; DELAY_LOOP -- busy-wait: B outer iterations of a ~$0086 inner countdown.
;
; .
;
; .
;
; In: B=outer count.
; .
; Clobbers: A,B,HL (HL preserved).
; .
; i8080: a pure timing loop -- retune the constant for 2MHz 8080.
@label=delay_loop
b$A85F DEFB $E5,$21,$86,$00,$2B,$7C,$B5,$20
 $A867 DEFB $FB,$10,$F6,$E1,$C9

; NEXT_RANDOM -- pseudo-random generator.
;
; Used by the routine at #R$A715.
;
; .
;
; Reads the 16-bit seed ($6002), applies a multiply/shift + add $0029 LCG step,
; writes the new seed back, and returns A = high byte.
; .
; Out: A=random byte, ($6002) advanced.
; .
; Clobbers: A,DE,HL.
@label=next_random
c$A86C PUSH DE       ;
 $A86D PUSH HL       ;
 $A86E LD DE,($6002) ;
 $A872 LD H,E        ;
 $A873 LD L,$00      ;
 $A875 ADD HL,DE     ;
 $A876 EX DE,HL      ;
 $A877 ADD HL,HL     ;
 $A878 ADD HL,HL     ;
 $A879 ADD HL,HL     ;
 $A87A EX DE,HL      ;
 $A87B OR A          ;
 $A87C SBC HL,DE     ;
 $A87E LD DE,$0029   ;
 $A881 ADD HL,DE     ;
 $A882 LD ($6002),HL ;
 $A885 LD A,H        ;
 $A886 POP HL        ;
 $A887 POP DE        ;
 $A888 RET           ;

; SAVE_REGS_FRAME / RESTORE_REGS_FRAME -- paired full CPU-context save and
; restore.
;
; .
;
; .
;
; save_regs_frame pushes main+alternate register sets, IX, IY (EX AF,AF'/EXX to
; reach the shadow bank), then reads a 16-bit value out of the saved frame
; ($SP+$17) into HL before returning.
; .
; restore_regs_frame ($A8A5) pops them all back.
; .
; i8080: no shadow regs/IX/IY on 8080 -- a port saves only the real register
; set drop the EXX/EX AF,AF' halves.
@label=save_regs_frame
b$A889 DEFB $E3,$D5,$C5,$F5,$08,$D9,$E5,$D5
 $A891 DEFB $C5,$F5,$08,$D9,$DD,$E5,$FD,$E5
 $A899 DEFB $E5,$F5,$21,$17,$00,$39,$7E
 $A8A0 DEFM "+ng"

