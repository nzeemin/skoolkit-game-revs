; SPRITE_SETUP -- compute on-screen positions for the 4 actor sprites (objects
; 0..3) ahead of drawing.
;
; Used by the routine at #R$8FC7.
;
; .
;
; Derives a buffer base from tower_height into $600A, fills two coordinate
; tables at $8B30/$8B40 (X and Y per sprite, via $8BEC/$8BFF), then per object
; copies sprite id (IX+18 -> IX+24) and stores the screen column (IX+30) from
; the angular position (IX+0).
; .
; Self-mod: $8B30/$8B40 are coordinate scratch buffers IN code.
; .
; i8080 PORT: IX object walk -> HL
@label=sprite_setup
c$8B50 LD HL,$60B9     ; HL -> tower_height
 $8B53 LD A,$04        ;
 $8B55 SUB (HL)        ; 4 - height, low 3 bits -> sub-row
 $8B56 AND $07         ;
 $8B58 LD L,$00        ;
 $8B5A SRL A           ;
 $8B5C RR L            ;
 $8B5E LD H,A          ;
 $8B5F LD DE,$6600     ; DE = $6600 sprite work buffer base
 $8B62 ADD HL,DE       ;
 $8B63 LD ($600A),HL   ; store buffer ptr -> $600A
 $8B66 LD HL,$8B30     ; fill X-coord table $8B30 (4 sprites, step 8)
 $8B69 LD A,$04        ;
*$8B6B PUSH AF         ;
 $8B6C CALL $8BEC      ;
 $8B6F ADD A,$1E       ;
 $8B71 LD (HL),A       ;
 $8B72 INC HL          ;
 $8B73 POP AF          ;
 $8B74 ADD A,$08       ;
 $8B76 CP $84          ;
 $8B78 JR NZ,$8B6B     ;
 $8B7A LD HL,$8B40     ; fill Y-coord table $8B40 (4 sprites)
 $8B7D LD A,$04        ;
*$8B7F PUSH AF         ;
 $8B80 CALL $8BFF      ;
 $8B83 LD (HL),A       ;
 $8B84 INC HL          ;
 $8B85 POP AF          ;
 $8B86 ADD A,$08       ;
 $8B88 CP $84          ;
 $8B8A JR NZ,$8B7F     ;
 $8B8C LD IX,$605B     ; IX -> object_table
 $8B90 LD B,$04        ;
*$8B92 PUSH BC         ;
 $8B93 LD A,(IX+$12)   ; back up sprite id (IX+18 -> IX+24)
 $8B96 LD (IX+$18),A   ;
 $8B99 LD A,(IX+$30)   ;
 $8B9C CP $00          ; state 0 (inactive) -> skip
 $8B9E JR Z,$8BD5      ;
 $8BA0 CP $07          ;
 $8BA2 LD A,$40        ; state 7 -> fixed screen col $40
 $8BA4 JR Z,$8BAC      ;
 $8BA6 LD A,(IX+$00)   ;
 $8BA9 CALL $8BFF      ; else screen col from angular pos (IX+0)
*$8BAC LD (IX+$1E),A   ; store sprite screen column (IX+30)
 $8BAF LD L,(IX+$06)   ;
 $8BB2 LD H,(IX+$0C)   ;
 $8BB5 LD DE,($6057)   ;
 $8BB9 OR A            ;
 $8BBA PUSH HL         ;
 $8BBB SBC HL,DE       ;
 $8BBD POP HL          ;
 $8BBE JR C,$8BDF      ;
 $8BC0 LD DE,($6059)   ;
 $8BC4 OR A            ;
 $8BC5 SBC HL,DE       ;
 $8BC7 JR NC,$8BD5     ;
 $8BC9 LD A,(IX+$30)   ;
 $8BCC CP $07          ;
 $8BCE JR Z,$8BD9      ;
 $8BD0 CALL $8CC2      ;
 $8BD3 JR NC,$8BD9     ;
*$8BD5 LD (IX+$18),$FF ;
*$8BD9 POP BC          ;
 $8BDA INC IX          ;
 $8BDC DJNZ $8B92      ;
 $8BDE RET             ;
*$8BDF LD A,(IX+$30)   ;
 $8BE2 CP $07          ;
 $8BE4 JR Z,$8BD5      ;
 $8BE6 LD (IX+$30),$00 ;
 $8BEA JR $8BD5        ;

; COL_SCREEN_Y -- map an actor's angular column to its screen Y /
; vertical-projection value.
;
; Used by the routines at #R$8B50 and #R$8CC2.
;
; .
;
; In: A = angular position (0..127).
; .
; Offsets by the tower rotation: rel = (A + $20 - tower_height) & $7F, then
; returns col_y_table[$6380 + rel].
; .
; Out: A = projected value.
; .
; Preserves HL (PUSH/POP).
; .
; i8080 PORT: the AND $7F is the around-the-tower wrap (128 cols) $6380 is a
; precomputed projection table -- port it verbatim and index with HL + rel.
@label=col_screen_y
c$8BEC PUSH HL       ;
 $8BED ADD A,$20     ; bias by +$20 (quarter turn)
 $8BEF LD HL,$60B9   ;
 $8BF2 SUB (HL)      ; subtract current tower rotation
 $8BF3 AND $7F       ; wrap to 0..127 (around the tower)
 $8BF5 LD E,A        ;
 $8BF6 LD D,$00      ;
 $8BF8 LD HL,$6380   ; HL -> col_y_table ($6380)
 $8BFB ADD HL,DE     ;
 $8BFC LD A,(HL)     ; A = table[rel] = projected Y/value
 $8BFD POP HL        ;
 $8BFE RET           ;

; COL_SCREEN_X -- map an actor's angular column to a screen X column, folding
; the cylinder so only the front face shows.
;
; Used by the routine at #R$8B50.
;
; .
;
; In: A = angular position (0..127).
; .
; rel = (A + $20 - tower_height) & $7F, then fold: rel < $20        -> rel +
; $20      (left quadrant) $20..$5F         -> $60 - rel      (front, mirrored)
; rel >= $60       -> rel - $60      (right quadrant) Out: A = screen column.
; .
; Preserves HL.
; .
; i8080 PORT: pure arithmetic fold of a 7-bit ang
@label=col_screen_x
c$8BFF PUSH HL       ;
 $8C00 ADD A,$20     ; bias +$20
 $8C02 LD HL,$60B9   ;
 $8C05 SUB (HL)      ; subtract tower rotation
 $8C06 AND $7F       ; wrap to 0..127
 $8C08 CP $20        ; left quadrant?
 $8C0A JR NC,$8C10   ;
 $8C0C ADD A,$20     ; -> rel + $20
 $8C0E JR $8C1C      ;
*$8C10 CP $60        ; back face?
 $8C12 JR C,$8C18    ;
 $8C14 SUB $60       ; -> rel - $60 (right quadrant)
 $8C16 JR $8C1C      ;
*$8C18 LD H,A        ;
 $8C19 LD A,$60      ;
 $8C1B SUB H         ; front: mirror $60 - rel
*$8C1C POP HL        ;
 $8C1D RET           ;

; SPRITE_SHIFT_MASKS -- 1bpp AND/shift mask data for drawing the tower-column
; sprites at sub-byte X offsets (patterns 3F/0F/03/00 FF...).
;
; .
;
; .
;
; Base referenced from $8D35/$8F5E.
; .
; Interleaved with a few SELF-MODIFIED 1-byte slots
; ($8C76/$8C77/$8C78/$8C81/$8C82/$8C83/ $8C85) that calc_sprite_shift patches
; with computed shift counts.
; .
; Spans $8C1E..$8CC1 code resumes at calc_sprite_shift.
; .
; i8080 PORT: keep as a RAM mask table the self-mod slots become normal
@label=sprite_shift_masks
b$8C1E DEFB $FF,$FF,$FC,$FF,$FF,$F0,$FF,$FF
