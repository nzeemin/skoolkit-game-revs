@label=bonus_sub
c$AA21 LD B,A        ;
 $AA22 LD HL,$604B   ;
 $AA25 LD A,($6040)  ;
 $AA28 OR A          ;
 $AA29 JR Z,$AA2D    ;
 $AA2B INC HL        ;
 $AA2C INC HL        ;
*$AA2D LD A,(HL)     ;
