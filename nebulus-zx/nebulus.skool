 $BA25 RET           ;

; PAINT_TOWER_ATTRS -- repaint the tower's attribute (colour) band in the $58xx
; attribute file from $5860, using lookup_col_attr ($BA16) for per-column
; colours and fill_run ($BA61) to lay rows.
;
; Used by the routine at #R$A799.
;
; .
;
; SELF-MOD: $BA66 row count.
; .
; Clobbers: A,BC,D,HL.
@label=paint_tower_attrs
c$BA26 LD A,$0E      ;
 $BA28 LD ($BA66),A  ;
 $BA2B LD HL,$5860   ;
 $BA2E LD B,$20      ;
 $BA30 XOR A         ;
 $BA31 LD D,A        ;
 $BA32 CALL $BA61    ;
 $BA35 LD C,$0B      ;
*$BA37 LD (HL),D     ;
 $BA38 INC HL        ;
 $BA39 LD (HL),D     ;
 $BA3A INC HL        ;
 $BA3B LD B,$1C      ;
 $BA3D CALL $BA16    ;
 $BA40 CALL $BA61    ;
 $BA43 LD (HL),D     ;
 $BA44 INC HL        ;
 $BA45 LD (HL),D     ;
 $BA46 INC HL        ;
 $BA47 DEC C         ;
 $BA48 JR NZ,$BA37   ;
 $BA4A LD C,$08      ;
*$BA4C LD (HL),D     ;
 $BA4D INC HL        ;
 $BA4E LD (HL),D     ;
 $BA4F INC HL        ;
 $BA50 LD B,$1C      ;
 $BA52 LD A,$41      ;
 $BA54 CALL $BA61    ;
 $BA57 LD (HL),D     ;
 $BA58 INC HL        ;
 $BA59 LD (HL),D     ;
 $BA5A INC HL        ;
 $BA5B DEC C         ;
 $BA5C JR NZ,$BA4C   ;
 $BA5E LD B,$20      ;
 $BA60 XOR A         ;
@label=fill_run
*$BA61 LD (HL),A     ;
 $BA62 INC HL        ;
 $BA63 DJNZ $BA61    ;
 $BA65 RET           ;

; Unused
s$BA66 DEFS $01

; SCROLL_TOWER_ATTRS -- adjust the painted attribute band as scroll_pos
; advances (compares against the $BA66 latch set by paint_tower_attrs) so
; colours track the scrolling tower.
;
; Used by the routine at #R$A79C.
;
; .
;
; Clobbers: A,B,HL.
@label=scroll_tower_attrs
c$BA67 LD HL,($6030) ;
 $BA6A LD A,H        ;
 $BA6B CP $03        ;
 $BA6D LD A,$16      ;
 $BA6F JR NZ,$BA7C   ;
 $BA71 LD A,L        ;
 $BA72 NEG           ;
 $BA74 RRA           ;
 $BA75 RRA           ;
 $BA76 AND $0F       ;
 $BA78 SUB $16       ;
 $BA7A NEG           ;
*$BA7C LD B,A        ;
 $BA7D LD A,($BA66)  ;
 $BA80 SUB B         ;
 $BA81 JR Z,$BA94    ;
 $BA83 CP $FF        ;
 $BA85 JR Z,$BA99    ;
 $BA87 CP $01        ;
 $BA89 JR NZ,$BA94   ;
 $BA8B LD A,B        ;
 $BA8C LD ($BA66),A  ;
 $BA8F INC B         ;
 $BA90 LD C,$41      ;
 $BA92 JR $BAA1      ;
*$BA94 LD A,B        ;
 $BA95 LD ($BA66),A  ;
 $BA98 RET           ;
*$BA99 LD A,B        ;
 $BA9A LD ($BA66),A  ;
 $BA9D CALL $BA16    ;
 $BAA0 LD C,A        ;
*$BAA1 LD L,B        ;
 $BAA2 LD H,$00      ;
 $BAA4 ADD HL,HL     ;
 $BAA5 ADD HL,HL     ;
 $BAA6 ADD HL,HL     ;
 $BAA7 ADD HL,HL     ;
 $BAA8 ADD HL,HL     ;
 $BAA9 LD DE,$5802   ;
 $BAAC ADD HL,DE     ;
 $BAAD LD B,$1C      ;
*$BAAF LD (HL),C     ;
 $BAB0 INC HL        ;
 $BAB1 DJNZ $BAAF    ;
 $BAB3 RET           ;

; Unused
s$BAB4 DEFS $06

