 $95C7 PUSH IX        ;
 $95C9 PUSH IY        ;
 $95CB POP DE         ;
 $95CC POP HL         ;
 $95CD LD A,H         ;
 $95CE CP D           ;
 $95CF JR NZ,$95D6    ;
 $95D1 LD A,L         ;
 $95D2 CP E           ;
 $95D3 JP Z,$9648     ; }
*$95D6 LD A,(IY+$30)  ; A = target's state (+48)
 $95D9 CP $07         ; {skip if state is 0/4/6/7 (non-collidable)
 $95DB JP Z,$9648     ;
 $95DE CP $00         ;
 $95E0 JP Z,$9648     ;
 $95E3 CP $04         ;
 $95E5 JP Z,$9648     ;
 $95E8 CP $06         ;
 $95EA JP Z,$9648     ; }
 $95ED LD A,(IX+$00)  ; {angular distance |IX+0 - IY+0| within window?
 $95F0 SUB (IY+$00)   ;
 $95F3 AND $7F        ;
 $95F5 CP $04         ; }
 $95F7 JR C,$95FE     ;
 $95F9 CP $7C         ;
 $95FB JP C,$9648     ;
*$95FE ADD A,$03      ;
 $9600 AND $07        ;
