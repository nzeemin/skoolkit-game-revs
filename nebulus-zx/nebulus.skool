 $9C5A JP NZ,$9D07   ; }
 $9C5D LD A,($6017)  ; get Game mode
 $9C60 INC A         ; {advance/wrap option index 0..4
 $9C61 CP $05        ; }
 $9C63 JR NZ,$9C50   ;
 $9C65 LD A,$24      ; A = key $24 ('1')
 $9C67 CALL $A706    ; test_key
 $9C6A JR Z,$9C74    ; pressed? -> 1-player start
 $9C6C LD A,$01      ; A = 1 (running_flag: 1 player)
 $9C6E LD ($603F),A  ; set Running flag
 $9C71 JP $9BA5      ; restart into game (#R$9BA5 draw path with running_flag
                     ; set)
*$9C74 LD A,$1C      ; A = key $1C ('2')
