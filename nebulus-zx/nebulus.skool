; Setup level
;
; Used by the routines at #R$802B and #R$8064.
;
; .
;
; (Re)build the current level's working state.
; .
; Zeroes the work_buffers block (#R$F000.., $0FFF bytes via LDIR), loads the
; level's column data (load_level_col), resets the tower position
; (init_tower_pos), re-inits flags (init_b5cf) and the renderers (#R$8FB7,
; #R$96D4).
; .
; Clobbers: most.
@label=setup_level
c$81D7 LD HL,$F000   ; Clear work_buffers (#R$F000) for tower map
 $81DA LD DE,$F001   ;
 $81DD LD BC,$0FFF   ;
 $81E0 LD (HL),$00   ;
 $81E2 LDIR          ;
 $81E4 CALL $A763    ; Load level column data into #R$F000
 $81E7 CALL $83D0    ; Init tower pos
 $81EA CALL $A77E    ;
 $81ED CALL $8FB7    ; Clear actor states
 $81F0 CALL $96D4    ;
 $81F3 LD B,$04      ; Initialise 4 object slots to empty
 $81F5 LD HL,$60A9   ;
*$81F8 LD (HL),$FF   ; Fill slots with $FF (empty)
 $81FA INC HL        ;
 $81FB DJNZ $81F8    ;
 $81FD LD A,($60D9)  ; Check if game_state == 3 (level transition)
 $8200 CP $03        ;
 $8202 JR Z,$8235    ; Skip attribute painting if transitioning
 $8204 CALL $A799    ; Paint tower colour attributes
 $8207 LD A,$01      ;
 $8209 LD ($60C9),A  ; Set $60C9 = 1 (enable column visibility update)
 $820C LD A,$24      ; Compute disp_height = 36 - tower_height
 $820E LD HL,$60B9   ;
 $8211 SUB (HL)      ;
 $8212 AND $7F       ;
 $8214 LD ($6032),A  ; set Display height
 $8217 CALL $A751    ; Mark visible tower columns for rendering
 $821A CALL $9F11    ; Init attract actors
 $821D LD HL,$60C9   ;
 $8220 DEC (HL)      ;
 $8221 XOR A         ;
 $8222 LD ($60D9),A  ; Set game_state = 0 (normal play)
 $8225 LD A,$7D      ;
 $8227 LD ($60A3),A  ;
 $822A LD A,$01      ; Set player starting column = 1
 $822C LD ($60A4),A  ; set Player's current column
 $822F LD A,($60D7)  ; get Control-key toggle flag
 $8232 JP $8237      ;
*$8235 LD A,$FF      ; Set #R$6055 = $FF during level transition
*$8237 LD ($6055),A  ; Store $FF or $00 into timer prescaler #R$6055
 $823A LD A,$02      ; Freeze input for 2 frames
 $823C LD ($8004),A  ;
 $823F RET           ;

; Main tick
;
; Used by the routine at #R$8064.
;
; .
;
; One frame of the game.
; .
; Called from main_loop.
; .
; Order: read input (unless frozen) -> run game-state machine (player move,
; tower rotation, enemies) -> redraw widgets -> HALT to sync to the 50Hz frame
; interrupt.
; .
; State: game_state (#R$60D9): 3=level transition, 4=finished,
; .
; else = normal play.
; .
; demo_pause (#R$60D8) skips logic.
; .
; freeze_ctr ($8004) freezes input for N frames.
; .
; Clobbers: most regs.
; .
; Returns once per frame.
@label=main_tick
c$8240 LD HL,$8004   ; HL -> freeze_ctr (in code padding at $8004)
 $8243 LD A,(HL)     ; A = freeze counter
 $8244 OR A          ;
 $8245 JR Z,$8254    ; 0 = not frozen -> read input normally
 $8247 DEC (HL)      ; frozen: count down one frame
 $8248 XOR A         ;
 $8249 LD ($601D),A  ; zero the three input vars while frozen
 $824C LD ($601E),A  ; set Signed input
 $824F LD ($601C),A  ; set Signed input
 $8252 JR $8257      ;
*$8254 CALL $A700    ; Proc table
*$8257 LD A,($60D8)  ; A = demo_pause flag
 $825A OR A          ;
 $825B JR NZ,$8291   ; set -> skip all game logic (attract/demo), just redraw
 $825D LD A,($60D9)  ; A = game_state
 $8260 CP $03        ; state 3 = level transition?
 $8262 JR NZ,$8270   ;
 $8264 CALL $8482    ; Player tick
 $8267 LD A,($60D9)  ; get Game state
 $826A CP $04        ;
 $826C RET Z         ; state 4 = finished -> done this frame
 $826D JP $8291      ;
*$8270 CALL $A769    ; --- normal play: update one frame ---
 $8273 CALL $96E9    ; Update actor pos
 $8276 CALL $8482    ; Player tick
 $8279 LD A,($60A4)  ; A = player column before move
 $827C PUSH AF       ;
 $827D CALL $A76F    ; move player (proc_table slot)
 $8280 POP AF        ;
 $8281 LD B,A        ;
 $8282 LD A,($60A4)  ; compare new vs old player column
 $8285 CP B          ;
 $8286 LD A,$00      ;
 $8288 CALL NZ,$A3DE ; Play sound
 $828B CALL $90DA    ; Update enemies
 $828E CALL $89C5    ; Check collision
*$8291 LD A,$24      ; --- redraw HUD: A = $24 (36 rows) ---
 $8293 LD HL,$60B9   ;
 $8296 SUB (HL)      ; subtract tower_height (#R$60B9)
 $8297 AND $7F       ;
 $8299 LD ($6032),A  ; store display height (#R$6032)
 $829C CALL $A751    ; draw widgets (proc_table slots)
 $829F CALL $A75A    ;
 $82A2 CALL $A75D    ;
 $82A5 CALL $A757    ;
 $82A8 PUSH AF       ;
 $82A9 CALL $8FC7    ; Draw player
 $82AC HALT          ; HALT: wait for the 50Hz frame IRQ (Z80
 $82AD CALL $A41C    ; Sound tick
 $82B0 CALL $A760    ;
 $82B3 CALL $A790    ;
 $82B6 CALL $8FFA    ; Draw actors sorted
 $82B9 CALL $A787    ;
 $82BC CALL $A796    ;
 $82BF POP AF        ;
 $82C0 CALL $A793    ;
 $82C3 CALL $A754    ;
 $82C6 CALL $A79C    ;
 $82C9 LD A,($60D9)  ; get Game state
 $82CC CP $03        ;
 $82CE JR Z,$82D9    ;
 $82D0 CALL $82DA    ; Tally score to
 $82D3 CALL $A724    ;
 $82D6 CALL $A736    ;
*$82D9 RET           ;

; Tally score to
;
; Used by the routine at #R$8240.
;
; .
;
; Count $60BC up toward #R$60BA, awarding $10 (BCD) points per step via
; add_bcd_score, until the two 16-bit values meet.
; .
; Used to animate an end-of-section bonus tally.
