; CALC_SPRITE_COL -- resolve a sprite column: index table $8B30 by A, compare
; the result against the actor's clip field (IX+30), and patch the shift slot
; $8C81.
;
; Used by the routine at #R$8CC2.
;
; .
;
; RET early when within bounds.
; .
; Clobbers: A,DE,HL.
@label=calc_sprite_col
c$8EF1 LD E,A        ;
 $8EF2 ADD A,$F0     ;
 $8EF4 LD H,A        ;
 $8EF5 LD D,$00      ;
 $8EF7 PUSH HL       ;
 $8EF8 LD HL,$8B30   ;
 $8EFB ADD HL,DE     ;
 $8EFC LD A,(HL)     ;
 $8EFD LD DE,$0010   ;
 $8F00 ADD HL,DE     ;
 $8F01 LD E,A        ;
 $8F02 LD A,(HL)     ;
 $8F03 CP (IX+$1E)   ;
 $8F06 JR NC,$8F0A   ;
 $8F08 POP HL        ;
 $8F09 RET           ;
*$8F0A LD A,E        ;
 $8F0B LD HL,$8C81   ;
 $8F0E SUB (HL)      ;
 $8F0F ADD A,$0B     ;
