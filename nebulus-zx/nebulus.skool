; TICK_TIMER -- prescaled level-timer countdown.
;
; Used by the routine at #R$A736.
;
; .
;
; $6055 counts 0..4 only every 5th call does it BCD-decrement play_timer (2
; bytes, clamped at 0) and redraw via draw_timer.
; .
; RET M while prescaler is negative (timer disabled).
; .
; Clobbers: A,HL.
@label=tick_timer
c$AA70 LD HL,$6055   ;
 $AA73 LD A,(HL)     ;
 $AA74 OR A          ;
 $AA75 RET M         ;
 $AA76 INC A         ;
 $AA77 LD (HL),A     ;
 $AA78 CP $05        ;
 $AA7A RET C         ;
 $AA7B LD (HL),$00   ;
 $AA7D LD HL,$6053   ;
 $AA80 LD A,(HL)     ;
 $AA81 SUB $01       ;
 $AA83 DAA           ;
 $AA84 LD (HL),A     ;
 $AA85 INC HL        ;
 $AA86 LD A,(HL)     ;
 $AA87 SBC A,$00     ;
 $AA89 DAA           ;
 $AA8A LD (HL),A     ;
 $AA8B JP P,$AA96    ;
 $AA8E XOR A         ;
 $AA8F LD (HL),A     ;
 $AA90 DEC HL        ;
 $AA91 LD (HL),A     ;
 $AA92 DEC A         ;
 $AA93 LD ($6055),A  ;

; DRAW_TIMER -- print the 2-byte BCD play_timer ($6054) as decimal digits at
; print row $0E (white).
;
; Used by the routines at #R$A739, #R$AA5B and #R$AA70.
;
; .
;
; Uses print_2digits/print_digit.
; .
; Clobbers: A,BC,HL.
@label=draw_timer
c$AA96 LD A,$FF      ;
 $AA98 LD ($60C8),A  ;
 $AA9B LD BC,$0E00   ;
 $AA9E CALL $AB7A    ;
 $AAA1 LD HL,$6054   ;
 $AAA4 CALL $AAA8    ;
 $AAA7 DEC HL        ;
@label=print_2digits
*$AAA8 LD A,(HL)     ;
 $AAA9 RRA           ;
 $AAAA RRA           ;
 $AAAB RRA           ;
 $AAAC RRA           ;
 $AAAD CALL $AAB1    ;
 $AAB0 LD A,(HL)     ;
@label=print_digit
*$AAB1 AND $0F       ;
 $AAB3 ADD A,$30     ;
 $AAB5 JP $AAC5      ;

; Data block at AAB8
@label=punct_map
b$AAB8 DEFB $20,$00
 $AABA DEFM "<(>'"

; Data block at AABE
b$AABE DEFB $40,$26,$2A,$19,$CD,$7A,$AB

; PRINT_CHAR -- render one character at the current text cursor.
;
; Used by the routines at #R$A73F, #R$A936, #R$A993, #R$AA96 and #R$AB56.
;
; .
;
; In:  A = character code.
; .
; >=$80 : direct glyph index (graphics char), A&$7F.
; .
; 'A'..'Z' : glyph = (A-'A')+2.
; .
; '0'..'9' : glyph = (A-'0')+$1C.
; .
; <$10     : colour/attribute control code -> cur_color.
; .
; else     : looked up in punct_map.
; .
; cursor in print_cursor ($60C6 lo=col) cur_color ($60C8).
; .
; Out: glyph blitted to screen column cursor ($60C7) advanced.
@label=print_char
c$AAC5 PUSH AF       ; save all regs (caller-transparent)
 $AAC6 PUSH BC       ;
 $AAC7 PUSH DE       ;
 $AAC8 PUSH HL       ;
 $AAC9 BIT 7,A       ; bit7 set? -> direct graphics glyph index
 $AACB JR Z,$AAD1    ;
 $AACD AND $7F       ; strip bit7, use as glyph index
 $AACF JR $AB0F      ;
*$AAD1 CP $41        ; 'A'($41)..'Z'($5A)?
 $AAD3 JR C,$AADF    ;
 $AAD5 CP $5B        ;
 $AAD7 JR NC,$AADF   ;
 $AAD9 SUB $41       ; glyph = (A-'A') + 2  (letters start at glyph 2)
 $AADB ADD A,$02     ;
 $AADD JR $AB0F      ;
*$AADF CP $30        ; '0'($30)..'9'($39)?
 $AAE1 JR C,$AAED    ;
 $AAE3 CP $3A        ;
 $AAE5 JR NC,$AAED   ;
 $AAE7 SUB $30       ; glyph = (A-'0') + $1C  (digits start at glyph $1C)
 $AAE9 ADD A,$1C     ;
 $AAEB JR $AB0F      ;
*$AAED CP $10        ; code <$10? -> colour control code
 $AAEF JR NC,$AAFF   ;
 $AAF1 LD B,A        ;
 $AAF2 AND $07       ; ink = A & 7
 $AAF4 BIT 3,B       ; bit3 of code = BRIGHT -> OR $40
 $AAF6 JR Z,$AAFA    ;
 $AAF8 OR $40        ;
*$AAFA LD ($60C8),A  ; store into cur_color ($60C8)
 $AAFD JR $AB4E      ;
*$AAFF LD HL,$AAB8   ; HL -> punct_map (5 entries)
 $AB02 LD B,$05      ;
*$AB04 CP (HL)       ; compare code against each map char
 $AB05 JR Z,$AB0D    ;
 $AB07 INC HL        ;
 $AB08 INC HL        ;
 $AB09 DJNZ $AB04    ;
 $AB0B JR $AB4E      ;
*$AB0D INC HL        ;
 $AB0E LD A,(HL)     ; matched: A = glyph index from map
@label=glyph_addr
*$AB0F LD L,A        ; L = glyph index
 $AB10 ADD A,A       ; A = index*6 via index + index*2, then *2 (6 bytes/glyph)
 $AB11 ADD A,L       ;
 $AB12 ADD A,A       ;
 $AB13 LD L,A        ; HL = index*6
 $AB14 LD H,$00      ;
 $AB16 LD DE,$C000   ; DE = $C000 = font base
 $AB19 ADD HL,DE     ; HL -> glyph bitmap (6 bytes)
 $AB1A PUSH HL       ;
 $AB1B LD BC,($60C6) ; BC = print_cursor (C=column 0..31)
@label=glyph_blit
 $AB1F LD A,C        ; A = column
 $AB20 AND $18       ; H = (col & $18) | $40 : screen-addr high byte
                     ; (third+page)
 $AB22 LD H,A        ;
 $AB23 SET 6,H       ;
 $AB25 RRCA          ;
 $AB26 RRCA          ;
 $AB27 RRCA          ;
 $AB28 OR $58        ; OR $58 -> D = matching attribute-area high byte ($58xx)
 $AB2A LD D,A        ;
 $AB2B LD A,C        ;
 $AB2C AND $07       ;
 $AB2E RRCA          ;
 $AB2F RRCA          ;
 $AB30 RRCA          ;
 $AB31 ADD A,B       ;
 $AB32 LD L,A        ;
 $AB33 LD E,A        ;
 $AB34 LD A,($60C8)  ; A = cur_color
 $AB37 CP $FF        ; $FF = 'transparent' -> skip attribute write
 $AB39 JR Z,$AB3C    ;
 $AB3B LD (DE),A     ; write colour to attribute cell
*$AB3C POP DE        ;
 $AB3D LD (HL),$00   ; blank top scanline of the cell
 $AB3F INC H         ; INC H = step down one pixel row (Z80 ZX adjacency)
 $AB40 LD B,$06      ; B = 6 font rows
*$AB42 LD A,(DE)     ; copy one font row to screen
 $AB43 LD (HL),A     ;
 $AB44 INC DE        ;
 $AB45 INC H         ;
 $AB46 DJNZ $AB42    ;
 $AB48 LD (HL),$00   ; blank bottom scanline
 $AB4A LD HL,$60C7   ;
 $AB4D INC (HL)      ; advance column cursor ($60C7)
*$AB4E POP HL        ;
 $AB4F POP DE        ;
 $AB50 POP BC        ;
 $AB51 POP AF        ;
 $AB52 RET           ;

; PRINT_STRING -- print an ASCIIZ string at position BC.
;
; Used by the routine at #R$A8EB.
;
; .
;
; In: HL=string (00-terminated), BC=cursor pos.
; .
; Out: HL past terminator.
; .
; Uses print_char per byte.
@label=print_string
c$AB53 CALL $AB7A    ; set cursor = BC

; Routine at AB56
;
; Used by the routine at #R$AB5F.
@label=print_string_loop
c$AB56 LD A,(HL)     ; A = next char
 $AB57 INC HL        ;
 $AB58 OR A          ; 00 terminator?
 $AB59 RET Z         ; done (ASCIIZ) -- RET on Z
 $AB5A CALL $AAC5    ; print it
 $AB5D JR $AB56      ; next char

; Routine at AB5F
;
; Used by the routine at #R$A745.
@label=print_centered
c$AB5F PUSH HL       ;
 $AB60 LD C,$00      ; C = visible-char count
*$AB62 LD A,(HL)     ;
 $AB63 OR A          ;
 $AB64 JR Z,$AB6E    ;
 $AB66 CP $10        ; ignore codes <$10 (colour controls) in the count
 $AB68 JR C,$AB6B    ;
 $AB6A INC C         ;
*$AB6B INC HL        ;
 $AB6C JR $AB62      ;
*$AB6E LD A,$20      ; A = 32 - count
 $AB70 SUB C         ;
 $AB71 RRA           ; RRA = /2 = left margin
 $AB72 LD ($60C7),A  ; store as start column ($60C7)
 $AB75 POP HL        ;
 $AB76 CALL $AB56    ;
 $AB79 RET           ;

; Routine at AB7A
;
; Used by the routines at #R$A936, #R$A993, #R$AA96 and #R$AB53.
@label=set_print_pos
c$AB7A LD ($60C6),BC ;
 $AB7E RET           ;

