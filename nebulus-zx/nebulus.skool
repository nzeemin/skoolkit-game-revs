 $9F29 LD B,$32      ;
*$9F2B HALT          ;
 $9F2C DJNZ $9F2B    ;
 $9F2E XOR A         ;
 $9F2F CALL $9F33    ; Attract step
 $9F32 RET           ;

; Attract step
;
; Used by the routines at #R$9F11 and #R$A170.
;
; .
;
; Advance the attract/demo one frame: silence SFX, render_play_frame, then fire
; scripted sounds keyed off the demo phase #R$9F0E.
; .
; Phase 0: sweeps a tone counter down by 2/frame until $68, then advances to
; phase 1 (also plays sound 3). Phase 1: cycles the 4 actor Y-offsets down by
; 2/frame at $9EFB, resetting a sub-counter every 9th frame, plays sound 3
; every wrap, advances to phase 2 at the end. Phase 2/4: replay scripted
; actor-position frames from tables #R$9F04/$9F09 indexed by a frame counter
; ($9F0F). Phase 3: sweeps $9EFA up/down by 2/frame between bounds, plays sound
; 3 at each end, toggling direction via $9F10. Phase else (5+): sweeps the same
; tone counter back up by 2/frame until $90, then RET (attract sequence done).
; .
; Clobbers: most.
@label=attract_step
c$9F33 LD ($9F10),A  ; stash tune id / phase-0 marker ($9F10)
 $9F36 CALL $A36D    ; Stop sound
*$9F39 CALL $A02A    ; Render play frame
 $9F3C LD A,($9F0E)  ; A = demo phase (#R$9F0E)
 $9F3F CP $01        ; {phase == 1? -> $9F6A
 $9F41 JR NZ,$9F6A   ; }
 $9F43 LD A,$0B      ; A = sound id 11 (phase-0 tone)
 $9F45 CALL $A3DE    ; Play sound
 $9F48 LD HL,$9EFB   ; HL -> actor Y-offsets ($9EFB)
 $9F4B LD B,$04      ; B = 4 (offset count)
*$9F4D LD A,(HL)     ; {subtract 2 from this offset, next
 $9F4E SUB $02       ;
 $9F50 LD (HL),A     ;
 $9F51 INC HL        ; }
 $9F52 DJNZ $9F4D    ; loop 4 offsets
 $9F54 CP $68        ; reached lower bound ($68)?
 $9F56 JP NZ,$9F39   ;
 $9F59 LD HL,$9F0E   ; HL -> demo phase
 $9F5C INC (HL)      ; advance to phase 1
 $9F5D LD A,$00      ;
 $9F5F LD ($9F0F),A  ; reset frame sub-counter ($9F0F)=0
 $9F62 LD A,$03      ;
 $9F64 CALL $A3DE    ; Play sound
 $9F67 JP $9F39      ;
*$9F6A CP $02        ; {phase == 2? -> $9F97
 $9F6C JR NZ,$9F97   ; }
 $9F6E LD A,($9F0F)  ; A = frame sub-counter
 $9F71 SRL A         ; /2 -> table index
 $9F73 LD E,A        ;
 $9F74 LD D,$00      ;
 $9F76 LD HL,$9F04   ; HL -> position table #R$9F04
 $9F79 ADD HL,DE     ;
 $9F7A LD A,(HL)     ; {fetch scripted X, store ($9EF6)
 $9F7B LD ($9EF6),A  ; }
 $9F7E LD HL,$9F09   ; HL -> position table $9F09
 $9F81 ADD HL,DE     ;
 $9F82 LD A,(HL)     ; {fetch scripted Y, store (#R$9EF1)
 $9F83 LD ($9EF1),A  ; }
 $9F86 LD HL,$9F0F   ; HL -> frame sub-counter
 $9F89 INC (HL)      ; {advance sub-counter
 $9F8A LD A,(HL)     ; }
 $9F8B CP $09        ; {reached frame $09? -> advance to phase 2
 $9F8D JP NZ,$9F39   ; }
 $9F90 LD HL,$9F0E   ;
 $9F93 INC (HL)      ;
 $9F94 JP $9F39      ;
*$9F97 CP $03        ; {phase == 3? -> $9FE7
 $9F99 JR NZ,$9FE7   ; }
 $9F9B LD A,($9F10)  ; A = sweep direction flag ($9F10)
 $9F9E OR A          ; {nonzero? -> sweep up branch $9FC4
 $9F9F JR NZ,$9FC4   ; }
 $9FA1 LD A,$00      ; {zero flag: clear demo-actor marker (#R$9EF0)
 $9FA3 LD ($9EF0),A  ; }
 $9FA6 LD A,($9EFA)  ; A = sweep value ($9EFA)
 $9FA9 SUB $02       ; {subtract 2 (sweep down)
 $9FAB LD ($9EFA),A  ; }
 $9FAE CP $54        ; reached lower bound ($54)?
 $9FB0 JP NZ,$9F39   ;
 $9FB3 LD HL,$9F0E   ;
 $9FB6 INC (HL)      ;
 $9FB7 LD A,$08      ; {A = 8, seed frame sub-counter
 $9FB9 LD ($9F0F),A  ; }
 $9FBC LD A,$03      ;
 $9FBE CALL $A3DE    ; Play sound
 $9FC1 JP $9F39      ;
*$9FC4 LD A,($9EFA)  ; A = sweep value ($9EFA)
 $9FC7 ADD A,$02     ; {add 2 (sweep up)
 $9FC9 LD ($9EFA),A  ; }
 $9FCC CP $68        ; reached upper bound ($68)?
 $9FCE JP NZ,$9F39   ;
 $9FD1 LD HL,$9F0E   ;
 $9FD4 INC (HL)      ;
 $9FD5 LD A,$FF      ; {A = $FF, mark demo-actor active
 $9FD7 LD ($9EF0),A  ; }
 $9FDA LD A,$08      ;
 $9FDC LD ($9F0F),A  ;
 $9FDF LD A,$03      ;
 $9FE1 CALL $A3DE    ; Play sound
 $9FE4 JP $9F39      ;
*$9FE7 CP $04        ; {phase == 4? -> $A013
 $9FE9 JR NZ,$A013   ; }
 $9FEB LD A,($9F0F)  ; A = frame sub-counter
 $9FEE SRL A         ;
 $9FF0 LD E,A        ;
 $9FF1 LD D,$00      ;
 $9FF3 LD HL,$9F04   ;
 $9FF6 ADD HL,DE     ;
 $9FF7 LD A,(HL)     ;
 $9FF8 LD ($9EF6),A  ;
 $9FFB LD HL,$9F09   ;
 $9FFE ADD HL,DE     ;
 $9FFF LD A,(HL)     ;
 $A000 LD ($9EF1),A  ;
 $A003 LD HL,$9F0F   ; HL -> frame sub-counter
 $A006 DEC (HL)      ; decrement sub-counter
 $A007 BIT 7,(HL)    ; underflowed (bit7 set)?
 $A009 JP Z,$9F39    ;
 $A00C LD HL,$9F0E   ; HL -> demo phase
 $A00F INC (HL)      ; advance to next phase
 $A010 JP $9F39      ;
*$A013 LD A,$0B      ; A = sound id 11 (final sweep tone)
 $A015 CALL $A3DE    ; Play sound
 $A018 LD HL,$9EFB   ; HL -> actor Y-offsets ($9EFB)
 $A01B LD B,$04      ; B = 4 (offset count)
*$A01D LD A,(HL)     ; {add 2 to this offset, next
 $A01E ADD A,$02     ;
 $A020 LD (HL),A     ;
 $A021 INC HL        ; }
 $A022 DJNZ $A01D    ; loop 4 offsets
 $A024 CP $90        ; reached upper bound ($90)? done
 $A026 JP NZ,$9F39   ;
 $A029 RET           ;

; Render play frame
;
; Used by the routines at #R$9F11 and #R$9F33.
;
; .
;
; One frame of the in-play tower screen: setup_tower_scroll, code_ad00, wait
; vsync (HALT), tick the sound engine (sound_tick), draw the tower body +
; column strip, refresh the strip params and the scroll-wrap edge, then process
; the 5 actor records at #R$9EF0.
; .
; Clobbers: most.
@label=render_play_frame
c$A02A CALL $A75D    ; {setup_tower_scroll / code_ad00 trampolines
 $A02D CALL $A757    ; }
 $A030 PUSH AF       ;
 $A031 HALT          ;
 $A032 CALL $A41C    ; Sound tick
 $A035 CALL $A760    ; draw tower body (jp_draw_tower)
 $A038 CALL $A796    ; draw column strip (jp_draw_strip)
 $A03B POP AF        ;
 $A03C CALL $A793    ; refresh strip params (jp_setup_strip)
 $A03F CALL $A754    ; scroll-wrap edge (jp_blit_scroll_wrap)
 $A042 LD IX,$9EF0   ; {IX -> demo actor records (#R$9EF0), B=5
 $A046 LD B,$05      ; }
*$A048 PUSH IX       ; {save IX/BC for this actor
 $A04A PUSH BC       ; }
 $A04B LD A,(IX+$00) ; {marker==$FF? inactive, skip
 $A04E CP $FF        ; }
 $A050 JP Z,$A109    ;
 $A053 LD A,(IX+$05) ; {compute screen row from actor Y and row table
 $A056 SRL A         ;
 $A058 SRL A         ;
 $A05A SRL A         ;
 $A05C LD L,A        ;
 $A05D LD H,(IX+$0A) ; }
 $A060 CALL $A781    ;
 $A063 PUSH HL       ;
 $A064 LD A,(IX+$00) ; {compute screen column
 $A067 CALL $A784    ; }
 $A06A POP DE        ;
 $A06B LD A,(IX+$0A) ; {off-screen (Y>=$7C)? skip
 $A06E CP $7C        ;
 $A070 JP NC,$A109   ; }
 $A073 LD B,$14      ; {clamp cell count near the bottom edge
 $A075 CP $6A        ;
 $A077 JR C,$A07E    ;
 $A079 LD B,A        ;
 $A07A LD A,$7C      ;
 $A07C SUB B         ;
 $A07D LD B,A        ; }
*$A07E DI            ; DI
 $A07F LD ($6000),SP ; set Temporary place for SP
 $A083 LD SP,HL      ;
 $A084 EX DE,HL      ;
 $A085 LD A,C        ; {C selects row-width variant: 1/2/3-cell
 $A086 CP $04        ;
 $A088 JP Z,$A0DB    ;
 $A08B CP $03        ;
 $A08D JP Z,$A0B2    ; }
*$A090 POP DE        ; {--- 1-cell-wide: copy+merge 2 mask/data pairs ---
 $A091 LD A,(HL)     ;
 $A092 AND E         ;
 $A093 OR D          ;
 $A094 LD (HL),A     ;
 $A095 INC L         ;
 $A096 POP DE        ;
 $A097 LD A,(HL)     ;
 $A098 AND E         ;
 $A099 OR D          ;
 $A09A LD (HL),A     ;
 $A09B DEC L         ;
 $A09C INC H         ; }
 $A09D LD A,H        ; {wrap to next screen row (char-cell step)
 $A09E AND $07       ;
 $A0A0 JP NZ,$A0AD   ;
 $A0A3 LD A,L        ;
 $A0A4 ADD A,$20     ;
 $A0A6 LD L,A        ;
 $A0A7 JR C,$A0AD    ;
 $A0A9 LD A,H        ;
 $A0AA SUB $08       ;
 $A0AC LD H,A        ; }
*$A0AD DJNZ $A090    ; {loop B rows; done -> restore SP
 $A0AF JP $A104      ; }
*$A0B2 POP DE        ; {--- 2-cell-wide: copy+merge 3 mask/data pairs ---
 $A0B3 LD A,(HL)     ;
 $A0B4 AND E         ;
 $A0B5 OR D          ;
 $A0B6 LD (HL),A     ;
 $A0B7 INC L         ;
 $A0B8 POP DE        ;
 $A0B9 LD A,(HL)     ;
 $A0BA AND E         ;
 $A0BB OR D          ;
 $A0BC LD (HL),A     ;
 $A0BD INC L         ;
 $A0BE POP DE        ;
 $A0BF LD A,(HL)     ;
 $A0C0 AND E         ;
 $A0C1 OR D          ;
 $A0C2 LD (HL),A     ;
 $A0C3 DEC L         ;
 $A0C4 DEC L         ; }
 $A0C5 INC H         ; {wrap to next screen row
 $A0C6 LD A,H        ;
 $A0C7 AND $07       ;
 $A0C9 JP NZ,$A0D6   ;
 $A0CC LD A,L        ;
 $A0CD ADD A,$20     ;
 $A0CF LD L,A        ;
 $A0D0 JR C,$A0D6    ;
 $A0D2 LD A,H        ;
 $A0D3 SUB $08       ;
 $A0D5 LD H,A        ; }
*$A0D6 DJNZ $A0B2    ; {loop B rows; done -> restore SP
 $A0D8 JP $A104      ; }
*$A0DB POP DE        ; {--- 3-cell-wide: copy+merge 3 mask/data pairs ---
 $A0DC LD C,L        ;
 $A0DD LD A,(HL)     ;
 $A0DE AND E         ;
 $A0DF LD (HL),A     ;
 $A0E0 INC L         ;
 $A0E1 LD A,(HL)     ;
 $A0E2 AND D         ;
 $A0E3 POP DE        ;
 $A0E4 OR E          ;
 $A0E5 LD (HL),A     ;
 $A0E6 INC L         ;
 $A0E7 LD A,(HL)     ;
 $A0E8 AND D         ;
 $A0E9 POP DE        ;
 $A0EA OR E          ;
 $A0EB LD (HL),A     ;
 $A0EC INC L         ;
 $A0ED LD A,(HL)     ;
 $A0EE AND D         ; }
 $A0EF LD (HL),A     ; {restore L, advance H
 $A0F0 LD L,C        ;
 $A0F1 INC H         ; }
 $A0F2 LD A,H        ; {wrap to next screen row
 $A0F3 AND $07       ;
 $A0F5 JP NZ,$A102   ;
 $A0F8 LD A,L        ;
 $A0F9 ADD A,$20     ;
 $A0FB LD L,A        ;
 $A0FC JR C,$A102    ;
 $A0FE LD A,H        ;
 $A0FF SUB $08       ;
 $A101 LD H,A        ; }
*$A102 DJNZ $A0DB    ; loop B rows
*$A104 LD SP,($6000) ; get Temporary place for SP
 $A108 EI            ;
*$A109 POP BC        ; {next actor, loop B=5, RET
 $A10A POP IX        ;
 $A10C INC IX        ;
 $A10E DEC B         ;
 $A10F JP NZ,$A048   ;
 $A112 RET           ; }

; Level shift entry
;
; Used by the routine at #R$879B.
;
; .
;
; Entry into pstate_9, taken from pstate_4's landing code ($87E9) when
; game_state==3 (level transition).
; .
; Sets pstate_phase=$FF (negative, selects pstate_9's shift-in-progress branch)
; and player_state=9, falls into pstate_9.
@label=level_shift_entry
c$A113 LD A,$FF      ;
 $A115 LD ($60BF),A  ; set Player state-machine phase/height window
 $A118 LD A,$09      ;
 $A11A LD ($60C0),A  ; set Player state-machine state

; Pstate 9
;
; .
;
; .
;
; State 9: level-transition tower-column shift (slides the next section of the
; tower map into place after landing).
; .
; While pstate_phase is negative: if the level-column property byte ($603A) has
; counted down to 6, jumps to $A15B to wait for scroll_pos to reach the wrap
; point (#R$6030==$03E0), then INCs pstate_phase (0, still non-negative) to end
; the shift on the next call.
; .
; Otherwise: steps actor_obj column position back by 4, shifts 6 columns of the
; #R$F000 tower map left by one row (byte-copy loop), decrements $603A, stops
; the current sound and plays sound $0C -- repeats every call until the column
; property hits 6.
; .
; Once pstate_phase is non-negative, falls through (next call) to #R$A170 to
; finish the transition.
@label=pstate_9
c$A11D LD A,($60BF)  ; get Player state-machine phase/height window
 $A120 OR A          ;
 $A121 JP P,$A170    ;
 $A124 LD A,($603A)  ;
 $A127 CP $06        ;
 $A129 JR Z,$A15B    ;
 $A12B LD HL,($60BA) ;
 $A12E LD DE,$FFFC   ;
 $A131 ADD HL,DE     ;
 $A132 LD ($60BA),HL ;
 $A135 LD A,($603A)  ;
 $A138 SUB $05       ;
 $A13A LD L,A        ;
 $A13B LD H,$F0      ;
 $A13D LD C,$06      ;
*$A13F PUSH HL       ;
 $A140 LD B,$10      ;
*$A142 LD A,(HL)     ;
 $A143 DEC L         ;
 $A144 LD (HL),A     ;
 $A145 INC L         ;
 $A146 INC H         ;
 $A147 DJNZ $A142    ;
 $A149 POP HL        ;
 $A14A INC L         ;
 $A14B DEC C         ;
 $A14C JR NZ,$A13F   ;
 $A14E LD HL,$603A   ;
 $A151 DEC (HL)      ;
 $A152 CALL $A36D    ; Stop sound
 $A155 LD A,$0C      ;
 $A157 CALL $A3DE    ; Play sound
 $A15A RET           ;
*$A15B LD HL,($6030) ; get Vertical scroll position
 $A15E LD A,H        ;
 $A15F CP $03        ;
 $A161 RET NZ        ;
 $A162 LD A,L        ;
 $A163 CP $E0        ;
 $A165 RET NZ        ;
 $A166 LD HL,$60BF   ;
 $A169 INC (HL)      ;
 $A16A RET           ;

; Data block at A16B
;
; .
;
; .
;
; 5-byte attract-actor template, copied into the demo actor slot ($9EFA) by
; #R$A170.
b$A16B DEFB $54,$7C,$90,$90,$90

; Level shift done
;
; Used by the routine at #R$A11D.
;
; .
;
; Finishes the level-transition shift (reached once pstate_9's pstate_phase
; goes non-negative).
; .
; Resets the attract/demo actor state at #R$9EF0 (copies the #R$A16B template,
; clears the marker, sets phase 1), calls ATTRACT_STEP once, then sets
; game_state=4 (finished) -- the signal main_tick polls to end the transition
; and hand control back to main_loop's level-complete handling.
@label=level_shift_done
c$A170 LD HL,$A16B   ;
 $A173 LD DE,$9EFA   ;
 $A176 LD BC,$0005   ;
 $A179 LDIR          ;
 $A17B LD A,$00      ;
 $A17D LD ($9EF0),A  ;
 $A180 LD A,$01      ;
 $A182 LD ($9F0E),A  ;
 $A185 LD A,$01      ;
 $A187 CALL $9F33    ; Attract step
 $A18A LD A,$04      ;
 $A18C LD ($60D9),A  ; set Game state
 $A18F RET           ;

; Data block at A190
;
; .
;
; .
;
; Music sequencer's live state, not fixed data: stream pointer (#R$A190/91),
; current-note pointer ($A192/93), note-groups-remaining counter ($A194), note
; timer ($A195), active tune id ($A196). The DEFB values shown are just the
; reset state baked into the snapshot.
b$A190 DEFB $59,$A2,$72,$A2,$09,$00,$00

; Start music
;
; Used by the routines at #R$9963, #R$99A1, #R$99CE and #R$9B8A.
;
; .
;
; Begin music/jingle A: stash the id ($A196) then fall into init_music_seq to
; choose the data stream and arm the sequencer.
; .
; In: A=tune id.
@label=start_music
c$A197 LD ($A196),A  ;

; Init music sequence
;
; Used by the routine at #R$A1BD.
;
; .
;
; Picks one of 3 preset note-stream start addresses by tune id: 0 -> $A257 (9
; note-groups), 1 -> $A269 (1 group), else -> $A26B (fallback/short stinger).
; Arms the stream pointer, group counter and note timer (=1, fires
; immediately).
@label=init_music_seq
c$A19A LD A,($A196)  ;
 $A19D LD HL,$A257   ; {id==0 -> stream $A257, 9 groups
 $A1A0 LD B,$09      ; }
 $A1A2 OR A          ;
 $A1A3 JR Z,$A1B0    ;
 $A1A5 LD HL,$A269   ; {id==1 -> stream $A269, 1 group
 $A1A8 LD B,$01      ; }
 $A1AA DEC A         ;
 $A1AB JR Z,$A1B0    ;
 $A1AD LD HL,$A26B   ; else -> stream $A26B (same group count)
*$A1B0 LD ($A190),HL ; {arm stream pointer, group counter, note timer
 $A1B3 LD A,B        ;
 $A1B4 LD ($A194),A  ;
 $A1B7 LD A,$01      ; }
 $A1B9 LD ($A195),A  ;
 $A1BC RET           ;

; Music tick
;
; Used by the routines at #R$9963, #R$99A1, #R$99CE and #R$9BA5.
;
; .
;
; Per-frame music sequencer step (DI around it).
; .
; When the note timer ($A195) elapses, fetch the next event from the stream
; (#R$A190), update the current note ($A192), and play it.
; .
; A $FF note byte ends the current group: decrements the group counter ($A194)
; and loops to the next group if any remain, otherwise either holds the last
; note (tune id==0) or restarts via init_music_seq (id!=0, one-shot jingles
; loop back to their own start).
; .
; Otherwise the note byte indexes two parallel tables at #R$A238 (or $A23A,
; selected by the Specialist-beeper flag $6056) for a period value and #R$A249
; (an 11-char string used as a duration/shape lookup) for a tone-loop shape,
; then bit-bangs OUT ($FE) via an inlined tone loop (same shape as sfx_tone).
; .
; The Specialist has a 1-bit beeper too -- retarget the port and retune the
; delay loops.
@label=music_tick
c$A1BD DI            ;
 $A1BE LD A,($A195)  ;
 $A1C1 OR A          ;
 $A1C2 JR Z,$A1D6    ;
*$A1C4 XOR A         ;
 $A1C5 LD ($A195),A  ;
 $A1C8 LD HL,($A190) ; HL -> stream pointer, fetch next 16-bit event
 $A1CB LD E,(HL)     ;
 $A1CC INC HL        ;
 $A1CD LD D,(HL)     ;
 $A1CE INC HL        ;
 $A1CF LD ($A190),HL ;
 $A1D2 LD ($A192),DE ;
*$A1D6 LD HL,($A192) ; {A = current note byte
 $A1D9 LD A,(HL)     ; }
 $A1DA CP $FF        ; $FF = end of note-group
 $A1DC JR NZ,$A1F0   ;
 $A1DE LD HL,$A194   ;
 $A1E1 DEC (HL)      ; {decrement group counter
 $A1E2 JR NZ,$A1C4   ; }
 $A1E4 LD A,($A196)  ; {last group done: id==0 -> hold, else -> restart tune
 $A1E7 OR A          ;
 $A1E8 SCF           ;
 $A1E9 JR NZ,$A236   ; }
 $A1EB CALL $A19A    ; Init music sequence
 $A1EE JR $A1C4      ;
*$A1F0 INC HL        ;
 $A1F1 LD ($A192),HL ;
 $A1F4 LD HL,$A237   ; {index period table $A237+note, select beeper variant
 $A1F7 LD E,A        ; via $6056
 $A1F8 LD D,$00      ;
 $A1FA ADD HL,DE     ;
 $A1FB LD BC,$A238   ; }
 $A1FE LD A,($6056)  ;
 $A201 OR A          ;
 $A202 JR NZ,$A207   ;
 $A204 LD BC,$A23A   ;
*$A207 LD A,(BC)     ;
 $A208 LD ($A22B),A  ;
 $A20B INC BC        ;
 $A20C LD A,(BC)     ;
 $A20D LD ($A22C),A  ;
 $A210 LD B,(HL)     ;
 $A211 LD A,$01      ;
 $A213 ADD A,B       ;
 $A214 LD C,A        ;
 $A215 LD E,$00      ;
 $A217 LD D,$16      ;
 $A219 LD H,B        ;
 $A21A XOR A         ;
*$A21B DEC H         ; {inlined tone-loop bit-bang (OUT $FE), shaped by
 $A21C JR NZ,$A221   ; duration string byte
 $A21E OR $10        ;
 $A220 LD H,B        ;
*$A221 DEC L         ;
 $A222 JR NZ,$A227   ;
 $A224 OR $10        ;
 $A226 LD L,C        ;
*$A227 ADD A,$08     ;
 $A229 AND $10       ;
 $A22B OUT ($FE),A   ;
 $A22D SRL A         ;
 $A22F DEC E         ;
 $A230 JR NZ,$A21B   ;
 $A232 DEC D         ;
 $A233 JR NZ,$A21B   ;
 $A235 OR A          ;
*$A236 EI            ;
 $A237 RET           ; }

; Data block at A238
;
; .
;
; .
;
; Two parallel 8-entry period/duration tables (ZX at #R$A238, alternate
; "Specialist" beeper variant at $A240), indexed by note code and selected via
; $6056.
b$A238 DEFB $D3,$FE,$23,$2B,$00,$F2,$E7,$D8
 $A240 DEFB $CD,$C2,$B7,$AC,$A1,$99,$90,$88
 $A248 DEFB $80
; 11-char duration/shape string, one char per note code: each character's ASCII
; value supplies the H/L sub-loop counts for music_tick's inlined tone loop.
 $A249 DEFM "yslfa[VPLHD"

; Data block at A254
;
; .
;
; .
;
; A second, shorter period/shape table pair (1 byte + 3 chars) -- sparse
; coverage, likely only used by a short jingle's reduced note set.
b$A254 DEFB $40
 $A255 DEFM "96m"

; Data block at A258
;
; .
;
; .
;
; Real note-stream data starts one byte earlier, at $A257 (see init_music_seq):
; $A257 (9-group stream), $A269 (1-group stream) and $A26B (fallback stream)
; are literal entry addresses into this block, not a lookup table.
; .
; Byte values are note codes (indices into the #R$A238/#R$A249 tables) $FF
; marks the end of a note-group. Runs through $A367 the final 5 bytes
; ($A368-$A36C) are SFX-engine state (active effect id/pointer/priority), not
; music data.
b$A258 DEFB $A2,$6D,$A2,$8E,$A2,$8E,$A2,$AF
