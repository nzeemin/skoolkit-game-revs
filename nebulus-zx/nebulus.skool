b$B95D DEFB $12,$29,$16,$08,$1B,$10,$3F,$2A

; Setup strip draw
;
; Used by the routine at #R$A700.
;
; .
;
; Patch the tower column-strip blitter's params (#R$B941/$B9A1 row, $B942
; column base) from disp_height and scroll_pos (bit2 selects the $24/$2C column
; phase).
; .
; SELF-MOD.
; .
; Clobbers: A,B,C.
@label=setup_strip_draw
c$B965 LD B,A        ;
 $B966 LD A,($6032)  ; get Display height
 $B969 LD ($B941),A  ;
 $B96C LD ($B9A1),A  ;
 $B96F LD C,$24      ;
 $B971 LD A,($6030)  ; get Vertical scroll position
 $B974 BIT 2,A       ;
 $B976 JR Z,$B97B    ;
 $B978 LD C,$2C      ;
 $B97A DEC B         ;
*$B97B AND $03       ;
 $B97D ADD A,A       ;
 $B97E ADD A,C       ;
 $B97F LD C,A        ;
 $B980 LD ($B942),A  ;
 $B983 LD A,($6030)  ; get Vertical scroll position
 $B986 RRA           ;
 $B987 RRA           ;
 $B988 RRA           ;
 $B989 XOR $0F       ;
 $B98B AND $0F       ;
 $B98D LD E,A        ;
 $B98E LD D,$00      ;
 $B990 LD HL,$B945   ;
 $B993 ADD HL,DE     ;
 $B994 LD ($B944),HL ;
 $B997 EX DE,HL      ;
 $B998 LD H,C        ;
 $B999 LD A,B        ;
 $B99A EXX           ;
 $B99B LD B,A        ;
 $B99C EXX           ;
 $B99D LD B,$0A      ;
*$B99F LD A,(DE)     ;
 $B9A0 SUB $00       ;
 $B9A2 AND $3F       ;
 $B9A4 CP $1C        ;
 $B9A6 JR NC,$B9C7   ;
 $B9A8 EXX           ;
 $B9A9 BIT 7,B       ;
 $B9AB EXX           ;
 $B9AC JR Z,$B9B6    ;
 $B9AE CP $08        ;
 $B9B0 JR C,$B9B6    ;
 $B9B2 CP $14        ;
 $B9B4 JR C,$B9C7    ;
*$B9B6 ADD A,$02     ;
 $B9B8 LD L,A        ;
 $B9B9 LD C,H        ;
 $B9BA CALL $B5D9    ; Get screen addr
 $B9BD LD A,(HL)     ;
 $B9BE OR A          ;
 $B9BF JR NZ,$B9C6   ;
 $B9C1 LD (HL),$18   ;
 $B9C3 INC H         ;
 $B9C4 LD (HL),$18   ;
*$B9C6 LD H,C        ;
*$B9C7 INC DE        ;
 $B9C8 LD A,H        ;
 $B9C9 ADD A,$10     ;
 $B9CB LD H,A        ;
 $B9CC CP $B8        ;
 $B9CE RET NC        ;
 $B9CF EXX           ;
 $B9D0 DEC B         ;
 $B9D1 DEC B         ;
 $B9D2 EXX           ;
 $B9D3 DJNZ $B99F    ;
 $B9D5 RET           ;

; Draw tower strip
;
; Used by the routine at #R$A700.
;
; .
;
; Blit one vertical column strip of up to 10 tower elements using the params
; patched by setup_strip_draw resolves each cell's screen address via
; get_screen_addr.
; .
; Clobbers: A,B,DE,HL.
@label=draw_tower_strip
c$B9D6 LD DE,($B944)   ;
 $B9DA LD HL,($B941)   ;
 $B9DD LD B,$0A        ;
 $B9DF LD A,($B941)    ;
 $B9E2 LD ($B9E7),A    ;
*$B9E5 LD A,(DE)       ;
 $B9E6 SUB $00         ;
 $B9E8 AND $3F         ;
 $B9EA CP $1C          ;
 $B9EC JR NC,$BA03     ;
 $B9EE ADD A,$02       ;
 $B9F0 LD L,A          ;
 $B9F1 LD C,H          ;
 $B9F2 CALL $B5D9      ; Get screen addr
 $B9F5 LD A,$18        ;
 $B9F7 CP (HL)         ;
 $B9F8 JR NZ,$BA02     ;
 $B9FA INC H           ;
 $B9FB CP (HL)         ;
 $B9FC JR NZ,$BA02     ;
 $B9FE XOR A           ;
 $B9FF LD (HL),A       ;
 $BA00 DEC H           ;
 $BA01 LD (HL),A       ;
*$BA02 LD H,C          ;
*$BA03 INC DE          ;
 $BA04 LD A,H          ;
 $BA05 ADD A,$10       ;
 $BA07 LD H,A          ;
 $BA08 CP $B8          ;
 $BA0A RET NC          ;
 $BA0B DJNZ $B9E5      ;
 $BA0D RET             ;
 $BA0E DEFM "GFEDGFED" ;

; Routine at BA16
;
; Used by the routines at #R$B587, #R$BA26 and #R$BA67.
@label=lookup_col_attr
c$BA16 PUSH DE       ;
 $BA17 PUSH HL       ;
 $BA18 LD A,($6039)  ; get Level number 0
 $BA1B LD L,A        ;
 $BA1C LD H,$00      ;
 $BA1E LD DE,$BA0E   ;
 $BA21 ADD HL,DE     ;
 $BA22 LD A,(HL)     ;
 $BA23 POP HL        ;
 $BA24 POP DE        ;
 $BA25 RET           ;

; Paint tower attrs
;
; Used by the routine at #R$A700.
;
; .
;
; Repaint the tower's attribute (colour) band in the $58xx attribute file from
; $5860, using lookup_col_attr (#R$BA16) for per-column colours and fill_run
; ($BA61) to lay rows.
; .
; SELF-MOD: #R$BA66 row count.
; .
; Clobbers: A,BC,D,HL.
@label=paint_tower_attrs
c$BA26 LD A,$0E      ; {self-mod row count = $0E
 $BA28 LD ($BA66),A  ; }
 $BA2B LD HL,$5860   ; HL -> attribute band base ($5860)
 $BA2E LD B,$20      ;
 $BA30 XOR A         ; {D = 0 (edge/border colour)
 $BA31 LD D,A        ; }
 $BA32 CALL $BA61    ; fill_run: paint the left edge
 $BA35 LD C,$0B      ; C = $0B (column count)
*$BA37 LD (HL),D     ;
 $BA38 INC HL        ;
 $BA39 LD (HL),D     ;
 $BA3A INC HL        ;
 $BA3B LD B,$1C      ;
 $BA3D CALL $BA16    ; lookup_col_attr: colour for this column
 $BA40 CALL $BA61    ; fill_run: paint this column's rows
 $BA43 LD (HL),D     ;
 $BA44 INC HL        ;
 $BA45 LD (HL),D     ;
 $BA46 INC HL        ;
 $BA47 DEC C         ; {loop C columns
 $BA48 JR NZ,$BA37   ; }
 $BA4A LD C,$08      ;
*$BA4C LD (HL),D     ;
 $BA4D INC HL        ;
 $BA4E LD (HL),D     ;
 $BA4F INC HL        ;
 $BA50 LD B,$1C      ;
 $BA52 LD A,$41      ;
 $BA54 CALL $BA61    ;
 $BA57 LD (HL),D     ;
 $BA58 INC HL        ;
 $BA59 LD (HL),D     ;
 $BA5A INC HL        ;
 $BA5B DEC C         ;
 $BA5C JR NZ,$BA4C   ;
 $BA5E LD B,$20      ;
 $BA60 XOR A         ;
@label=fill_run
*$BA61 LD (HL),A     ;
 $BA62 INC HL        ;
 $BA63 DJNZ $BA61    ;
 $BA65 RET           ;

; Unused
s$BA66 DEFS $01

; Scroll tower attrs
;
; Used by the routine at #R$A700.
;
; .
;
; Adjust the painted attribute band as scroll_pos advances (compares against
; the #R$BA66 latch set by paint_tower_attrs) so colours track the scrolling
; tower.
; .
; Clobbers: A,B,HL.
@label=scroll_tower_attrs
c$BA67 LD HL,($6030) ; HL = scroll_pos
 $BA6A LD A,H        ; {top-of-tower page (H==3)?
 $BA6B CP $03        ; }
 $BA6D LD A,$16      ; A = $16 (default row index)
 $BA6F JR NZ,$BA7C   ;
 $BA71 LD A,L        ; A = scroll_pos low byte
 $BA72 NEG           ; negate (count down from top)
 $BA74 RRA           ; {/4, mask to row range
 $BA75 RRA           ;
 $BA76 AND $0F       ; }
 $BA78 SUB $16       ; bias by -$16
 $BA7A NEG           ; negate back
*$BA7C LD B,A        ; B = target row index
 $BA7D LD A,($BA66)  ; A = previous row index (#R$BA66 latch)
 $BA80 SUB B         ; delta = new - previous
 $BA81 JR Z,$BA94    ; unchanged? -> just update latch, RET
 $BA83 CP $FF        ; delta == -1 (scrolled up one row)?
 $BA85 JR Z,$BA99    ;
 $BA87 CP $01        ; delta == +1 (scrolled down one row)?
 $BA89 JR NZ,$BA94   ;
 $BA8B LD A,B        ; {store new row index in latch
 $BA8C LD ($BA66),A  ; }
 $BA8F INC B         ; B++ (paint the row below)
 $BA90 LD C,$41      ; C = $41 (default attribute)
 $BA92 JR $BAA1      ;
*$BA94 LD A,B        ;
 $BA95 LD ($BA66),A  ;
 $BA98 RET           ;
*$BA99 LD A,B        ; {store new row index in latch
 $BA9A LD ($BA66),A  ; }
 $BA9D CALL $BA16    ; recompute the attribute for this column via
                     ; lookup_col_attr
 $BAA0 LD C,A        ;
*$BAA1 LD L,B        ; {HL = B * 32 (attribute row address)
 $BAA2 LD H,$00      ;
 $BAA4 ADD HL,HL     ;
 $BAA5 ADD HL,HL     ;
 $BAA6 ADD HL,HL     ;
 $BAA7 ADD HL,HL     ;
 $BAA8 ADD HL,HL     ; }
 $BAA9 LD DE,$5802   ; DE = $5802 (attribute area base + offset)
 $BAAC ADD HL,DE     ;
 $BAAD LD B,$1C      ; B = $1C (28 columns)
*$BAAF LD (HL),C     ; {fill one attribute row with C, loop
 $BAB0 INC HL        ;
 $BAB1 DJNZ $BAAF    ; }
 $BAB3 RET           ;

; Unused
s$BAB4 DEFS $06

