; CLEAR_ACTOR_STATES -- zero the state byte (+48) of all four object_table
; actors, deactivating every enemy.
;
; Used by the routine at #R$81D7.
;
; .
;
; Clobbers: A,B,IX.
@label=clear_actor_states
c$8FB7 LD IX,$605B   ;
 $8FBB LD A,$00      ;
 $8FBD LD B,$04      ;
*$8FBF LD (IX+$30),A ;
 $8FC2 INC IX        ;
 $8FC4 DJNZ $8FBF    ;
 $8FC6 RET           ;

; DRAW_PLAYER -- compute the player sprite's on-screen address from the
; vertical scroll ($6030) and draw it.
;
; Used by the routine at #R$8240.
;
; .
;
; Handles the tower wrap: the playfield scrolls vertically mod the tower
; height, so the screen row is ($6030 +/- offset) kept in range.
; .
; Stores the two derived screen pointers ($6057, $6059) then calls the blit
; helpers ($8B50, $9035).
; .
; In: $6030 = scroll position.
; .
; Out: player drawn.
; .
; Clobbers A,HL.
; .
; i8080 PORT: the SBC/AND $03 wrap math maps the s
@label=draw_player
c$8FC7 LD HL,($6030) ; HL = scroll position ($6030)
 $8FCA LD A,L        ;
 $8FCB SUB $08       ; - 8 (sprite top offset)
 $8FCD LD L,A        ;
 $8FCE LD A,H        ;
 $8FCF SBC A,$00     ;
 $8FD1 AND $03       ; keep within the 3 screen-thirds (mod via AND 3)
 $8FD3 LD H,A        ;
 $8FD4 CP $03        ; past the wrap point ($3D0)?
 $8FD6 JR NZ,$8FE0   ;
 $8FD8 LD A,L        ;
 $8FD9 CP $D0        ;
 $8FDB JR C,$8FE0    ;
 $8FDD LD HL,$0000   ; -> clamp to top (0)
*$8FE0 LD ($6057),HL ; store upper screen pointer ($6057)
 $8FE3 LD HL,($6030) ;
 $8FE6 LD A,L        ;
 $8FE7 ADD A,$4D     ; + $4D (sprite body offset)
 $8FE9 LD L,A        ;
 $8FEA LD A,H        ;
 $8FEB ADC A,$00     ;
 $8FED AND $03       ;
 $8FEF LD H,A        ;
 $8FF0 LD ($6059),HL ; store lower screen pointer ($6059)
 $8FF3 CALL $8B50    ; blit sprite (mask + data)
 $8FF6 CALL $9035    ; draw attached widgets
 $8FF9 RET           ;

