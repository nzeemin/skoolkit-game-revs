 $AA0F JR Z,$AA13    ;
 $AA11 INC HL        ;
 $AA12 INC HL        ;
*$AA13 LD (HL),$00   ;
 $AA15 INC HL        ;
 $AA16 LD (HL),$01   ;
 $AA18 INC HL        ;
 $AA19 INC HL        ;
 $AA1A INC HL        ;
 $AA1B LD (HL),$00   ;
 $AA1D INC HL        ;
 $AA1E LD (HL),$00   ;
 $AA20 RET           ;

; BONUS_SUB -- BCD-subtract B from the active player's bonus value ($604B, 2
