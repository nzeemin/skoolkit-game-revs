; Stop sound
;
; Used by the routines at #R$802B, #R$9F33 and #R$A11D.
;
; .
;
; Silences the current SFX effect by marking $A368=$FF (sound_tick's "active
; marker" gate).
@label=stop_sound
c$A36D LD A,$FF      ;
 $A36F LD ($A368),A  ;
 $A372 RET           ;

; Data block at A373
;
; .
;
; .
;
; 13 pointer words (ids 0..$0C, matching play_sound's "id<$0D" range), one per
; sound effect, resolved by lookup_sound.
@label=snd_ptr_table
b$A373 DEFB $8D,$A3,$97,$A3,$9A,$A3,$9D,$A3
 $A37B DEFB $A2,$A3,$AA,$A3,$AF,$A3,$C9,$A3
 $A383 DEFB $C9,$A3,$CD,$A3,$D5,$A3,$D8,$A3
 $A38B DEFB $DB,$A3

; Data block at A38D
;
; .
;
; .
;
; The 13 effects' byte streams, back-to-back, addressed via snd_ptr_table. Each
; stream starts with 2 header bytes (priority, then a repeat/duration count
; copied into $A36C) followed by command/data bytes consumed by sound_tick:
; values <$80 are raw tone/length data for sfx_tone values $80/$81/$C8/$C9/$CA
; are specific ops (noise burst, random tone, etc., handled at
; #R$A48A/#R$A470/#R$A4BF/#R$A52E/#R$A4F2) values $82..$C7 go through the
; generic handler at #R$A493 anything else ends the effect.
@label=snd_effect_data
b$A38D DEFB $14,$08,$20,$1C,$18,$14,$20,$18
 $A395 DEFB $20,$18,$05,$01,$81,$0A,$01,$C9
 $A39D DEFB $0A,$03,$01,$20,$01,$0A,$06,$04
 $A3A5 DEFB $08,$0C,$10,$14,$18,$1E,$03,$01
 $A3AD DEFB $80,$81,$1E,$18,$01,$80,$82,$01
 $A3B5 DEFB $80,$82,$80,$82,$20,$81,$1C,$81
 $A3BD DEFB $18,$81,$14,$81,$10,$82,$0C,$82
 $A3C5 DEFB $08,$82,$04,$82,$1E,$02,$81,$82
 $A3CD DEFB $1E,$06,$82,$83,$84,$85,$86,$87
 $A3D5 DEFB $0A,$01,$80,$28,$01,$C8,$28,$01
 $A3DD DEFB $CA

; Play sound
;
; Used by the routines at #R$8240, #R$84B9, #R$85DB, #R$8656, #R$868D, #R$8724,
; #R$8736, #R$8831, #R$88BD, #R$8A4A, #R$8A71, #R$92D0, #R$9372, #R$955B,
; #R$96E9, #R$9F33 and #R$A11D.
;
; .
;
; Trigger sound effect A (id < $0D).
; .
; Saves all regs, looks up the effect via lookup_sound, and (subject to a
; priority check against the currently playing effect at $A368/$A369) latches
; its data pointer at $A36A for sound_tick to play out.
; .
; In: A=effect id.
; .
; Preserves all registers.
; .
; Most-called audio API.
@label=play_sound
c$A3DE PUSH AF       ;
 $A3DF PUSH BC       ;
 $A3E0 PUSH DE       ;
 $A3E1 PUSH HL       ;
 $A3E2 CP $0D        ;
 $A3E4 JR NC,$A406   ;
 $A3E6 CALL $A40B    ;
 $A3E9 LD D,A        ;
 $A3EA LD A,($A368)  ;
 $A3ED CP $FF        ;
 $A3EF JR Z,$A3F7    ;
 $A3F1 LD A,($A369)  ;
 $A3F4 CP B          ;
 $A3F5 JR C,$A406    ;
*$A3F7 LD ($A36A),HL ;
 $A3FA LD A,C        ;
 $A3FB LD ($A36C),A  ;
 $A3FE LD A,D        ;
 $A3FF LD ($A368),A  ;
 $A402 LD A,B        ;
 $A403 LD ($A369),A  ;
*$A406 POP HL        ;
 $A407 POP DE        ;
 $A408 POP BC        ;
 $A409 POP AF        ;
 $A40A RET           ;

; Routine at A40B
;
; Used by the routine at #R$A3DE.
@label=lookup_sound
c$A40B LD L,A        ;
 $A40C LD H,$00      ;
 $A40E LD DE,$A373   ;
 $A411 ADD HL,HL     ;
 $A412 ADD HL,DE     ;
 $A413 LD E,(HL)     ;
 $A414 INC HL        ;
 $A415 LD D,(HL)     ;
 $A416 EX DE,HL      ;
 $A417 LD B,(HL)     ;
 $A418 INC HL        ;
 $A419 LD C,(HL)     ;
 $A41A INC HL        ;
 $A41B RET           ;

; Sound tick
;
; Used by the routines at #R$8240 and #R$A02A.
;
; .
;
; Per-frame SFX engine step.
; .
; Gated by the sound-enable flag ($6056) and the active marker ($A368).
; .
; Reads the next byte of the current effect (pointer $A36A), interpreting
; commands (>=$80) vs tone/length data, and emits to the speaker.
; .
; The Specialist has a 1-bit beeper too -- retarget the port and retune the
; delay loops.
@label=sound_tick
c$A41C LD A,($6056)  ; sound-enable flag; off -> RET
 $A41F OR A          ;
 $A420 JP Z,$A50E    ;
 $A423 LD A,($A368)  ; {no active effect -> RET
 $A426 CP $FF        ; }
 $A428 JP Z,$A50E    ;
 $A42B LD HL,($A36A) ; {fetch next command/data byte from the effect stream
 $A42E LD A,(HL)     ;
 $A42F INC HL        ;
 $A430 LD ($A36A),HL ; }
 $A433 CP $80        ; raw data (<$80)? -> SFX tone
 $A435 JR C,$A462    ;
 $A437 CALL Z,$A48A  ;
 $A43A JR Z,$A465    ;
 $A43C CP $81        ;
 $A43E CALL Z,$A470  ;
 $A441 JR Z,$A465    ;
 $A443 CP $C8        ;
 $A445 CALL Z,$A4BF  ; SFX_ROM_NOISE
 $A448 JR Z,$A465    ;
 $A44A CP $C9        ;
 $A44C CALL Z,$A52E  ;
 $A44F JR Z,$A465    ;
 $A451 CP $CA        ;
 $A453 CALL Z,$A4F2  ;
 $A456 JR Z,$A465    ;
 $A458 CP $82        ; {else dispatch on command byte ($82-$C7 -> generic
 $A45A CALL NC,$A493 ; handler)}
 $A45D JR NC,$A465   ;
 $A45F JP $A46A      ;
*$A462 CALL $A539    ; SFX tone
*$A465 LD HL,$A36C   ;
 $A468 DEC (HL)      ;
 $A469 RET NZ        ;
*$A46A LD A,$FF      ;
 $A46C LD ($A368),A  ;
 $A46F RET           ;

; Routine at A470
;
; Used by the routine at #R$A41C.
c$A470 PUSH AF       ;
 $A471 LD E,$10      ;
 $A473 LD C,$12      ;
 $A475 LD D,$80      ;
*$A477 LD A,E        ;
 $A478 OUT ($FE),A   ;
 $A47A XOR $10       ;
 $A47C LD E,A        ;
 $A47D LD B,D        ;
*$A47E DJNZ $A47E    ;
 $A480 LD A,D        ;
 $A481 SUB $03       ;
 $A483 LD D,A        ;
 $A484 DEC C         ;
 $A485 JP NZ,$A477   ;
 $A488 POP AF        ;
 $A489 RET           ;

; Routine at A48A
;
; Used by the routine at #R$A41C.
c$A48A PUSH AF       ;
 $A48B LD DE,$0143   ;
 $A48E CALL $A4AD    ; SFX noise
 $A491 POP AF        ;
 $A492 RET           ;

; Routine at A493
;
; Used by the routine at #R$A41C.
c$A493 PUSH AF       ;
 $A494 LD B,$10      ;
 $A496 ADD A,$A3     ;
 $A498 LD H,A        ;
 $A499 LD L,$6D      ;
 $A49B LD DE,$0143   ;
*$A49E LD A,(HL)     ;
 $A49F AND B         ;
 $A4A0 OUT ($FE),A   ;
 $A4A2 INC HL        ;
 $A4A3 DEC DE        ;
 $A4A4 LD A,D        ;
 $A4A5 OR E          ;
 $A4A6 NOP           ;
 $A4A7 NOP           ;
 $A4A8 JP NZ,$A49E   ;
 $A4AB POP AF        ;
 $A4AC RET           ;

; SFX noise
;
; Used by the routine at #R$A48A.
;
; .
;
; White-noise burst: XORs the refresh register R into the speaker bit and
; toggles OUT ($FE) for DE iterations.
; .
; The Specialist has a 1-bit beeper too -- retarget the port and retune the
; delay loops.
@label=sfx_noise
c$A4AD LD B,$10      ;
*$A4AF LD A,R        ;
 $A4B1 XOR D         ;
 $A4B2 ADD A,E       ;
 $A4B3 AND B         ;
 $A4B4 OUT ($FE),A   ;
 $A4B6 DEC DE        ;
 $A4B7 LD A,D        ;
 $A4B8 OR E          ;
 $A4B9 NOP           ;
 $A4BA NOP           ;
 $A4BB JP NZ,$A4AF   ;
 $A4BE RET           ;

; SFX_ROM_NOISE
;
; Used by the routine at #R$A41C.
;
; .
;
; Noise burst sourced from ROM bytes at $8000+ (game code, used as
; pseudo-random data) rather than the R register: steps through with a random
; increment each read, OUTs bit 4 of each byte to the speaker, for BC=$7A
; iterations.
@label=sfx_rom_noise
c$A4BF PUSH AF       ; {save AF; A = random step (jp_random)
 $A4C0 CALL $A715    ; }
 $A4C3 LD E,A        ;
 $A4C4 LD HL,$8000   ; {HL -> $8000, BC = $7A (iteration count)
 $A4C7 LD BC,$007A   ; }
*$A4CA LD A,(HL)     ; {speaker bit = byte's bit 4
 $A4CB AND $10       ;
 $A4CD OUT ($FE),A   ; }
 $A4CF LD A,L        ; {HL += random step
 $A4D0 ADD A,E       ;
 $A4D1 LD L,A        ; }
 $A4D2 LD A,(HL)     ;
 $A4D3 AND $10       ;
 $A4D5 OUT ($FE),A   ;
 $A4D7 LD A,L        ;
 $A4D8 ADD A,E       ;
 $A4D9 LD L,A        ;
 $A4DA LD A,(HL)     ;
 $A4DB AND $10       ;
 $A4DD OUT ($FE),A   ;
 $A4DF LD A,L        ;
 $A4E0 ADD A,E       ;
 $A4E1 LD L,A        ;
 $A4E2 LD A,(HL)     ;
 $A4E3 AND $10       ;
 $A4E5 OUT ($FE),A   ;
 $A4E7 LD A,L        ;
 $A4E8 ADD A,E       ;
 $A4E9 LD L,A        ;
 $A4EA DEC BC        ; {loop BC iterations
 $A4EB LD A,B        ;
 $A4EC OR C          ;
 $A4ED JP NZ,$A4CA   ; }
 $A4F0 POP AF        ;
 $A4F1 RET           ;

; Routine at A4F2
;
; Used by the routine at #R$A41C.
c$A4F2 PUSH AF       ;
 $A4F3 LD A,($603A)  ;
 $A4F6 SRL A         ;
 $A4F8 SRL A         ;
 $A4FA CP $23        ;
 $A4FC JR C,$A500    ;
 $A4FE LD A,$22      ;
*$A500 PUSH AF       ;
 $A501 CALL $A715    ;
 $A504 AND $03       ;
 $A506 LD B,A        ;
 $A507 POP AF        ;
 $A508 XOR B         ;
 $A509 CALL $A539    ; SFX tone
 $A50C POP AF        ;
 $A50D RET           ;

; Routine at A50E
;
; Used by the routine at #R$A41C.
c$A50E LD HL,$036B   ;
*$A511 DEC HL        ;
 $A512 LD A,H        ;
 $A513 OR L          ;
 $A514 JP NZ,$A511   ;
 $A517 RET           ;

; Unused
s$A518 DEFS $01

