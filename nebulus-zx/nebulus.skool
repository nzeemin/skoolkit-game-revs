; Reads the column buffer ($600A) to skip empty/edge columns ($0F/$0E
; sentinels).
; .
; Called from sprite_setup ($8BD0).
; .
; i8080 PORT: replace self-mod patching with RAM shift vars the AND $7F / SRL
; x3 is the around-tower wrap + /8 byte-column calc.
@label=calc_sprite_shift
c$8CC2 LD A,(IX+$00)  ; A = actor angular pos (IX+0)
 $8CC5 CALL $8BEC     ; -> screen row / projected Y
 $8CC8 ADD A,$1E      ;
 $8CCA ADD A,$02      ;
