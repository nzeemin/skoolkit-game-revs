 $A4B1 XOR D         ;
 $A4B2 ADD A,E       ;
 $A4B3 AND B         ;
 $A4B4 OUT ($FE),A   ;
 $A4B6 DEC DE        ;
 $A4B7 LD A,D        ;
 $A4B8 OR E          ;
