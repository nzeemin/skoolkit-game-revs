 $8CF5 SRL A          ;
 $8CF7 SRL A          ;
 $8CF9 SRL A          ;
 $8CFB ADD A,C        ;
 $8CFC AND $0F        ;
 $8CFE LD ($8C76),A   ; patch shift count slot $8C76
