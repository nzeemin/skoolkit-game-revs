; Read input
;
; Used by the routine at #R$A700.
;
; .
;
; Proc_table[0]: sample controls into the signed input_x/input_y/input_fire
; vars.
; .
; Only active when game_mode (#R$6017) == 4 (in play) otherwise returns.
; .
; Reads the Kempston joystick and converts each axis to -1/0/+1 via bit tests +
; SBC/NEG.
; .
; The Specialist has no Kempston port -- replace read_joystick with the
; target's keyboard/joystick scan, keeping the -1/0/+1 result.
@label=read_input
c$A79F LD A,($6017)  ; A = game_mode (#R$6017)
 $A7A2 CP $04        ;
 $A7A4 JR NZ,$A7ED   ; only read controls while in play (mode 4)
 $A7A6 CALL $A7C8    ; A = raw joystick bits
 $A7A9 LD B,A        ;
 $A7AA AND $01       ;
 $A7AC SRL B         ;
 $A7AE SRL B         ;
 $A7B0 SBC A,$00     ;
 $A7B2 LD ($601D),A  ; input_y = -1/0/+1
 $A7B5 LD A,B        ;
 $A7B6 AND $01       ;
 $A7B8 SRL B         ;
 $A7BA SRL B         ;
 $A7BC SBC A,$00     ;
 $A7BE NEG           ;
 $A7C0 LD ($601E),A  ; input_fire = -1/0/+1 (negated)
 $A7C3 LD A,B        ;
 $A7C4 LD ($601C),A  ; input_x = -1/0/+1
 $A7C7 RET           ;

; Routine at A7C8
;
; Used by the routines at #R$A79F and #R$A840.
@label=read_joystick
c$A7C8 IN A,($1F)    ; read Kempston joystick port $1F (Z80 IN
 $A7CA AND $1F       ;
 $A7CC CP $1F        ; all 5 bits = nothing pressed
 $A7CE RET NZ        ;
 $A7CF XOR A         ;
 $A7D0 RET           ;

; Data block at A7D1
b$A7D1 DEFB $1D,$15,$19,$22,$0F,$12,$1A,$1E
 $A7D9 DEFB $25,$08,$24,$1C,$14,$0C,$04,$04
 $A7E1 DEFB $13,$03,$0B,$23,$D1,$A7,$D6,$A7
 $A7E9 DEFB $DB,$A7,$E0,$A7

; Scan control keys
;
; Used by the routines at #R$A700 and #R$A79F.
;
; .
;
; Read one 5-key control set into the flag array at $6018.
; .
; A selects the set: index a word-pointer table at $A7E5 (A*2) to a 5-byte
; key-id list, then test_key each one, storing 0/1 into $6018..#R$601C.
; .
; Used to read the redefinable keys.
; .
; In: A=set index.
; .
; Out: $6018[0..4] flags.
; .
; Clobbers: A,B,DE,HL.
@label=scan_control_keys
c$A7ED ADD A,A       ;
 $A7EE LD L,A        ;
 $A7EF LD H,$00      ;
 $A7F1 LD DE,$A7E5   ;
 $A7F4 ADD HL,DE     ;
 $A7F5 LD E,(HL)     ;
 $A7F6 INC HL        ;
 $A7F7 LD D,(HL)     ;
 $A7F8 LD HL,$6018   ;
 $A7FB LD B,$05      ;
*$A7FD LD A,(DE)     ;
 $A7FE CALL $A81F    ; Test key
 $A801 LD (HL),$00   ;
 $A803 JR Z,$A806    ;
 $A805 INC (HL)      ;
*$A806 INC HL        ;
 $A807 INC DE        ;
 $A808 DJNZ $A7FD    ;
 $A80A LD HL,$6018   ;
 $A80D LD A,(HL)     ;
 $A80E INC HL        ;
 $A80F SUB (HL)      ;
 $A810 INC HL        ;
 $A811 NEG           ;
 $A813 LD ($601D),A  ; set Signed input
 $A816 LD A,(HL)     ;
 $A817 INC HL        ;
 $A818 SUB (HL)      ;
 $A819 NEG           ;
 $A81B LD ($601E),A  ; set Signed input
 $A81E RET           ;

; Test key
;
; Used by the routines at #R$A700 and #R$A7ED.
;
; .
;
; Is a specific key down?
; .
; (proc_table slot $A706.) In:  A = key id, encoded (row<<3 | column) into the
; ZX keyboard matrix.
; .
; Out: Z set (A=0) if the key is pressed.
; .
; Builds the half-row select on the address bus (A=$FE rotated <row> times so
; one of A8..A15 is low) and reads ULA port $FE rotates out <column> bits and
; tests the active-low key bit.
@label=test_key
c$A81F PUSH BC       ;
 $A820 LD C,A        ; C = key id
 $A821 AND $07       ; low 3 bits = column -> bit count
 $A823 INC A         ;
 $A824 LD B,A        ;
 $A825 SRL C         ; C >>= 3 -> row index
 $A827 SRL C         ;
 $A829 SRL C         ;
 $A82B LD A,$05      ;
 $A82D SUB C         ; 5 - row -> number of rotates for the row select
 $A82E LD C,A        ;
 $A82F LD A,$FE      ; A = $FE: one address line low selects a keyboard
                     ; half-row
*$A831 RRCA          ; rotate the low bit into the row position (DJNZ)
 $A832 DJNZ $A831    ;
 $A834 IN A,($FE)    ; read ULA keyboard port $FE (Z80 IN
*$A836 RRA           ; shift out columns
 $A837 DEC C         ;
 $A838 JR NZ,$A836   ;
 $A83A LD A,C        ;
 $A83B JR C,$A83E    ; carry set = not pressed -> A=1
 $A83D INC A         ;
*$A83E POP BC        ;
 $A83F RET           ;

; Poll any key
;
; Used by the routine at #R$A700.
;
; .
;
; Return NZ if ANY input is active: scans the five keyboard half-rows via IN
; ($FE) (CPL+AND $1F), and if none, tests the Kempston fire bit ($10).
; .
; Out: A/flags NZ = pressed.
@label=poll_any_key
c$A840 XOR A         ;
 $A841 IN A,($FE)    ;
 $A843 CPL           ;
 $A844 AND $1F       ;
 $A846 RET NZ        ;
 $A847 CALL $A7C8    ;
 $A84A AND $10       ;
 $A84C RET           ;
; This entry point is used by the routine at #R$A700.
@label=wait_no_key
*$A84D CALL $A840    ; Poll any key
 $A850 JR NZ,$A84D   ;
 $A852 RET           ;

; Test break key
;
; Used by the routine at #R$A700.
;
; .
;
; Test the BREAK combination (CAPS SHIFT + SPACE) via two IN ($FE) row reads.
; .
; Returns with CARRY CLEAR only when both are held (used to abort).
; .
; Clobbers: A.
@label=test_break_key
c$A853 LD A,$7F      ;
 $A855 IN A,($FE)    ;
 $A857 RRA           ;
 $A858 RET C         ;
 $A859 LD A,$FE      ;
 $A85B IN A,($FE)    ;
 $A85D RRA           ;
 $A85E RET           ;

; Delay loop
;
; Used by the routine at #R$A700.
;
; .
;
; Busy-wait: B outer iterations of a ~$0086 inner countdown.
; .
; In: B=outer count.
; .
; Clobbers: A,B,HL (HL preserved).
@label=delay_loop
c$A85F PUSH HL       ;
*$A860 LD HL,$0086   ;
*$A863 DEC HL        ;
 $A864 LD A,H        ;
 $A865 OR L          ;
 $A866 JR NZ,$A863   ;
 $A868 DJNZ $A860    ;
 $A86A POP HL        ;
 $A86B RET           ;

; Next random
;
; Used by the routine at #R$A700.
;
; .
;
; Pseudo-random generator.
; .
; Reads the 16-bit seed (#R$6002), applies a multiply/shift + add $0029 LCG
; step, writes the new seed back, and returns A = high byte.
; .
; Out: A=random byte, (#R$6002) advanced.
; .
; Clobbers: A,DE,HL.
@label=next_random
c$A86C PUSH DE       ;
 $A86D PUSH HL       ;
 $A86E LD DE,($6002) ; get 16-bit LCG seed
 $A872 LD H,E        ;
 $A873 LD L,$00      ;
 $A875 ADD HL,DE     ;
 $A876 EX DE,HL      ;
 $A877 ADD HL,HL     ;
 $A878 ADD HL,HL     ;
 $A879 ADD HL,HL     ;
 $A87A EX DE,HL      ;
 $A87B OR A          ;
 $A87C SBC HL,DE     ;
 $A87E LD DE,$0029   ;
 $A881 ADD HL,DE     ;
 $A882 LD ($6002),HL ; set 16-bit LCG seed
 $A885 LD A,H        ;
 $A886 POP HL        ;
 $A887 POP DE        ;
 $A888 RET           ;

; Save regs frame
;
; Used by the routine at #R$A700.
;
; .
;
; Paired full CPU-context save and restore.
; .
; save_regs_frame pushes main+alternate register sets, IX, IY (EX AF,AF'/EXX to
; reach the shadow bank), then reads a 16-bit value out of the saved frame
; ($SP+$17) into HL before returning.
@label=save_regs_frame
c$A889 EX (SP),HL    ;
 $A88A PUSH DE       ;
 $A88B PUSH BC       ;
 $A88C PUSH AF       ;
 $A88D EX AF,AF'     ;
 $A88E EXX           ;
 $A88F PUSH HL       ;
 $A890 PUSH DE       ;
 $A891 PUSH BC       ;
 $A892 PUSH AF       ;
 $A893 EX AF,AF'     ;
 $A894 EXX           ;
 $A895 PUSH IX       ;
 $A897 PUSH IY       ;
 $A899 PUSH HL       ;
 $A89A PUSH AF       ;
 $A89B LD HL,$0017   ;
 $A89E ADD HL,SP     ;
 $A89F LD A,(HL)     ;
 $A8A0 DEC HL        ;
 $A8A1 LD L,(HL)     ;
 $A8A2 LD H,A        ;
 $A8A3 POP AF        ;
 $A8A4 RET           ;

; Restore regs frame
;
; Used by the routine at #R$A700.
;
; .
;
; Pops all registers back.
@label=restore_regs_frame
c$A8A5 POP HL                       ;
 $A8A6 POP IY                       ;
 $A8A8 POP IX                       ;
 $A8AA EX AF,AF'                    ;
 $A8AB EXX                          ;
 $A8AC POP AF                       ;
 $A8AD POP BC                       ;
 $A8AE POP DE                       ;
 $A8AF POP HL                       ;
 $A8B0 EX AF,AF'                    ;
 $A8B1 EXX                          ;
 $A8B2 POP AF                       ;
 $A8B3 POP BC                       ;
 $A8B4 POP DE                       ;
 $A8B5 EX (SP),HL                   ;
 $A8B6 RET                          ;
; Initial values for #R$6053
@label=tbl_play_timer_init
 $A8B7 DEFW $0500,$0600,$0700,$0800 ;
 $A8BF DEFW $0900,$1000,$1100,$1200 ;
@label=str_player1
 $A8C7 DEFM "PLAYER 1"              ;
 $A8CF DEFB $00                     ;
@label=str_player2
 $A8D0 DEFM "PLAYER 2"              ;
 $A8D8 DEFB $00                     ;

; Data block at A8D9
@label=attr_rle
b$A8D9 DEFB $08,$04,$02,$00,$0C,$06,$02,$00
 $A8E1 DEFB $08,$04,$08,$07,$10,$06,$08,$07
 $A8E9 DEFB $20,$00

; Setup attrs
;
; Used by the routine at #R$A700.
;
; .
;
; Paint the static playfield attribute layout and the two PLAYER score labels.
; .
; Run once at start (via jp_setup_attrs).
; .
; Reads attr_rle (9 run-length [count,attr] pairs) and floods the attribute
; area $5800+ with attr|$40 (BRIGHT set on every cell).
; .
; Then prints the PLAYER 1 / PLAYER 2 strings and seeds two score/counter
; widgets via helper calls.
; .
; In: nothing.
; .
; Clobbers: A,BC,DE,HL.
@label=setup_attrs
c$A8EB LD A,$FF      ; A = $FF
 $A8ED LD ($60C8),A  ; store $FF to a flag at #R$60C8
 $A8F0 LD HL,$A8D9   ; HL -> attr_rle (run-length attribute table)
 $A8F3 LD DE,$5800   ; DE -> $5800 = attribute area base
 $A8F6 LD C,$09      ; C = 9 outer groups
*$A8F8 LD B,(HL)     ; B = run length for this group
 $A8F9 INC HL        ;
 $A8FA LD A,(HL)     ; A = attribute byte for this group
 $A8FB OR $40        ; force BRIGHT bit ($40) on
 $A8FD INC HL        ;
*$A8FE LD (DE),A     ; write attr to cell
 $A8FF INC DE        ;
 $A900 DJNZ $A8FE    ;
 $A902 DEC C         ;
 $A903 JR NZ,$A8F8   ; next group until C groups done
 $A905 LD HL,$A8C7   ; HL -> 'PLAYER 1' string
 $A908 LD BC,$0000   ; BC = 0x0000 = attr/screen position arg
 $A90B CALL $AB53    ; Print string
 $A90E LD BC,$1800   ; BC = 0x1800 = position for 'PLAYER 2'
 $A911 CALL $AB53    ; Print string
 $A914 LD BC,$0900   ;
 $A917 LD A,$A8      ;
 $A919 CALL $AAC2    ;
 $A91C LD BC,$1600   ;
 $A91F LD A,$A7      ;
 $A921 CALL $AAC2    ;
 $A924 LD BC,$0002   ;
 $A927 CALL $A936    ; Draw HUD bar
 $A92A LD BC,$1802   ;
 $A92D CALL $A936    ; Draw HUD bar
 $A930 CALL $A943    ; Reset score state
 $A933 JP $A959      ; tail-jump into the next setup step

; Draw HUD bar
;
; Used by the routine at #R$A8EB.
;
; .
;
; At the print position in BC, print 8 copies of glyph $81 (a solid block) --
; the score-panel divider bar.
; .
; In: BC=print pos.
; .
; Clobbers: A,B.
@label=draw_hud_bar
c$A936 CALL $AB7A    ;
 $A939 LD A,$81      ;
 $A93B LD B,$08      ;
*$A93D CALL $AAC5    ; Print char
 $A940 DJNZ $A93D    ;
 $A942 RET           ;

; Reset score state
;
; Used by the routines at #R$A700 and #R$A8EB.
;
; .
;
; Init the score/lives HUD state for a new game: lives_p2 (#R$6041)=3, $6042=3,
; $60C2=0, and zero the 8-byte block $6043..$604A (the two 4-byte BCD score
; buffers).
; .
; Reached from proc_table slot $A721 (JP) and from $A930 (CALL, then falls
; through to draw_hud_counters).
@label=reset_score_state
c$A943 LD A,$03      ;
 $A945 LD ($6041),A  ; set Lives
 $A948 LD ($6042),A  ;
 $A94B XOR A         ;
 $A94C LD ($60C2),A  ;
 $A94F LD HL,$6043   ;
 $A952 LD B,$08      ;
*$A954 LD (HL),A     ;
 $A955 INC HL        ;
 $A956 DJNZ $A954    ;
 $A958 RET           ;

; Draw HUD counters
;
; Used by the routines at #R$A700 and #R$A8EB.
;
; .
;
; Paint the score/lives panel.
; .
; Sets the '1UP'/'2UP' marker attribute cells (toggled by lives_p1), then
; prints lives_p2/$6042 as 2-digit decimals and the two BCD score buffers via
; set_print_pos + print_bcd_byte.
; .
; Clobbers: A,BC,DE,HL.
@label=draw_hud_counters
c$A959 LD A,$FF      ;
 $A95B LD ($60C8),A  ; set Current text colour/attribute
 $A95E LD HL,$0046   ;
 $A961 LD A,($6040)  ; get Lives
 $A964 OR A          ;
 $A965 JR Z,$A96A    ;
 $A967 LD HL,$4600   ;
*$A96A LD A,L        ;
 $A96B LD ($5809),A  ;
 $A96E LD A,H        ;
 $A96F LD ($5816),A  ;
 $A972 LD HL,$5840   ;
 $A975 LD A,($6041)  ; get Lives
 $A978 CALL $A9AD    ;
 $A97B LD HL,$5858   ;
 $A97E LD A,($6042)  ;
 $A981 CALL $A9AD    ;
 $A984 LD BC,$0001   ;
 $A987 LD HL,$6046   ;
 $A98A CALL $A993    ; Print score field
 $A98D LD BC,$1801   ;
 $A990 LD HL,$604A   ;

; Print score field
;
; Used by the routine at #R$A959.
;
; .
;
; Position the cursor (BC) then print a 2-byte (4-digit) BCD value at HL via
; print_bcd_word.
; .
; In: BC=pos, HL=MSB.
@label=print_score_field
c$A993 CALL $AB7A    ;
 $A996 CALL $A999    ;
@label=print_bcd_word
*$A999 CALL $A99C    ;
@label=print_bcd_byte
*$A99C LD A,(HL)     ;
 $A99D RRA           ;
 $A99E RRA           ;
 $A99F RRA           ;
 $A9A0 RRA           ;
 $A9A1 CALL $A9A6    ;
 $A9A4 LD A,(HL)     ;
 $A9A5 DEC HL        ;
@label=print_nibble
*$A9A6 AND $0F       ;
 $A9A8 ADD A,$30     ;
 $A9AA JP $AAC5      ;

; Routine at A9AD
;
; Used by the routine at #R$A959.
@label=draw_gauge8
c$A9AD LD B,$08      ;
 $A9AF LD C,A        ;
*$A9B0 LD A,$00      ;
 $A9B2 DEC C         ;
 $A9B3 JP M,$A9B8    ;
 $A9B6 LD A,$42      ;
*$A9B8 LD (HL),A     ;
 $A9B9 INC HL        ;
 $A9BA DJNZ $A9B0    ;
 $A9BC RET           ;

; Add BCD score
;
; Used by the routine at #R$A700.
;
; .
;
; Add HL (16-bit BCD delta) to the active player's 4-byte BCD score (lives_p1
; selects $6043 or $6047), with DAA carry propagation across all 4 bytes.
; .
; In: HL=BCD delta, lives_p1=index.
; .
; Clobbers: A,B,C,DE.
@label=add_bcd_score
c$A9BD LD DE,$6043   ;
 $A9C0 LD A,($6040)  ; get Lives
 $A9C3 OR A          ;
 $A9C4 JR Z,$A9C9    ;
 $A9C6 LD DE,$6047   ;
*$A9C9 LD A,(DE)     ;
 $A9CA ADD A,L       ;
 $A9CB DAA           ;
 $A9CC LD (DE),A     ;
 $A9CD INC DE        ;
 $A9CE LD A,(DE)     ;
 $A9CF LD B,A        ;
 $A9D0 ADC A,H       ;
 $A9D1 DAA           ;
 $A9D2 LD (DE),A     ;
 $A9D3 LD C,A        ;
 $A9D4 INC DE        ;
 $A9D5 LD A,(DE)     ;
 $A9D6 ADC A,$00     ;
 $A9D8 LD (DE),A     ;
 $A9D9 INC DE        ;
 $A9DA LD A,(DE)     ;
 $A9DB ADC A,$00     ;
 $A9DD LD (DE),A     ;
 $A9DE LD A,B        ;
 $A9DF AND $F0       ;
 $A9E1 CP $40        ;
 $A9E3 JR NZ,$A9EC   ;
 $A9E5 LD A,C        ;
 $A9E6 AND $F0       ;
 $A9E8 CP $50        ;
 $A9EA JR Z,$A9F6    ;
*$A9EC LD A,B        ;
 $A9ED AND $F0       ;
 $A9EF CP $90        ;
 $A9F1 RET NZ        ;
 $A9F2 LD A,C        ;
 $A9F3 AND $F0       ;
 $A9F5 RET NZ        ;
*$A9F6 LD HL,$6041   ;
 $A9F9 LD A,($6040)  ; get Lives
 $A9FC OR A          ;
 $A9FD JR Z,$AA00    ;
 $A9FF INC HL        ;
*$AA00 INC (HL)      ;
 $AA01 LD A,(HL)     ;
 $AA02 CP $08        ;
 $AA04 RET C         ;
 $AA05 LD (HL),$08   ;
 $AA07 RET           ;

; Init bonus
;
; Used by the routine at #R$A700.
;
; .
;
; Seed the active player's (lives_p1 index) bonus/ accumulator block at $604B:
; bonus = BCD 0100, $604F-side cleared.
; .
; Clobbers: A,HL.
@label=init_bonus
c$AA08 LD HL,$604B   ;
 $AA0B LD A,($6040)  ; get Lives
 $AA0E OR A          ;
 $AA0F JR Z,$AA13    ;
 $AA11 INC HL        ;
 $AA12 INC HL        ;
*$AA13 LD (HL),$00   ;
 $AA15 INC HL        ;
 $AA16 LD (HL),$01   ;
 $AA18 INC HL        ;
 $AA19 INC HL        ;
 $AA1A INC HL        ;
 $AA1B LD (HL),$00   ;
 $AA1D INC HL        ;
 $AA1E LD (HL),$00   ;
 $AA20 RET           ;

; Bonus sub
;
; Used by the routine at #R$A700.
;
; .
;
; BCD-subtract B from the active player's bonus value ($604B, 2 bytes),
; clamping at 0 on underflow (RET NC else zero it).
; .
; In: A/B=BCD amount.
; .
; Clobbers: A,B,HL.
@label=bonus_sub
c$AA21 LD B,A        ;
 $AA22 LD HL,$604B   ;
 $AA25 LD A,($6040)  ; get Lives
 $AA28 OR A          ;
 $AA29 JR Z,$AA2D    ;
 $AA2B INC HL        ;
 $AA2C INC HL        ;
*$AA2D LD A,(HL)     ;
 $AA2E SUB B         ;
 $AA2F DAA           ;
 $AA30 LD (HL),A     ;
 $AA31 INC HL        ;
 $AA32 LD A,(HL)     ;
 $AA33 SBC A,$00     ;
 $AA35 DAA           ;
 $AA36 LD (HL),A     ;
 $AA37 RET NC        ;
 $AA38 XOR A         ;
 $AA39 LD (HL),A     ;
 $AA3A DEC HL        ;
 $AA3B LD (HL),A     ;
 $AA3C RET           ;

; Add to bonus field 604F
;
; Used by the routine at #R$A700.
;
; .
;
; BCD-add B to the active player's 2-byte field at $604F, saturating: high byte
; hitting 6 resets to 05/low=00.
; .
; In: A/B=BCD amount.
; .
; Clobbers: A,B,HL.
@label=field_604f_add
c$AA3D LD B,A        ;
 $AA3E LD HL,$604F   ;
 $AA41 LD A,($6040)  ; get Lives
 $AA44 OR A          ;
 $AA45 JR Z,$AA49    ;
 $AA47 INC HL        ;
 $AA48 INC HL        ;
*$AA49 LD A,(HL)     ;
 $AA4A ADD A,B       ;
 $AA4B DAA           ;
 $AA4C LD (HL),A     ;
 $AA4D INC HL        ;
 $AA4E LD A,(HL)     ;
 $AA4F ADC A,$00     ;
 $AA51 LD (HL),A     ;
 $AA52 CP $06        ;
 $AA54 RET C         ;
 $AA55 LD (HL),$05   ;
 $AA57 DEC HL        ;
 $AA58 LD (HL),$00   ;
 $AA5A RET           ;

; Set level timer
;
; Used by the routine at #R$A700.
;
; .
;
; Load play_timer from the word table at #R$A8B7 indexed by (#R$6039)*2
; (per-level start time), then fall into #R$AA96 to show it.
; .
; Clobbers: A,DE,HL.
@label=set_level_timer
c$AA5B LD A,($6039)  ;
 $AA5E ADD A,A       ;
 $AA5F LD E,A        ;
 $AA60 LD D,$00      ;
 $AA62 LD HL,$A8B7   ;
 $AA65 ADD HL,DE     ;
 $AA66 LD E,(HL)     ;
 $AA67 INC HL        ;
 $AA68 LD D,(HL)     ;
 $AA69 LD ($6053),DE ; set Level countdown timer
 $AA6D JP $AA96      ;

; Tick timer
;
; Used by the routine at #R$A700.
;
; .
;
; Prescaled level-timer countdown.
; .
; #R$6055 counts 0..4 only every 5th call does it BCD-decrement play_timer (2
; bytes, clamped at 0) and redraw via draw_timer.
; .
; RET M while prescaler is negative (timer disabled).
; .
; Clobbers: A,HL.
@label=tick_timer
c$AA70 LD HL,$6055   ;
 $AA73 LD A,(HL)     ;
 $AA74 OR A          ;
 $AA75 RET M         ;
 $AA76 INC A         ;
 $AA77 LD (HL),A     ;
 $AA78 CP $05        ;
 $AA7A RET C         ;
 $AA7B LD (HL),$00   ;
 $AA7D LD HL,$6053   ;
 $AA80 LD A,(HL)     ;
 $AA81 SUB $01       ;
 $AA83 DAA           ;
 $AA84 LD (HL),A     ;
 $AA85 INC HL        ;
 $AA86 LD A,(HL)     ;
 $AA87 SBC A,$00     ;
 $AA89 DAA           ;
 $AA8A LD (HL),A     ;
 $AA8B JP P,$AA96    ;
 $AA8E XOR A         ;
 $AA8F LD (HL),A     ;
 $AA90 DEC HL        ;
 $AA91 LD (HL),A     ;
 $AA92 DEC A         ;
 $AA93 LD ($6055),A  ; set Level timer prescaler

; Draw timer
;
; Used by the routines at #R$A700, #R$AA5B and #R$AA70.
;
; .
;
; Print the 2-byte BCD play_timer ($6054) as decimal digits at print row $0E
; (white).
; .
; Uses print_2digits/print_digit.
; .
; Clobbers: A,BC,HL.
@label=draw_timer
c$AA96 LD A,$FF      ;
 $AA98 LD ($60C8),A  ; set Current text colour/attribute
 $AA9B LD BC,$0E00   ;
 $AA9E CALL $AB7A    ; Set print pos
 $AAA1 LD HL,$6054   ;
 $AAA4 CALL $AAA8    ;
 $AAA7 DEC HL        ;
@label=print_2digits
*$AAA8 LD A,(HL)     ;
 $AAA9 RRA           ;
 $AAAA RRA           ;
 $AAAB RRA           ;
 $AAAC RRA           ;
 $AAAD CALL $AAB1    ;
 $AAB0 LD A,(HL)     ;
@label=print_digit
*$AAB1 AND $0F       ;
 $AAB3 ADD A,$30     ;
 $AAB5 JP $AAC5      ;

; Data block at AAB8
@label=punct_map
b$AAB8 DEFB $20,$00
 $AABA DEFM "<(>'"

; Data block at AABE
b$AABE DEFB $40,$26,$2A,$19,$CD,$7A,$AB

; Print char
;
; Used by the routines at #R$A700, #R$A936, #R$A993, #R$AA96 and #R$AB53.
;
; .
;
; Render one character at the current text cursor.
; .
; In:  A = character code.
; .
; >=$80 : direct glyph index (graphics char), A&$7F.
; .
; 'A'..'Z' : glyph = (A-'A')+2.
; .
; '0'..'9' : glyph = (A-'0')+$1C.
; .
; <$10     : colour/attribute control code -> cur_color.
; .
; else     : looked up in punct_map.
; .
; cursor in print_cursor (#R$60C6 lo=col) cur_color (#R$60C8).
; .
; Out: glyph blitted to screen column cursor ($60C7) advanced.
@label=print_char
c$AAC5 PUSH AF       ; save all regs (caller-transparent)
 $AAC6 PUSH BC       ;
 $AAC7 PUSH DE       ;
 $AAC8 PUSH HL       ;
 $AAC9 BIT 7,A       ; bit7 set? -> direct graphics glyph index
 $AACB JR Z,$AAD1    ;
 $AACD AND $7F       ; strip bit7, use as glyph index
 $AACF JR $AB0F      ;
*$AAD1 CP $41        ; 'A'($41)..'Z'($5A)?
 $AAD3 JR C,$AADF    ;
 $AAD5 CP $5B        ;
 $AAD7 JR NC,$AADF   ;
 $AAD9 SUB $41       ; glyph = (A-'A') + 2  (letters start at glyph 2)
 $AADB ADD A,$02     ;
 $AADD JR $AB0F      ;
*$AADF CP $30        ; '0'($30)..'9'($39)?
 $AAE1 JR C,$AAED    ;
 $AAE3 CP $3A        ;
 $AAE5 JR NC,$AAED   ;
 $AAE7 SUB $30       ; glyph = (A-'0') + $1C  (digits start at glyph $1C)
 $AAE9 ADD A,$1C     ;
 $AAEB JR $AB0F      ;
*$AAED CP $10        ; code <$10? -> colour control code
 $AAEF JR NC,$AAFF   ;
 $AAF1 LD B,A        ;
 $AAF2 AND $07       ; ink = A & 7
 $AAF4 BIT 3,B       ; bit3 of code = BRIGHT -> OR $40
 $AAF6 JR Z,$AAFA    ;
 $AAF8 OR $40        ;
*$AAFA LD ($60C8),A  ; store into cur_color (#R$60C8)
 $AAFD JR $AB4E      ;
*$AAFF LD HL,$AAB8   ; HL -> punct_map (5 entries)
 $AB02 LD B,$05      ;
*$AB04 CP (HL)       ; compare code against each map char
 $AB05 JR Z,$AB0D    ;
 $AB07 INC HL        ;
 $AB08 INC HL        ;
 $AB09 DJNZ $AB04    ;
 $AB0B JR $AB4E      ;
*$AB0D INC HL        ;
 $AB0E LD A,(HL)     ; matched: A = glyph index from map
@label=glyph_addr
*$AB0F LD L,A        ; L = glyph index
 $AB10 ADD A,A       ; A = index*6 via index + index*2, then *2 (6 bytes/glyph)
 $AB11 ADD A,L       ;
 $AB12 ADD A,A       ;
 $AB13 LD L,A        ; HL = index*6
 $AB14 LD H,$00      ;
 $AB16 LD DE,$C000   ; DE = #R$C000 = font base
 $AB19 ADD HL,DE     ; HL -> glyph bitmap (6 bytes)
 $AB1A PUSH HL       ;
 $AB1B LD BC,($60C6) ; BC = print_cursor (C=column 0..31)
@label=glyph_blit
 $AB1F LD A,C        ; A = column
 $AB20 AND $18       ; H = (col & $18) | $40 : screen-addr high byte
                     ; (third+page)
 $AB22 LD H,A        ;
 $AB23 SET 6,H       ;
 $AB25 RRCA          ;
 $AB26 RRCA          ;
 $AB27 RRCA          ;
 $AB28 OR $58        ; OR $58 -> D = matching attribute-area high byte ($58xx)
 $AB2A LD D,A        ;
 $AB2B LD A,C        ;
 $AB2C AND $07       ;
 $AB2E RRCA          ;
 $AB2F RRCA          ;
 $AB30 RRCA          ;
 $AB31 ADD A,B       ;
 $AB32 LD L,A        ;
 $AB33 LD E,A        ;
 $AB34 LD A,($60C8)  ; A = cur_color
 $AB37 CP $FF        ; $FF = 'transparent' -> skip attribute write
 $AB39 JR Z,$AB3C    ;
 $AB3B LD (DE),A     ; write colour to attribute cell
*$AB3C POP DE        ;
 $AB3D LD (HL),$00   ; blank top scanline of the cell
 $AB3F INC H         ; INC H = step down one pixel row (Z80 ZX adjacency)
 $AB40 LD B,$06      ; B = 6 font rows
*$AB42 LD A,(DE)     ; copy one font row to screen
 $AB43 LD (HL),A     ;
 $AB44 INC DE        ;
 $AB45 INC H         ;
 $AB46 DJNZ $AB42    ;
 $AB48 LD (HL),$00   ; blank bottom scanline
 $AB4A LD HL,$60C7   ;
 $AB4D INC (HL)      ; advance column cursor ($60C7)
*$AB4E POP HL        ;
 $AB4F POP DE        ;
 $AB50 POP BC        ;
 $AB51 POP AF        ;
 $AB52 RET           ;

; Print string
;
; Used by the routine at #R$A8EB.
;
; .
;
; Print an ASCIIZ string at position BC.
; .
; In: HL=string (00-terminated), BC=cursor pos.
; .
; Out: HL past terminator.
@label=print_string
c$AB53 CALL $AB7A    ; set cursor = BC
; This entry point is used by the routines at #R$A700 and #R$AB5F.
@label=print_string_loop
*$AB56 LD A,(HL)     ; A = next char
 $AB57 INC HL        ;
 $AB58 OR A          ; 00 terminator?
 $AB59 RET Z         ; done (ASCIIZ) -- RET on Z
 $AB5A CALL $AAC5    ; Print char
 $AB5D JR $AB56      ; next char

; Print centered
;
; Used by the routine at #R$A700.
@label=print_centered
c$AB5F PUSH HL       ;
 $AB60 LD C,$00      ; C = visible-char count
*$AB62 LD A,(HL)     ;
 $AB63 OR A          ;
 $AB64 JR Z,$AB6E    ;
 $AB66 CP $10        ; ignore codes <$10 (colour controls) in the count
 $AB68 JR C,$AB6B    ;
 $AB6A INC C         ;
*$AB6B INC HL        ;
 $AB6C JR $AB62      ;
*$AB6E LD A,$20      ; A = 32 - count
 $AB70 SUB C         ;
 $AB71 RRA           ; RRA = /2 = left margin
 $AB72 LD ($60C7),A  ; store as start column ($60C7)
 $AB75 POP HL        ;
 $AB76 CALL $AB56    ;
 $AB79 RET           ;

; Set print pos
;
; Used by the routines at #R$A700, #R$A936, #R$A993, #R$AA96 and #R$AB53.
@label=set_print_pos
c$AB7A LD ($60C6),BC ;
 $AB7E RET           ;

; Clear obj table
;
; Used by the routines at #R$A700 and #R$AD82.
@label=clear_obj_table
c$AB7F LD HL,$6460   ;
 $AB82 LD DE,$000D   ;
 $AB85 LD B,$14      ;
 $AB87 XOR A         ;
*$AB88 LD (HL),A     ;
 $AB89 INC HL        ;
 $AB8A LD (HL),A     ;
 $AB8B INC HL        ;
 $AB8C LD (HL),A     ;
 $AB8D ADD HL,DE     ;
 $AB8E LD (HL),A     ;
 $AB8F INC HL        ;
 $AB90 LD (HL),A     ;
 $AB91 INC HL        ;
 $AB92 LD (HL),A     ;
 $AB93 INC HL        ;
 $AB94 DJNZ $AB88    ;
 $AB96 RET           ;

; Calc tower col addr
;
; Used by the routines at #R$A700 and #R$AD82.
;
; .
;
; Compute a byte address inside the $6400 tower/column buffer from disp_height
; (&7, *24) and scroll_pos, returning the slot pointer(s) for column rendering.
; .
; Clobbers: A,BC,DE,HL.
@label=calc_tower_col_addr
c$AB97 LD A,($6032)  ; {row offset = (disp_height&7)*24 into $6400
 $AB9A AND $07       ;
 $AB9C LD B,A        ;
 $AB9D ADD A,A       ;
 $AB9E ADD A,B       ;
 $AB9F ADD A,A       ;
 $ABA0 ADD A,A       ; }
 $ABA1 LD C,A        ;
 $ABA2 LD B,$00      ;
 $ABA4 LD HL,$6400   ;
 $ABA7 ADD HL,BC     ;
 $ABA8 EX DE,HL      ;
 $ABA9 ADD A,$30     ; {column offset, wrapped mod $60 (96)
 $ABAB CP $60        ;
 $ABAD JR C,$ABB1    ;
 $ABAF SUB $60       ; }
*$ABB1 LD C,A        ;
 $ABB2 LD HL,$6400   ; {HL -> $6400+offset (primary column pointer)
 $ABB5 ADD HL,BC     ; }
 $ABB6 LD A,($6030)  ; get Vertical scroll position
 $ABB9 AND $04       ; {scroll_pos bit2 selects HL/DE swap
 $ABBB JR NZ,$ABBE   ;
 $ABBD EX DE,HL      ; }
*$ABBE PUSH DE       ; {copy 2x12-byte snapshot from HL/DE into $6463/$6475
 $ABBF LD DE,$6463   ; scratch
 $ABC2 LDI           ;
 $ABC4 LDI           ;
 $ABC6 LDI           ;
 $ABC8 LDI           ;
 $ABCA LDI           ;
 $ABCC LDI           ;
 $ABCE LDI           ;
 $ABD0 LDI           ;
 $ABD2 LDI           ;
 $ABD4 LDI           ;
 $ABD6 LDI           ;
 $ABD8 LDI           ;
 $ABDA LD DE,$6475   ;
 $ABDD POP HL        ;
 $ABDE LDI           ;
 $ABE0 LDI           ;
 $ABE2 LDI           ;
 $ABE4 LDI           ;
 $ABE6 LDI           ;
 $ABE8 LDI           ;
 $ABEA LDI           ;
 $ABEC LDI           ;
 $ABEE LDI           ;
 $ABF0 LDI           ;
 $ABF2 LDI           ;
 $ABF4 LDI           ; }
 $ABF6 LD HL,$6463   ; {HL/DE -> $6463/$6487, A=$12 repeat count
 $ABF9 LD DE,$6487   ;
 $ABFC LD A,$12      ; }
*$ABFE LDI           ; {duplicate the 24-byte snapshot forward (stride 12) to
 $AC00 LDI           ; extend the strip buffer
 $AC02 LDI           ;
 $AC04 LDI           ;
 $AC06 LDI           ;
 $AC08 LDI           ;
 $AC0A LDI           ;
 $AC0C LDI           ;
 $AC0E LDI           ;
 $AC10 LDI           ;
 $AC12 LDI           ;
 $AC14 LDI           ;
 $AC16 LD BC,$0006   ;
 $AC19 ADD HL,BC     ;
 $AC1A EX DE,HL      ;
 $AC1B ADD HL,BC     ;
 $AC1C EX DE,HL      ;
 $AC1D DEC A         ;
 $AC1E JP NZ,$ABFE   ;
 $AC21 RET           ; }

; Col visible offset
;
; Used by the routine at #R$A700.
;
; .
;
; Compute the on-screen column offset of the object at #R$60BA relative to
; scroll_pos, folded into the 4-quadrant (mod $03) tower wrap.
; .
; Returns A=offset (RET Z if off-screen).
; .
; Clobbers: A,B,DE,HL.
@label=col_visible_offset
c$AC22 LD HL,($60BA) ; {HL = object position ($60BA), biased and wrapped mod 4
 $AC25 LD A,L        ;
 $AC26 SUB $28       ;
 $AC28 LD L,A        ;
 $AC29 LD A,H        ;
 $AC2A SBC A,$00     ;
 $AC2C AND $03       ;
 $AC2E LD H,A        ; }
 $AC2F LD B,$00      ;
 $AC31 LD DE,($6030) ; get Vertical scroll position
 $AC35 LD A,L        ; {delta = position - scroll_pos
 $AC36 SUB E         ;
 $AC37 LD L,A        ;
 $AC38 LD A,H        ;
 $AC39 SBC A,D       ;
 $AC3A AND $03       ; }
 $AC3C CP $02        ;
 $AC3E LD A,L        ;
 $AC3F JR C,$AC44    ;
 $AC41 DEC B         ;
 $AC42 NEG           ;
*$AC44 OR A          ; {zero delta -> RET (off-screen)
 $AC45 RET Z         ; }
 $AC46 ADD A,$03     ; {fold delta to an on-screen column offset
 $AC48 SRL A         ; }
 $AC4A SRL A         ;
 $AC4C BIT 7,B       ;
 $AC4E JR Z,$AC52    ;
 $AC50 NEG           ;
*$AC52 LD HL,$6030   ; {apply the offset back into scroll_pos, wrapped mod 4
 $AC55 ADD A,(HL)    ;
 $AC56 LD (HL),A     ;
 $AC57 LD A,B        ;
 $AC58 INC HL        ;
 $AC59 ADC A,(HL)    ;
 $AC5A AND $03       ;
 $AC5C LD (HL),A     ; }
 $AC5D RET           ;

; Blit scroll wrap
;
; Used by the routine at #R$A700.
;
; .
;
; When scroll_pos has wrapped past the top (H==$03 && L>=$D8), fast-fill the
; newly exposed strip using the LD SP,screen / stack-write trick (saves real SP
; to #R$6000, DI, reads mask_acb0).
; .
; RET early when no wrap is pending.
@label=blit_scroll_wrap
c$AC5E LD HL,($6030) ;
 $AC61 LD A,H        ;
 $AC62 CP $03        ;
 $AC64 RET NZ        ;
 $AC65 LD A,L        ;
 $AC66 CP $D8        ;
 $AC68 RET C         ;
 $AC69 XOR A         ;
 $AC6A SUB L         ;
 $AC6B SUB L         ;
 $AC6C PUSH AF       ;
 $AC6D LD B,A        ;
 $AC6E LD A,$B8      ;
 $AC70 SUB B         ;
 $AC71 LD H,A        ;
 $AC72 LD L,$1E      ;
 $AC74 CALL $B5D9    ; Get screen addr
 $AC77 POP AF        ;
 $AC78 LD ($6000),SP ; set Temporary place for SP
 $AC7C DI            ;
 $AC7D LD DE,$ACB0   ;
*$AC80 EX AF,AF'     ;
 $AC81 LD SP,HL      ;
 $AC82 EX DE,HL      ;
 $AC83 LD C,(HL)     ;
 $AC84 INC HL        ;
 $AC85 LD B,C        ;
 $AC86 PUSH BC       ;
 $AC87 PUSH BC       ;
 $AC88 PUSH BC       ;
 $AC89 PUSH BC       ;
 $AC8A PUSH BC       ;
 $AC8B PUSH BC       ;
 $AC8C PUSH BC       ;
 $AC8D PUSH BC       ;
 $AC8E PUSH BC       ;
 $AC8F PUSH BC       ;
 $AC90 PUSH BC       ;
 $AC91 PUSH BC       ;
 $AC92 PUSH BC       ;
 $AC93 PUSH BC       ;
 $AC94 EX DE,HL      ;
 $AC95 INC H         ;
 $AC96 LD A,H        ;
 $AC97 AND $07       ;
 $AC99 JR NZ,$ACA5   ;
 $AC9B LD A,L        ;
 $AC9C ADD A,$20     ;
 $AC9E LD L,A        ;
 $AC9F JR C,$ACA5    ;
 $ACA1 LD A,H        ;
 $ACA2 SUB $08       ;
 $ACA4 LD H,A        ;
*$ACA5 EX AF,AF'     ;
 $ACA6 DEC A         ;
 $ACA7 JP NZ,$AC80   ;
 $ACAA LD SP,($6000) ; get Temporary place for SP
 $ACAE EI            ;
 $ACAF RET           ;

; Data block at ACB0
@label=mask_acb0
b$ACB0 DEFB $00,$00,$00,$00,$00,$00,$20,$00
 $ACB8 DEFB $08,$00,$40,$00,$02,$20,$00,$01
 $ACC0 DEFB $80,$04,$20,$08,$40,$02,$10,$01
 $ACC8 DEFB $88,$22,$44,$11,$88,$22,$44,$11
 $ACD0 DEFB $92,$25,$92,$45,$8A,$51,$A2,$51
 $ACD8 DEFB $55,$AA,$55,$AA,$55,$AA,$55,$AA
 $ACE0 DEFB $6D,$DA,$6D,$BA,$75,$AE,$5D,$AE
 $ACE8 DEFB $77,$DD,$BB,$EE,$77,$DD,$BB,$EE
 $ACF0 DEFB $7F,$FB,$DF,$F7,$BF,$FD,$EF,$FE
 $ACF8 DEFB $FF,$FF,$FF,$FF,$FF,$FF,$FF,$FF

; Clear object list near scroll seam
;
; Used by the routine at #R$A700.
;
; .
;
; Called every frame from render_play_frame, before setup_tower_scroll.
; .
; Reads scroll_pos and checks whether it is near the tower's top or bottom wrap
; seam (two symmetric branches on the high byte, biased by +$15/+$13 and
; compared against the $603A level-column threshold). If near an edge, computes
; an overshoot count C and zero-fills C*9 bytes at $6460+ -- clearing stale
; object/sprite-list entries that would otherwise linger once the visible
; column range shrinks near the seam. If not near an edge (C==0), returns
; immediately.
; .
; Clobbers: A,BC,DE,HL.
@label=code_ad00
c$AD00 LD C,$00      ; C = 0 (default: no overshoot)
 $AD02 LD HL,($6030) ; get Vertical scroll position
 $AD05 LD A,H        ; {near the top seam (H==3)?
 $AD06 CP $03        ;
 $AD08 JR NZ,$AD23   ; }
 $AD0A LD A,L        ; {low byte far from the wrap point ($D8)? skip
 $AD0B CP $D8        ;
 $AD0D JR C,$AD23    ; }
 $AD0F LD A,L        ; {fold scroll_pos to a coarse row (>>2)
 $AD10 SRL H         ;
 $AD12 RRA           ;
 $AD13 SRL H         ;
 $AD15 RRA           ; }
 $AD16 ADD A,$15     ; bias by $15 (top-seam offset)
 $AD18 LD HL,$603A   ;
 $AD1B CP (HL)       ; compare vs level-column threshold ($603A)
 $AD1C JR C,$AD35    ;
 $AD1E DEC A         ; {overshoot = row-1 - threshold
 $AD1F SUB (HL)      ;
 $AD20 JP $AD34      ; }
*$AD23 LD A,L        ; {bottom-seam mirror: fold, bias by $13, compare
 $AD24 SRL H         ;
 $AD26 RRA           ;
 $AD27 SRL H         ;
 $AD29 RRA           ;
 $AD2A ADD A,$13     ;
 $AD2C LD HL,$603A   ;
 $AD2F CP (HL)       ; }
 $AD30 JR C,$AD35    ;
 $AD32 INC A         ;
 $AD33 SUB (HL)      ;
*$AD34 LD C,A        ;
*$AD35 LD A,C        ; {A = overshoot count; none -> RET
 $AD36 OR A          ;
 $AD37 RET Z         ; }
 $AD38 PUSH AF       ;
 $AD39 ADD A,A       ; {count*9 -> BC (9 bytes per overshoot unit)
 $AD3A ADD A,A       ;
 $AD3B ADD A,A       ;
 $AD3C ADD A,C       ;
 $AD3D ADD A,A       ;
 $AD3E LD C,A        ; }
 $AD3F LD B,$00      ;
 $AD41 DEC BC        ;
 $AD42 LD HL,$6460   ;
 $AD45 LD DE,$6461   ;
 $AD48 LD (HL),$00   ; seed first byte = 0
 $AD4A LDIR          ; LDIR: zero-fill BC bytes at $6460 (stale slot cleanup)
 $AD4C POP AF        ;
 $AD4D RET           ;

; Anim bg phase
;
; Used by the routine at #R$A700.
;
; .
;
; Advance the background animation phase counter ($603D) on the wrap point
; reload $603C with $08 (animation restart).
; .
; Clobbers: A,HL.
@label=anim_bg_phase
c$AD4E LD HL,$603D   ;
 $AD51 INC (HL)      ;
 $AD52 LD A,(HL)     ;
 $AD53 ADD A,A       ;
 $AD54 AND $18       ;
 $AD56 CP $18        ;
 $AD58 JR NZ,$AD5C   ;
 $AD5A LD A,$08      ;
*$AD5C LD ($603C),A  ;
 $AD5F RET           ;

; Data block at AD60
;
; .
;
; .
;
; Self-modified scratch, not pure data: #R$AD60/$AD61 are 1-byte accumulators
; seeded by setup_tower_scroll ($ADA1/$ADAF) with a row-start bias and a fine
; row offset, then incremented every pass of setup_tower_scroll's row loop
; ($AE6E-$AE81) by table bytes stored at $AD62..$AD80 (16 rows x 2-byte deltas)
; -- i.e. a per-row coarse/fine screen-row stepping table, not just static
; data.
b$AD60 DEFB $00,$00,$FF,$F8,$FF,$F8,$FF,$F8
 $AD68 DEFB $04,$20,$01,$08,$01,$08,$01,$08
 $AD70 DEFB $F8,$C0,$FF,$F8,$FF,$F8,$FF,$F8
 $AD78 DEFB $FC,$E0,$01,$08,$01,$08,$01,$08
 $AD80 DEFB $00,$00

; Setup tower scroll
;
; Used by the routine at #R$A700.
;
; .
;
; Per-frame scroll/render setup.
; .
; Clears the object table, derives the coarse column ($ADC6) and sub-column
; fraction ($6021) from scroll_pos, and the row base ($AD61) from disp_height.
; .
; SELF-MODIFIES the render code ($ADC6/$AD61) and latches $6021 for
; draw_tower_cols.
; .
; Runs a 16-row loop ($ADB8..$AE85): for each row it reads two per-column-cell
; nibbles from map data at #R$6200+DE / $6280+DE, classifies the cell
; (bit-pattern tests at $AE21-$AE67) and jumps to one of the masked-blit
; handlers below (#R$AEBB/#R$AF2A/#R$AF86/#R$AFD0/#R$B03F) or straight to the
; row-accumulator advance at $AE6D. Each handler returns to the common
; continuation $AE18 (advance HL by -$12, DJNZ loop) before the next row.
; .
; Clobbers: A,C,HL.
@label=setup_tower_scroll
c$AD82 CALL $AB7F    ; clear object table (calc_tower_col_addr's prep)
 $AD85 LD HL,($6030) ; get Vertical scroll position
 $AD88 LD A,L        ;
 $AD89 SRL H         ; shift scroll_pos right by 3 (coarse column)
 $AD8B RRA           ;
 $AD8C SRL H         ;
 $AD8E RRA           ;
 $AD8F LD ($ADC6),A  ; self-mod store: coarse column ($ADC6)
 $AD92 LD A,L        ;
 $AD93 AND $03       ; isolate sub-column fraction bits
 $AD95 ADD A,A       ;
 $AD96 LD ($6021),A  ; latch sub-column phase ($6021)
 $AD99 LD A,($6032)  ; get Display height
 $AD9C LD C,A        ;
 $AD9D AND $07       ; isolate row-in-cell bits (disp_height&7)
 $AD9F ADD A,$58     ; bias by $58 (attribute-row base)
 $ADA1 LD ($AD61),A  ; self-mod store: row base ($AD61)
 $ADA4 SRL C         ; C = disp_height >> 3 (coarse row)
 $ADA6 SRL C         ;
 $ADA8 SRL C         ;
 $ADAA LD A,$0B      ; A = $0B - coarse row
 $ADAC SUB C         ;
 $ADAD AND $0F       ; mask to 4 bits
 $ADAF LD ($AD60),A  ; self-mod store: row accumulator (#R$AD60)
 $ADB2 EXX           ;
 $ADB3 LD B,$00      ; B = 0 (row counter)
 $ADB5 LD HL,$AD62   ; HL -> per-row delta table ($AD62)
*$ADB8 LD A,B        ; A = row counter
 $ADB9 CP $08        ; {row==8? recompute column addr mid-loop
 $ADBB JP NZ,$ADC5   ; }
 $ADBE PUSH BC       ;
 $ADBF PUSH HL       ;
 $ADC0 CALL $AB97    ; Calc tower col addr
 $ADC3 POP HL        ;
 $ADC4 POP BC        ;
*$ADC5 LD E,$00      ; E = 0 (cell index low)
 $ADC7 LD A,($AD60)  ; {D = row accumulator + $F0 (map page)
 $ADCA ADD A,$F0     ; }
 $ADCC LD D,A        ;
 $ADCD EXX           ;
 $ADCE LD A,($AD61)  ; {E = column fraction (map offset low)
 $ADD1 LD E,A        ; }
 $ADD2 LD D,$00      ;
 $ADD4 LD HL,$6200   ; {HL -> #R$6200 + column (cell type table 1)
 $ADD7 ADD HL,DE     ; }
 $ADD8 LD A,(HL)     ;
 $ADD9 OR A          ; {negative? -> $AE6D (empty cell, skip)
 $ADDA JP M,$AE6D    ; }
 $ADDD SRL A         ; {shift cell nibble right 2
 $ADDF SRL A         ; }
 $ADE1 LD ($AE35),A  ; {self-mod: patch two render-handler operands
 $ADE4 LD ($AE4B),A  ; }
 $ADE7 LD A,(HL)     ; {A = cell byte again, mask low 2 bits
 $ADE8 AND $03       ; }
 $ADEA LD ($AF2D),A  ; {self-mod: patch two more render-handler operands
 $ADED LD ($AFD3),A  ; }
 $ADF0 LD HL,$6280   ; {HL -> $6280 + column (cell type table 2)
 $ADF3 ADD HL,DE     ; }
 $ADF4 LD A,(HL)     ;
 $ADF5 OR A          ;
 $ADF6 JP M,$ADFD    ; negative? skip the shift
 $ADF9 SRL A         ; shift cell nibble right 2
 $ADFB SRL A         ;
*$ADFD LD ($AE40),A  ; {self-mod: patch two render-handler operands
 $AE00 LD ($AE58),A  ; }
 $AE03 LD A,(HL)     ; {A = 2nd cell byte, mask low 2 bits
 $AE04 AND $03       ; }
 $AE06 LD ($AF89),A  ; {self-mod: patch two more render-handler operands
 $AE09 LD ($B044),A  ; }
 $AE0C LD B,$14      ; B = $14 (20 sub-cells to classify)
 $AE0E LD HL,$65B6   ; HL -> classification bitmap ($65B6)
*$AE11 EXX           ; {fetch next classification bit
 $AE12 LD A,(DE)     ;
 $AE13 INC E         ;
 $AE14 EXX           ; }
 $AE15 ADD A,A       ; shift bit into carry
 $AE16 JR C,$AE21    ;
; This entry point is used by the routines at #R$AEBB, #R$AF2A, #R$AF86,
; #R$AFD0 and #R$B03F.
*$AE18 LD DE,$FFEE   ; DE = -$12 (back up dest ptr)
 $AE1B ADD HL,DE     ;
 $AE1C DJNZ $AE11    ; loop 20 sub-cells
 $AE1E JP $AE6D      ;
*$AE21 RRA           ; shift in the next bit
 $AE22 LD C,A        ; C = classification byte so far
 $AE23 AND $0C       ; test bits $0C (cell sub-type)
 $AE25 JR Z,$AE2B    ;
 $AE27 BIT 0,C       ; test bit 0 of C
 $AE29 JR NZ,$AE4A   ;
*$AE2B LD A,C        ;
 $AE2C AND $03       ; mask to bits 0-1
 $AE2E SRL A         ; shift right (test bit 0)
 $AE30 JR NZ,$AE55   ; nonzero -> $AE55 (anim-texture case)
 $AE32 JR NC,$AE3F   ; no carry -> $AE3F (cap-b case)
 $AE34 LD DE,$0000   ; self-mod operand for the handler call
 $AE37 BIT 7,E       ; test bit 7 of E
 $AE39 JP Z,$AF2A    ; dispatch -> render_col_cap_a
 $AE3C JP $AE18      ;
*$AE3F LD DE,$0000   ;
 $AE42 BIT 7,E       ;
 $AE44 JP Z,$AF86    ;
 $AE47 JP $AE18      ;
*$AE4A LD DE,$0000   ;
 $AE4D BIT 7,E       ;
 $AE4F JP Z,$AFD0    ;
 $AE52 JP $AE18      ;
*$AE55 JR C,$AE62    ; carry set -> $AE62 (partial-column case)
 $AE57 LD DE,$0000   ;
 $AE5A BIT 7,E       ;
 $AE5C JP Z,$B03F    ;
 $AE5F JP $AE18      ;
*$AE62 LD A,($AD61)  ; A = row base
 $AE65 CP $40        ; compare vs $40 (screen-half boundary)
 $AE67 JP C,$AEBB    ; dispatch -> render_col_partial
 $AE6A JP $AE18      ;
*$AE6D EXX           ; EXX back to main register set
 $AE6E LD A,($AD60)  ; A = row accumulator
 $AE71 ADD A,(HL)    ; {add per-row delta, wrap to 4 bits
 $AE72 AND $0F       ; }
 $AE74 LD ($AD60),A  ; store updated row accumulator
 $AE77 INC HL        ;
 $AE78 LD A,($AD61)  ; A = fine row offset
 $AE7B ADD A,(HL)    ; {add per-row delta, wrap to 7 bits
 $AE7C AND $7F       ; }
 $AE7E LD ($AD61),A  ; store updated fine row offset
 $AE81 INC HL        ;
 $AE82 INC B         ; B++ (row counter)
 $AE83 BIT 4,B       ; done all 16 rows?
 $AE85 JP Z,$ADB8    ;
 $AE88 RET           ;

; Data block at AE89
;
; .
;
; .
;
; 24-entry (2 bytes each) AND/OR mask-pair table: "AND clear old bits, OR in
; new bits" merge masks for column pixel bytes that don't align to a whole
; screen byte (edge-clipped column tops/bottoms). Read by the handler at
; #R$AEBB.
@label=col_blit_masks
b$AE89 DEFB $FF,$00,$FC,$02,$F3,$08,$F0,$0A
 $AE91 DEFB $CF,$20,$CC,$00,$C3,$28,$C0,$22
 $AE99 DEFB $3F,$80,$3C,$00,$33,$00,$30,$00
 $AEA1 DEFB $0F,$A0,$0C,$00,$03,$88,$00,$82
 $AEA9 DEFB $00,$80,$C0,$20,$F0,$08,$FC,$02
 $AEB1 DEFB $3F,$80,$0F,$20,$03,$08,$00,$02
 $AEB9 DEFB $00,$00

; Render col partial
;
; Used by the routine at #R$AD82.
;
; .
;
; One of setup_tower_scroll's five per-cell render handlers -- the
; "partial/short column" case.
; .
; Looks up a length adjustment (table $6300) and an edge-type value (table
; $6340) indexed by the column (DE), computes and self-mod-stores a destination
; pointer ($AEB9), then masked-merges the destination byte(s) using mask pairs
; picked from col_blit_masks (#R$AE89, 16-entry branch for tall/negative case)
; or from a second 4-entry table at $AEA9 (short/positive case), plus a run of
; up to 3 plain-store bytes and a final 2-entry table ($AEB1) merge.
; .
; Ends by jumping back to setup_tower_scroll's row loop continuation ($AE18).
; .
; Clobbers: A,DE,HL.
@label=render_col_partial
c$AEBB PUSH BC       ; {DE=A; HL -> length table $6300+DE
 $AEBC PUSH HL       ;
 $AEBD LD E,A        ;
 $AEBE LD D,$00      ;
 $AEC0 LD HL,$6300   ;
 $AEC3 ADD HL,DE     ; }
 $AEC4 LD A,(HL)     ; {length+3 -> destination byte offset
 $AEC5 ADD A,$03     ;
 $AEC7 LD C,A        ;
 $AEC8 LD B,$00      ;
 $AECA POP HL        ;
 $AECB PUSH HL       ;
 $AECC ADD HL,BC     ; }
 $AECD LD ($AEB9),HL ; self-mod store: destination pointer ($AEB9)
 $AED0 LD HL,$6340   ; {HL -> edge-type table $6340+DE
 $AED3 ADD HL,DE     ;
 $AED4 LD A,(HL)     ;
 $AED5 OR A          ; }
 $AED6 JP P,$AEEF    ; sign bit set? -> short/positive branch
 $AED9 AND $0F       ; {tall branch: index col_blit_masks (#R$AE89) by
 $AEDB ADD A,A       ; (type&$0F)*2
 $AEDC LD E,A        ;
 $AEDD LD HL,$AE89   ;
 $AEE0 ADD HL,DE     ;
 $AEE1 LD DE,($AEB9) ; }
 $AEE5 LD A,(DE)     ; {AND/OR merge one byte, restore regs, return
 $AEE6 AND (HL)      ;
 $AEE7 INC HL        ;
 $AEE8 OR (HL)       ;
 $AEE9 LD (DE),A     ;
 $AEEA POP HL        ;
 $AEEB POP BC        ;
 $AEEC JP $AE18      ; }
*$AEEF LD C,A        ; {short branch: index 2nd mask table $AEA9 by (type&3)*2
 $AEF0 AND $03       ;
 $AEF2 ADD A,A       ;
 $AEF3 LD E,A        ;
 $AEF4 LD HL,$AEA9   ;
 $AEF7 ADD HL,DE     ;
 $AEF8 LD DE,($AEB9) ; }
 $AEFC LD A,(DE)     ; {AND/OR merge first byte, advance DE
 $AEFD AND (HL)      ;
 $AEFE INC HL        ;
 $AEFF OR (HL)       ;
 $AF00 LD (DE),A     ;
 $AF01 INC DE        ; }
 $AF02 LD A,C        ; {C = type; test bits $30 (extra-byte count)
 $AF03 AND $30       ; }
 $AF05 JR Z,$AF15    ;
 $AF07 CP $20        ; {write 0/1/2 plain bytes depending on $30 bits
 $AF09 LD A,$00      ;
 $AF0B JR C,$AF13    ;
 $AF0D JR Z,$AF11    ;
 $AF0F LD (DE),A     ;
 $AF10 INC DE        ;
*$AF11 LD (DE),A     ;
 $AF12 INC DE        ;
*$AF13 LD (DE),A     ;
 $AF14 INC DE        ; }
*$AF15 LD A,C        ; {C = (type>>1)&$06 -> index final 2-entry table $AEB1
 $AF16 RRA           ;
 $AF17 AND $06       ;
 $AF19 LD C,A        ;
 $AF1A LD B,$00      ;
 $AF1C LD HL,$AEB1   ; }
 $AF1F ADD HL,BC     ;
 $AF20 LD A,(DE)     ; {AND/OR merge last byte, restore regs, return
 $AF21 AND (HL)      ;
 $AF22 INC HL        ;
 $AF23 OR (HL)       ;
 $AF24 LD (DE),A     ;
 $AF25 POP HL        ;
 $AF26 POP BC        ; }
 $AF27 JP $AE18      ;

; Render col cap a
;
; Used by the routine at #R$AD82.
;
; .
;
; Another per-cell render handler, selected for a specific column-edge sub-case
; (DE==0 test in setup_tower_scroll's classification).
; .
; 4-way branch on a self-mod test byte ($AF2C/$AF2E, patched by
; setup_tower_scroll at $ADEA/$ADED). Each branch writes 3 destination bytes
; with mostly-fixed bit patterns (pre-rendered tower-cap/edge tile graphics)
; merged via AND/OR masks at the first/last byte to blend with the adjacent
; column.
; .
; Ends `POP HL / JP $AE18` in all 4 branches.
c$AF2A PUSH HL       ; save dest ptr
 $AF2B ADD HL,DE     ; HL += DE (apply column offset)
 $AF2C LD A,$00      ; A = self-mod test byte
 $AF2E SRL A         ; shift test byte -> Z/C flags
 $AF30 JP NZ,$AF57   ; nonzero -> branch 3/4 ($AF57)
 $AF33 JP C,$AF42    ; carry set -> branch 2 ($AF42)
 $AF36 LD (HL),$1B   ; branch 1: fixed byte 1 ($1B)
 $AF38 INC HL        ;
 $AF39 LD (HL),$FB   ; fixed byte 2 ($FB)
 $AF3B INC HL        ;
 $AF3C LD (HL),$A4   ; fixed byte 3 ($A4)
 $AF3E POP HL        ; restore dest ptr
 $AF3F JP $AE18      ; done -> setup_tower_scroll continuation
*$AF42 LD A,(HL)     ; branch 2: A = dest byte 1
 $AF43 AND $C0       ; keep high 2 bits (blend mask)
 $AF45 OR $06        ; OR in fixed low bits
 $AF47 LD (HL),A     ;
 $AF48 INC HL        ;
 $AF49 LD (HL),$FE   ; fixed byte 2 ($FE)
 $AF4B INC HL        ;
 $AF4C LD (HL),$E9   ; fixed byte 3 ($E9)
 $AF4E INC HL        ;
 $AF4F LD A,(HL)     ; A = dest byte 3
 $AF50 AND $3F       ; keep low 6 bits (blend mask)
 $AF52 LD (HL),A     ;
 $AF53 POP HL        ;
 $AF54 JP $AE18      ;
*$AF57 JP C,$AF71    ; branch 3/4: carry set -> branch 4 ($AF71)
 $AF5A LD A,(HL)     ; branch 3: A = dest byte 1
 $AF5B AND $F0       ; keep high nibble (blend mask)
 $AF5D OR $01        ; OR in fixed low bit
 $AF5F LD (HL),A     ;
 $AF60 INC HL        ;
 $AF61 LD (HL),$BF   ; fixed byte 2 ($BF)
 $AF63 INC HL        ;
 $AF64 LD (HL),$BA   ; fixed byte 3 ($BA)
 $AF66 INC HL        ;
 $AF67 LD A,(HL)     ; A = dest byte 3
 $AF68 AND $0F       ; keep low nibble (blend mask)
 $AF6A OR $40        ; OR in fixed high bits
 $AF6C LD (HL),A     ;
 $AF6D POP HL        ;
 $AF6E JP $AE18      ;
*$AF71 LD A,(HL)     ; branch 4: A = dest byte 1
 $AF72 AND $FC       ; keep high 6 bits (blend mask)
 $AF74 LD (HL),A     ;
 $AF75 INC HL        ;
 $AF76 LD (HL),$6F   ; fixed byte 2 ($6F)
 $AF78 INC HL        ;
 $AF79 LD (HL),$EE   ; fixed byte 3 ($EE)
 $AF7B INC HL        ;
 $AF7C LD A,(HL)     ; A = dest byte 3
 $AF7D AND $03       ; keep low 2 bits (blend mask)
 $AF7F OR $90        ; OR in fixed high bits
 $AF81 LD (HL),A     ;
 $AF82 POP HL        ;
 $AF83 JP $AE18      ;

; Render col cap b
;
; Used by the routine at #R$AD82.
;
; .
;
; Structurally identical 4-way dispatch to render_col_cap_a (self-mod test byte
; at $AF89, patched by $AE06/$AE09), but writes only 2 destination bytes per
; branch instead of 3 -- a narrower cap/edge graphic for a different column
; class.
; .
; Ends `POP HL / JP $AE18` in all branches.
@label=render_col_cap_b
c$AF86 PUSH HL       ; {save dest ptr, apply column offset
 $AF87 ADD HL,DE     ; }
 $AF88 LD A,$00      ; {self-mod test byte -> Z/C flags
 $AF8A SRL A         ; }
 $AF8C JP NZ,$AFB0   ; nonzero -> branch 3/4
 $AF8F JP C,$AF9F    ; carry set -> branch 2
 $AF92 LD (HL),$2F   ; branch 1: fixed byte 1 ($2F)
 $AF94 INC HL        ;
 $AF95 LD A,(HL)     ;
 $AF96 AND $0F       ;
 $AF98 OR $80        ;
 $AF9A LD (HL),A     ;
 $AF9B POP HL        ;
 $AF9C JP $AE18      ;
*$AF9F LD A,(HL)     ;
 $AFA0 AND $C0       ;
 $AFA2 OR $0B        ;
 $AFA4 LD (HL),A     ;
 $AFA5 INC HL        ;
 $AFA6 LD A,(HL)     ;
 $AFA7 AND $03       ;
 $AFA9 OR $E0        ;
 $AFAB LD (HL),A     ;
 $AFAC POP HL        ;
 $AFAD JP $AE18      ;
*$AFB0 JP C,$AFC0    ;
 $AFB3 LD A,(HL)     ;
 $AFB4 AND $F0       ;
 $AFB6 OR $02        ;
 $AFB8 LD (HL),A     ;
 $AFB9 INC HL        ;
 $AFBA LD (HL),$F8   ;
 $AFBC POP HL        ;
 $AFBD JP $AE18      ;
*$AFC0 LD A,(HL)     ;
 $AFC1 AND $FC       ;
 $AFC3 LD (HL),A     ;
 $AFC4 INC HL        ;
 $AFC5 LD (HL),$BE   ;
 $AFC7 INC HL        ;
 $AFC8 LD A,(HL)     ;
 $AFC9 AND $3F       ;
 $AFCB LD (HL),A     ;
 $AFCC POP HL        ;
 $AFCD JP $AE18      ;

; Render col fill
;
; Used by the routine at #R$AD82.
;
; .
;
; Third 4-way dispatch variant (test byte self-mod at $AFD3, sharing the
; $ADEA/$ADED patch point with render_col_partial's mask selection), writing up
; to 3 bytes with mostly solid-$FF fill patterns -- a plain/bright
; tower-segment fill rather than a textured cap. One branch ($B000) has a
; nested sub-branch (JP C,$B016), making 5 cases total.
; .
; Ends `POP HL / JP $AE18` in all branches.
@label=render_col_fill
c$AFD0 PUSH HL       ; save dest ptr
 $AFD1 ADD HL,DE     ; HL += DE (apply column offset)
 $AFD2 LD A,$00      ; A = self-mod test byte
 $AFD4 SRL A         ; shift test byte -> Z/C flags
 $AFD6 JP NZ,$B000   ; nonzero -> branch 3/4 ($B000)
 $AFD9 JP C,$AFF0    ; carry set -> branch 2 ($AFF0)
 $AFDC LD A,(HL)     ; branch 1: A = dest byte 1
 $AFDD AND $C0       ; keep high 2 bits (blend mask)
 $AFDF OR $0F        ; OR in fixed low bits
 $AFE1 LD (HL),A     ;
 $AFE2 INC HL        ;
 $AFE3 LD (HL),$FF   ; solid fill byte 2 ($FF)
 $AFE5 INC HL        ;
 $AFE6 LD A,(HL)     ; A = dest byte 3
 $AFE7 AND $03       ; keep low 2 bits (blend mask)
 $AFE9 OR $F0        ;
 $AFEB LD (HL),A     ;
 $AFEC POP HL        ;
 $AFED JP $AE18      ;
*$AFF0 LD A,(HL)     ; branch 2: A = dest byte 1
 $AFF1 AND $F0       ; keep high nibble (blend mask)
 $AFF3 OR $03        ;
 $AFF5 LD (HL),A     ;
 $AFF6 INC HL        ;
 $AFF7 LD (HL),$FF   ; solid fill byte 2 ($FF)
 $AFF9 INC HL        ;
 $AFFA LD (HL),$FC   ; solid fill byte 3 ($FC)
 $AFFC POP HL        ;
 $AFFD JP $AE18      ;
*$B000 JP C,$B016    ; branch 3/4: carry set -> branch 4 ($B016)
 $B003 LD A,(HL)     ; branch 3: A = dest byte 1
 $B004 AND $FC       ; keep high 6 bits (blend mask)
 $B006 LD (HL),A     ;
 $B007 INC HL        ;
 $B008 LD (HL),$FF   ; solid fill byte 2 ($FF)
 $B00A INC HL        ;
 $B00B LD (HL),$FF   ; solid fill byte 3 ($FF)
 $B00D INC HL        ;
 $B00E LD A,(HL)     ; A = dest byte 3
 $B00F AND $3F       ; keep low 6 bits (blend mask)
 $B011 LD (HL),A     ;
 $B012 POP HL        ;
 $B013 JP $AE18      ;
*$B016 INC HL        ; branch 4: skip byte 1 (no write)
 $B017 LD (HL),$3F   ; solid fill byte 2 ($3F)
 $B019 INC HL        ;
 $B01A LD (HL),$FF   ; solid fill byte 3 ($FF)
 $B01C INC HL        ;
 $B01D LD A,(HL)     ; A = dest byte 3
 $B01E AND $0F       ; keep low nibble (blend mask)
 $B020 OR $C0        ; OR in fixed high bits
 $B022 LD (HL),A     ;
 $B023 POP HL        ;
 $B024 JP $AE18      ;

; Data block at B027
;
; .
;
; .
;
; 3 groups of 8 bytes (mask/value pairs), indexed by the $603C animation phase
; counter (anim_bg_phase) via render_anim_texture (#R$B03F) -- an animated
; dithered/striped tower texture that cycles as $603C advances.
@label=anim_texture_masks
b$B027 DEFB $3F,$C0,$0F,$F0,$03,$FC,$FF,$00
 $B02F DEFB $2A,$80,$0A,$A0,$02,$A8,$AA,$00
 $B037 DEFB $15,$40,$05,$50,$01,$54,$55,$00

; Render anim texture
;
; Used by the routine at #R$AD82.
;
; .
;
; Final per-cell render handler, and the only one whose graphic depends on
; animation phase rather than static column geometry: reads $603C into BC as an
; index into anim_texture_masks (#R$B027), giving an animated tower
; stripe/shade effect.
; .
; Same self-mod 4-way branch-and-mask-merge shape as the other handlers (test
; byte at $B045), each branch copying/merging bytes from a different #R$B027
; offset ($B029/$B02B/$B02D).
; .
; Ends `POP BC / POP HL / JP $AE18` in all branches.
@label=render_anim_texture
c$B03F PUSH HL       ; save HL (destination byte ptr)
 $B040 ADD HL,DE     ; DE += HL (advance to next cell)
 $B041 EX DE,HL      ; swap: HL=dest ptr, DE=advance amount
 $B042 PUSH BC       ; save BC
 $B043 LD A,$00      ; A = self-mod test byte (patched by setup_tower_scroll)
 $B045 SRL A         ; shift test byte -> Z/C flags
 $B047 LD A,($603C)  ; A = anim_bg_phase ($603C)
 $B04A LD C,A        ; C = phase (BC = table index)
 $B04B LD B,$00      ;
 $B04D JP NZ,$B078   ; test byte nonzero -> $B078
 $B050 JP C,$B063    ; test byte carry set -> $B063
 $B053 LD HL,$B027   ; HL -> anim_texture_masks + phase
 $B056 ADD HL,BC     ;
 $B057 LDI           ; copy one animated byte via LDI
 $B059 LD A,(DE)     ; A = current dest byte
 $B05A AND $0F       ; mask low nibble
 $B05C OR (HL)       ; OR in the animated bits
 $B05D LD (DE),A     ;
 $B05E POP BC        ;
 $B05F POP HL        ;
 $B060 JP $AE18      ;
*$B063 LD HL,$B029   ; HL -> $B029 + phase (2nd branch base)
 $B066 ADD HL,BC     ;
 $B067 LD A,(DE)     ; A = current dest byte
 $B068 AND $C0       ; mask high 2 bits ($C0)
 $B06A OR (HL)       ;
 $B06B LD (DE),A     ;
 $B06C INC HL        ;
 $B06D INC DE        ;
 $B06E LD A,(DE)     ; A = second dest byte
 $B06F AND $03       ; mask low 2 bits ($03)
 $B071 OR (HL)       ;
 $B072 LD (DE),A     ;
 $B073 POP BC        ;
 $B074 POP HL        ;
 $B075 JP $AE18      ;
*$B078 JP C,$B08D    ; test byte carry set -> $B08D
 $B07B LD HL,$B02B   ; HL -> $B02B + phase (3rd branch base)
 $B07E ADD HL,BC     ;
 $B07F LD A,(DE)     ; A = current dest byte
 $B080 AND $F0       ; mask high nibble ($F0)
 $B082 OR (HL)       ;
 $B083 LD (DE),A     ;
 $B084 INC HL        ;
 $B085 INC DE        ;
 $B086 LD A,(HL)     ;
 $B087 LD (DE),A     ;
 $B088 POP BC        ;
 $B089 POP HL        ;
 $B08A JP $AE18      ;
*$B08D LD HL,$B02D   ; HL -> $B02D + phase (4th branch base)
 $B090 ADD HL,BC     ;
 $B091 LD A,(DE)     ; A = current dest byte
 $B092 AND $FC       ; mask high 6 bits ($FC)
 $B094 LD (DE),A     ;
 $B095 INC DE        ;
 $B096 LDI           ; copy one animated byte via LDI
 $B098 LD A,(DE)     ; A = second dest byte
 $B099 AND $3F       ; mask low 6 bits ($3F)
 $B09B LD (DE),A     ;
 $B09C POP BC        ;
 $B09D POP HL        ;
 $B09E JP $AE18      ;

; Unused
;
; .
