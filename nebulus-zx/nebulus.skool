; UPDATE_ACTOR_POS -- advance one actor's position around/along the tower for
; this frame.
;
; Used by the routine at #R$8240.
;
; .
;
; IX = actor_obj ($605F).
; .
; Fields used: (IX+0)  angular column around the tower (accumulated mod 128)
; (IX+6)  vertical position, low  (sub-pixel) (IX+12) vertical position, high
; (0..3) (IX+18) per-frame scratch, cleared on entry (IX+42) animation/move
; phase 0..$0C ($FF = inactive/done) (IX+48) actor state (2,4,5,8,9 -- see
; transitions below) (IX+54)
@label=update_actor_pos
c$96E9 LD IX,$605F     ; IX -> actor struct base ($605F)
 $96ED LD (IX+$12),$00 ; clear per-frame scratch field (+18)
 $96F1 LD A,(IX+$2A)   ; A = phase (+42)
 $96F4 CP $FF          ; $FF = inactive -> nothing to do
 $96F6 RET Z           ;
 $96F7 CP $0C          ; phase $0C = end of move -> mark done ($FF)
 $96F9 JR NZ,$9700     ;
*$96FB LD (IX+$2A),$FF ;
 $96FF RET             ;
*$9700 LD E,A          ; E = phase (table index)
 $9701 INC (IX+$2A)    ; advance phase
 $9704 LD A,(IX+$36)   ; A = speed(+54) * 2
 $9707 ADD A,A         ;
 $9708 ADD A,(IX+$00)  ; + angular pos (+0)
 $970B AND $7F         ; wrap to 0..127 (around the tower)
 $970D LD (IX+$00),A   ; store new angular column (+0)
 $9710 LD D,$00        ;
 $9712 LD HL,$96DD     ; HL -> move_curve[phase]
 $9715 ADD HL,DE       ;
 $9716 LD A,(IX+$06)   ; add curve delta to vertical-low (+6)
 $9719 ADD A,(HL)      ;
 $971A LD (IX+$06),A   ;
 $971D LD A,(IX+$0C)   ; carry into vertical-high (+12), keep 0..3
 $9720 ADC A,$00       ;
 $9722 AND $03         ;
 $9724 LD (IX+$0C),A   ;
 $9727 CALL $9372      ; collision test (carry set = blocked)
 $972A JR C,$96FB      ; blocked -> mark move done
 $972C CALL $95BD      ; landing/edge test (NC = no event)
 $972F RET NC          ;
 $9730 PUSH IX         ;
 $9732 PUSH HL         ;
 $9733 POP IX          ;
 $9735 LD A,(IX+$30)   ; branch on actor state (+48)
 $9738 CP $05          ;
 $973A JR Z,$976A      ;
 $973C CP $08          ;
 $973E JR Z,$976A      ;
 $9740 CP $09          ;
 $9742 JR Z,$976A      ;
 $9744 CP $02          ;
 $9746 JR NZ,$9752     ;
 $9748 LD (IX+$2A),$4B ; state 2: arm phase=$4B, state=5
 $974C LD (IX+$30),$05 ;
 $9750 JR $976A        ;
*$9752 LD (IX+$30),$04 ; default: state=4, phase=0
 $9756 LD (IX+$2A),$00 ;
 $975A LD HL,$0100     ;
 $975D CALL $A727      ;
 $9760 LD A,$05        ;
 $9762 CALL $A730      ;
 $9765 LD A,$09        ;
 $9767 CALL $A3DE      ;
*$976A POP IX          ;
 $976C JP $96FB        ;

