 $9C79 JR Z,$9C83    ; pressed? -> 2-player start
 $9C7B LD A,$02      ; A = 2 (running_flag: 2 player)
 $9C7D LD ($603F),A  ; set Running flag
 $9C80 JP $9BA5      ;
*$9C83 LD A,$14      ; A = key $14 (controls toggle)
 $9C85 CALL $A706    ; test_key
 $9C88 JR Z,$9C96    ;
 $9C8A LD HL,$6056   ; HL -> $6056 (sound-enable/control flag)
 $9C8D BIT 7,(HL)    ; test bit 7
 $9C8F JR NZ,$9C96   ;
 $9C91 LD (HL),$80   ; set bit 7 (toggle on)
 $9C93 JP $9BA5      ;
*$9C96 LD A,$0C      ; A = key $0C (controls toggle off)
 $9C98 CALL $A706    ; test_key
 $9C9B JR Z,$9CA9    ;
 $9C9D LD HL,$6056   ; HL -> $6056
 $9CA0 BIT 7,(HL)    ; test bit 7
 $9CA2 JR Z,$9CA9    ;
 $9CA4 LD (HL),$00   ; clear bit 7 (toggle off)
 $9CA6 JP $9BA5      ;
*$9CA9 LD HL,$9B88   ; HL -> attract_timer
 $9CAC DEC (HL)      ; decrement
 $9CAD JR NZ,$9C32   ; not yet expired -> keep polling
 $9CAF LD A,$01      ; A = 1
 $9CB1 LD HL,$9B87   ;
 $9CB4 SUB (HL)      ; flip menu_page (1-current)
 $9CB5 LD (HL),A     ;
 $9CB6 LD A,$C0      ; reload attract_timer = $C0
 $9CB8 LD ($9B88),A  ;
 $9CBB JP $9BA2      ; redraw the other page

; Fill attr row
;
; Used by the routine at #R$9BA5.
;
; .
;
; Flood-fill 16 bytes starting at HL with the byte already stored at (HL)
; (DE=HL+1, LDIR propagates it forward) -- paints one attribute row a single
; flat colour.
; .
; In: HL=start address (byte already set), fills 16 bytes total.
@label=fill_attr_row
c$9CBE LD E,L        ; {DE = HL+1
 $9CBF LD D,H        ;
 $9CC0 INC DE        ; }
 $9CC1 LD BC,$000F   ; BC = 15 (remaining bytes)
 $9CC4 LDIR          ; LDIR: propagate the seed byte forward
 $9CC6 RET           ;

; Draw menu text
;
; Used by the routine at #R$9BA5.
;
; .
;
; Prints the two state-dependent menu lines: CONTROLS (row $15, text depends on
; running_flag==1 vs other -- 1P vs 2P control scheme) and SOUND (row $17, text
; depends on $6056 bit7 -- on/off).
@label=draw_menu_text
c$9CC7 LD A,($603F)  ; A = running_flag
 $9CCA CP $01        ; ==1 (single player)?
 $9CCC LD A,$15      ;
 $9CCE LD HL,$98F0   ;
 $9CD1 JR Z,$9CD6    ;
 $9CD3 LD HL,$98FA   ;
*$9CD6 CALL $9D21    ; Print string at
 $9CD9 LD A,($6056)  ; A = sound-enable flag ($6056)
 $9CDC OR A          ;
 $9CDD LD A,$17      ;
 $9CDF LD HL,$990E   ; HL -> "on" text
 $9CE2 JR Z,$9CE7    ;
 $9CE4 LD HL,$9904   ; HL -> "off" text (if flag clear)
*$9CE7 CALL $9D21    ; Print string at
 $9CEA RET           ;

; Title anim tick
;
; Used by the routines at #R$9963, #R$99A1, #R$99CE, #R$99F0, #R$9A23, #R$9B8A
; and #R$9D80.
