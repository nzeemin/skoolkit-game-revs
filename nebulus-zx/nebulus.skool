;
; Self-mod scratch byte, not unused: draw_tower_cols patches this as the
; immediate operand of its column-count loop (see draw_tower_cols's own note)
; -- the live loop-count constant, reduced near the scroll wrap edge.
s$B0A1 DEFS $01

; Draw tower cols
;
; Used by the routine at #R$A700.
;
; .
;
; Render the visible tower column strip.
; .
; Patches the column count at #R$B0A1 ($14, reduced near the wrap edge from
; scroll_pos) and dispatches on the $6021 sub-column phase.
; .
; SELF-MOD: #R$B0A1 loop count.
; .
; Clobbers: A,B,HL (+ render regs).
@label=draw_tower_cols
c$B0A2 LD A,$14      ; {self-mod default column count = $14
 $B0A4 LD ($B0A1),A  ; }
 $B0A7 LD HL,($6030) ; get Vertical scroll position
