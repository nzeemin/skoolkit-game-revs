 $9C2F OR A          ;
 $9C30 JR NZ,$9C29   ;
*$9C32 LD A,$01      ; {menu_active = 1
 $9C34 LD ($9B89),A  ; }
 $9C37 CALL $A1BD    ; Music tick
 $9C3A XOR A         ;
