@label=tally_score_to
c$82DA LD HL,($60BC) ;
 $82DD LD DE,($60BA) ;
 $82E1 OR A          ;
 $82E2 SBC HL,DE     ;
 $82E4 RET NC        ;
*$82E5 LD HL,($60BC) ;
 $82E8 LD DE,($60BA) ;
 $82EC LD A,L        ;
 $82ED CP E          ;
 $82EE JR NZ,$82F3   ;
 $82F0 LD A,H        ;
 $82F1 CP D          ;
 $82F2 RET Z         ;
*$82F3 PUSH HL       ;
 $82F4 LD HL,$0010   ;
 $82F7 CALL $A727    ;
 $82FA POP HL        ;
 $82FB INC HL        ;
 $82FC LD ($60BC),HL ;
 $82FF JR $82E5      ;

