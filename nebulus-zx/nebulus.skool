; LOAD_LEVEL_COL -- fetch column descriptor #$6039 from the column-major table
; at $7A00 (stride 8): low byte (+0) and high byte (+8) form a pointer (offset
; by $6A00 into level data), and the property byte (+16) is stashed in $603A.
;
; Used by the routine at #R$A763.
;
; .
;
; Returns IX=pointer.
; .
; Clobbers: A,BC,DE,HL,IX.
@label=load_level_col
c$B346 LD A,($6039)  ;
 $B349 LD C,A        ;
 $B34A ADD A,A       ;
 $B34B ADD A,$6A     ;
 $B34D LD D,A        ;
 $B34E LD E,$00      ;
 $B350 LD B,$00      ;
 $B352 LD IX,$7A00   ;
 $B356 ADD IX,BC     ;
 $B358 LD L,(IX+$00) ;
 $B35B LD H,(IX+$08) ;
 $B35E LD BC,$6A00   ;
 $B361 ADD HL,BC     ;
 $B362 LD A,(IX+$10) ;
 $B365 LD ($603A),A  ;
 $B368 PUSH HL       ;
 $B369 POP IX        ;
 $B36B LD C,A        ;
 $B36C LD HL,$F000   ;
*$B36F CALL $B382    ;
 $B372 CALL $B382    ;
 $B375 LD H,$F0      ;
 $B377 INC L         ;
 $B378 DEC C         ;
 $B379 JR NZ,$B36F   ;
 $B37B LD HL,$F000   ;
 $B37E LD ($6015),HL ;
 $B381 RET           ;

; BLIT_MASKED_COLUMN -- draw an 8-pixel-tall column at HL: for each set bit of
; the mask byte at (DE), store the next source byte (IX++) and step down one
; pixel row (INC H) skip rows whose mask bit is 0.
;
; Used by the routine at #R$B346.
;
; .
;
