 $962F CP $05         ; }
 $9631 JR Z,$9645     ;
 $9633 LD HL,$959F    ; {else pick shape table #R$959F/$95AE by index==4
 $9636 CP $04         ;
 $9638 JR NZ,$963D    ; }
 $963A LD HL,$95AE    ;
*$963D ADD HL,DE      ; {test bit E in shape table byte
 $963E LD A,(HL)      ;
 $963F INC B          ;
*$9640 RRA            ;
 $9641 DJNZ $9640     ; }
 $9643 JR NC,$9648    ;
*$9645 SCF            ;
 $9646 JR $9650       ;
*$9648 INC IY         ; {next object: INC IY, loop B
 $964A EX AF,AF'      ;
 $964B DEC A          ;
 $964C JP NZ,$95C6    ; }
 $964F OR A           ;
*$9650 PUSH IY        ; {exit: HL=IY (colliding object), EI, RET
 $9652 POP HL         ;
 $9653 POP IY         ;
 $9655 EI             ; }
 $9656 RET            ;

; Read actor cell
;
; Used by the routine at #R$92EC.
;
; .
;
; Compute the tower-map cell address for actor IX (column IX+0>>3, position
; IX+6/IX+12) and read the cell there the actor counterpart of
; player_cell_addr.
; .
; Beyond the address/read, also classifies the result: tests the cell's type
; bits, then re-reads the cell one row above or below (direction chosen by the
; facing/movement bit at IX+54) to detect an edge. Returns A=0
; (blocked/special), 1 (open) or 2 (edge in the movement direction) -- consumed
; by enemy_hazard_react's 0/1/else dispatch.
; .
; Clobbers: A,HL.
@label=read_actor_cell
c$9657 LD A,(IX+$00)  ; A = actor's angular column (IX+0)
 $965A RRA            ;
 $965B RRA            ;
 $965C RRA            ;
 $965D AND $0F        ; isolate row nibble
 $965F ADD A,$F0      ; bias to $F0.. row page
 $9661 LD H,A         ;
 $9662 LD L,(IX+$06)  ; L = actor's vertical pos low (IX+6)
 $9665 LD A,(IX+$0C)  ;
 $9668 RRA            ;
 $9669 RR L           ;
 $966B RRA            ;
 $966C RR L           ;
 $966E DEC L          ; L -= 1 (row above)
 $966F LD A,(HL)      ; A = cell at (HL)
 $9670 OR A           ;
 $9671 JP P,$9685     ; sign bit set? -> skip to $9685
 $9674 AND $03        ; mask cell type bits
 $9676 CP $01         ; type == 1?
 $9678 JR NZ,$9681    ;
 $967A LD A,(HL)      ;
 $967B AND $0C        ; test sub-bits $0C
 $967D JR Z,$96D2     ;
 $967F JR $96CF       ;
*$9681 CP $03         ;
 $9683 JR NZ,$96D2    ;
*$9685 LD A,(IX+$00)  ; A = actor's angular column again
 $9688 AND $07        ; mask to row-in-column (0..7)
 $968A CP $02         ; row < 2? -> $9694 (near top)
 $968C JR C,$9694     ;
 $968E CP $07         ; row < 7? -> $96CC (open, no edge)
 $9690 JR C,$96CC     ;
 $9692 JR $96B0       ;
*$9694 LD A,H         ; A = row-page byte (H)
 $9695 SUB $F0        ;
 $9697 DEC A          ; row -= 1 (check row above)
 $9698 AND $0F        ;
 $969A ADD A,$F0      ;
 $969C LD H,A         ;
 $969D LD A,(HL)      ; A = cell above
 $969E OR A           ;
 $969F JP P,$96CC     ;
 $96A2 AND $03        ;
 $96A4 CP $03         ;
 $96A6 JR Z,$96CC     ;
 $96A8 BIT 7,(IX+$36) ; test facing/direction bit (IX+54)
 $96AC JR Z,$96CF     ;
 $96AE JR $96D2       ;
*$96B0 LD A,H         ; A = row-page byte (H)
 $96B1 SUB $F0        ;
 $96B3 INC A          ; row += 1 (check row below)
 $96B4 AND $0F        ;
 $96B6 ADD A,$F0      ;
 $96B8 LD H,A         ;
 $96B9 LD A,(HL)      ; A = cell below
 $96BA OR A           ;
 $96BB JP P,$96CC     ;
 $96BE AND $03        ;
 $96C0 CP $03         ;
 $96C2 JR Z,$96CC     ;
 $96C4 BIT 7,(IX+$36) ; test facing/direction bit (IX+54)
 $96C8 JR NZ,$96CF    ;
 $96CA JR $96D2       ;
*$96CC LD A,$01       ; return 1 (open/no obstruction)
 $96CE RET            ;
*$96CF LD A,$02       ; return 2 (edge in movement direction)
 $96D1 RET            ;
*$96D2 XOR A          ; return 0 (blocked/special)
 $96D3 RET            ;

