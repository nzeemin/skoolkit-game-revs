 $89E9 LD A,($60C0)  ;
 $89EC CP $06        ;
 $89EE RET NZ        ;
 $89EF LD A,($60B9)  ;
 $89F2 LD HL,($60BA) ;
 $89F5 CALL $9330    ;
 $89F8 RET NC        ;
 $89F9 LD A,$14      ;
 $89FB LD ($8A49),A  ; patch response code at $8A49 = $14 (SELF-MOD)
