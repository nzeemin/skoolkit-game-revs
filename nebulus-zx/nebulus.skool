; SFX_TONE -- emit a square-wave tone: pitch index A selects a half-period from
; table $A560 toggles the speaker for a fixed duration ($0148 outer).
;
; Used by the routines at #R$A41C, #R$A4F2, #R$A519 and #R$A52E.
;
; .
;
; In: A=pitch.
; .
; Clobbers: A,BC,DE,HL,AF'.
; .
; i8080: speaker via OUT ($FE) bit4 (ULA).
; .
; The Specialist has a 1-bit beeper too -- retarget the port and retune the
; delay loops.
@label=sfx_tone
c$A539 LD L,A          ;
 $A53A LD H,$00        ;
 $A53C LD DE,$A560     ;
 $A53F ADD HL,DE       ;
 $A540 LD DE,$0148     ;
 $A543 LD C,(HL)       ;
 $A544 LD A,$10        ;
 $A546 EX AF,AF'       ;
 $A547 LD B,$10        ;
 $A549 LD L,C          ;
*$A54A DEC L           ;
 $A54B JR NZ,$A559     ;
 $A54D EX AF,AF'       ;
 $A54E XOR B           ;
 $A54F OUT ($FE),A     ;
 $A551 EX AF,AF'       ;
 $A552 LD L,C          ;
*$A553 DEC DE          ;
 $A554 LD A,D          ;
 $A555 OR E            ;
 $A556 JR NZ,$A54A     ;
 $A558 RET             ;
*$A559 OR $00          ;
 $A55B BIT 0,A         ;
 $A55D JP $A553        ;
 $A560 DEFM "fa[VQMHD" ;

