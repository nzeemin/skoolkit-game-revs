; Set up the attract/demo actor records at #R$9EF0 (copy 5-byte template
; $9EFF->$9EFA, plant markers #R$9EF0=$FF, #R$9F0E=1).
; .
; Clobbers: A,BC,DE,HL.
@label=init_attract_actors
c$9F11 LD HL,$9EFF   ;
 $9F14 LD DE,$9EFA   ;
 $9F17 LD BC,$0005   ;
 $9F1A LDIR          ;
 $9F1C LD A,$FF      ;
 $9F1E LD ($9EF0),A  ;
 $9F21 LD A,$01      ;
 $9F23 LD ($9F0E),A  ;
