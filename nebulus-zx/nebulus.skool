@label=blit_masked_column
c$B382 LD A,(DE)     ;
 $B383 INC DE        ;
 $B384 LD B,$08      ;
*$B386 RRA           ;
 $B387 JR NC,$B391   ;
 $B389 PUSH AF       ;
 $B38A LD A,(IX+$00) ;
 $B38D INC IX        ;
 $B38F LD (HL),A     ;
 $B390 POP AF        ;
*$B391 INC H         ;
 $B392 DJNZ $B386    ;
 $B394 RET           ;

; ALLOC_OBJECT_SLOT -- find a free entry (marker $FF at +0) in the 4-slot
; active-object table at $60A9.
;
; Used by the routine at #R$A766.
;
; .
;
; On success store its type ($7D), source pointer (HL) and a copied data byte,
; set CY, RET.
; .
