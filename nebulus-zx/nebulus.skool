; Clobbers: A,DE,HL.
@label=tally_score_to
c$82DA LD HL,($60BC) ;
 $82DD LD DE,($60BA) ;
 $82E1 OR A          ;
 $82E2 SBC HL,DE     ;
 $82E4 RET NC        ;
*$82E5 LD HL,($60BC) ;
 $82E8 LD DE,($60BA) ;
 $82EC LD A,L        ;
 $82ED CP E          ;
 $82EE JR NZ,$82F3   ;
 $82F0 LD A,H        ;
 $82F1 CP D          ;
 $82F2 RET Z         ;
*$82F3 PUSH HL       ;
 $82F4 LD HL,$0010   ;
 $82F7 CALL $A727    ;
 $82FA POP HL        ;
 $82FB INC HL        ;
 $82FC LD ($60BC),HL ;
 $82FF JR $82E5      ;

; Unused
@label=col_state_words
s$8301 DEFS $04

; Init col state
;
; Used by the routine at #R$802B.
;
; .
;
; Seed BOTH players' saved column-mask words.
; .
; HL = (pad_var_8005) [low=0 at level start], then H forced to $FF (all 8
; columns present) the same $FF00|sel is written to the P1 (#R$8301) and P2
; ($8303) slots.
; .
; Called once per level build.
; .
; In: pad_var_8005.
; .
; Out: (#R$8301),($8303).
; .
; Clobbers: A,HL.
@label=init_col_state
c$8305 LD HL,($8005) ;
 $8308 LD H,$FF      ;
 $830A LD ($8301),HL ;
 $830D LD ($8303),HL ;
 $8310 RET           ;

; Restore col state
;
; Used by the routine at #R$802B.
;
; .
;
; Expand a player's saved column bitmask into the 8-byte col_flags[] array
; (#R$60CB) and mirror its counter into #R$6039.
; .
; lives_p1 (#R$6040) selects the slot (0=P1 word #R$8301, else P2 word $8303)
; -- here #R$6040 doubles as an ACTIVE-PLAYER INDEX, not a life count.
; .
; running_flag gates an alternate (re)init path.
; .
; Unpacks via RR through col_flags[] returns CY=1 on success.
; .
; Out: col_flags[0..7], #R$6039, CY.
; .
; Clobbers: A,B,C,H
@label=restore_col_state
c$8311 LD A,($603F)  ;
 $8314 CP $01        ;
 $8316 LD A,$00      ;
 $8318 LD HL,$6040   ;
 $831B JR Z,$831F    ;
 $831D INC A         ;
 $831E SUB (HL)      ;
*$831F LD (HL),A     ;
 $8320 LD HL,$8302   ;
 $8323 OR A          ;
 $8324 JR Z,$8328    ;
 $8326 INC HL        ;
 $8327 INC HL        ;
*$8328 LD A,(HL)     ;
 $8329 OR A          ;
 $832A JR NZ,$8346   ;
 $832C LD A,($603F)  ; get Running flag
 $832F CP $01        ;
 $8331 JR Z,$835E    ;
 $8333 LD A,$01      ;
 $8335 LD HL,$6040   ;
 $8338 SUB (HL)      ;
 $8339 LD (HL),A     ;
 $833A LD HL,$8302   ;
 $833D OR A          ;
 $833E JR Z,$8342    ;
 $8340 INC HL        ;
 $8341 INC HL        ;
*$8342 LD A,(HL)     ;
 $8343 OR A          ;
 $8344 JR Z,$835E    ;
*$8346 DEC HL        ;
 $8347 LD A,(HL)     ;
 $8348 LD ($6039),A  ; set Level number 0
 $834B INC HL        ;
 $834C LD C,(HL)     ;
 $834D LD HL,$60CB   ;
 $8350 LD B,$08      ;
*$8352 XOR A         ;
 $8353 RR C          ;
 $8355 JR NC,$8358   ;
 $8357 INC A         ;
*$8358 LD (HL),A     ;
 $8359 INC HL        ;
 $835A DJNZ $8352    ;
 $835C SCF           ;
 $835D RET           ;
*$835E OR A          ;
 $835F RET           ;

; Pack col state
;
; Used by the routine at #R$8064.
;
; .
;
; Inverse of restore_col_state.
; .
; Writes the live counter (#R$6039) into the selected player's low byte, then
; packs the 8 col_flags[] LSBs (#R$60CB..$60D2) back into the high mask byte.
; .
; lives_p1 selects the P1/P2 slot.
; .
; Clobbers: A,B,C,HL.
@label=pack_col_state
c$8360 LD HL,$8301   ;
 $8363 LD A,($6040)  ; get Lives
 $8366 OR A          ;
 $8367 JR Z,$836B    ;
 $8369 INC HL        ;
 $836A INC HL        ;
*$836B LD A,($6039)  ; get Level number 0
 $836E LD (HL),A     ;
 $836F INC HL        ;
 $8370 PUSH HL       ;
 $8371 LD B,$08      ;
 $8373 XOR A         ;
 $8374 LD HL,$60CB   ;
*$8377 LD C,(HL)     ;
 $8378 RR C          ;
 $837A RR A          ;
 $837C INC HL        ;
 $837D DJNZ $8377    ;
 $837F POP HL        ;
 $8380 LD (HL),A     ;
 $8381 RET           ;

; Clear col mask
;
; Used by the routine at #R$8064.
;
; .
;
; Zero the selected player's column mask byte (high byte of #R$8301/$8303).
; .
; lives_p1 selects the slot.
@label=clear_col_mask
c$8382 LD HL,$8302   ;
 $8385 LD A,($6040)  ; get Lives
 $8388 OR A          ;
 $8389 JR Z,$838D    ;
 $838B INC HL        ;
 $838C INC HL        ;
*$838D LD (HL),$00   ;
 $838F RET           ;

; Advance col counter
;
; Used by the routine at #R$8064.
;
; .
;
; Mark current column done: clear col_flags[#R$6039], then bump the selected
; player's saved counter (low byte) and mirror it back to #R$6039.
@label=advance_col_counter
c$8390 LD A,($6039)  ;
 $8393 LD E,A        ;
 $8394 LD D,$00      ;
 $8396 LD HL,$60CB   ;
 $8399 ADD HL,DE     ;
 $839A LD (HL),$00   ;
 $839C LD HL,$8301   ;
 $839F LD A,($6040)  ; get Lives
 $83A2 OR A          ;
 $83A3 JR Z,$83A7    ;
 $83A5 INC HL        ;
 $83A6 INC HL        ;
*$83A7 INC (HL)      ;
 $83A8 LD A,(HL)     ;
 $83A9 LD ($6039),A  ; set Level number 0
 $83AC RET           ;

; Setup IM2
;
; Used by the routine at #R$8000.
;
; .
;
; Install the Z80 mode-2 interrupt vector.
; .
; Builds a 257-byte page of identical bytes at $BB00..#R$BC00 so that, whatever
; the data-bus byte is at IRQ time, the Z80 reads the 16-bit vector #R$BABA
; from table[$FF]/table[$100].
; .
; At #R$BABA it plants 'JP #R$83CA' -- the actual interrupt service routine.
; .
; In:  nothing.
; .
; Out: IM 2 active, IFF1=1 (interrupts enabled).
; .
; Clobbers: A, B, HL, I.
; .
; The porter must emulate this
@label=setup_im2
c$83AD DI            ; no IRQs while we build the vector table
 $83AE LD HL,$BB00   ; HL -> vector-table page base $BB00
 $83B1 LD A,H        ; A = $BB = high byte of the table page
 $83B2 LD I,A        ; I = $BB: IM2 reads vectors from page I (Z80-only)
 $83B4 DEC A         ; A = $BA = the byte we flood the table with
 $83B5 LD B,$00      ; B = 0 -> DJNZ loops 256 times (Z80 DJNZ: dec B, jump nz)
*$83B7 LD (HL),A     ; table[i] = $BA
 $83B8 INC HL        ; next table slot
 $83B9 DJNZ $83B7    ; fill all 256 bytes of $BB00..$BBFF
 $83BB LD (HL),A     ; +1 byte at #R$BC00 = $BA: covers the table[$100]
                     ; off-by-one
 $83BC LD H,A        ; H = $BA
 $83BD LD L,A        ; L = $BA  -> HL = #R$BABA (the vector the IRQ will fetch)
 $83BE LD (HL),$C3   ; plant C3 = JP opcode at #R$BABA
 $83C0 INC L         ;
 $83C1 LD (HL),$CA   ; low byte of JP target -> $CA
 $83C3 INC L         ;
 $83C4 LD (HL),$83   ; high byte -> $83, so vector = 'JP #R$83CA' = irq_handler
 $83C6 IM 2          ; switch CPU to interrupt mode 2 (Z80-only)
 $83C8 EI            ; interrupts on

; IM2 noop return
;
; Used by the routine at #R$83CA.
@label=im2_noop_ret
c$83C9 RET           ; return to game_entry

; IRQ handler
;
; Used by the routine at #R$BABA.
;
; .
;
; IM 2 interrupt service routine (50 Hz vblank).
; .
; Reached via the planted vector at #R$BABA -> JP here.
; .
; It is a deliberate NEAR-NO-OP: 'CALL #R$83C9' targets the bare RET at the end
; of setup_im2, so the call does nothing.
; .
; The point is to REPLACE the 48K ROM's own interrupt routine (which scans the
; keyboard and bumps the FRAMES sysvar) with a handler that has no side
; effects, while still letting interrupts fire.
; .
; Verified: no code anywhere
@label=irq_handler
c$83CA CALL $83C9    ; CALL #R$83C9 = the RET in setup_im2: a no-op
                     ; (neutralized ISR)
 $83CD EI            ; re-enable interrupts
 $83CE RETI          ; RETI: return from maskable interrupt (Z80-only

; Init tower pos
;
; Used by the routine at #R$81D7.
;
; .
;
; Reset the tower/scroll position for a new level: tower_height=$04,
; #R$60BA/$60BC (current & target column)=8,
; .
; scroll_pos = 8-$28, and clear the high bytes $60BB/$60BD.
; .
; Clobbers: A.
@label=init_tower_pos
c$83D0 LD A,$04      ;
 $83D2 LD ($60B9),A  ; set Tower rotation position
 $83D5 LD A,$08      ;
 $83D7 LD ($60BA),A  ;
 $83DA LD ($60BC),A  ;
 $83DD SUB $28       ;
 $83DF LD ($6030),A  ; set Vertical scroll position
 $83E2 LD A,$00      ;
 $83E4 LD ($60BB),A  ;
 $83E7 LD ($60BD),A  ;
 $83EA SBC A,$00     ;
 $83EC AND $03       ;
 $83EE LD ($6031),A  ;
 $83F1 XOR A         ;
 $83F2 LD ($6037),A  ; set Unknown byte
 $83F5 LD ($60BF),A  ; set Player state-machine phase/height window
 $83F8 LD ($60C3),A  ; set Player died this frame
 $83FB LD ($6020),A  ; set Debounce latch
 $83FE LD ($60C5),A  ;
 $8401 LD A,$00      ;
 $8403 LD ($60C0),A  ; set Player state-machine state
 $8406 LD A,$80      ;
 $8408 LD ($60BE),A  ;
 $840B LD A,$01      ;
 $840D LD ($60C2),A  ;
 $8410 RET           ;

; Rotate tower
;
; Used by the routines at #R$8460, #R$84B9, #R$85DB, #R$868D and #R$8736.
;
; .
;
; Rotate the tower by signed B: tower_height = (tower_height + B) AND $7F
; (128-column wrap), saving the old value in #R$6033.
; .
; Tests the new position for a wall/collision (#R$9330) on collision (NC) it
; reverts tower_height.
; .
; In: B=delta.
; .
; Out: CY=moved.
; .
; Clobbers: A,B,HL.
@label=rotate_tower
c$8411 LD B,A        ;
 $8412 LD A,($60B9)  ; get Tower rotation position
 $8415 LD ($6033),A  ; set Previous tower_height
 $8418 ADD A,B       ;
 $8419 AND $7F       ;
 $841B LD ($60B9),A  ; set Tower rotation position
 $841E LD HL,($60BA) ;
 $8421 CALL $9330    ; Check rotate collision
 $8424 JR NC,$842E   ;
 $8426 LD A,($6033)  ; get Previous tower_height
 $8429 LD ($60B9),A  ; set Tower rotation position
 $842C SCF           ;
 $842D RET           ;
*$842E OR A          ;
 $842F RET           ;

; Step scroll
;
; Used by the routines at #R$85DB, #R$868D and #R$879B.
;
; .
;
; Advance the column/scroll position #R$60BA by signed A (sign-extended via B),
; folding H into the 4-quadrant range (AND $03) saves the previous position in
; #R$6034.
; .
; Clobbers: A,B,HL.
@label=step_scroll
c$8430 LD HL,($60BA) ;
 $8433 LD ($6034),HL ; set Previous scroll_pos
 $8436 LD B,$00      ;
 $8438 OR A          ;
 $8439 JP P,$843D    ;
 $843C DEC B         ;
*$843D ADD A,L       ;
 $843E LD L,A        ;
 $843F LD A,B        ;
 $8440 ADC A,H       ;
 $8441 JP M,$845C    ;
 $8444 AND $03       ;
 $8446 LD H,A        ;
 $8447 LD ($60BA),HL ;
 $844A LD A,($60B9)  ; get Tower rotation position
 $844D CALL $9330    ; Check rotate collision
 $8450 JR NC,$845A   ;
 $8452 LD HL,($6034) ; get Previous scroll_pos
 $8455 LD ($60BA),HL ;
 $8458 SCF           ;
 $8459 RET           ;
*$845A OR A          ;
 $845B RET           ;
*$845C POP HL        ;
 $845D JP $8AD7      ;

; Rotate if idle
;
; Used by the routines at #R$84B9 and #R$8854.
;
; .
;
; If #R$957A returns a pending step (CY) and there is no vertical input
; (input_y==0), rotate the tower by it (tail-calls rotate_tower).
; .
; Clobbers: A,B.
@label=rotate_if_idle
c$8460 CALL $957A    ;
 $8463 RET NC        ;
 $8464 LD B,A        ;
 $8465 LD A,($601D)  ; get Signed input
 $8468 OR A          ;
 $8469 RET NZ        ;
 $846A LD A,B        ;
 $846B JP $8411      ;

; Data block at 846E
@label=player_state_table
b$846E DEFB $B9,$84,$8D,$86,$DB,$85,$63,$85
 $8476 DEFB $36,$87,$54,$88,$BD,$88,$71,$8A
 $847E DEFB $0E,$8B,$1D,$A1

; Player tick
;
; Used by the routine at #R$8240.
;
; .
;
; Per-frame player state machine, run every frame from main_tick (both in
; normal play AND on the game_state==3 level-transition path TASK.md called
; this 'the level-transition path' -- it is really the general player update,
; the transition is just one caller).
; .
; Preamble debounces directional input: input_latch (#R$6020) records whether
; input_x is active so a press fires once a held input is consumed (input_x
; cleared).
; .
; Tail reads player_state and dispatches through a 2-byte JP-address table at
; #R$846E (index = state*2) to the pstate_N handler below.
@label=player_tick
c$8482 LD HL,$6020   ;
 $8485 LD A,(HL)     ;
 $8486 OR A          ;
 $8487 JR NZ,$8492   ;
 $8489 LD A,($601C)  ; get Signed input
 $848C OR A          ;
 $848D JR Z,$849F    ;
 $848F LD (HL),A     ;
 $8490 JR $849F      ;
*$8492 LD A,($601C)  ; get Signed input
 $8495 OR A          ;
 $8496 JR NZ,$849B   ;
 $8498 LD (HL),A     ;
 $8499 JR $849F      ;
*$849B XOR A         ;
 $849C LD ($601C),A  ; set Signed input (debounce: force input_x=0 this frame)
*$849F LD A,($60C0)  ; get Player state-machine state
 $84A2 ADD A,A       ; {index player_state*2 into jump table #R$846E and
 $84A3 LD E,A        ; dispatch (JP (HL))
 $84A4 LD D,$00      ;
 $84A6 LD HL,$846E   ; }
 $84A9 ADD HL,DE     ;
 $84AA LD E,(HL)     ;
 $84AB INC HL        ;
 $84AC LD D,(HL)     ;
 $84AD EX DE,HL      ;
 $84AE JP (HL)       ;

; Pstate reset
;
; Used by the routines at #R$8563, #R$85DB, #R$868D, #R$879B, #R$8831, #R$8854
; and #R$88BD.
;
; .
;
; Common "return to normal/play" exit: player_state=0, pstate_phase=0.
; .
; Reached by tail-jump from most other pstate_N handlers when their
; animation/action completes.
@label=pstate_reset
c$84AF LD A,$00      ;
 $84B1 LD ($60C0),A  ; set Player state-machine state
 $84B4 XOR A         ;
 $84B5 LD ($60BF),A  ; set Player state-machine phase/height window
 $84B8 RET           ;

; Pstate play
;
; .
;
; .
;
; State 0: standing/walking, the default state.
; .
; Reads the cell under the player (READ_PLAYER_CELL) and dispatches on its type
; (0=normal falls through, 1->#R$8590, 2->#R$85A1, else->#R$85B0).
; .
; Normal cell: ROTATE_IF_IDLE, then vertical input picks a climb direction
; (tests $60BE facing sign) and enters pstate_3 (climb) at $8559.
; .
; No vertical input: horizontal input nonzero -> JP #R$8656 (enter pstate_1,
; climb a column) else ROTATE_TOWER with vertical input, carry (blocked) -> JP
; #R$8673 (alt pstate_1 entry).
; .
; No input at all: CHECK_CONVEYOR / TEST_CELL_SPECIAL under fire button -> may
; set game_state=1 and JP #R$8724 (enter pstate_4, jump/fall) else just
; advances the idle-walk animation phase (0..7, sound 2 every 4th step).
@label=pstate_play
c$84B9 CALL $955B    ;
 $84BC CALL $949D    ; Read player cell
 $84BF OR A          ;
 $84C0 JR Z,$84CF    ;
 $84C2 CP $01        ;
 $84C4 JP Z,$8590    ;
 $84C7 CP $02        ;
 $84C9 JP Z,$85A1    ;
 $84CC JP $85B0      ;
*$84CF CALL $8460    ; Rotate if idle
 $84D2 LD A,($601D)  ; get Signed input
 $84D5 OR A          ;
 $84D6 JR Z,$8518    ;
 $84D8 JP M,$84E4    ;
 $84DB LD A,($60BE)  ;
 $84DE OR A          ;
 $84DF JP P,$8559    ;
 $84E2 JR $84EB      ;
*$84E4 LD A,($60BE)  ;
 $84E7 OR A          ;
 $84E8 JP M,$8559    ;
*$84EB LD A,($601C)  ; get Signed input
 $84EE OR A          ;
 $84EF JP NZ,$8656   ;
 $84F2 LD A,($601D)  ; get Signed input
 $84F5 CALL $8411    ; Rotate tower
 $84F8 JP C,$8673    ;
 $84FB LD A,($60BF)  ; get Player state-machine phase/height window
 $84FE INC A         ;
 $84FF AND $07       ;
 $8501 LD ($60BF),A  ; set Player state-machine phase/height window
 $8504 LD HL,$60BE   ;
 $8507 ADD A,(HL)    ;
 $8508 ADD A,$00     ;
 $850A LD ($60C1),A  ;
 $850D LD A,($60BF)  ; get Player state-machine phase/height window
 $8510 AND $03       ;
 $8512 RET NZ        ;
 $8513 LD A,$02      ;
 $8515 JP $A3DE      ;
*$8518 LD A,($601C)  ; get Signed input
 $851B OR A          ;
 $851C JP NZ,$8831   ;
 $851F LD A,($601E)  ; get Signed input
 $8522 OR A          ;
 $8523 JR Z,$8550    ;
 $8525 CALL $9540    ; Check conveyor
 $8528 JR NC,$8539   ;
 $852A OR A          ;
 $852B JR Z,$8533    ;
 $852D LD HL,$601E   ;
 $8530 CP (HL)       ;
 $8531 JR NZ,$8539   ;
*$8533 LD A,($601E)  ; get Signed input
 $8536 JP $88AB      ;
*$8539 LD A,($601E)  ; get Signed input
 $853C CP $01        ;
 $853E JR NZ,$8550   ;
 $8540 CALL $952A    ; Test cell special
 $8543 JR NC,$8550   ;
 $8545 OR A          ;
 $8546 JR Z,$854D    ;
 $8548 LD A,$01      ;
 $854A LD ($60D9),A  ; set Game state
*$854D JP $8724      ;
*$8550 LD A,($60BE)  ;
 $8553 OR $0C        ;
 $8555 LD ($60C1),A  ;
 $8558 RET           ;
*$8559 LD A,$03      ;
 $855B LD ($60C0),A  ; set Player state-machine state
 $855E XOR A         ;
 $855F LD ($60BF),A  ; set Player state-machine phase/height window
 $8562 RET           ;

; Pstate 3
;
; .
;
; .
;
; State 3: vertical climb animation (entered from pstate_play at $8559).
; .
; Picks a sprite frame from table #R$86F2 indexed by phase (mirrored via +7
; when $60BE facing is negative), increments phase each call.
; .
; At phase==7 the climb cycle ends: flips the facing bit ($60BE ^= $80) and
; returns to pstate_reset (state 0).
@label=pstate_3
c$8563 LD A,($60BE)  ;
 $8566 OR A          ;
 $8567 LD A,($60BF)  ; get Player state-machine phase/height window
 $856A JP P,$856F    ;
 $856D ADD A,$07     ;
*$856F LD E,A        ;
 $8570 LD D,$00      ;
 $8572 LD HL,$86F2   ;
 $8575 ADD HL,DE     ;
 $8576 LD A,(HL)     ;
 $8577 LD ($60C1),A  ;
 $857A LD HL,$60BF   ;
 $857D INC (HL)      ;
 $857E LD A,(HL)     ;
 $857F CP $07        ;
 $8581 RET NZ        ;
 $8582 LD A,($60BE)  ;
 $8585 XOR $80       ;
 $8587 LD ($60BE),A  ;
 $858A JP $84AF      ;

; Unused
s$858D DEFS $03

; Pstate play cell1
;
; Used by the routines at #R$84B9 and #R$8A71.
;
; .
;
; pstate_play continuation for cell type 1 (also re-entered from code_8a71's
; wall-bump bounce-back path).
@label=pstate_play_cell1
c$8590 LD A,$00      ;
 $8592 LD B,$00      ;
 $8594 JR $85BD      ;

; Routine at 8596
;
; Used by the routine at #R$868D.
@label=pstate_play_cell1b
c$8596 LD A,$03      ;
 $8598 LD ($858D),A  ;
 $859B LD A,$00      ;
 $859D LD B,$00      ;
 $859F JR $85C2      ;

; Pstate play cell2
;
; Used by the routine at #R$84B9.
;
; .
;
; pstate_play continuation for cell type 2.
@label=pstate_play_cell2
c$85A1 LD A,$0F      ;
 $85A3 LD B,$FF      ;
 $85A5 LD HL,$60BE   ;
 $85A8 BIT 7,(HL)    ;
 $85AA JR NZ,$85BD   ;
 $85AC LD B,$01      ;
 $85AE JR $85BD      ;

; Pstate play cell other
;
; Used by the routine at #R$84B9.
;
; .
;
; pstate_play continuation for any other cell type (not 0/1/2).
@label=pstate_play_cell_other
c$85B0 LD A,$0E      ;
 $85B2 LD B,$01      ;
 $85B4 LD HL,$60BE   ;
 $85B7 BIT 7,(HL)    ;
 $85B9 JR NZ,$85BD   ;
 $85BB LD B,$FF      ;
; This entry point is used by the routines at #R$8590 and #R$85A1.
*$85BD LD HL,$858D   ;
 $85C0 LD (HL),$01   ;
; This entry point is used by the routine at #R$8596.
*$85C2 LD HL,$60BE   ;
 $85C5 ADD A,(HL)    ;
 $85C6 LD ($60C1),A  ;
 $85C9 LD A,B        ;
 $85CA LD ($858E),A  ;
 $85CD LD A,$02      ;
 $85CF LD ($60C0),A  ; set Player state-machine state
 $85D2 XOR A         ;
 $85D3 LD ($60BF),A  ; set Player state-machine phase/height window
 $85D6 DEC A         ;
 $85D7 LD ($858F),A  ;
 $85DA RET           ;

; Pstate 2
;
; .
;
; .
;
; State 2: top-of-climb slide-in, entered from pstate_1 when a column climb
; finishes normally (phase reaches its $8642 limit).
; .
; Nudges tower rotation (ROTATE_TOWER) and scroll position (STEP_SCROLL), plays
; a sound, then hands off (see C-lines) back to normal play.
@label=pstate_2
c$85DB LD A,($60BF)  ;
 $85DE OR A          ;
 $85DF JR NZ,$8612   ;
 $85E1 LD HL,$858F   ;
 $85E4 INC (HL)      ;
 $85E5 LD A,($858E)  ;
 $85E8 CALL $8411    ; Rotate tower
 $85EB JR NC,$85F1   ;
 $85ED XOR A         ;
 $85EE LD ($858E),A  ;
*$85F1 LD A,($858D)  ;
 $85F4 NEG           ;
 $85F6 CALL $8430    ; Step scroll
 $85F9 JR NC,$8631   ;
 $85FB LD HL,$858D   ;
 $85FE DEC (HL)      ;
 $85FF JR NZ,$85F1   ;
 $8601 LD A,($858E)  ;
 $8604 OR A          ;
 $8605 JR Z,$860E    ;
 $8607 LD A,($858F)  ;
 $860A CP $02        ;
 $860C JR C,$8631    ;
*$860E LD HL,$60BF   ;
 $8611 INC (HL)      ;
*$8612 LD A,$02      ;
 $8614 LD HL,$60BF   ;
 $8617 SUB (HL)      ;
 $8618 LD HL,$60BE   ;
 $861B ADD A,(HL)    ;
 $861C ADD A,$0C     ;
 $861E LD ($60C1),A  ;
 $8621 LD HL,$60BF   ;
 $8624 INC (HL)      ;
 $8625 LD A,(HL)     ;
 $8626 CP $03        ;
 $8628 RET NZ        ;
 $8629 LD A,$02      ;
 $862B CALL $A3DE    ; Play sound
 $862E JP $84AF      ;
*$8631 LD A,($858D)  ;
 $8634 INC A         ;
 $8635 CP $04        ;
 $8637 JR C,$863B    ;
 $8639 LD A,$04      ;
*$863B LD ($858D),A  ;
 $863E RET           ;

; Data block at 863F
;
; .
;
; .
;
; 23-byte signed-offset data table read by pstate_1 for scroll-delta/frame
; lookups.
; .
; Byte #R$863F itself doubles as a SELF-MODIFIED scratch cell:
; code_8656/#R$8673 store the climb's vertical-input direction there for
; pstate_1 to feed into ROTATE_TOWER.
@label=tbl_863f
b$863F DEFB $00,$00,$00,$00,$03,$02,$02,$01
 $8647 DEFB $01,$00,$00,$FF,$FF,$FE,$FE,$FD
 $864F DEFB $02,$02,$01,$00,$FF,$FE,$FE

; Enter column climb (via horizontal input)
;
; Used by the routine at #R$84B9.
;
; .
;
; Climb-column entry #1 (from pstate_play when horizontal input is pressed on a
; normal cell).
; .
; Sets player_state=1 (pstate_1), stashes vertical input into tbl_863f[0]
; (self-mod, read back by pstate_1), resets phase=0, sets self-mod climb params
; $8641=0/$8642=$0C, plays sound 4 (climb start).
@label=code_8656
c$8656 LD A,$01      ;
 $8658 LD ($60C0),A  ; set Player state-machine state
 $865B LD A,($601D)  ; get Signed input
 $865E LD ($863F),A  ;
 $8661 XOR A         ;
 $8662 LD ($60BF),A  ; set Player state-machine phase/height window
 $8665 LD ($8641),A  ;
 $8668 LD A,$0C      ;
 $866A LD ($8642),A  ;
 $866D LD A,$04      ;
 $866F CALL $A3DE    ; Play sound
 $8672 RET           ;

; Enter column climb (via blocked rotate)
;
; Used by the routine at #R$84B9.
;
; .
;
; Climb-column entry #2: alternate entry into pstate_1, taken from pstate_play
; when ROTATE_TOWER reports a collision (carry) while vertical input is held.
; .
; Same shape as code_8656 but with different climb params ($8641=$80,
; $8642=$07) and no sound call.
@label=code_8673
c$8673 LD A,$01      ;
 $8675 LD ($60C0),A  ; set Player state-machine state
 $8678 LD A,($601D)  ; get Signed input
 $867B LD ($863F),A  ;
 $867E XOR A         ;
 $867F LD ($60BF),A  ; set Player state-machine phase/height window
 $8682 LD A,$80      ;
 $8684 LD ($8641),A  ;
 $8687 LD A,$07      ;
 $8689 LD ($8642),A  ;
 $868C RET           ;

; Pstate 1
;
; .
;
; .
;
; State 1: climbing a tower column (entered via code_8656/#R$8673).
; .
; Sets a sprite frame from phase&7 combined with facing, ROTATE_TOWERs using
; the direction stashed in tbl_863f, then looks up a scroll delta (table $8643,
; mirrored $864F when climbing the other way) and applies it via STEP_SCROLL.
; .
; On a special zero-crossing case it aborts the climb (sound 2, back to
; pstate_reset). Otherwise advances phase; once phase reaches the $8642 limit
; it does a final STEP_SCROLL($FF) -- no-carry falls into the pstate_5 setup
; path (#R$8596), carry sets phase=1 and player_state=2 (pstate_2, slide-in).
@label=pstate_1
c$868D LD A,($60BF)  ;
 $8690 AND $07       ;
 $8692 LD HL,$60BE   ;
 $8695 OR (HL)       ;
 $8696 ADD A,$00     ;
 $8698 LD ($60C1),A  ;
 $869B LD A,($863F)  ;
 $869E CALL $8411    ; Rotate tower
 $86A1 LD A,($60BF)  ; get Player state-machine phase/height window
 $86A4 LD E,A        ;
 $86A5 LD D,$00      ;
 $86A7 LD HL,$8643   ;
 $86AA LD A,($8641)  ;
 $86AD OR A          ;
 $86AE JP P,$86B4    ;
 $86B1 LD HL,$864F   ;
*$86B4 ADD HL,DE     ;
 $86B5 LD A,(HL)     ;
*$86B6 LD ($8640),A  ;
 $86B9 CALL $8430    ; Step scroll
 $86BC JR NC,$86D5   ;
 $86BE LD A,($8640)  ;
 $86C1 OR A          ;
 $86C2 JP M,$86CA    ;
 $86C5 DEC A         ;
 $86C6 JR NZ,$86B6   ;
 $86C8 JR $86D5      ;
*$86CA INC A         ;
 $86CB JR NZ,$86B6   ;
 $86CD LD A,$02      ;
 $86CF CALL $A3DE    ; Play sound
 $86D2 JP $84AF      ;
*$86D5 LD HL,$60BF   ;
 $86D8 INC (HL)      ;
 $86D9 LD A,(HL)     ;
 $86DA LD HL,$8642   ;
 $86DD CP (HL)       ;
 $86DE RET C         ;
 $86DF LD A,$FF      ;
 $86E1 CALL $8430    ; Step scroll
 $86E4 JP NC,$8596   ;
 $86E7 LD A,$01      ;
 $86E9 LD ($60BF),A  ; set Player state-machine phase/height window
 $86EC LD A,$02      ;
 $86EE LD ($60C0),A  ; set Player state-machine state
 $86F1 RET           ;

; Data block at 86F2
;
; .
;
; .
;
; Sprite-frame table for pstate_3 (climb animation), indexed by phase.
b$86F2 DEFB $08,$09,$0A,$0B,$8A,$89,$88,$88
 $86FA DEFB $89,$8A,$0B,$0A,$09,$08,$90,$91
 $8702 DEFB $92,$13,$10,$11,$12,$13,$0B,$8A
 $870A DEFB $89,$88,$0B,$0A,$09,$08,$94,$14
 $8712 DEFB $15,$95,$96,$16,$97,$17,$98,$18
 $871A DEFB $19,$99,$1A,$1B,$1A,$00,$1C,$1D
 $8722 DEFB $1E,$00

; Enter pstate 4 (jump/fall)
;
; Used by the routine at #R$84B9.
;
; .
;
; Entry into pstate_4 (jump/fall), taken from pstate_play when fire is pressed
; over a conveyor/special cell.
; .
; Sets player_state=4, phase=0, clears self-mod flag $8723 (used later inside
; pstate_4's landing logic), plays sound 3 (jump start).
@label=pstate4_entry
c$8724 LD A,$04      ;
 $8726 LD ($60C0),A  ; set Player state-machine state
 $8729 XOR A         ;
 $872A LD ($60BF),A  ; set Player state-machine phase/height window
 $872D LD ($8723),A  ;
 $8730 LD A,$03      ;
 $8732 CALL $A3DE    ; Play sound
 $8735 RET           ;

; Pstate 4
;
; .
;
; .
;
; State 4: jump/fall arc (entered from #R$8724 or from pstate_play's
; ROTATE_TOWER-blocked path).
; .
; Early phase (0..6): plays a landing sound at gated points, picks a sprite
; frame from tables $8700/$8704 (mirrored by facing), nudges tower rotation
; toward the center column (#R$60B9&7 vs 4) via ROTATE_TOWER, advances phase.
; .
; Phase 7..$0C: picks frame from table $8709, advances phase. Falls through to
; #R$879B for the rest of the arc.
@label=pstate_4
c$8736 LD A,($60BF)  ; A = pstate_phase (landing-sound gate)
 $8739 CP $07        ; {phase in [7,$22]? sound-gate window test
 $873B JR C,$874A    ;
 $873D CP $23        ;
 $873F JR NC,$874A   ; }
 $8741 SUB $07       ;
 $8743 AND $03       ;
 $8745 LD A,$02      ;
 $8747 CALL Z,$A3DE  ; Play sound
*$874A LD A,($60BF)  ; get Player state-machine phase/height window
 $874D CP $04        ; {phase>=4? skip walk-frame select
 $874F JR NC,$877D   ; }
 $8751 LD E,A        ; {select sprite frame table $8700/$8704 (mirrored by
 $8752 LD D,$00      ; facing)
 $8754 LD HL,$8704   ;
 $8757 LD A,($60BE)  ;
 $875A OR A          ;
 $875B JP P,$8761    ;
 $875E LD HL,$8700   ; }
*$8761 ADD HL,DE     ;
 $8762 LD A,(HL)     ;
 $8763 LD ($60C1),A  ;
 $8766 LD A,($60B9)  ; get Tower rotation position
 $8769 AND $07       ; {rotate tower toward center column (compare &7 vs 4)
 $876B CP $04        ;
 $876D JR Z,$8778    ;
 $876F LD A,$01      ;
 $8771 JR C,$8775    ;
 $8773 LD A,$FF      ; }
*$8775 CALL $8411    ; Rotate tower
*$8778 LD HL,$60BF   ;
 $877B INC (HL)      ;
 $877C RET           ;
*$877D CP $07        ; {phase<7: force phase=7 (skip window)
 $877F JR NC,$8786   ;
 $8781 LD A,$07      ; }
 $8783 LD ($60BF),A  ; set Player state-machine phase/height window
*$8786 CP $0D        ; phase>=$0D? end of this section
 $8788 JR NC,$879B   ;
 $878A LD E,A        ; {phase 7..$0C: frame from table $8709, phase++
 $878B LD D,$00      ;
 $878D LD HL,$8709   ;
 $8790 ADD HL,DE     ;
 $8791 LD A,(HL)     ;
 $8792 LD ($60C1),A  ; }
 $8795 LD HL,$60BF   ;
 $8798 INC (HL)      ;
 $8799 RET           ;

; Unused
s$879A DEFS $01

; Pstate 4 land
;
; Used by the routine at #R$8736.
;
; .
;
; Continuation of pstate_4 for phase>=$0D (descent/landing).
; .
; At phase==$1D: clears $60C2, and if game_state!=0 sets game_state=2 (signals
; landing to main_tick). Also rotates tower position by +-2 per facing,
; toggling a self-mod alternator so this only fires every other call.
; .
; Phase $1D..$22: frame from table $86F9. Phase>=$23: if game_state==3, JP
; #R$A113 (external -- special level-transition landing, not covered here).
; Else STEP_SCROLL($FC) and, at phase<$24, latches a landing facing direction
; into $60BE from vertical input.
; .
; Phase $24..$27: frame from table $86E4/$86E8 (mirrored). Phase>=$28: jump
; sequence complete, JP pstate_reset.
c$879B CP $1D        ; phase < $1D? skip landing-signal block
 $879D JR NC,$87CF   ;
 $879F XOR A         ; {clear $60C2
 $87A0 LD ($60C2),A  ; }
 $87A3 LD A,($60D9)  ; get Game state
 $87A6 OR A          ;
 $87A7 JR Z,$87AF    ;
 $87A9 LD A,$02      ;
 $87AB LD ($60D9),A  ; set Game state
 $87AE RET           ;
*$87AF LD A,($60BE)  ; {rotate +-2 per facing (self-mod alternator gated)
 $87B2 OR A          ;
 $87B3 LD A,$02      ;
 $87B5 JP M,$87BA    ;
 $87B8 LD A,$FE      ; }
*$87BA LD HL,$60B9   ;
 $87BD ADD A,(HL)    ;
 $87BE AND $7F       ;
 $87C0 LD ($60B9),A  ; set Tower rotation position
 $87C3 LD HL,$879A   ; {alternator toggled -> fire every other call
 $87C6 INC (HL)      ;
 $87C7 BIT 0,(HL)    ;
 $87C9 RET NZ        ; }
 $87CA LD HL,$60BF   ; {not yet: phase++, done
 $87CD INC (HL)      ;
 $87CE RET           ; }
*$87CF CP $23        ; phase < $23? use table $86F9 frame
 $87D1 JR NC,$87E8   ;
 $87D3 LD E,A        ; {frame from $86F9[phase], phase++
 $87D4 LD D,$00      ;
 $87D6 LD HL,$86F9   ;
 $87D9 ADD HL,DE     ;
 $87DA LD A,(HL)     ;
 $87DB LD ($60C1),A  ;
 $87DE LD A,$01      ;
 $87E0 LD ($60C2),A  ; }
 $87E3 LD HL,$60BF   ;
 $87E6 INC (HL)      ;
 $87E7 RET           ;
*$87E8 LD B,A        ; phase >= $23: check game_state==3
 $87E9 LD A,($60D9)  ; get Game state
 $87EC CP $03        ;
 $87EE JP Z,$A113    ;
 $87F1 LD A,B        ;
 $87F2 CP $24        ;
 $87F4 JR NC,$8812   ;
 $87F6 LD A,$FC      ;
 $87F8 CALL $8430    ; Step scroll
 $87FB RET NC        ;
 $87FC LD B,$00      ;
 $87FE LD A,($601D)  ; get Signed input
 $8801 OR A          ;
 $8802 JR Z,$880D    ;
 $8804 JP M,$8809    ;
 $8807 LD B,$80      ;
*$8809 LD A,B        ;
 $880A LD ($60BE),A  ;
*$880D LD HL,$60BF   ;
 $8810 INC (HL)      ;
 $8811 RET           ;
*$8812 CP $28        ; phase < $28? frame table $86E4/E8
 $8814 JP NC,$84AF   ;
 $8817 LD E,A        ;
 $8818 LD D,$00      ;
 $881A LD HL,$86E4   ;
 $881D LD A,($60BE)  ;
 $8820 OR A          ;
 $8821 JP M,$8827    ;
 $8824 LD HL,$86E8   ;
*$8827 ADD HL,DE     ;
 $8828 LD A,(HL)     ;
 $8829 LD ($60C1),A  ;
 $882C LD HL,$60BF   ;
 $882F INC (HL)      ;
 $8830 RET           ;

; Pstate 4 land tail
;
; Used by the routine at #R$84B9.
;
; .
;
; Tail of pstate_4's landing phase-$24..$27 frame-select branch: sets
; player_state=2 or similar hand-off, phase, plays a sound.
@label=pstate_4_land_tail
c$8831 LD IX,$605F   ;
 $8835 LD A,(IX+$2A) ;
 $8838 CP $FF        ;
 $883A JP NZ,$84AF   ;
 $883D LD A,$05      ;
 $883F LD ($60C0),A  ; set Player state-machine state
 $8842 XOR A         ;
 $8843 LD ($60BF),A  ; set Player state-machine phase/height window
 $8846 LD A,($60BE)  ;
 $8849 OR $00        ;
 $884B LD ($60C1),A  ;
 $884E LD A,$08      ;
 $8850 CALL $A3DE    ; Play sound
 $8853 RET           ;

; Pstate 5
;
; .
;
; .
;
; State 5: ledge-grab / climb-onto (entered from pstate_1 at #R$8596 when a
; column climb ends without reaching the top-of-climb case).
; .
; Calls ROTATE_IF_IDLE each frame. At phase==3 the grab completes -> JP
; pstate_reset. Otherwise picks a sprite frame from table $871C indexed by
; phase OR'd with facing bits ($60BE), and at phase==1 calls update_player_obj
; to sync the actor's screen position. Increments phase each call.
@label=pstate_5
c$8854 CALL $8460    ;
 $8857 LD A,($60BF)  ; get Player state-machine phase/height window
 $885A CP $03        ;
 $885C JP Z,$84AF    ;
 $885F LD E,A        ;
 $8860 LD D,$00      ;
 $8862 LD HL,$871C   ;
 $8865 ADD HL,DE     ;
 $8866 LD A,(HL)     ;
 $8867 LD HL,$60BE   ;
 $886A OR (HL)       ;
 $886B LD ($60C1),A  ;
 $886E LD A,E        ;
 $886F CP $01        ;
 $8871 JR NZ,$8876   ;
 $8873 CALL $887B    ; Update player obj
*$8876 LD HL,$60BF   ;
 $8879 INC (HL)      ;
 $887A RET           ;

; Update player obj
;
; Used by the routine at #R$8854.
;
; .
;
; Copy the live tower position (#R$60BA) into the player object (actor_obj)
; column fields (+6/+12), biased by tower_height and facing ($60BE bit7).
; .
; Clobbers: A,HL,IX.
@label=update_player_obj
c$887B LD IX,$605F     ;
 $887F LD HL,($60BA)   ;
 $8882 LD (IX+$06),L   ;
 $8885 LD (IX+$0C),H   ;
 $8888 LD A,($60B9)    ; get Tower rotation position
 $888B DEC A           ;
 $888C LD HL,$60BE     ;
 $888F BIT 7,(HL)      ;
 $8891 JR Z,$8895      ;
 $8893 ADD A,$02       ;
*$8895 AND $7F         ;
 $8897 LD (IX+$00),A   ;
 $889A LD (IX+$2A),$00 ;
 $889E LD A,$01        ;
 $88A0 BIT 7,(HL)      ;
 $88A2 JR NZ,$88A6     ;
 $88A4 LD A,$FF        ;
*$88A6 LD (IX+$36),A   ;
 $88A9 RET             ;

; Unused
s$88AA DEFS $01

; Exit pstate 5 (ledge grab)
;
; Used by the routine at #R$84B9.
;
; .
;
; Exit path from pstate_5's ledge-grab completion: checks CHECK_CONVEYOR under
; the player and either hands off into pstate_6 (state=6, on a conveyor) or
; resets phase/state back to normal play.
@label=pstate5_exit
c$88AB LD ($88AA),A  ;
 $88AE XOR A         ;
 $88AF LD ($60BF),A  ; set Player state-machine phase/height window
 $88B2 LD A,$06      ;
 $88B4 LD ($60C0),A  ; set Player state-machine state
 $88B7 CALL $9540    ; Check conveyor
 $88BA JP $A76C      ;

; Pstate 6
;
; .
;
; .
;
; State 6: riding a conveyor / column-transition (entered from #R$88AB).
; .
; Phase==0: nudges tower rotation (#R$60B9) toward the center column (compare
; &7 vs 4), same trick as pstate_4.
; .
; Phase==1: sets flag #R$6038=$FE, calls CHECK_CONVEYOR and combines its result
; with a self-mod "descending" byte at #R$88AA to build a movement mask, then
; applies a signed 16-bit step to the actor's column position (#R$60BA). Every
; 4th sub-step plays sound $0A and re-checks the conveyor.
; .
; Examines the cell flags to either block movement (early RET) or complete it:
; on completion ORs $81 into the cell flags, calls $A766 (object/effect hook,
; not analysed here), sets #R$6038=$FF, returns to pstate_reset.
@label=pstate_6
c$88BD LD A,($60BF)   ; {phase!=0? skip center-rotate step
 $88C0 OR A           ;
 $88C1 JR NZ,$88F6    ; }
 $88C3 LD A,($60B9)   ; get Tower rotation position
 $88C6 AND $07        ;
 $88C8 CP $04         ;
 $88CA JR Z,$88DA     ;
 $88CC LD A,$01       ;
 $88CE JR C,$88D2     ;
 $88D0 LD A,$FF       ;
*$88D2 LD HL,$60B9    ;
 $88D5 ADD A,(HL)     ;
 $88D6 AND $7F        ;
 $88D8 LD (HL),A      ;
 $88D9 RET            ;
*$88DA LD HL,$60BF    ; {phase==0 tail: phase++, flag_6038=$FE
 $88DD INC (HL)       ;
 $88DE LD A,$FE       ; }
 $88E0 LD ($6038),A   ; set Flag?? $00 $FE $FF
 $88E3 CALL $9540     ; Check conveyor
 $88E6 LD A,(HL)      ; {combine conveyor result with self-mod #R$88AA
 $88E7 AND $0C        ; descending flag
 $88E9 LD IX,$88AA    ;
 $88ED BIT 7,(IX+$00) ; }
 $88F1 JR NZ,$88F5    ;
 $88F3 OR $80         ;
*$88F5 LD (HL),A      ;
*$88F6 LD A,($88AA)   ; {A = descending flag; B = sign extend
 $88F9 LD B,$00       ;
 $88FB OR A           ;
 $88FC JP P,$8900     ; }
 $88FF DEC B          ;
*$8900 LD HL,($60BA)  ; {apply signed step to actor column (16-bit)
 $8903 ADD A,L        ;
 $8904 LD L,A         ;
 $8905 LD A,B         ;
 $8906 ADC A,H        ;
 $8907 AND $03        ;
 $8909 LD H,A         ;
 $890A LD ($60BA),HL  ;
 $890D LD A,L         ;
 $890E AND $03        ;
 $8910 RET NZ         ; }
 $8911 LD A,$0A       ;
 $8913 CALL $A3DE     ; Play sound
 $8916 CALL $9540     ; Check conveyor
 $8919 LD A,($88AA)   ; {re-check conveyor result sign
 $891C OR A           ; }
 $891D JP P,$8936     ;
 $8920 LD A,(HL)      ; {facing-negative branch: test cell flags, block or pass
 $8921 AND $0C        ;
 $8923 CP $04         ;
 $8925 JR Z,$894D     ;
 $8927 CP $0C         ;
 $8929 JR NZ,$8934    ;
 $892B LD B,A         ; }
 $892C LD A,($601E)   ; get Signed input
 $892F OR A           ;
 $8930 LD A,B         ;
 $8931 JP P,$894D     ;
*$8934 LD (HL),A      ;
 $8935 RET            ;
*$8936 LD A,(HL)      ; {facing-positive branch: mirrored test
 $8937 AND $0C        ;
 $8939 CP $08         ;
 $893B JR Z,$894D     ;
 $893D CP $0C         ;
 $893F JR NZ,$8949    ;
 $8941 LD B,A         ; }
 $8942 LD A,($601E)   ; get Signed input
 $8945 DEC A          ;
 $8946 LD A,B         ;
 $8947 JR NZ,$894D    ;
*$8949 OR $80         ;
 $894B LD (HL),A      ;
 $894C RET            ;
*$894D OR $81         ; {complete: mark cell done, notify, reset flag, return
 $894F LD (HL),A      ;
 $8950 CALL $A766     ;
 $8953 LD A,$FF       ; }
 $8955 LD ($6038),A   ; set Flag?? $00 $FE $FF
 $8958 JP $84AF       ;

; Collision test
;
; Used by the routine at #R$89C5.
;
; .
;
; Player-vs-world collision probe, called from check_collision.
; .
; Builds a synthetic object record for the player at $6060 (angular
; pos=tower_height, column=#R$60BA+1/$60BB carry AND 3) so the shared
; actor-vs-actor code in check_collisions can be reused, then calls it.
; .
; If check_collisions reports a hit (CY), converts its returned IY pointer into
; IX and returns CY=1 (hit an enemy/moving actor).
; .
; If no actor hit, falls back to a static "wall marker" scan: walks the 4
; object_table entries, considering only those with state (+48)==7 (used here
; as a static-obstacle marker, distinct from player_state's own state 7), and
; tests whether the player's row (16-bit, from #R$60BA/$60BB) falls within
; roughly [entry_row-9, entry_row+16] of the entry's position (IX+6/IX+12).
; First match sets CY=1 with IX pointing at that entry else NC.
; .
; Out: CY=hit, IX=colliding object (actor or wall-marker entry).
; .
; Clobbers: A,BC,DE,HL,IX.
@label=collision_test
c$895B LD IX,$6060   ; IX -> synthetic player record ($6060)
 $895F LD A,($60B9)  ; get Tower rotation position
 $8962 LD (IX+$00),A ; {store angular pos + column (16-bit) into it
 $8965 LD A,($60BA)  ;
 $8968 ADD A,$01     ;
 $896A LD (IX+$06),A ;
 $896D LD A,($60BB)  ;
 $8970 ADC A,$00     ;
 $8972 AND $03       ;
 $8974 LD (IX+$0C),A ; }
 $8977 CALL $95BD    ; Check collisions
 $897A JR C,$89C0    ; actor hit -> convert IY to IX (below)
 $897C LD B,$04      ; {fallback: B=4, walk object_table for wall markers
 $897E LD IX,$605B   ; }
*$8982 LD A,(IX+$30) ; {only consider state==7 (wall marker) entries
 $8985 CP $07        ;
 $8987 JR Z,$898F    ;
 $8989 INC IX        ; }
 $898B DJNZ $8982    ;
*$898D OR A          ;
 $898E RET           ;
*$898F LD A,(IX+$00) ; {row window test vs entry's position: too far?
 $8992 CP $35        ;
 $8994 JR C,$898D    ;
 $8996 CP $44        ; }
 $8998 JR NC,$898D   ;
 $899A LD A,(IX+$06) ; {row+7 <= entry's position? (upper bound)
 $899D ADD A,$07     ;
 $899F LD L,A        ;
 $89A0 LD A,(IX+$0C) ;
 $89A3 ADC A,$00     ;
 $89A5 LD H,A        ; }
 $89A6 LD DE,($60BA) ;
 $89AA OR A          ;
 $89AB SBC HL,DE     ;
 $89AD JR C,$898D    ;
 $89AF LD HL,$0009   ; {entry's position+9 >= row? (lower bound)
 $89B2 ADD HL,DE     ;
 $89B3 LD E,(IX+$06) ;
 $89B6 LD D,(IX+$0C) ;
 $89B9 OR A          ;
 $89BA SBC HL,DE     ;
 $89BC JR C,$898D    ; }
 $89BE SCF           ;
 $89BF RET           ;
*$89C0 PUSH HL       ; {convert actor hit: HL(from check_collisions)->IX, set
 $89C1 POP IX        ; CY
 $89C3 SCF           ;
 $89C4 RET           ; }

; Check collision
;
; Used by the routine at #R$8240.
;
; .
;
; Test the player against the tower/hazards and apply the result.
; .
; Dispatches on player_state (#R$60C0):
; .
; 7 = invulnerable/idle -> no test (RET)
; .
; 4 = check a height window (#R$60BF in $0A..$1E)
; .
; 8 = RET else test flag $60C5.
; .
; Calls #R$895B (carry = hit).
; .
; On a hit it patches the value at #R$8A49 (SELF-MODIFYING: $14/$0F/$20 select
; the bump/death response used downstream) and branches into the hit handler.
@label=check_collision
c$89C5 LD A,($60C0)  ; A = player_state (#R$60C0)
 $89C8 CP $07        ;
 $89CA RET Z         ; state 7: no collision this frame
 $89CB CP $04        ;
 $89CD JR NZ,$89DB   ;
 $89CF LD A,($60BF)  ; A = #R$60BF (height-in-column)
 $89D2 CP $0A        ;
 $89D4 JR C,$89E4    ;
 $89D6 CP $1F        ;
 $89D8 JR NC,$89E4   ;
 $89DA RET           ;
*$89DB CP $08        ;
 $89DD RET Z         ;
 $89DE LD A,($60C5)  ;
 $89E1 OR A          ;
 $89E2 JR NZ,$8A26   ;
*$89E4 CALL $895B    ; Collision test
 $89E7 JR C,$8A01    ; hit -> hit handler
 $89E9 LD A,($60C0)  ; get Player state-machine state
 $89EC CP $06        ;
 $89EE RET NZ        ;
 $89EF LD A,($60B9)  ; get Tower rotation position
 $89F2 LD HL,($60BA) ;
 $89F5 CALL $9330    ; Check rotate collision
 $89F8 RET NC        ;
 $89F9 LD A,$14      ;
 $89FB LD ($8A49),A  ; patch response code at #R$8A49 = $14 (SELF-MOD)
 $89FE JP $8A17      ;
*$8A01 LD A,(IX+$30) ; A = colliding object state (+48)
 $8A04 LD B,$0F      ;
 $8A06 CP $07        ;
 $8A08 JR Z,$8A0C    ;
 $8A0A LD B,$14      ;
*$8A0C LD A,B        ;
 $8A0D LD ($8A49),A  ; patch response code ($0F enemy / $14 wall)
 $8A10 LD A,($60C0)  ; get Player state-machine state
 $8A13 CP $06        ;
 $8A15 JR NZ,$8A23   ;
*$8A17 LD A,($60BA)  ;
 $8A1A AND $03       ;
 $8A1C JR Z,$8A33    ;
 $8A1E LD HL,$60C5   ;
 $8A21 INC (HL)      ;
 $8A22 RET           ;
*$8A23 JP $8A4A      ;
*$8A26 LD A,($60C0)  ; get Player state-machine state
 $8A29 CP $06        ;
 $8A2B JR NZ,$8A42   ;
 $8A2D LD A,($60BA)  ;
 $8A30 AND $03       ;
 $8A32 RET NZ        ;
*$8A33 CALL $9540    ; Check conveyor
 $8A36 CALL $A766    ;
 $8A39 JR NC,$8A3D   ;
 $8A3B LD (HL),$8D   ;
*$8A3D LD A,$FF      ;
 $8A3F LD ($6038),A  ; set Flag?? $00 $FE $FF
*$8A42 XOR A         ;
 $8A43 LD ($60C5),A  ;
 $8A46 JP $8A4A      ;

; Unused
;
; .
;
; .
;
; SELF-MODIFIED scratch byte, not code: check_collision writes a response code
; here ($14 wall / $0F enemy) on a hit, and code_a871 reads it at $8A74 to pick
; the bump-vs-death branch.
@label=hit_response
s$8A49 DEFS $01

; Apply a hit (player invulnerable, sound)
;
; Used by the routine at #R$89C5.
;
; .
;
; Common "player got hit" handler, reached from check_collision's hit path.
; .
; Sets player_state=7 (invulnerable/frozen, matches check_collision's "state 7
; = no test" case), phase=0, game_state=0, calls $A72D with A=2 (life/damage
; counter update), plays sound 5 (hit sound).
@label=coll_apply
c$8A4A LD A,$07      ;
 $8A4C LD ($60C0),A  ; set Player state-machine state
 $8A4F XOR A         ;
 $8A50 LD ($60BF),A  ; set Player state-machine phase/height window
 $8A53 LD ($60D9),A  ; set Game state
 $8A56 LD A,$02      ;
 $8A58 CALL $A72D    ;
 $8A5B LD A,$05      ;
 $8A5D CALL $A3DE    ; Play sound
 $8A60 RET           ;

; Data block at 8A61
;
; .
;
; .
;
; 16-byte signed-offset table used by code_8a71 to size the knockback step,
; indexed by (response_code>>1)&3.
@label=tbl_8a61
b$8A61 DEFB $03,$02,$01,$01,$01,$00,$00,$FF
 $8A69 DEFB $FE,$FE,$FD,$FD,$FD,$FD,$FD,$FC

; Bump/knockback handler
;
; .
;
; .
;
; Bump/knockback handler, dispatched from check_collision's hit path via the
; response code at hit_response (#R$8A49).
; .
; If the current animation phase equals the stored response code: "wall bump"
; branch ($8AB5) -- sets a sprite frame, subtracts 4 from the actor's column
; position (#R$60BA), and if that didn't go negative, re-checks via
; CHECK_ROTATE_COLLISION; no collision bounces back into pstate_play_cell1
; (#R$8590), otherwise (or on negative position) falls into the death handler
; at $8AD7.
; .
; If phase differs from the response code: "step" branch -- picks a sprite
; frame from table $871F (mirrored by facing), clamps the response code to $0F,
; looks up a signed delta from tbl_8a61 and applies it to the actor's column
; position; going negative also falls into $8AD7 (death), otherwise the
; position is masked/stored and phase increments.
@label=code_8a71
c$8A71 LD A,($60BF)    ; {A=phase; compare vs stored response code
 $8A74 LD HL,$8A49     ; (hit_response)
 $8A77 CP (HL)         ; }
 $8A78 JR Z,$8AB5      ;
 $8A7A LD C,A          ; {step branch: index sprite frame table $871F by
 $8A7B SRL A           ; (code>>1)&3
 $8A7D AND $03         ;
 $8A7F LD E,A          ;
 $8A80 LD D,$00        ;
 $8A82 LD HL,$871F     ;
 $8A85 ADD HL,DE       ;
 $8A86 LD A,($60BE)    ; }
 $8A89 OR (HL)         ;
 $8A8A LD ($60C1),A    ;
 $8A8D LD D,$00        ; {clamp response code to $0F for delta lookup
 $8A8F LD A,C          ;
 $8A90 CP $0F          ;
 $8A92 JR C,$8A96      ;
 $8A94 LD C,$0F        ; }
*$8A96 LD B,$00        ; {B=0; lookup signed delta from tbl_8a61
 $8A98 LD HL,$8A61     ;
 $8A9B ADD HL,BC       ;
 $8A9C LD A,(HL)       ;
 $8A9D OR A            ; }
 $8A9E JP P,$8AA2      ;
 $8AA1 DEC B           ;
*$8AA2 LD HL,$60BA     ; {apply delta to actor column (16-bit)
 $8AA5 ADD A,(HL)      ;
 $8AA6 LD (HL),A       ;
 $8AA7 LD A,B          ;
 $8AA8 INC HL          ;
 $8AA9 ADC A,(HL)      ; }
 $8AAA JP M,$8AD7      ; went negative -> death_handler
 $8AAD AND $03         ;
 $8AAF LD (HL),A       ;
 $8AB0 LD HL,$60BF     ;
 $8AB3 INC (HL)        ;
 $8AB4 RET             ;
*$8AB5 LD A,($60BE)    ; {bump branch: sprite frame from facing
 $8AB8 OR $00          ;
 $8ABA LD ($60C1),A    ; }
 $8ABD LD HL,($60BA)   ; {subtract 4 from actor column (wall bump)
 $8AC0 LD DE,$0004     ;
 $8AC3 OR A            ;
 $8AC4 SBC HL,DE       ;
 $8AC6 LD ($60BA),HL   ; }
 $8AC9 BIT 7,H         ; {negative -> death_handler
 $8ACB JR NZ,$8AD7     ; }
 $8ACD LD A,($60B9)    ; get Tower rotation position
 $8AD0 CALL $9330      ; Check rotate collision
 $8AD3 RET C           ;
 $8AD4 JP $8590        ;
; Death processing: sets player_state=8 (pstate_8), phase=0, clears actor
; position (#R$60BA/$60BB), resets each of the 4 object_table actors' state
; field (+48: 7->0, else->4) and clears their +42 field, plays sound 6, falls
; straight into pstate_8.
@label=death_handler
*$8AD7 LD A,$08        ; death: state=8
 $8AD9 LD ($60C0),A    ; set Player state-machine state
 $8ADC XOR A           ;
 $8ADD LD ($60BF),A    ; set Player state-machine phase/height window
 $8AE0 LD ($60BA),A    ; {clear actor position (#R$60BA/$60BB)
 $8AE3 LD ($60BB),A    ; }
 $8AE6 LD IX,$605B     ; IX -> object_table, B=4
 $8AEA LD B,$04        ;
*$8AEC LD A,(IX+$30)   ; {reset each actor's state (7->0, else->4), clear phase
 $8AEF CP $00          ;
 $8AF1 JR Z,$8B05      ;
 $8AF3 CP $07          ;
 $8AF5 JR NZ,$8AFC     ;
 $8AF7 LD A,$00        ;
 $8AF9 JP $8AFE        ;
*$8AFC LD A,$04        ;
*$8AFE LD (IX+$30),A   ;
 $8B01 LD (IX+$2A),$00 ; }
*$8B05 INC IX          ; {next actor, loop
 $8B07 DJNZ $8AEC      ; }
 $8B09 LD A,$06        ;
 $8B0B CALL $A3DE      ; Play sound

; Pstate 8
;
; .
;
; .
;
; State 8: death fall-off animation, entered from death_handler ($8AD7).
; .
; While phase<$18, sets sprite frame ($60C1) from phase>>2 and increments phase
; each call. Once phase>=$18, clears $60C2 and keeps counting.
; .
; At phase==$38 sets death_flag (#R$60C3)=1 -- this is the signal main_loop
; polls to trigger the life-loss handler.
@label=pstate_8
c$8B0E LD HL,$60BF   ; {A = pstate_phase
 $8B11 LD A,(HL)     ; }
 $8B12 CP $18        ; {phase<$18: frame=phase>>2, phase++
 $8B14 JR NC,$8B1F   ;
 $8B16 SRL A         ;
 $8B18 SRL A         ; }
 $8B1A LD ($60C1),A  ;
 $8B1D INC (HL)      ;
 $8B1E RET           ;
*$8B1F XOR A         ; {phase>=$18: clear $60C2, check phase==$38
 $8B20 LD ($60C2),A  ;
 $8B23 LD A,(HL)     ;
 $8B24 CP $38        ;
 $8B26 JR Z,$8B2A    ; }
 $8B28 INC (HL)      ;
 $8B29 RET           ;
*$8B2A LD A,$01      ;
 $8B2C LD ($60C3),A  ; set Player died this frame
 $8B2F RET           ;

; Unused
s$8B30 DEFS $20

; Sprite setup
;
; Used by the routine at #R$8FC7.
;
; .
;
; Compute on-screen positions for the 4 actor sprites (objects 0..3) ahead of
; drawing.
; .
; Derives a buffer base from tower_height into #R$600A, fills two coordinate
; tables at #R$8B30/$8B40 (X and Y per sprite, via #R$8BEC/#R$8BFF), then per
; object copies sprite id (IX+18 -> IX+24) and stores the screen column (IX+30)
; from the angular position (IX+0).
; .
; Self-mod: #R$8B30/$8B40 are coordinate scratch buffers IN code.
@label=sprite_setup
c$8B50 LD HL,$60B9     ; HL -> tower_height
 $8B53 LD A,$04        ;
 $8B55 SUB (HL)        ; 4 - height, low 3 bits -> sub-row
 $8B56 AND $07         ;
 $8B58 LD L,$00        ;
 $8B5A SRL A           ;
 $8B5C RR L            ;
 $8B5E LD H,A          ;
 $8B5F LD DE,$6600     ; DE = $6600 sprite work buffer base
 $8B62 ADD HL,DE       ;
 $8B63 LD ($600A),HL   ; store buffer ptr -> #R$600A
 $8B66 LD HL,$8B30     ; fill X-coord table #R$8B30 (4 sprites, step 8)
 $8B69 LD A,$04        ;
*$8B6B PUSH AF         ;
 $8B6C CALL $8BEC      ; Col screen y
 $8B6F ADD A,$1E       ;
 $8B71 LD (HL),A       ;
 $8B72 INC HL          ;
 $8B73 POP AF          ;
 $8B74 ADD A,$08       ;
 $8B76 CP $84          ;
 $8B78 JR NZ,$8B6B     ;
 $8B7A LD HL,$8B40     ; fill Y-coord table $8B40 (4 sprites)
 $8B7D LD A,$04        ;
*$8B7F PUSH AF         ;
 $8B80 CALL $8BFF      ; Col screen x
 $8B83 LD (HL),A       ;
 $8B84 INC HL          ;
 $8B85 POP AF          ;
 $8B86 ADD A,$08       ;
 $8B88 CP $84          ;
 $8B8A JR NZ,$8B7F     ;
 $8B8C LD IX,$605B     ; IX -> object_table
 $8B90 LD B,$04        ;
*$8B92 PUSH BC         ;
 $8B93 LD A,(IX+$12)   ; back up sprite id (IX+18 -> IX+24)
 $8B96 LD (IX+$18),A   ;
 $8B99 LD A,(IX+$30)   ;
 $8B9C CP $00          ; state 0 (inactive) -> skip
 $8B9E JR Z,$8BD5      ;
 $8BA0 CP $07          ;
 $8BA2 LD A,$40        ; state 7 -> fixed screen col $40
 $8BA4 JR Z,$8BAC      ;
 $8BA6 LD A,(IX+$00)   ;
 $8BA9 CALL $8BFF      ; Col screen x
*$8BAC LD (IX+$1E),A   ; store sprite screen column (IX+30)
 $8BAF LD L,(IX+$06)   ;
 $8BB2 LD H,(IX+$0C)   ;
 $8BB5 LD DE,($6057)   ;
 $8BB9 OR A            ;
 $8BBA PUSH HL         ;
 $8BBB SBC HL,DE       ;
 $8BBD POP HL          ;
 $8BBE JR C,$8BDF      ;
 $8BC0 LD DE,($6059)   ;
 $8BC4 OR A            ;
 $8BC5 SBC HL,DE       ;
 $8BC7 JR NC,$8BD5     ;
 $8BC9 LD A,(IX+$30)   ;
 $8BCC CP $07          ;
 $8BCE JR Z,$8BD9      ;
 $8BD0 CALL $8CC2      ; Calc sprite shift
 $8BD3 JR NC,$8BD9     ;
*$8BD5 LD (IX+$18),$FF ;
*$8BD9 POP BC          ;
 $8BDA INC IX          ;
 $8BDC DJNZ $8B92      ;
 $8BDE RET             ;
*$8BDF LD A,(IX+$30)   ;
 $8BE2 CP $07          ;
 $8BE4 JR Z,$8BD5      ;
 $8BE6 LD (IX+$30),$00 ;
 $8BEA JR $8BD5        ;

; Col screen y
;
; Used by the routines at #R$8B50 and #R$8CC2.
;
; .
;
; Map an actor's angular column to its screen Y / vertical-projection value.
; .
; In: A = angular position (0..127).
; .
; Offsets by the tower rotation: rel = (A + $20 - tower_height) & $7F, then
; returns col_y_table[#R$6380 + rel].
; .
; Out: A = projected value.
; .
; Preserves HL (PUSH/POP).
@label=col_screen_y
c$8BEC PUSH HL       ;
 $8BED ADD A,$20     ; bias by +$20 (quarter turn)
 $8BEF LD HL,$60B9   ;
 $8BF2 SUB (HL)      ; subtract current tower rotation
 $8BF3 AND $7F       ; wrap to 0..127 (around the tower)
 $8BF5 LD E,A        ;
 $8BF6 LD D,$00      ;
 $8BF8 LD HL,$6380   ; HL -> col_y_table (#R$6380)
 $8BFB ADD HL,DE     ;
 $8BFC LD A,(HL)     ; A = table[rel] = projected Y/value
 $8BFD POP HL        ;
 $8BFE RET           ;

; Col screen x
;
; Used by the routine at #R$8B50.
;
; .
;
; Map an actor's angular column to a screen X column, folding the cylinder so
; only the front face shows.
; .
; In: A = angular position (0..127).
; .
; rel = (A + $20 - tower_height) & $7F, then fold: rel < $20        -> rel +
; $20      (left quadrant) $20..$5F         -> $60 - rel      (front, mirrored)
; rel >= $60       -> rel - $60      (right quadrant) Out: A = screen column.
; .
; Preserves HL.
@label=col_screen_x
c$8BFF PUSH HL       ;
 $8C00 ADD A,$20     ; bias +$20
 $8C02 LD HL,$60B9   ;
 $8C05 SUB (HL)      ; subtract tower rotation
 $8C06 AND $7F       ; wrap to 0..127
 $8C08 CP $20        ; left quadrant?
 $8C0A JR NC,$8C10   ;
 $8C0C ADD A,$20     ; -> rel + $20
 $8C0E JR $8C1C      ;
*$8C10 CP $60        ; back face?
 $8C12 JR C,$8C18    ;
 $8C14 SUB $60       ; -> rel - $60 (right quadrant)
 $8C16 JR $8C1C      ;
*$8C18 LD H,A        ;
 $8C19 LD A,$60      ;
 $8C1B SUB H         ; front: mirror $60 - rel
*$8C1C POP HL        ;
 $8C1D RET           ;

; Sprite shift masks
;
; .
;
; .
;
; 1bpp AND/shift mask data for drawing the tower-column sprites at sub-byte X
; offsets (patterns 3F/0F/03/00 FF...).
; .
; Base referenced from $8D35/$8F5E.
; .
; Interleaved with a few SELF-MODIFIED 1-byte slots
; ($8C76/$8C77/$8C78/$8C81/$8C82/$8C83/ $8C85) that calc_sprite_shift patches
; with computed shift counts.
; .
; Spans #R$8C1E..$8CC1 code resumes at calc_sprite_shift.
@label=sprite_shift_masks
b$8C1E DEFB $FF,$FF,$FC,$FF,$FF,$F0,$FF,$FF
 $8C26 DEFB $C0,$FF,$FF,$00,$FF,$FC,$00,$FF
 $8C2E DEFB $F0,$00,$FF,$C0,$00,$FF,$00,$00
 $8C36 DEFB $FC,$00,$00,$F0,$00,$00,$C0,$00
 $8C3E DEFB $00,$3F,$FF,$FF,$0F,$FF,$FF,$03
 $8C46 DEFB $FF,$FF,$00,$FF,$FF,$00,$3F,$FF
 $8C4E DEFB $00,$0F,$FF,$00,$03,$FF,$00,$00
 $8C56 DEFB $FF,$00,$00,$3F,$00,$00,$0F,$00
 $8C5E DEFB $00,$03,$C0,$03,$FF,$F0,$00,$FF
 $8C66 DEFB $FC,$00,$3F,$FF,$00,$0F,$FF,$C0
 $8C6E DEFB $03,$C0,$00,$03,$00,$00,$00,$00
 $8C76 DEFB $00,$00,$00,$00,$08,$02,$06,$04
 $8C7E DEFB $04,$06,$02,$00,$00,$00,$00,$FF
 $8C86 DEFB $FF,$FF,$03,$03,$03,$07,$07,$07
 $8C8E DEFB $07,$00,$00,$00,$00,$00,$00,$00
 $8C96 DEFB $00,$00,$00,$00,$00,$00,$00,$00
 $8C9E DEFB $00,$00,$00,$00,$00,$00,$00,$00
 $8CA6 DEFB $00,$00,$00,$00,$00,$00,$00,$00
 $8CAE DEFB $00,$00,$00,$00,$00,$00,$00,$00
 $8CB6 DEFB $00,$00,$12,$12,$12,$0E,$0E,$0E
 $8CBE DEFB $0E,$FF,$FF,$FF

; Calc sprite shift
;
; Used by the routine at #R$8B50.
;
; .
;
; For the actor at IX, compute its screen row (via col_screen_y) and the
; horizontal sub-byte shift, and patch the shift counts into the self-mod slots
; above ($8C76/77/ 81).
; .
; Reads the column buffer (#R$600A) to skip empty/edge columns ($0F/$0E
; sentinels).
; .
; Called from sprite_setup ($8BD0).
@label=calc_sprite_shift
c$8CC2 LD A,(IX+$00)  ; A = actor angular pos (IX+0)
 $8CC5 CALL $8BEC     ; Col screen y
 $8CC8 ADD A,$1E      ;
 $8CCA ADD A,$02      ;
 $8CCC AND $FC        ;
 $8CCE LD ($8C81),A   ; patch self-mod slot $8C81 (row)
 $8CD1 LD HL,($600A)  ; HL -> column buffer (#R$600A)
 $8CD4 ADD HL,DE      ;
 $8CD5 LD A,(HL)      ;
 $8CD6 CP $0F         ; $0F = empty column -> skip (RET)
 $8CD8 RET Z          ;
 $8CD9 CP $0E         ;
 $8CDB CCF            ;
 $8CDC RET Z          ;
 $8CDD LD B,A         ;
 $8CDE LD A,($60B9)   ; A = tower_height (rotation)
 $8CE1 SUB $1D        ;
 $8CE3 AND $7F        ;
 $8CE5 SRL A          ; /8 -> byte-column shift
 $8CE7 SRL A          ;
 $8CE9 SRL A          ;
 $8CEB LD C,A         ;
 $8CEC ADD A,B        ;
 $8CED AND $0F        ;
 $8CEF LD ($8C77),A   ; patch shift count slot $8C77
 $8CF2 LD B,A         ;
 $8CF3 SRL A          ;
 $8CF5 SRL A          ;
 $8CF7 SRL A          ;
 $8CF9 SRL A          ;
 $8CFB ADD A,C        ;
 $8CFC AND $0F        ;
 $8CFE LD ($8C76),A   ; patch shift count slot $8C76
 $8D01 LD HL,$FFFF    ;
 $8D04 LD ($600C),HL  ;
 $8D07 LD ($600E),HL  ;
 $8D0A LD ($6010),HL  ;
 $8D0D LD ($6012),HL  ;
 $8D10 LD ($6013),HL  ;
 $8D13 XOR A          ;
 $8D14 LD ($8C78),A   ;
 $8D17 LD A,(IX+$00)  ;
 $8D1A CALL $8BEC     ; Col screen y
 $8D1D BIT 6,E        ;
 $8D1F LD ($8C83),A   ;
 $8D22 JR Z,$8D5D     ;
 $8D24 ADD A,$1E      ;
 $8D26 LD E,A         ;
 $8D27 LD D,$00       ;
 $8D29 LD HL,$8C85    ;
 $8D2C ADD HL,DE      ;
 $8D2D LD A,(HL)      ;
 $8D2E CP $FF         ;
 $8D30 JR Z,$8D5D     ;
 $8D32 ADD A,A        ;
 $8D33 ADD A,(HL)     ;
 $8D34 LD E,A         ;
 $8D35 LD HL,$8C1E    ;
 $8D38 ADD HL,DE      ;
 $8D39 LD A,(HL)      ;
 $8D3A INC HL         ;
 $8D3B LD ($600C),A   ;
 $8D3E LD ($600F),A   ;
 $8D41 LD ($6012),A   ;
 $8D44 LD A,(HL)      ;
 $8D45 INC HL         ;
 $8D46 LD ($600D),A   ;
 $8D49 LD ($6010),A   ;
 $8D4C LD ($6013),A   ;
 $8D4F LD A,(HL)      ;
 $8D50 LD ($600E),A   ;
 $8D53 LD ($6011),A   ;
 $8D56 LD ($6014),A   ;
 $8D59 LD HL,$8C78    ;
 $8D5C INC (HL)       ;
*$8D5D LD A,(IX+$06)  ;
 $8D60 AND $03        ;
 $8D62 LD ($8C82),A   ;
 $8D65 LD L,(IX+$06)  ;
 $8D68 LD A,(IX+$0C)  ;
 $8D6B RRA            ;
 $8D6C RR L           ;
 $8D6E RRA            ;
 $8D6F RR L           ;
 $8D71 LD A,($8C77)   ;
 $8D74 LD B,A         ;
 $8D75 LD A,($8C76)   ;
*$8D78 PUSH AF        ;
 $8D79 PUSH BC        ;
 $8D7A PUSH HL        ;
 $8D7B CALL $8EF1     ; Calc sprite col
 $8D7E POP HL         ;
 $8D7F POP BC         ;
 $8D80 POP AF         ;
 $8D81 INC A          ;
 $8D82 AND $0F        ;
 $8D84 CP B           ;
 $8D85 JR NZ,$8D78    ;
 $8D87 LD A,($8C78)   ;
 $8D8A OR A           ;
 $8D8B RET Z          ;
 $8D8C PUSH IX        ;
 $8D8E POP DE         ;
 $8D8F LD A,($8C83)   ;
 $8D92 ADD A,$3C      ;
 $8D94 AND $03        ;
 $8D96 ADD A,(IX+$12) ;
 $8D99 PUSH AF        ;
 $8D9A LD A,E         ;
 $8D9B SUB $5B        ;
 $8D9D ADD A,$7C      ;
 $8D9F LD (IX+$18),A  ;
 $8DA2 SUB $7C        ;
 $8DA4 ADD A,A        ;
 $8DA5 ADD A,A        ;
 $8DA6 ADD A,A        ;
 $8DA7 ADD A,A        ;
 $8DA8 ADD A,A        ;
 $8DA9 LD L,A         ;
 $8DAA ADD A,A        ;
 $8DAB ADD A,L        ;
 $8DAC LD L,A         ;
 $8DAD LD H,$00       ;
 $8DAF JR NC,$8DB2    ;
 $8DB1 INC H          ;
*$8DB2 LD DE,$BC80    ;
 $8DB5 ADD HL,DE      ;
 $8DB6 POP AF         ;
 $8DB7 PUSH HL        ;
 $8DB8 CALL $A784     ;
 $8DBB POP DE         ;
 $8DBC LD A,C         ;
 $8DBD CP $02         ;
 $8DBF JP NZ,$8E48    ;
 $8DC2 LD A,($8C82)   ;
 $8DC5 ADD A,A        ;
 $8DC6 ADD A,$79      ;
 $8DC8 LD C,A         ;
 $8DC9 LD A,$8C       ;
 $8DCB ADC A,$00      ;
 $8DCD LD B,A         ;
 $8DCE LD A,(BC)      ;
 $8DCF LD ($8DF2),A   ;
 $8DD2 INC BC         ;
 $8DD3 LD A,(BC)      ;
 $8DD4 LD ($8E24),A   ;
 $8DD7 LD A,($8C82)   ;
 $8DDA OR A           ;
 $8DDB JR Z,$8DF6     ;
 $8DDD LD A,($600C)   ;
 $8DE0 LD ($8E2D),A   ;
 $8DE3 CPL            ;
 $8DE4 LD ($8E27),A   ;
 $8DE7 LD A,($600D)   ;
 $8DEA LD ($8E39),A   ;
 $8DED CPL            ;
 $8DEE LD ($8E33),A   ;
 $8DF1 LD B,$00       ;
 $8DF3 CALL $8E25     ; Expand sprite a
*$8DF6 LD A,($600F)   ;
 $8DF9 LD ($8E2D),A   ;
 $8DFC CPL            ;
 $8DFD LD ($8E27),A   ;
 $8E00 LD A,($6010)   ;
 $8E03 LD ($8E39),A   ;
 $8E06 CPL            ;
 $8E07 LD ($8E33),A   ;
 $8E0A LD B,$08       ;
 $8E0C CALL $8E25     ; Expand sprite a
 $8E0F LD A,($6012)   ;
 $8E12 LD ($8E2D),A   ;
 $8E15 CPL            ;
 $8E16 LD ($8E27),A   ;
 $8E19 LD A,($6013)   ;
 $8E1C LD ($8E39),A   ;
 $8E1F CPL            ;
 $8E20 LD ($8E33),A   ;
 $8E23 LD B,$00       ;

; Expand sprite a
;
; Used by the routine at #R$8CC2.
;
; .
;
; Unrolled copy of a sprite/mask definition from (HL) to (DE), terminated by
; $FF.
; .
; The alternating OR $00 / AND $00 immediates are SELF-MODIFIED (by
; calc_sprite_shift) to apply the per-column shift mask.
; .
; Clobbers: A,DE,HL.
@label=expand_sprite_a
c$8E25 LD A,(HL)     ; A = source byte (HL)
 $8E26 OR $00        ; self-mod OR mask (set by calc_sprite_shift)
 $8E28 LD (DE),A     ; store merged byte, advance dest
 $8E29 INC HL        ;
 $8E2A INC DE        ;
 $8E2B LD A,(HL)     ; A = next source byte
 $8E2C AND $00       ; self-mod AND mask (set by calc_sprite_shift)
 $8E2E LD (DE),A     ;
 $8E2F INC HL        ;
 $8E30 INC DE        ;
 $8E31 LD A,(HL)     ;
 $8E32 OR $00        ;
 $8E34 LD (DE),A     ;
 $8E35 INC HL        ;
 $8E36 INC DE        ;
 $8E37 LD A,(HL)     ;
 $8E38 AND $00       ;
 $8E3A LD (DE),A     ;
 $8E3B INC HL        ;
 $8E3C INC DE        ;
 $8E3D LD A,$FF      ; A = $FF (terminator byte)
 $8E3F LD (DE),A     ; store terminator, advance dest
 $8E40 INC DE        ;
 $8E41 INC A         ; A += 1 (second terminator byte)
 $8E42 LD (DE),A     ;
 $8E43 INC DE        ;
 $8E44 DJNZ $8E25    ; loop 4 columns
 $8E46 OR A          ;
 $8E47 RET           ;
; Entry point used by calc_sprite_shift, not by expand_sprite_a's own DJNZ
; loop.
; .
; Reads the self-mod shift-count slot ($8C82) to index a 2-byte pair from table
; $8C79 (shift*2), storing it into the loop-count operands of the first/third
; strip's "LD B,nn" at $8E81/$8EC7 (operand bytes $8E82/$8EC8) -- CORRECTION:
; these are NOT routine pointers or mask operands, they are the row counts for
; the two edge strips. Confirmed by emulation: for every shift value 0-3,
; (first-strip-count + third-strip-count) == 8, and combined with the
; always-8-row middle strip, TOTAL decoded height is a shift-INVARIANT 16 rows.
; When the shift-count slot is 0, the first strip is skipped entirely (JR
; Z,$8E86) and its row count (0) is moot.
; .
; Then, per 8-pixel strip, copies 3 source mask bytes ($600C/$600D/$600E or
; $600F/$6010/$6011 or $6012/$6013/$6014, selected by the same shift-count
; test) straight into expand_sprite_b's real OR-immediate operands
; ($8ECB/$8ED7/$8EE3), and their bitwise complement (CPL) into the paired
; AND-immediate operands ($8ED1/$8EDD/$8EE9) -- so expand_sprite_b ORs in the
; new sprite bits and ANDs out the old ones at the right sub-byte shift, then
; calls expand_sprite_b.
; .
; See gfx_c1f6 (#R$C1F6) for the full sprite-bitmap decode writeup (this
; self-modifying pipeline is why the bitmap can't be rendered as a raw UDG
; array image).
; .
; Clobbers: A,BC.
@label=patch_expand_masks
*$8E48 LD A,($8C82)  ; A = shift-count slot ($8C82)
 $8E4B ADD A,A       ; {index a 2-byte routine-pointer pair
 $8E4C ADD A,$79     ;
 $8E4E LD C,A        ; }
 $8E4F LD A,$8C      ;
 $8E51 ADC A,$00     ;
 $8E53 LD B,A        ;
 $8E54 LD A,(BC)     ; fetch first pointer byte
 $8E55 LD ($8E82),A  ; self-mod store: expand_sprite_b OR operand
 $8E58 INC BC        ;
 $8E59 LD A,(BC)     ; fetch second pointer byte
 $8E5A LD ($8EC8),A  ; self-mod store: expand_sprite_b AND operand
 $8E5D LD A,($8C82)  ; re-test shift-count slot
 $8E60 OR A          ;
 $8E61 JR Z,$8E86    ; zero? -> skip first mask triple
 $8E63 LD A,($600C)  ; A = mask byte 1 ($600C)
 $8E66 LD ($8ED1),A  ; self-mod store: OR operand
 $8E69 CPL           ; complement for AND operand
 $8E6A LD ($8ECB),A  ; self-mod store: AND operand
 $8E6D LD A,($600D)  ;
 $8E70 LD ($8EDD),A  ;
 $8E73 CPL           ;
 $8E74 LD ($8ED7),A  ;
 $8E77 LD A,($600E)  ;
 $8E7A LD ($8EE9),A  ;
 $8E7D CPL           ;
 $8E7E LD ($8EE3),A  ;
 $8E81 LD B,$00      ; B = 0 (loop count for this strip)
 $8E83 CALL $8EC9    ; Expand sprite b
*$8E86 LD A,($600F)  ;
 $8E89 LD ($8ED1),A  ;
 $8E8C CPL           ;
 $8E8D LD ($8ECB),A  ;
 $8E90 LD A,($6010)  ;
 $8E93 LD ($8EDD),A  ;
 $8E96 CPL           ;
 $8E97 LD ($8ED7),A  ;
 $8E9A LD A,($6011)  ;
 $8E9D LD ($8EE9),A  ;
 $8EA0 CPL           ;
 $8EA1 LD ($8EE3),A  ;
 $8EA4 LD B,$08      ; B = $08 (loop count for this strip)
 $8EA6 CALL $8EC9    ; Expand sprite b
 $8EA9 LD A,($6012)  ;
 $8EAC LD ($8ED1),A  ;
 $8EAF CPL           ;
 $8EB0 LD ($8ECB),A  ;
 $8EB3 LD A,($6013)  ;
 $8EB6 LD ($8EDD),A  ;
 $8EB9 CPL           ;
 $8EBA LD ($8ED7),A  ;
 $8EBD LD A,($6014)  ;
 $8EC0 LD ($8EE9),A  ;
 $8EC3 CPL           ;
 $8EC4 LD ($8EE3),A  ;
 $8EC7 LD B,$00      ; B = 0 (loop count for final strip)

; Expand sprite b
;
; Used by the routine at #R$8E25.
;
; .
;
; Same unrolled-copy shape as expand_sprite_a, but its OR/AND immediate
; operands are self-modified by patch_expand_masks ($8E48) rather than
; calc_sprite_shift directly -- used for the shift-boundary case where 3 source
; mask bytes (not 2) are needed per strip.
; .
; Clobbers: A,DE,HL.
@label=expand_sprite_b
c$8EC9 LD A,(HL)     ; A = source byte (HL)
 $8ECA OR $00        ; self-mod OR mask (set by patch_expand_masks)
 $8ECC LD (DE),A     ; store merged byte, advance dest
 $8ECD INC HL        ;
 $8ECE INC DE        ;
 $8ECF LD A,(HL)     ;
 $8ED0 AND $00       ;
 $8ED2 LD (DE),A     ;
 $8ED3 INC HL        ;
 $8ED4 INC DE        ;
 $8ED5 LD A,(HL)     ;
 $8ED6 OR $00        ;
 $8ED8 LD (DE),A     ;
 $8ED9 INC HL        ;
 $8EDA INC DE        ;
 $8EDB LD A,(HL)     ;
 $8EDC AND $00       ;
 $8EDE LD (DE),A     ;
 $8EDF INC HL        ;
 $8EE0 INC DE        ;
 $8EE1 LD A,(HL)     ;
 $8EE2 OR $00        ;
 $8EE4 LD (DE),A     ;
 $8EE5 INC HL        ;
 $8EE6 INC DE        ;
 $8EE7 LD A,(HL)     ;
 $8EE8 AND $00       ;
 $8EEA LD (DE),A     ;
 $8EEB INC HL        ;
 $8EEC INC DE        ;
 $8EED DJNZ $8EC9    ; loop 3 mask bytes
 $8EEF OR A          ; {restore flags, RET
 $8EF0 RET           ; }

; Calc sprite col
;
; Used by the routine at #R$8CC2.
;
; .
;
; Resolve a sprite column: index table #R$8B30 by A, compare the result against
; the actor's clip field (IX+30), and patch the shift slot $8C81.
; .
; RET early when within bounds.
; .
; Clobbers: A,DE,HL.
@label=calc_sprite_col
c$8EF1 LD E,A        ;
 $8EF2 ADD A,$F0     ;
 $8EF4 LD H,A        ;
 $8EF5 LD D,$00      ;
 $8EF7 PUSH HL       ;
 $8EF8 LD HL,$8B30   ;
 $8EFB ADD HL,DE     ;
 $8EFC LD A,(HL)     ;
 $8EFD LD DE,$0010   ;
 $8F00 ADD HL,DE     ;
 $8F01 LD E,A        ;
 $8F02 LD A,(HL)     ;
 $8F03 CP (IX+$1E)   ;
 $8F06 JR NC,$8F0A   ;
 $8F08 POP HL        ;
 $8F09 RET           ;
*$8F0A LD A,E        ;
 $8F0B LD HL,$8C81   ;
 $8F0E SUB (HL)      ;
 $8F0F ADD A,$0B     ;
 $8F11 POP HL        ;
 $8F12 RET M         ;
 $8F13 CP $16        ;
 $8F15 RET NC        ;
 $8F16 LD E,A        ;
 $8F17 PUSH DE       ;
 $8F18 LD BC,$6012   ;
 $8F1B CALL $8F31    ; Draw tower cell
 $8F1E INC L         ;
 $8F1F POP DE        ;
 $8F20 PUSH DE       ;
 $8F21 LD BC,$600F   ;
 $8F24 CALL $8F31    ; Draw tower cell
 $8F27 INC L         ;
 $8F28 POP DE        ;
 $8F29 LD A,($8C82)  ;
 $8F2C OR A          ;
 $8F2D RET Z         ;
 $8F2E LD BC,$600C   ;

; Draw tower cell
;
; Used by the routine at #R$8EF1.
;
; .
;
; Decode one tower map cell byte at (HL) -- full bitfield format documented in
; docs/Level-Format.md (bit7=occupied, bits0-1=type, bits4-5=subtype).
; .
; Bit7 clear (unoccupied) or type==3 (invalid combo here) -> RET, nothing
; drawn. Otherwise type bit0 selects one of three offset tables (bit0==0 ->
; tbl_cell_offsets_c $8FA1 bit0==1 and bits2-3==0 -> tbl_cell_offsets_a #R$8F75
; bit0==1 and bits2-3!=0 -> tbl_cell_offsets_b $8F8B).
; .
; The chosen table is indexed by DE (caller-supplied sub-position, not part of
; the cell byte) negative entries ($FF) mean nothing to draw at that
; sub-position.
; .
; A non-negative entry is *3 and indexes sprite_shift_masks (#R$8C1E) for 3
; AND-mask bytes, ANDed into 3 destination screen bytes at (BC) to punch out
; the feature's silhouette. Bumps a self-mod counter at $8C78 on every
; successful draw.
; .
; Clobbers: A,HL,...
@label=draw_tower_cell
c$8F31 PUSH HL       ;
 $8F32 LD A,(HL)     ; {A = cell byte; bit7 clear (unoccupied) -> RET
 $8F33 OR A          ;
 $8F34 JP P,$8F73    ; }
 $8F37 LD H,A        ; {H = cell byte; isolate type bits0-1
 $8F38 AND $03       ; }
 $8F3A CP $03        ; {type==3 (invalid/no-render)? -> RET
 $8F3C JR Z,$8F73    ; }
 $8F3E SRL A         ; {test type bit0
 $8F40 JR NC,$8F51   ; }
 $8F42 LD A,H        ; {reload cell byte, isolate bits2-3
 $8F43 AND $0C       ; }
 $8F45 JR Z,$8F4C    ; bits2-3==0 -> table_a
 $8F47 LD HL,$8F8B   ; {else -> table_b ($8F8B)
 $8F4A JR $8F54      ; }
*$8F4C LD HL,$8F75   ; {table_a (#R$8F75)
 $8F4F JR $8F54      ; }
*$8F51 LD HL,$8FA1   ; bit0==0 -> table_c ($8FA1)
*$8F54 ADD HL,DE     ; HL += DE (sub-position index)
 $8F55 LD A,(HL)     ; {A = table[DE]; negative -> RET (nothing here)
 $8F56 OR A          ;
 $8F57 JP M,$8F73    ; }
 $8F5A LD E,A        ; {index = A*3 into sprite_shift_masks
 $8F5B ADD A,A       ;
 $8F5C ADD A,E       ;
 $8F5D LD E,A        ; }
 $8F5E LD HL,$8C1E   ; {HL -> sprite_shift_masks[index]
 $8F61 ADD HL,DE     ; }
 $8F62 LD A,(BC)     ; {AND-mask 3 destination bytes at (BC)
 $8F63 AND (HL)      ;
 $8F64 LD (BC),A     ;
 $8F65 INC BC        ;
 $8F66 INC HL        ;
 $8F67 LD A,(BC)     ;
 $8F68 AND (HL)      ;
 $8F69 LD (BC),A     ;
 $8F6A INC BC        ;
 $8F6B INC HL        ;
 $8F6C LD A,(BC)     ;
 $8F6D AND (HL)      ;
 $8F6E LD (BC),A     ; }
 $8F6F LD HL,$8C78   ; {bump feature-drawn counter ($8C78)
 $8F72 INC (HL)      ; }
*$8F73 POP HL        ;
 $8F74 RET           ;

; Data block at 8F75
;
; .
;
; .
;
; First of three sibling offset tables (#R$8F75/$8F8B/$8FA1), selected by
; draw_tower_cell on the cell descriptor's bits 2-3, then indexed by DE (low
; descriptor bits) to get an offset into sprite_shift_masks (#R$8C1E).
@label=tbl_cell_offsets_a
b$8F75 DEFB $0B,$0C,$0D,$0E,$0F,$10,$11,$12
 $8F7D DEFB $13,$14,$15,$1C,$0A,$09,$08,$07
 $8F85 DEFB $06,$05,$04,$03,$02,$01,$FF,$0B
 $8F8D DEFB $0C,$0D,$0E,$0F,$10,$11,$12,$13
 $8F95 DEFB $14,$1B,$09,$08,$07,$06,$05,$04
 $8F9D DEFB $03,$02,$01,$00,$FF,$FF,$FF,$0B
 $8FA5 DEFB $0C,$0D,$0E,$0F,$10,$16,$17,$18
 $8FAD DEFB $19,$1A,$05,$04,$03,$02,$01,$00
 $8FB5 DEFB $FF,$FF

; Clear actor states
;
; Used by the routine at #R$81D7.
;
; .
;
; Zero the state byte (+48) of all four object_table actors, deactivating every
; enemy.
; .
; Clobbers: A,B,IX.
@label=clear_actor_states
c$8FB7 LD IX,$605B   ;
 $8FBB LD A,$00      ;
 $8FBD LD B,$04      ;
*$8FBF LD (IX+$30),A ;
 $8FC2 INC IX        ;
 $8FC4 DJNZ $8FBF    ;
 $8FC6 RET           ;

; Draw player
;
; Used by the routine at #R$8240.
;
; .
;
; Compute the player sprite's on-screen address from the vertical scroll
; (#R$6030) and draw it.
; .
; Handles the tower wrap: the playfield scrolls vertically mod the tower
; height, so the screen row is (#R$6030 +/- offset) kept in range.
; .
; Stores the two derived screen pointers ($6057, $6059) then calls the blit
; helpers (#R$8B50, #R$9035).
; .
; In: #R$6030 = scroll position.
; .
; Out: player drawn.
; .
; Clobbers A,HL.
@label=draw_player
c$8FC7 LD HL,($6030) ; HL = scroll position (#R$6030)
 $8FCA LD A,L        ;
 $8FCB SUB $08       ; - 8 (sprite top offset)
 $8FCD LD L,A        ;
 $8FCE LD A,H        ;
 $8FCF SBC A,$00     ;
 $8FD1 AND $03       ; keep within the 3 screen-thirds (mod via AND 3)
 $8FD3 LD H,A        ;
 $8FD4 CP $03        ; past the wrap point ($3D0)?
 $8FD6 JR NZ,$8FE0   ;
 $8FD8 LD A,L        ;
 $8FD9 CP $D0        ;
 $8FDB JR C,$8FE0    ;
 $8FDD LD HL,$0000   ; -> clamp to top (0)
*$8FE0 LD ($6057),HL ; store upper screen pointer ($6057)
 $8FE3 LD HL,($6030) ; get Vertical scroll position
 $8FE6 LD A,L        ;
 $8FE7 ADD A,$4D     ; + $4D (sprite body offset)
 $8FE9 LD L,A        ;
 $8FEA LD A,H        ;
 $8FEB ADC A,$00     ;
 $8FED AND $03       ;
 $8FEF LD H,A        ;
 $8FF0 LD ($6059),HL ; store lower screen pointer ($6059)
 $8FF3 CALL $8B50    ; Sprite setup
 $8FF6 CALL $9035    ; Sprite depth sort
 $8FF9 RET           ;

; Draw actors sorted
;
; Used by the routine at #R$8240.
;
; .
;
; Draw the 4 actors back-to-front: for depth key C=3..0, find the object whose
; field (+36) matches and draw it via draw_actor.
; .
; Clobbers: A,BC,IX.
@label=draw_actors_sorted
c$8FFA LD C,$03      ; C = 3 (starting depth key, back-most)
*$8FFC LD IX,$605B   ; {IX -> object_table, B = 4 slots
 $9000 LD B,$04      ;
 $9002 LD A,C        ; }
*$9003 CP (IX+$24)   ; {match this slot's draw-order field (+36)? draw it
 $9006 JR Z,$9012    ;
 $9008 INC IX        ; }
 $900A DJNZ $9003    ;
*$900C DEC C         ; {next depth key; done all 4? -> player tail
 $900D JP P,$8FFC    ;
 $9010 JR $9019      ; }
*$9012 PUSH BC       ;
 $9013 CALL $A78A    ;
 $9016 POP BC        ;
 $9017 JR $900C      ;
*$9019 LD IX,$605F   ; {player actor: skip if inactive (phase==$FF)
 $901D LD A,(IX+$2A) ;
 $9020 CP $FF        ; }
 $9022 RET Z         ;
 $9023 LD A,(IX+$12) ;
 $9026 ADD A,$4A     ;
 $9028 LD (IX+$18),A ;
 $902B CALL $A78A    ;
 $902E LD A,($60A6)  ;
 $9031 LD ($60A5),A  ;
 $9034 RET           ;

; Sprite depth sort
;
; Used by the routine at #R$8FC7.
;
; .
;
; Decide the back-to-front draw order of the 4 actor sprites so nearer ones
; overdraw farther ones around the tower.
; .
; Does all 6 pairwise comparisons of the sprites' screen columns
; (IX+30..IX+33), packing the results into 6 bits of B, XORs $3F, and uses that
; as an index into data_908e -- a precomputed table mapping each comparison
; outcome to a draw permutation.
; .
; The 4 order indices are unpacked (2 bits each) into IX+36..IX+39.
; .
; TRI
@label=sprite_depth_sort
c$9035 LD IX,$605B   ; IX -> object_table
 $9039 LD B,$00      ;
 $903B LD A,(IX+$1E) ; compare sprite0 col vs sprite1..3
 $903E CP (IX+$1F)   ;
 $9041 RL B          ; shift compare result into key (RL B)
 $9043 CP (IX+$20)   ;
 $9046 RL B          ;
 $9048 CP (IX+$21)   ;
 $904B RL B          ;
 $904D LD A,(IX+$1F) ;
 $9050 CP (IX+$20)   ;
 $9053 RL B          ;
 $9055 CP (IX+$21)   ;
 $9058 RL B          ;
 $905A LD A,(IX+$20) ;
 $905D CP (IX+$21)   ;
 $9060 RL B          ;
 $9062 LD A,B        ; A = packed 6-bit comparison key
 $9063 XOR $3F       ; invert (XOR $3F) to index orientation
 $9065 LD C,A        ;
 $9066 LD B,$00      ;
 $9068 LD HL,$908E   ; HL -> data_908e[key]
 $906B ADD HL,BC     ;
 $906C LD B,(HL)     ; B = packed draw order (4 x 2-bit indices)
 $906D LD A,B        ;
 $906E AND $03       ;
 $9070 LD (IX+$27),A ; unpack order[0] -> IX+39
 $9073 LD A,B        ;
 $9074 RRA           ;
 $9075 RRA           ;
 $9076 LD B,A        ;
 $9077 AND $03       ;
 $9079 LD (IX+$26),A ; unpack order[1] -> IX+38
 $907C LD A,B        ;
 $907D RRA           ;
 $907E RRA           ;
 $907F LD B,A        ;
 $9080 AND $03       ;
 $9082 LD (IX+$25),A ; unpack order[2] -> IX+37
 $9085 LD A,B        ;
 $9086 RRA           ;
 $9087 RRA           ;
 $9088 AND $03       ;
 $908A LD (IX+$24),A ; unpack order[3] -> IX+36
 $908D RET           ; return: draw order in IX+36..+39

; DATA_908E
;
; .
;
; .
;
; 64-entry packed draw-order permutation table for sprite_depth_sort.
; .
; Index = 6-bit pairwise-comparison key of the 4 sprites' columns (XOR $3F).
; .
; Each byte packs 4 two-bit object
; .
; indices = the back-to-front draw order.
; .
; Bounded by update_enemies.
@label=data_908e
b$908E DEFB $E4,$E1,$00,$D2,$D8,$00,$C9,$C6
 $9096 DEFB $00,$00,$00,$93,$00,$00,$00,$87
 $909E DEFB $00,$00,$00,$00,$9C,$00,$8D,$00
 $90A6 DEFB $00,$00,$00,$00,$00,$00,$4E,$4B
 $90AE DEFB $B4,$B1,$00,$00,$00,$00,$00,$00
 $90B6 DEFB $00,$72,$00,$63,$00,$00,$00,$00
 $90BE DEFB $78,$00,$00,$00,$6C,$00,$00,$00
 $90C6 DEFB $39,$36,$00,$27,$2D,$00,$1E,$1B
 $90CE DEFB $02,$02,$01,$01,$00,$00,$FF,$FF
 $90D6 DEFB $FE,$FE,$FC,$00

; Update enemies
;
; Used by the routine at #R$8240.
;
; .
;
; Step the 4 enemy actors (objects 0..3 of object_table).
; .
; For each: dispatch on its state (+48):
; .
; 0 = inactive (skip), 7 = patrol/home toward player_col,
; .
; 4/6 = -> #R$9158 (full movement state machine), 5 = phase countdown (+42) --
; expires (bit7 of +42 set) into state 2.
; .
; else (any other state, e.g. 3/8/9) falls straight into #R$9158 too, since
; only 0/7/5 are filtered out here.
; .
; State 7 homing: moves angular pos (+0) by speed (+54), then compares against
; player_col and the tower quadrant marks $3C/$78 to pick a chase direction (+2
; / -2), or deactivates.
; .
; In: nothing.
; .
; Loops B=4 objects.
; .
; Clobbers most regs + IX.
@label=update_enemies
c$90DA LD IX,$605B     ; IX -> object_table (enemy 0)
 $90DE LD B,$04        ; B = 4 enemies
; This entry point is used by the routine at #R$931F.
*$90E0 PUSH BC         ;
 $90E1 LD A,(IX+$30)   ; A = this enemy's state (+48)
 $90E4 CP $00          ;
 $90E6 JP Z,$931F      ; 0 = inactive -> next enemy
 $90E9 CP $07          ;
 $90EB JR NZ,$912C     ; state 7 = active/homing?
 $90ED LD (IX+$12),$4E ; set sprite id (+18) = $4E
 $90F1 LD A,(IX+$00)   ;
 $90F4 ADD A,(IX+$36)  ; angular pos (+0) += speed (+54)
 $90F7 LD (IX+$00),A   ;
 $90FA LD HL,$60A4     ; HL -> player_col
 $90FD BIT 7,(HL)      ; bit7 = which side of the tower the player is on
 $90FF JR NZ,$9111     ;
 $9101 CP $3C          ; at quadrant mark $3C?
 $9103 JR Z,$910B      ;
 $9105 CP $78          ;
 $9107 JR NZ,$9129     ;
 $9109 JR $9120        ;
*$910B LD (IX+$36),$02 ; chase: speed = +2 (toward player)
 $910F JR $9129        ;
*$9111 CP $3C          ;
 $9113 JR Z,$911A      ;
 $9115 OR A            ;
 $9116 JR NZ,$9129     ;
 $9118 JR $9120        ;
*$911A LD (IX+$36),$FE ; chase: speed = -2 ($FE)
 $911E JR $9129        ;
*$9120 LD (IX+$30),$00 ; off-screen/limit -> deactivate (state 0)
 $9124 LD A,$7D        ; flag $60A3 = $7D (respawn/notify)
 $9126 LD ($60A3),A    ;
*$9129 JP $931F        ;
*$912C CP $04          ; state 4?
 $912E JP Z,$9158      ;
 $9131 CP $06          ;
 $9133 JP Z,$9158      ;
 $9136 CP $05          ; state 5 = phase countdown
 $9138 JP NZ,$914B     ;
 $913B DEC (IX+$2A)    ; decrement phase (+42)
 $913E BIT 7,(IX+$2A)  ; phase underflowed (bit7 set) -> state=2
 $9142 JR Z,$9148      ;
 $9144 LD (IX+$30),$02 ;
*$9148 JP $931F        ;
*$914B CALL $934C      ; Check actor collision
 $914E JR NC,$9158     ;
 $9150 LD (IX+$30),$04 ; blocked -> force state=4, phase=0
 $9154 LD (IX+$2A),$00 ;

; Enemy state dispatch
;
; Used by the routine at #R$90DA.
;
; .
;
; Entry into the enemy's full movement/behaviour state machine, reached from
; update_enemies for states 4, 6, and the default case.
; .
; state==4 -> #R$9183 (idle/animate-in-place check). state==6 -> tests phase
; (+42): phase==6 means a pending transform is queued, jumps to enemy_transform
; (#R$9170) else falls into the shared idle-animation tail (enemy_idle_anim,
; #R$9191) with a mirrored phase.
; .
; Any other state falls through to #R$91A4 (enemy_move_dispatch2).
@label=enemy_move_dispatch
c$9158 LD A,(IX+$30) ; A = state (+48)
 $915B CP $04        ;
 $915D JR Z,$9183    ; state 4 -> #R$9183
 $915F CP $06        ; state 6?
 $9161 JR NZ,$91A4   ;
 $9163 LD A,(IX+$2A) ; A = phase (+42)
 $9166 CP $06        ; phase==6 -> pending transform
 $9168 JR Z,$9170    ;
 $916A NEG           ;
 $916C ADD A,$05     ;
 $916E JR $9191      ;

; Enemy transforms into queued next state
;
; Used by the routine at #R$9158.
;
; .
;
; Applies a queued state transform: copies the enemy's own +42/+3C fields into
; its live state (+48) and phase (+42), sets sprite id=$52.
; .
; This is how an enemy morphs into a different behaviour after a countdown
; (fields +42/+3C are pre-loaded elsewhere as the "next state/phase" to
; become).
@label=enemy_transform
c$9170 LD A,(IX+$42)   ;
 $9173 LD (IX+$30),A   ;
 $9176 LD A,(IX+$3C)   ;
 $9179 LD (IX+$2A),A   ;
 $917C LD (IX+$12),$52 ;
 $9180 JP $931F        ;

; Enemy idle: deactivate after full cycle
;
; Used by the routine at #R$9158.
;
; .
;
; state==4 path: if phase (+42) has reached 6, deactivates the enemy (state=0)
; else falls into enemy_idle_anim to keep cycling its idle sprite.
@label=enemy_idle_check
c$9183 LD A,(IX+$2A)   ;
 $9186 CP $06          ;
 $9188 JR NZ,$9191     ;
 $918A LD (IX+$30),$00 ;
 $918E JP $931F        ;

; Enemy idle animation cycle
;
; Used by the routines at #R$9158 and #R$9183.
;
; .
;
; Shared idle-animation tail for state 4 and the non-transform branch of state
; 6: clamps phase to 0..2 (wraps at 3), computes sprite id = phase*4+$5A,
; increments phase (+42), done.
@label=enemy_idle_anim
c$9191 CP $03        ; clamp phase to 0..2
 $9193 JR C,$9197    ;
 $9195 SUB $03       ;
*$9197 ADD A,A       ; {sprite id = phase*4 + $5A
 $9198 ADD A,A       ;
 $9199 ADD A,$5A     ;
 $919B LD (IX+$12),A ; }
 $919E INC (IX+$2A)  ; phase++
 $91A1 JP $931F      ;

; Enemy movement: pick vertical/horizontal/attack path
;
; Used by the routine at #R$9158.
;
; .
;
; Second dispatch tier, reached for any state other than 0/4/5/6/7.
; .
; state==3 -> #R$921D (enemy_post_move, shared attack/death dispatch). state==8
; -> #R$91AD (enemy_move_vertical). else -> #R$91F8 (enemy_move_horizontal, the
; default case covering states like 1/2/9 during normal movement).
@label=enemy_move_dispatch2
c$91A4 CP $03        ; state==3?
 $91A6 JP Z,$921D    ; -> enemy_post_move
 $91A9 CP $08        ; state==8?
 $91AB JR NZ,$91F8   ;

; Enemy moves vertically
;
; .
;
; .
;
; state 8: moves the enemy's 16-bit vertical position (+6/+12) by its signed
; speed (+54), backing up the old position in #R$6034 first.
; .
; Tests the new position via CHECK_ACTOR_COLLISION_A (#R$934C) and, if clear,
; CHECK_COLLISIONS against the player/other actors on-screen wraps checked via
; bit7 of the high byte (JP NZ,#R$9311 = out-of-bounds reset).
; .
; On a block, restores the previous position and reverses the speed sign
; (bounce).
; .
; Always ends by setting sprite id from the level number (#R$6039&3)*4+$66
; (level-tinted variant), then next enemy -- does not fall into
; enemy_post_move.
@label=enemy_move_vertical
c$91AD LD L,(IX+$06) ; {backup old position, add speed (16-bit)
 $91B0 LD H,(IX+$0C) ; }
 $91B3 LD ($6034),HL ;
 $91B6 LD E,(IX+$36) ;
 $91B9 BIT 7,E       ;
 $91BB LD D,$00      ;
 $91BD JR Z,$91C0    ;
 $91BF DEC D         ;
*$91C0 ADD HL,DE     ; {wrap-check: out of range -> #R$9311 (bounds reset)
 $91C1 BIT 7,H       ;
 $91C3 JP NZ,$9311   ; }
 $91C6 LD (IX+$06),L ;
 $91C9 LD A,H        ;
 $91CA AND $03       ;
 $91CC LD (IX+$0C),A ;
 $91CF CALL $934C    ; Check actor collision
 $91D2 JR C,$91D9    ;
 $91D4 CALL $95BD    ; Check collisions
 $91D7 JR NC,$91E9   ;
*$91D9 LD HL,($6034) ; {blocked: restore old position
 $91DC LD (IX+$06),L ;
 $91DF LD (IX+$0C),H ; }
 $91E2 XOR A         ; {reverse speed sign
 $91E3 SUB (IX+$36)  ;
 $91E6 LD (IX+$36),A ; }
; This entry point is used by the routine at #R$921D.
*$91E9 LD A,($6039)  ;
 $91EC AND $03       ;
 $91EE ADD A,A       ;
 $91EF ADD A,A       ;
 $91F0 ADD A,$66     ;
 $91F2 LD (IX+$12),A ;
 $91F5 JP $931F      ;

; Enemy moves horizontally (around tower)
;
; Used by the routine at #R$91A4.
;
; .
;
; Default movement case (any state not 3/4/5/6/7/8): moves the enemy's angular
; position (+0) by its signed speed (+54), mod 128, backing up the old value in
; #R$6033 first.
; .
; Same collision test/bounce pattern as enemy_move_vertical
; (CHECK_ACTOR_COLLISION_A then CHECK_COLLISIONS on clear on a block, restores
; old position and reverses speed).
; .
; Falls through into enemy_post_move (#R$921D), unlike enemy_move_vertical.
@label=enemy_move_horizontal
c$91F8 LD A,(IX+$00)  ; {backup old angular pos
 $91FB LD ($6033),A   ; }
 $91FE ADD A,(IX+$36) ; {add speed, wrap mod 128
 $9201 AND $7F        ;
 $9203 LD (IX+$00),A  ; }
 $9206 CALL $934C     ; Check actor collision
 $9209 JR C,$9210     ;
 $920B CALL $95BD     ; Check collisions
 $920E JR NC,$921D    ;
*$9210 LD A,($6033)   ; {blocked: restore old position, reverse speed
 $9213 LD (IX+$00),A  ;
 $9216 XOR A          ;
 $9217 SUB (IX+$36)   ; }
 $921A LD (IX+$36),A  ;

; Enemy post-move: hazard/attack dispatch
;
; Used by the routines at #R$91A4 and #R$91F8.
;
; .
;
; Shared post-movement dispatch: state==2 -> #R$92EC (enemy_hazard_react).
; state==9 -> $91E9 (just refresh the level-tinted sprite, no movement -- an
; inert/spawned variant).
; .
; Otherwise this is the attack-pattern driver: indexes a per-enemy step table
; at $90CE by phase (+42). A zero entry means no attack step due yet ->
; enemy_attack_cooldown (#R$92DC, phase++ up to $0A). A nonzero entry is a
; signed step consumed by enemy_attack_step (#R$9238) to chain a dash/charge
; move.
@label=enemy_post_move
c$921D LD A,(IX+$30) ; A = state (+48)
 $9220 CP $02        ; {state==2 -> enemy_hazard_react
 $9222 JP Z,$92EC    ; }
 $9225 CP $09        ; {state==9 -> refresh level-tinted sprite only
 $9227 JP Z,$91E9    ; }
 $922A LD E,(IX+$2A) ; {phase -> index into attack-step table $90CE
 $922D LD D,$00      ;
 $922F LD HL,$90CE   ;
 $9232 ADD HL,DE     ; }
 $9233 LD A,(HL)     ;
 $9234 OR A          ;
 $9235 JP Z,$92DC    ; entry==0 -> no attack step due, cooldown

; Enemy attack dash step
;
; .
;
; .
;
; One step of an attack dash/charge sequence, driven by the $90CE table entry
; for the current phase.
; .
; Applies the (sign-extended) step as a 16-bit delta to the enemy's vertical
; position (+6/+12), backing up the old value in #R$6034. Wrap past the tower
; bounds (bit7 of H) resets the enemy via #R$9311.
; .
; Tests the new position (CHECK_ACTOR_COLLISION_A then CHECK_COLLISIONS); on a
; block, restores the old position and falls to enemy_hazard_react (#R$92DC)
; instead of continuing the dash.
; .
; On success, re-examines the just-consumed table entry: $FF or $01 (a mid-dash
; unit step) loops back to consume the next table entry (re-enters at #R$9238)
; any other value (the dash's terminating marker) branches to either finish the
; attack (state==3 -> set state=2, phase=0) or fall to #R$928D to decide
; whether to trigger a fresh attack.
@label=enemy_attack_step
c$9238 LD ($90D9),A    ;
 $923B LD E,A          ;
 $923C ADD A,A         ;
 $923D SBC A,A         ;
 $923E LD D,A          ;
 $923F LD L,(IX+$06)   ;
 $9242 LD H,(IX+$0C)   ;
 $9245 LD ($6034),HL   ; backup old position (16-bit)
 $9248 ADD HL,DE       ;
 $9249 BIT 7,H         ;
 $924B JP NZ,$9311     ; wrap -> #R$9311 (bounds reset)
 $924E LD (IX+$06),L   ;
 $9251 LD A,H          ;
 $9252 AND $03         ;
 $9254 LD (IX+$0C),A   ;
 $9257 CALL $934C      ; Check actor collision
 $925A JR C,$9262      ;
 $925C CALL $95BD      ; Check collisions
 $925F JP NC,$92DC     ;
*$9262 LD HL,($6034)   ; {blocked: restore old position
 $9265 LD (IX+$06),L   ; }
 $9268 LD (IX+$0C),H   ;
 $926B LD A,($90D9)    ;
 $926E OR A            ;
 $926F JP M,$9278      ;
 $9272 DEC A           ;
 $9273 JR NZ,$9238     ;
 $9275 JP $92DC        ;
*$9278 INC A           ; {terminating step: A==1?
 $9279 JR NZ,$9238     ; }
 $927B LD A,(IX+$30)   ;
 $927E CP $03          ; {state==3 -> finish attack (state=2, phase=0)
 $9280 JR NZ,$928D     ;
 $9282 LD (IX+$30),$02 ; }
 $9286 LD (IX+$2A),$00 ;
 $928A JP $931F        ;

; Enemy checks whether to launch an attack
;
; Used by the routine at #R$9238.
;
; .
;
; End of a completed (or not-yet-started) attack cycle: only fires when the
; enemy is currently stationary (speed +54 == 0).
; .
; Requires $60C2 nonzero, player_state==0 (normal play), and the player's tower
; position to exactly match this enemy's (+6/+12) -- i.e. same column.
; .
; If so, computes the angular direction D (+1/-1) from tower_height to the
; enemy and, if the angular distance is under $20 (close enough), stores D into
