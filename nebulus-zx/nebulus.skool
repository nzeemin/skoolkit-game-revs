; Game entry
;
; .
;
; .
;
; Cold-start, reached from the resident loader.
; .
; The loader JP's here once the tape image is fully in RAM.
; .
; In:  nothing meaningful (IFF1=0, IM 1, SP still loader's).
; .
; Out: never returns -- falls through into the init chain and then the main
; game loop.
; .
; Side effects: installs private stack, blacks the border, runs three init
; subroutines, seeds game-state RAM.
@label=game_entry
c$8000 JP $8006      ; alignment trampoline -- skip 3 pad bytes (8003-8005)
 $8003 NOP           ;
@label=freeze_ctr
 $8004 NOP           ;
@label=pad_var_8005
 $8005 NOP           ;
@label=entry_setup
*$8006 LD SP,$5FFE   ; install game's private stack just under screen RAM
 $8009 XOR A         ; A = 0
 $800A OUT ($FE),A   ; ULA port FE: border=black(0), MIC/beeper off
 $800C CALL $83AD    ; Setup IM2
 $800F CALL $A772    ; init #2 = clear screen + game RAM (jp_clear_screen
                     ; trampoline)
 $8012 CALL $A71E    ; init #3 = paint playfield attributes (jp_setup_attrs
                     ; trampoline)
 $8015 LD A,$01      ; A = 1
 $8017 LD ($603F),A  ; first persistent-state write: running_flag = 1

; New game
;
; .
;
; .
;
; Set up a fresh game/level and run it.
; .
; Falls in from game_entry's init chain.
; .
; Seeds state vars, builds the level, draws the screen, then enters main_loop.
; .
; On death/level-end it loops back to level_retry or game-over handling.
@label=new_game
c$801A LD A,$80      ; A=$80 -> $6056 (start flag/counter)
 $801C LD ($6056),A  ;
 $801F XOR A         ;
 $8020 LD ($60D7),A  ; set Control-key toggle flag
 $8023 LD ($8005),A  ;
 $8026 LD A,$04      ; 4 attempts/lives -> #R$6017
 $8028 LD ($6017),A  ; set Game mode

; Level entry
;
; Used by the routine at #R$8115.
@label=level_retry
c$802B XOR A         ;
 $802C LD ($60D8),A  ; set Demo/pause mode flag
 $802F CALL $9B8A    ; Title menu
; This entry point is used by the routine at #R$8115.
*$8032 CALL $8305    ; Init col state
 $8035 CALL $A721    ; proc_table slot: build tower / level layout
 $8038 LD A,$01      ;
 $803A LD ($6040),A  ; set Lives
; This entry point is used by the routine at #R$8064.
*$803D CALL $8311    ; Restore col state
 $8040 PUSH AF       ;
 $8041 CALL $A72A    ;
 $8044 POP AF        ;
 $8045 JR NC,$802B   ; carry clear -> rebuild (retry)
; This entry point is used by the routine at #R$8064.
*$8047 CALL $A733    ;
 $804A CALL $A739    ;
 $804D CALL $A724    ;
 $8050 CALL $9963    ; Show level intro
 $8053 XOR A         ;
 $8054 LD ($60C3),A  ; set Player died this frame
 $8057 DEC A         ;
 $8058 LD ($6055),A  ; set Level timer prescaler
 $805B CALL $A778    ;
 $805E CALL $81D7    ; Setup level
 $8061 CALL $A36D    ; Stop sound

; Main loop
;
; .
;
; .
;
; The in-play frame loop.
; .
; Each pass runs main_tick (one frame) then checks end conditions: death_flag
; (#R$60C3) set      -> life-loss handler ($8084) game_state (#R$60D9) == 2
; -> level-complete ($80B2) play_timer (#R$6053) == 0     -> time-up ($8081)
; Otherwise CALL #R$8115 (status update) and loop.
@label=main_loop
c$8064 CALL $8240    ; run one frame of the game
 $8067 LD A,($60C3)  ; player died this frame?
 $806A OR A          ;
 $806B JR NZ,$8084   ; yes -> life-loss handler
 $806D LD A,($60D9)  ; level-complete state?
 $8070 CP $02        ;
 $8072 JR Z,$80B2    ; yes -> level-complete handler
 $8074 LD HL,($6053) ; play_timer reached 0?
 $8077 LD A,H        ;
 $8078 OR L          ;
 $8079 JR Z,$8081    ; yes -> time-up
 $807B CALL $8115    ; Poll controls
 $807E JP $8064      ; loop
*$8081 CALL $99CE    ; Draw timeup screen
@label=on_death
*$8084 LD A,$FF      ;
 $8086 LD ($6055),A  ; set Level timer prescaler
 $8089 LD A,($60D7)  ; get Control-key toggle flag
 $808C OR A          ;
 $808D JR NZ,$80A3   ;
 $808F LD HL,$6041   ;
 $8092 LD A,($6040)  ; get Lives
 $8095 OR A          ;
 $8096 JR Z,$8099    ;
 $8098 INC HL        ;
*$8099 DEC (HL)      ;
 $809A PUSH HL       ;
 $809B CALL $A724    ;
 $809E POP HL        ;
 $809F LD A,(HL)     ;
 $80A0 OR A          ;
 $80A1 JR Z,$80A9    ;
*$80A3 CALL $8360    ; Pack col state
 $80A6 JP $803D      ;
*$80A9 CALL $8382    ; Clear col mask
 $80AC CALL $99A1    ; Draw info screen a
 $80AF JP $803D      ;
@label=on_level_done
*$80B2 LD A,$FF      ;
 $80B4 LD ($6055),A  ; set Level timer prescaler
 $80B7 LD A,($60B9)  ; get Tower rotation position
 $80BA PUSH AF       ;
 $80BB LD HL,($60BA) ;
 $80BE PUSH HL       ;
 $80BF LD HL,($6030) ; get Vertical scroll position
 $80C2 PUSH HL       ;
 $80C3 CALL $9A23    ; Screen time bonus
 $80C6 CALL $A778    ;
 $80C9 LD A,$03      ;
 $80CB LD ($60D9),A  ; set Game state
 $80CE CALL $81D7    ; Setup level
 $80D1 POP HL        ;
 $80D2 LD ($6030),HL ; set Vertical scroll position
 $80D5 POP HL        ;
 $80D6 LD ($60BA),HL ;
 $80D9 POP AF        ;
 $80DA LD ($60B9),A  ; set Tower rotation position
 $80DD LD A,$04      ;
 $80DF LD ($60C0),A  ; set Player state-machine state
 $80E2 LD A,$1D      ;
 $80E4 LD ($60BF),A  ; set Player state-machine phase/height window
 $80E7 XOR A         ;
 $80E8 LD ($60C2),A  ;
*$80EB CALL $8240    ; Main tick
 $80EE CALL $8115    ; Poll controls
 $80F1 LD A,($60D9)  ; get Game state
 $80F4 CP $04        ;
 $80F6 JR NZ,$80EB   ;
 $80F8 XOR A         ;
 $80F9 LD ($60D9),A  ; set Game state
 $80FC CALL $8390    ; Advance col counter
 $80FF CP $08        ;
 $8101 JR NZ,$810C   ;
 $8103 CALL $8382    ; Clear col mask
 $8106 CALL $99F0    ; Draw info screen b
 $8109 JP $803D      ;
*$810C CALL $8360    ; Pack col state
 $810F CALL $A72A    ;
 $8112 JP $8047      ;

; Poll controls
;
; Used by the routine at #R$8064.
;
; .
;
; Per-frame keyboard handling (called from main_loop).
; .
; Skipped while input is frozen (freeze_ctr).
; .
; - restart key (via $A70F): NC -> jump to level_retry
; .
; - several control keys toggle ctrl_flag (#R$60D7) / pad_var_8005
; .
; - PAUSE/DEMO: key $21 enters demo_pause any joystick X exits
; .
; - menu select: tests a column of 8 keys the index of the one pressed (0..7)
; -> pad_var_8005, then restarts setup at $8032.
; .
; Uses test_key ($A706) for t
@label=poll_controls
c$8115 LD A,($8004)  ; A = freeze_ctr
 $8118 OR A          ;
 $8119 RET NZ        ; frozen -> do nothing this frame
 $811A CALL $A70F    ;
 $811D JP NC,$802B   ; restart condition -> rebuild level
 $8120 LD A,$27      ;
 $8122 CALL $A706    ;
 $8125 JR Z,$813A    ;
 $8127 LD A,$08      ;
 $8129 CALL $A706    ;
 $812C JR Z,$813A    ;
 $812E LD A,$15      ;
 $8130 CALL $A706    ;
 $8133 JR Z,$813A    ;
 $8135 LD A,$01      ;
 $8137 LD ($60D7),A  ; set ctrl_flag (#R$60D7) = 1
*$813A LD A,$20      ;
 $813C CALL $A706    ;
 $813F JR Z,$8148    ;
 $8141 XOR A         ;
 $8142 LD ($60D7),A  ; set Control-key toggle flag
 $8145 LD ($8005),A  ;
*$8148 LD A,($60D8)  ; A = demo_pause
