; CLEAR_SCREEN -- cold wipe before the title/play screen draws.
;
; Used by the routine at #R$A772.
;
; .
;
; 1) zero game RAM $6000..$61FF (512 bytes, 2 pages).
; .
; 2) zero the entire display $4000..$5AFF (pixels+attrs) via LDIR.
; .
; 3) CALL $B567 (build a lookup table in the reclaimed printer buffer $5B00)
; and $B5EA.
; .
; In: nothing.
; .
; Out: screen+vars cleared.
; .
; Clobbers: A,BC,DE,HL.
; .
; i8080 PORT: LDIR is a Z80 block fill -- expand to an explicit DCR/JNZ store
; loop.
; .
; The $6000 clear uses INC L / INC H pagi
@label=clear_screen
c$B546 LD HL,$6000   ; HL -> game RAM base $6000
 $B549 LD B,$02      ; B = 2 pages to clear
*$B54B LD (HL),$00   ; store 0
 $B54D INC L         ;
 $B54E JR NZ,$B54B   ; loop 256 bytes of this page
 $B550 INC H         ; next page
 $B551 DJNZ $B54B    ;
 $B553 LD HL,$4000   ; HL -> screen base $4000
 $B556 LD DE,$4001   ; DE -> $4001 (LDIR src=HL, dst=DE, overlap fill)
 $B559 LD BC,$1AFF   ; BC = $1AFF = 6911 bytes = whole display minus 1
 $B55C LD (HL),$00   ; seed first byte = 0
 $B55E LDIR          ; LDIR: propagate 0 across $4000..$5AFF (Z80 block op)
 $B560 CALL $B567    ; build pixel/attr lookup table in $5B00
 $B563 CALL $B5EA    ;
 $B566 RET           ;

; BUILD_SCREEN_HI_LUT -- fill a 256-byte table at $5B00 mapping a byte value to
; its bit-reordered form used in ZX screen-address math.
;
; Used by the routines at #R$A772 and #R$B546.
;
; .
;
; Processes the index in 2-bit groups groups 00 and 11 pass through, 01/10 get
; +$40 -- the Y2<->Y0 swap that makes the ZX pixel rows non-linear.
; .
; Result accumulates in H.
; .
; i8080 PORT: the Specialist framebuffer is LINEAR -- this whole table
; collapses to identity.
; .
; The porter can DELETE this and the $5B00 lookups, replac
@label=build_screen_hi_lut
c$B567 LD DE,$5B00   ; DE -> $5B00 LUT base (reclaimed printer buffer)
*$B56A LD C,E        ; C = current index (low byte of DE)
 $B56B LD B,$04      ; B = 4 groups of 2 bits
*$B56D LD A,C        ;
 $B56E AND $C0       ; isolate the top 2-bit group
 $B570 JR Z,$B578    ; 00 -> pass through
 $B572 CP $C0        ;
 $B574 JR Z,$B578    ; 11 -> pass through
 $B576 ADD A,$40     ; 01/10 -> +$40 (the scan-order bit swap)
*$B578 LD L,A        ;
 $B579 ADD HL,HL     ; HL <<= 2 (accumulate this group)
 $B57A ADD HL,HL     ;
 $B57B SLA C         ; shift C left 2 to expose next group (Z80 SLA)
 $B57D SLA C         ;
 $B57F DJNZ $B56D    ;
 $B581 LD A,H        ;
 $B582 LD (DE),A     ; store H as LUT[index]
 $B583 INC E         ;
 $B584 JR NZ,$B56A   ; loop all 256 entries (E wraps to 0)
 $B586 RET           ;

; Routine at B587
;
; Used by the routine at #R$A778.
@label=clear_playfield
c$B587 LD C,$20      ;
*$B589 LD A,C        ; compute screen-addr high byte from row index
 $B58A RRA           ;
 $B58B RRA           ;
 $B58C RRA           ;
 $B58D AND $18       ;
 $B58F OR $40        ;
 $B591 LD H,A        ;
 $B592 LD A,C        ;
 $B593 AND $07       ;
 $B595 ADD A,H       ;
 $B596 LD H,A        ;
 $B597 LD A,C        ;
 $B598 RLA           ;
 $B599 RLA           ;
 $B59A AND $E0       ;
 $B59C LD L,A        ;
 $B59D LD B,$20      ;
*$B59F LD (HL),$00   ; zero 32 pixel bytes of this row
 $B5A1 INC HL        ;
 $B5A2 DJNZ $B59F    ;
 $B5A4 INC C         ;
 $B5A5 LD A,C        ;
 $B5A6 CP $B8        ; stop at row $B8
 $B5A8 JR NZ,$B589   ;
 $B5AA LD HL,$5860   ;
 $B5AD LD DE,$5861   ;
 $B5B0 LD BC,$0020   ;
 $B5B3 LD (HL),$00   ;
 $B5B5 LDIR          ; LDIR: clear an attribute strip (Z80 block op)
 $B5B7 LD BC,$025F   ;
 $B5BA CALL $BA16    ;
 $B5BD LD (HL),A     ;
 $B5BE LDIR          ;
 $B5C0 LD BC,$0020   ;
 $B5C3 LD (HL),$00   ;
 $B5C5 LDIR          ;
 $B5C7 RET           ;

