; Load level col
;
; Used by the routine at #R$A700.
;
; .
;
; Fetch column descriptor #R$6039 from the column-major table at #R$7A00
; (stride 8): low byte (+0) and high byte (+8) form a pointer (offset by
; #R$6A00 into level data), and the property byte (+16) is stashed in $603A.
; .
; Cell byte format for the map this fills: docs/Level-Format.md.
; .
; Returns IX=pointer.
; .
; Clobbers: A,BC,DE,HL,IX.
@label=load_level_col
c$B346 LD A,($6039)  ;
 $B349 LD C,A        ;
 $B34A ADD A,A       ;
 $B34B ADD A,$6A     ;
 $B34D LD D,A        ;
 $B34E LD E,$00      ;
 $B350 LD B,$00      ;
 $B352 LD IX,$7A00   ;
 $B356 ADD IX,BC     ;
 $B358 LD L,(IX+$00) ;
 $B35B LD H,(IX+$08) ;
 $B35E LD BC,$6A00   ;
 $B361 ADD HL,BC     ;
 $B362 LD A,(IX+$10) ;
 $B365 LD ($603A),A  ;
 $B368 PUSH HL       ;
 $B369 POP IX        ;
 $B36B LD C,A        ;
 $B36C LD HL,$F000   ;
*$B36F CALL $B382    ; Blit masked column
 $B372 CALL $B382    ; Blit masked column
 $B375 LD H,$F0      ;
 $B377 INC L         ;
 $B378 DEC C         ;
 $B379 JR NZ,$B36F   ;
 $B37B LD HL,$F000   ;
 $B37E LD ($6015),HL ; set Unknown word
 $B381 RET           ;

; Blit masked column
;
; Used by the routine at #R$B346.
;
; .
;
; Draw an 8-pixel-tall column at HL: for each set bit of the mask byte at (DE),
; store the next source byte (IX++) and step down one pixel row (INC H) skip
; rows whose mask bit is 0.
; .
; In: DE=mask ptr, IX=pixels, HL=screen.
; .
; Clobbers: A,B,HL,IX.
@label=blit_masked_column
c$B382 LD A,(DE)     ;
 $B383 INC DE        ;
 $B384 LD B,$08      ;
*$B386 RRA           ;
 $B387 JR NC,$B391   ;
 $B389 PUSH AF       ;
 $B38A LD A,(IX+$00) ;
 $B38D INC IX        ;
 $B38F LD (HL),A     ;
 $B390 POP AF        ;
*$B391 INC H         ;
 $B392 DJNZ $B386    ;
 $B394 RET           ;

; Alloc object slot
;
; Used by the routine at #R$A700.
;
; .
;
; Find a free entry (marker $FF at +0) in the 4-slot active-object table at
; $60A9.
; .
; On success store its type ($7D), source pointer (HL) and a copied data byte,
; set CY, RET.
; .
; In: HL=source.
; .
; Out: CY=allocated.
; .
; Clobbers: A,B,IX.
@label=alloc_object_slot
c$B395 LD IX,$60A9     ;
 $B399 LD B,$04        ;
*$B39B LD A,(IX+$00)   ;
 $B39E CP $FF          ;
 $B3A0 JR NZ,$B3B9     ;
 $B3A2 LD A,(HL)       ;
 $B3A3 AND $0C         ;
 $B3A5 CP $04          ;
 $B3A7 JR Z,$B3BD      ;
 $B3A9 LD A,(HL)       ;
 $B3AA LD (IX+$0C),A   ;
 $B3AD LD (IX+$04),L   ;
 $B3B0 LD (IX+$08),H   ;
 $B3B3 LD (IX+$00),$7D ;
 $B3B7 SCF             ;
 $B3B8 RET             ;
*$B3B9 INC IX          ;
 $B3BB DJNZ $B39B      ;
*$B3BD OR A            ;
 $B3BE RET             ;

; Update object slots
;
; Used by the routine at #R$A700.
;
; .
;
; Tick the 4-entry active-object table at $60A9 (counterpart to
; alloc_object_slot).
; .
; For each slot: $FF=free (skip), >1 = decrement its countdown, and on expiry
; write the stored byte back through its screen pointer (erase the object).
; .
; Clobbers: A,B,HL,IX.
@label=update_object_slots
c$B3BF LD IX,$60A9     ; {IX -> active-object table ($60A9), B=4 slots
 $B3C3 LD B,$04        ; }
*$B3C5 LD A,(IX+$00)   ; {A = this slot's countdown
 $B3C8 OR A            ; }
 $B3C9 JR Z,$B3D4      ; zero -> expired, handle it
 $B3CB CP $FF          ; {$FF -> free slot, skip
 $B3CD JR Z,$B3F9      ; }
 $B3CF DEC (IX+$00)    ; {else: decrement countdown, next slot
 $B3D2 JR $B3F9        ; }
*$B3D4 LD L,(IX+$04)   ; {expired: HL -> stored screen pointer
 $B3D7 LD H,(IX+$08)   ;
 $B3DA LD A,(IX+$0C)   ; }
 $B3DD AND $0C         ;
 $B3DF LD (HL),A       ;
 $B3E0 DEC L           ;
 $B3E1 DEC (IX+$04)    ;
 $B3E4 LD A,(HL)       ;
 $B3E5 LD (IX+$0C),A   ;
 $B3E8 AND $0C         ;
 $B3EA CP $04          ;
 $B3EC JR Z,$B3F3      ;
 $B3EE LD (HL),$8D     ;
 $B3F0 JP $B3F9        ;
*$B3F3 LD (HL),$85     ;
 $B3F5 LD (IX+$00),$FF ;
*$B3F9 INC IX          ; {next slot, loop 4
 $B3FB DJNZ $B3C5      ; }
 $B3FD RET             ;

; Free object slot
;
; Used by the routine at #R$A700.
;
; .
;
; Mark the $60A9 slot whose stored pointer equals HL as free (set +0 = $FF).
; .
; In: HL=pointer.
; .
; Clobbers: A,B,IX.
@label=free_object_slot
c$B3FE LD IX,$60A9     ;
 $B402 LD B,$04        ;
*$B404 LD A,(IX+$00)   ;
 $B407 CP $FF          ;
 $B409 JR Z,$B41C      ;
 $B40B LD A,L          ;
 $B40C CP (IX+$04)     ;
 $B40F JR NZ,$B41C     ;
 $B411 LD A,H          ;
 $B412 CP (IX+$08)     ;
 $B415 JR NZ,$B41C     ;
 $B417 LD (IX+$00),$FF ;
 $B41B RET             ;
*$B41C INC IX          ;
 $B41E DJNZ $B404      ;
 $B420 RET             ;

; Update actors
;
; Used by the routine at #R$A700.
;
; .
;
; Per-frame actor pass (proc_table slot A76F).
; .
; Skips when player_state is 8/9 (level-end).
; .
; Derives the camera row #R$6036 from $6059, then walks the 4 object_table
; actors, acting on each live one (state field IX+48 != 0).
; .
; Clobbers: A,B,HL,IX.
@label=update_actors
c$B421 LD A,($60C0)    ; {skip if player_state 8 or 9 (level-end)
 $B424 CP $08          ;
 $B426 RET Z           ;
 $B427 CP $09          ;
 $B429 RET Z           ; }
 $B42A LD HL,($6059)   ; {camera row = ($6059)>>2 (RR chain)
 $B42D LD A,L          ;
 $B42E RR H            ;
 $B430 RRA             ;
 $B431 RR H            ;
 $B433 RRA             ; }
 $B434 LD ($6036),A    ; set Camera row
 $B437 LD IX,$605B     ; {find first active actor (state!=0) in object_table
 $B43B LD B,$04        ;
*$B43D LD A,(IX+$30)   ;
 $B440 CP $00          ;
 $B442 JR Z,$B449      ;
 $B444 INC IX          ;
 $B446 DJNZ $B43D      ;
 $B448 RET             ; }
*$B449 LD HL,($6015)   ; get Unknown word
 $B44C LD A,($603A)    ; {already aligned to camera row? -> spawn dispatch
 $B44F CP L            ; ($B512)}
 $B450 JP Z,$B512      ;
 $B453 LD A,($6036)    ; get Camera row
 $B456 CP L            ;
 $B457 JP Z,$B512      ;
 $B45A JP C,$B512      ;
*$B45D LD A,(HL)       ; {test cell flags at HL: special/type check
 $B45E OR A            ;
 $B45F JP M,$B466      ;
 $B462 AND $70         ;
 $B464 JR NZ,$B478     ; }
*$B466 LD A,H          ; {step #R$6015 high nibble toward $F0..$FF ring, wrap
 $B467 SUB $F0         ;
 $B469 INC A           ;
 $B46A AND $0F         ;
 $B46C ADD A,$F0       ;
 $B46E LD H,A          ;
 $B46F CP $F0          ;
 $B471 JR NZ,$B45D     ;
 $B473 INC L           ; }
 $B474 LD ($6015),HL   ; set Unknown word
 $B477 RET             ;
*$B478 LD ($6015),HL   ; set Unknown word
 $B47B LD A,(HL)       ;
 $B47C PUSH AF         ;
 $B47D PUSH HL         ;
 $B47E LD A,H          ;
 $B47F SUB $F0         ;
 $B481 INC A           ;
 $B482 AND $0F         ;
 $B484 ADD A,$F0       ;
 $B486 LD H,A          ;
 $B487 CP $F0          ;
 $B489 JR NZ,$B48C     ;
 $B48B INC L           ;
*$B48C LD ($6015),HL   ; set Unknown word
 $B48F POP HL          ;
 $B490 POP AF          ;
 $B491 AND $70         ; {classify flag bits ($70 mask)
 $B493 CP $10          ;
 $B495 JR Z,$B4E0      ; }
 $B497 CP $60          ; {bit pattern $60? branch
 $B499 JR NC,$B4CB     ; }
 $B49B CP $40          ; {bit pattern $40? branch
 $B49D JR NC,$B4B6     ; }
 $B49F CP $20          ; {bit $20 exact? set speed=1 else 0
 $B4A1 JR Z,$B4A6      ;
 $B4A3 XOR A           ;
 $B4A4 JR $B4A8        ;
*$B4A6 LD A,$01        ; }
*$B4A8 LD (IX+$36),A   ; {speed/phase/pattern = 0/1/0 (idle-ish spawn)
 $B4AB LD (IX+$42),$01 ;
 $B4AF LD (IX+$3C),$00 ; }
 $B4B3 JP $B4ED        ;
*$B4B6 AND $10         ; {speed=1or2, phase=8, pattern=0 (variant B)
 $B4B8 JR Z,$B4BC      ;
 $B4BA LD A,$01        ;
*$B4BC INC A           ;
 $B4BD LD (IX+$36),A   ; }
 $B4C0 LD (IX+$42),$08 ;
 $B4C4 LD (IX+$3C),$00 ;
 $B4C8 JP $B4ED        ;
*$B4CB AND $10         ; {speed=1or2, phase=9, pattern=0 (variant C)
 $B4CD JR Z,$B4D1      ;
 $B4CF LD A,$01        ;
*$B4D1 INC A           ;
 $B4D2 LD (IX+$36),A   ; }
 $B4D5 LD (IX+$42),$09 ;
 $B4D9 LD (IX+$3C),$00 ;
 $B4DD JP $B4ED        ;
*$B4E0 LD A,$01        ; {speed=1, phase=2, pattern=0 (variant D)
 $B4E2 LD (IX+$36),A   ;
 $B4E5 LD (IX+$42),$02 ; }
 $B4E9 LD (IX+$3C),$00 ;
*$B4ED LD A,H          ; {compute angular pos from row (H-$F0)*8+4
 $B4EE SUB $F0         ;
 $B4F0 ADD A,A         ;
 $B4F1 ADD A,A         ;
 $B4F2 ADD A,A         ;
 $B4F3 ADD A,$04       ;
 $B4F5 AND $7F         ; }
 $B4F7 LD (IX+$00),A   ;
 $B4FA XOR A           ; {compute position (IX+6/+12) via rotate-left pack
 $B4FB RL L            ;
 $B4FD RL A            ;
 $B4FF RL L            ;
 $B501 RL A            ; }
 $B503 LD (IX+$06),L   ;
 $B506 LD (IX+$0C),A   ;
 $B509 LD (IX+$30),$06 ; activate: state=6, phase=0
 $B50D LD (IX+$2A),$00 ;
 $B511 RET             ;
*$B512 LD A,($60A3)    ; {$60A3 flag: pending single-shot spawn?
 $B515 CP $FF          ;
 $B517 RET Z           ;
 $B518 DEC A           ; }
 $B519 LD ($60A3),A    ;
 $B51C CP $FF          ;
 $B51E RET NZ          ;
 $B51F LD (IX+$30),$07 ; {activate as state 7 (wall marker), reset phase
 $B523 LD (IX+$2A),$00 ; }
 $B527 LD A,($60A4)    ; get Player's current column
 $B52A NEG             ;
 $B52C LD ($60A4),A    ; set Player's current column
 $B52F LD (IX+$36),A   ;
 $B532 ADD A,A         ; {derive angular pos 0/$78 from sign
 $B533 LD A,$00        ;
 $B535 JR NC,$B539     ;
 $B537 LD A,$78        ; }
*$B539 LD (IX+$00),A   ; {store position (IX+0/+6/+12) from player position
 $B53C LD HL,($60BA)   ;
 $B53F LD (IX+$06),L   ;
 $B542 LD (IX+$0C),H   ;
 $B545 RET             ; }

; Clear screen
;
; Used by the routine at #R$A700.
;
; .
;
; Cold wipe before the title/play screen draws.
; .
; 1) zero game RAM #R$6000..$61FF (512 bytes, 2 pages).
; .
; 2) zero the entire display $4000..$5AFF (pixels+attrs) via LDIR.
; .
; 3) CALL #R$B567 (build a lookup table in the reclaimed printer buffer
; #R$5B00) and #R$B5EA.
; .
; Clobbers: A,BC,DE,HL.
@label=clear_screen
c$B546 LD HL,$6000   ; HL -> game RAM base #R$6000
 $B549 LD B,$02      ; B = 2 pages to clear
*$B54B LD (HL),$00   ; store 0
 $B54D INC L         ;
 $B54E JR NZ,$B54B   ; loop 256 bytes of this page
 $B550 INC H         ; next page
 $B551 DJNZ $B54B    ;
 $B553 LD HL,$4000   ; HL -> screen base $4000
 $B556 LD DE,$4001   ; DE -> $4001 (LDIR src=HL, dst=DE, overlap fill)
 $B559 LD BC,$1AFF   ; BC = $1AFF = 6911 bytes = whole display minus 1
 $B55C LD (HL),$00   ; seed first byte = 0
 $B55E LDIR          ; LDIR: propagate 0 across $4000..$5AFF
 $B560 CALL $B567    ; Build screen hi LUT
 $B563 CALL $B5EA    ; Build row addr table
 $B566 RET           ;

; Build screen hi LUT
;
; Used by the routines at #R$A700 and #R$B546.
;
; .
;
; Fill a 256-byte table at #R$5B00 mapping a byte value to its bit-reordered
; form used in ZX screen-address math.
; .
; Processes the index in 2-bit groups groups 00 and 11 pass through, 01/10 get
; +$40 -- the Y2<->Y0 swap that makes the ZX pixel rows non-linear.
; .
; Result accumulates in H.
; .
; The porter can DELETE this and the #R$5B00 lookups, replac
@label=build_screen_hi_lut
c$B567 LD DE,$5B00   ; DE -> #R$5B00 LUT base (reclaimed printer buffer)
*$B56A LD C,E        ; C = current index (low byte of DE)
 $B56B LD B,$04      ; B = 4 groups of 2 bits
*$B56D LD A,C        ;
 $B56E AND $C0       ; isolate the top 2-bit group
 $B570 JR Z,$B578    ; 00 -> pass through
 $B572 CP $C0        ;
 $B574 JR Z,$B578    ; 11 -> pass through
 $B576 ADD A,$40     ; 01/10 -> +$40 (the scan-order bit swap)
*$B578 LD L,A        ;
 $B579 ADD HL,HL     ; HL <<= 2 (accumulate this group)
 $B57A ADD HL,HL     ;
 $B57B SLA C         ; shift C left 2 to expose next group (Z80 SLA)
 $B57D SLA C         ;
 $B57F DJNZ $B56D    ;
 $B581 LD A,H        ;
 $B582 LD (DE),A     ; store H as LUT[index]
 $B583 INC E         ;
 $B584 JR NZ,$B56A   ; loop all 256 entries (E wraps to 0)
 $B586 RET           ;

; Routine at B587
;
; Used by the routine at #R$A700.
@label=clear_playfield
c$B587 LD C,$20      ;
*$B589 LD A,C        ; compute screen-addr high byte from row index
 $B58A RRA           ;
 $B58B RRA           ;
 $B58C RRA           ;
 $B58D AND $18       ;
 $B58F OR $40        ;
 $B591 LD H,A        ;
 $B592 LD A,C        ;
 $B593 AND $07       ;
 $B595 ADD A,H       ;
 $B596 LD H,A        ;
 $B597 LD A,C        ;
 $B598 RLA           ;
 $B599 RLA           ;
 $B59A AND $E0       ;
 $B59C LD L,A        ;
 $B59D LD B,$20      ;
*$B59F LD (HL),$00   ; zero 32 pixel bytes of this row
 $B5A1 INC HL        ;
 $B5A2 DJNZ $B59F    ;
 $B5A4 INC C         ;
 $B5A5 LD A,C        ;
 $B5A6 CP $B8        ; stop at row $B8
 $B5A8 JR NZ,$B589   ;
 $B5AA LD HL,$5860   ;
 $B5AD LD DE,$5861   ;
 $B5B0 LD BC,$0020   ;
 $B5B3 LD (HL),$00   ;
 $B5B5 LDIR          ; LDIR: clear an attribute strip
 $B5B7 LD BC,$025F   ;
 $B5BA CALL $BA16    ;
 $B5BD LD (HL),A     ;
 $B5BE LDIR          ;
 $B5C0 LD BC,$0020   ;
 $B5C3 LD (HL),$00   ;
 $B5C5 LDIR          ;
 $B5C7 RET           ;

; Routine at B5C8
;
; Used by the routine at #R$A700.
@label=hook_noop
c$B5C8 RET           ;
 $B5C9 NOP           ;
 $B5CA NOP           ;
@label=flag_b5cb
 $B5CB DEFB $00      ;
 $B5CC DEFB $00,$00  ;
 $B5CE DEFB $00      ;

; Routine at B5CF
;
; Used by the routine at #R$A700.
@label=init_b5cf
c$B5CF LD A,$FF      ;
 $B5D1 LD ($6038),A  ; set Flag?? $00 $FE $FF
 $B5D4 XOR A         ;
 $B5D5 LD ($B5CB),A  ; zero flag_b5cb at #R$B5CB (write into code padding)
 $B5D8 RET           ;

; Get screen addr
;
; Used by the routines at #R$A700, #R$AC5E, #R$B636, #R$B74D, #R$B8A8, #R$B965
; and #R$B9D6.
;
; .
;
; Pixel address for (row=H, col-in-row=L).
; .
; Indexes scr_row_addr_tbl (#R$5D00, 2 bytes/row) at 2*H to fetch the row base,
; then adds L to get the final byte address in HL.
; .
; In: H=row 0..191, L=byte offset within row.
; .
; Out: HL=screen addr.
; .
; Clobbers A preserves DE.
@label=get_screen_addr
c$B5D9 PUSH DE       ;
 $B5DA LD D,L        ;
 $B5DB LD A,H        ;
 $B5DC ADD A,A       ; L = 2*H = table index
 $B5DD LD L,A        ;
 $B5DE LD A,$5D      ; H = $5D + carry -> HL -> scr_row_addr_tbl[H]
 $B5E0 ADC A,$00     ;
 $B5E2 LD H,A        ;
 $B5E3 LD A,D        ;
 $B5E4 ADD A,(HL)    ; A = row base low + col offset
 $B5E5 INC L         ;
 $B5E6 LD H,(HL)     ; H = row base high
 $B5E7 LD L,A        ;
 $B5E8 POP DE        ;
 $B5E9 RET           ;

; Build row addr table
;
; Used by the routine at #R$B546.
;
; .
;
; Precompute 192 screen-row addresses into scr_row_addr_tbl (#R$5D00,
; little-endian words).
; .
; For each row y in 0..191 it builds the ZX pixel address:
; .
; high = $40 | (y&7) | ((y>>3)&$18)
; .
; low  = (y&$38)<<2 i.e.
; .
; the famous ZX scan-order layout (Y bits split across the address).
; .
; get_screen_addr then just indexes this table.
@label=build_row_addr_table
c$B5EA LD DE,$5D00   ; DE -> #R$5D00 table base
 $B5ED LD HL,$0000   ; HL: H = row counter y, builds address in HL
*$B5F0 PUSH HL       ;
 $B5F1 PUSH DE       ;
 $B5F2 LD A,H        ; (y>>3)&$18  -> D (the y bits 3..5 region)
 $B5F3 RRCA          ;
 $B5F4 RRCA          ;
 $B5F5 RRCA          ;
 $B5F6 AND $18       ;
 $B5F8 LD D,A        ;
 $B5F9 LD A,H        ;
 $B5FA AND $07       ;
 $B5FC ADD A,D       ; + (y&7) + $40 -> high byte
 $B5FD ADD A,$40     ;
 $B5FF LD D,A        ;
 $B600 LD A,H        ;
 $B601 RLC A         ; (y<<2)&$E0 -> low byte (E)
 $B603 RLC A         ;
 $B605 AND $E0       ;
 $B607 LD E,A        ;
 $B608 LD H,$00      ;
 $B60A ADD HL,DE     ; HL = full row-0 screen address
 $B60B POP DE        ;
 $B60C LD A,L        ;
 $B60D LD (DE),A     ; store LE word into table[y]
 $B60E INC DE        ;
 $B60F LD A,H        ;
 $B610 LD (DE),A     ;
 $B611 INC DE        ;
 $B612 POP HL        ;
 $B613 INC H         ;
 $B614 LD A,H        ;
 $B615 CP $C0        ; stop after row $BF (192 rows)
 $B617 JP NZ,$B5F0   ;
 $B61A RET           ;

; Get sprite def
;
; Used by the routines at #R$A700, #R$B636 and #R$B74D.
;
; .
;
; Look up sprite/graphic descriptor A in the #R$C100 table (A*2): unpack the
; frame count (top 2 bits, 0->4) into C and the bitmap pointer (low 6 bits +
; $C1xx base) into HL.
; .
; In: A=sprite id.
; .
; Out: HL=bitmap, C=frames.
; .
; Clobbers: A,HL.
@label=get_sprite_def
c$B61B ADD A,A       ; Sprite ID to word index
 $B61C LD L,A        ;
 $B61D LD H,$00      ;
 $B61F LD DE,$C101   ; Point to sprite offsets table (#R$C100)
 $B622 ADD HL,DE     ;
 $B623 LD A,(HL)     ; Descriptor: top 2 bits = frame count, low 6 bits =
                     ; offset
 $B624 RLCA          ;
 $B625 RLCA          ;
 $B626 AND $03       ; Extract frame count into C (0-3)
 $B628 LD C,A        ;
 $B629 JR NZ,$B62D   ;
 $B62B LD C,$04      ; Default to 4 frames if count is zero
*$B62D LD A,(HL)     ;
 $B62E AND $3F       ; Keep low 6 bits
 $B630 ADD A,$C1     ; Compute bitmap address high byte: $C1 + offset
 $B632 DEC HL        ;
 $B633 LD L,(HL)     ; Low byte from preceding word entry
 $B634 LD H,A        ;
 $B635 RET           ;

; Select player sprite
;
; Used by the routine at #R$A700.
;
; .
;
; Pick the player's current sprite frame from $60C1 plus facing ($60BE bit7)
; and player_state, applying frame-base offsets ($1F walking-left / $44
; walking-right).
; .
; RET early if $60C2==0 (nothing to draw).
; .
; Clobbers: A,H,L.
@label=select_player_sprite
c$B636 LD A,($60C2)  ;
 $B639 OR A          ;
 $B63A RET Z         ;
 $B63B LD A,($60C0)  ; get Player state-machine state
 $B63E CP $08        ;
 $B640 LD A,($60C1)  ;
 $B643 JR NZ,$B654   ;
 $B645 LD HL,$60BE   ;
 $B648 BIT 7,(HL)    ;
 $B64A JR Z,$B650    ;
 $B64C ADD A,$1F     ;
 $B64E JR $B661      ;
*$B650 ADD A,$44     ;
 $B652 JR $B661      ;
*$B654 LD H,A        ;
 $B655 AND $7F       ;
 $B657 BIT 7,H       ;
 $B659 JR NZ,$B65F   ;
 $B65B ADD A,$25     ;
 $B65D JR $B661      ;
*$B65F ADD A,$00     ;
*$B661 CALL $B61B    ; Get sprite def
 $B664 PUSH HL       ;
 $B665 PUSH BC       ;
 $B666 LD A,($60BA)  ;
 $B669 LD HL,$6030   ;
 $B66C SUB (HL)      ;
 $B66D ADD A,A       ;
 $B66E LD C,A        ;
 $B66F LD A,$A4      ;
 $B671 SUB C         ;
 $B672 LD H,A        ;
 $B673 LD L,$0E      ;
 $B675 LD ($B5C9),HL ;
 $B678 CALL $B5D9    ; Get screen addr
 $B67B EX DE,HL      ;
 $B67C POP BC        ;
 $B67D POP HL        ;
 $B67E LD ($6000),SP ; set Temporary place for SP
 $B682 DI            ;
 $B683 LD SP,HL      ;
 $B684 EX DE,HL      ;
 $B685 LD B,$0A      ;
 $B687 BIT 2,C       ;
 $B689 JP NZ,$B6BC   ;
 $B68C INC L         ;
*$B68D POP DE        ;
 $B68E LD A,(HL)     ;
 $B68F AND E         ;
 $B690 OR D          ;
 $B691 LD (HL),A     ;
 $B692 INC L         ;
 $B693 POP DE        ;
 $B694 LD A,(HL)     ;
 $B695 AND E         ;
 $B696 OR D          ;
 $B697 LD (HL),A     ;
 $B698 DEC L         ;
 $B699 INC H         ;
 $B69A POP DE        ;
 $B69B LD A,(HL)     ;
 $B69C AND E         ;
 $B69D OR D          ;
 $B69E LD (HL),A     ;
 $B69F INC L         ;
 $B6A0 POP DE        ;
 $B6A1 LD A,(HL)     ;
 $B6A2 AND E         ;
 $B6A3 OR D          ;
 $B6A4 LD (HL),A     ;
 $B6A5 DEC L         ;
 $B6A6 INC H         ;
 $B6A7 LD A,H        ;
 $B6A8 AND $07       ;
 $B6AA JP NZ,$B6B7   ;
 $B6AD LD A,L        ;
 $B6AE ADD A,$20     ;
 $B6B0 LD L,A        ;
 $B6B1 JR C,$B6B7    ;
 $B6B3 LD A,H        ;
 $B6B4 SUB $08       ;
 $B6B6 LD H,A        ;
*$B6B7 DJNZ $B68D    ;
 $B6B9 JP $B6FB      ;
*$B6BC POP DE        ;
 $B6BD LD C,L        ;
 $B6BE LD A,(HL)     ;
 $B6BF AND E         ;
 $B6C0 LD (HL),A     ;
 $B6C1 INC L         ;
 $B6C2 LD A,(HL)     ;
 $B6C3 AND D         ;
 $B6C4 POP DE        ;
 $B6C5 OR E          ;
 $B6C6 LD (HL),A     ;
 $B6C7 INC L         ;
 $B6C8 LD A,(HL)     ;
 $B6C9 AND D         ;
 $B6CA POP DE        ;
 $B6CB OR E          ;
 $B6CC LD (HL),A     ;
 $B6CD INC L         ;
 $B6CE LD A,(HL)     ;
 $B6CF AND D         ;
 $B6D0 LD (HL),A     ;
 $B6D1 LD L,C        ;
 $B6D2 INC H         ;
 $B6D3 POP DE        ;
 $B6D4 LD A,(HL)     ;
 $B6D5 AND E         ;
 $B6D6 LD (HL),A     ;
 $B6D7 INC L         ;
 $B6D8 LD A,(HL)     ;
 $B6D9 AND D         ;
 $B6DA POP DE        ;
 $B6DB OR E          ;
 $B6DC LD (HL),A     ;
 $B6DD INC L         ;
 $B6DE LD A,(HL)     ;
 $B6DF AND D         ;
 $B6E0 POP DE        ;
 $B6E1 OR E          ;
 $B6E2 LD (HL),A     ;
 $B6E3 INC L         ;
 $B6E4 LD A,(HL)     ;
 $B6E5 AND D         ;
 $B6E6 LD (HL),A     ;
 $B6E7 LD L,C        ;
 $B6E8 INC H         ;
 $B6E9 LD A,H        ;
 $B6EA AND $07       ;
 $B6EC JP NZ,$B6F9   ;
 $B6EF LD A,L        ;
 $B6F0 ADD A,$20     ;
 $B6F2 LD L,A        ;
 $B6F3 JR C,$B6F9    ;
 $B6F5 LD A,H        ;
 $B6F6 SUB $08       ;
 $B6F8 LD H,A        ;
*$B6F9 DJNZ $B6BC    ;
*$B6FB LD SP,($6000) ; get Temporary place for SP
 $B6FF EI            ;
 $B700 LD A,($6038)  ; get Flag?? $00 $FE $FF
 $B703 CP $FF        ;
 $B705 RET Z         ;
 $B706 LD HL,($B5C9) ;
 $B709 LD A,H        ;
 $B70A ADD A,$14     ;
 $B70C LD H,A        ;
 $B70D CALL $B5D9    ; Get screen addr
 $B710 LD DE,$FC3F   ;
 $B713 LD B,$00      ;
 $B715 CALL $B73E    ; Plot masked row
 $B718 DEC B         ;
 $B719 CALL $B73E    ; Plot masked row
 $B71C CALL $B72F    ; Plot row wrapped
 $B71F CALL $B73E    ; Plot masked row
 $B722 CALL $B72F    ; Plot row wrapped
 $B725 CALL $B73E    ; Plot masked row
 $B728 CALL $B72F    ; Plot row wrapped
 $B72B CALL $B73E    ; Plot masked row
 $B72E INC B         ;

; Plot row wrapped
;
; Used by the routine at #R$B636.
;
; .
;
; Advance the screen address HL down one pixel row (ZX scan-order arithmetic:
; char-cell wrap via +$20 / -$08) then fall into plot_masked_row.
; .
; Clobbers: A,HL (+ plot regs).
@label=plot_row_wrapped
c$B72F LD A,H        ;
 $B730 AND $07       ;
 $B732 JR NZ,$B73E   ;
 $B734 LD A,L        ;
 $B735 ADD A,$20     ;
 $B737 LD L,A        ;
 $B738 JR C,$B73E    ;
 $B73A LD A,H        ;
 $B73B SUB $08       ;
 $B73D LD H,A        ;

; Plot masked row
;
; Used by the routines at #R$B636 and #R$B72F.
;
; .
;
; Plot a 3-cell sprite slice at HL: AND the left edge cell with mask D, write
; the two middle cells = B, AND the right edge with mask E restores L and bumps
; H.
; .
; In: HL,B,D,E.
; .
; Clobbers: A,C,HL.
@label=plot_masked_row
c$B73E LD C,L        ;
 $B73F LD A,(HL)     ;
 $B740 AND D         ;
 $B741 LD (HL),A     ;
 $B742 INC L         ;
 $B743 LD (HL),B     ;
 $B744 INC L         ;
 $B745 LD (HL),B     ;
 $B746 INC L         ;
 $B747 LD A,(HL)     ;
 $B748 AND E         ;
 $B749 LD (HL),A     ;
 $B74A LD L,C        ;
 $B74B INC H         ;
 $B74C RET           ;

; Draw actor sprite
;
; Used by the routine at #R$A700.
;
; .
;
; Render one object_table actor (IX = entry).
; .
; Skips if the sprite id (IX+24)==$FF (inactive).
; .
; Computes screen-Y via actor_screen_y (also leaves an X-related byte in
; $60A6). State 7 (IX+48, the "static wall marker" convention used by
; collision_test) doubles $60A6 into a fresh angular-position copy rather than
; drawing normally.
; .
; Bounds-checks the screen row ($60A8) to [$18,$B0) (RET if off-screen),
; derives a sub-column fraction from $60A6, and for state-7 entries queues a
; one-shot deferred sprite via flag_b5cb/#R$B5CC/#R$B5CE (consumed later by
; draw_pending_sprite) instead of blitting immediately.
; .
; Otherwise computes the screen address (GET_SCREEN_ADDR), then picks the
; bitmap: sprite id >=$7C indexes the runtime table at $BC80 directly (fixed
; 3-cell-wide, 8-row blit) sprite id <$7C goes through GET_SPRITE_DEF (adds a
; facing offset derived from $60A6) to fetch the normal #R$C100 sprite
; definition. Falls through into blit_sprite_fast to draw.
; .
; Clobbers: A,HL,IX,...
@label=draw_actor_sprite
c$B74D LD A,(IX+$18) ;
 $B750 CP $FF        ; {sprite id == $FF -> RET (inactive)
 $B752 RET Z         ; }
 $B753 CALL $B869    ; Actor screen y
 $B756 LD A,(IX+$30) ; {state 7 (wall marker)?
 $B759 CP $07        ;
 $B75B JR NZ,$B764   ; }
 $B75D LD A,(IX+$00) ; {double angular pos -> $60A6
 $B760 ADD A,A       ;
 $B761 LD ($60A6),A  ; }
*$B764 LD A,($60A8)  ; A = screen row ($60A8)
 $B767 CP $18        ; {bounds check row to [$18,$B0), else RET
 $B769 RET C         ;
 $B76A CP $B0        ;
 $B76C RET NC        ; }
 $B76D LD H,A        ;
 $B76E LD A,($60A6)  ; {sub-column fraction: ($60A6)>>3 &$1F -> L
 $B771 RRA           ;
 $B772 RRA           ;
 $B773 RRA           ;
 $B774 AND $1F       ;
 $B776 LD L,A        ; }
 $B777 LD A,(IX+$30) ; {state 7 again -> defer draw
 $B77A CP $07        ;
 $B77C JR NZ,$B790   ; }
 $B77E LD ($B5CC),HL ; queue deferred sprite: pos -> #R$B5CC
 $B781 LD A,($60A6)  ; {facing quadrant -> #R$B5CE
 $B784 SRL A         ;
 $B786 AND $03       ;
 $B788 LD ($B5CE),A  ; }
 $B78B LD A,$01      ; {flag_b5cb = 1 (pending)
 $B78D LD ($B5CB),A  ; }
*$B790 CALL $B5D9    ; Get screen addr
 $B793 PUSH HL       ;
 $B794 LD A,(IX+$18) ; {sprite id >= $7C? (fixed runtime-table graphic)
 $B797 CP $7C        ;
 $B799 JR C,$B7B5    ; }
 $B79B SUB $7C       ; {offset*24 into $BC80 table
 $B79D ADD A,A       ;
 $B79E ADD A,A       ;
 $B79F ADD A,A       ;
 $B7A0 ADD A,A       ;
 $B7A1 ADD A,A       ;
 $B7A2 LD H,$00      ;
 $B7A4 LD L,A        ;
 $B7A5 ADD A,A       ;
 $B7A6 ADD A,L       ;
 $B7A7 LD L,A        ;
 $B7A8 JR NC,$B7AB   ;
 $B7AA INC H         ; }
*$B7AB LD DE,$BC80   ; {HL -> $BC80 + offset
 $B7AE ADD HL,DE     ; }
 $B7AF LD C,$03      ; {C=3,B=8: fixed 3-cell/8-row blit
 $B7B1 LD B,$08      ;
 $B7B3 JR $B7CB      ; }
*$B7B5 LD C,A        ; else: C = raw sprite id
 $B7B6 LD A,($60A6)  ; {facing quadrant + sprite id
 $B7B9 SRL A         ;
 $B7BB AND $03       ;
 $B7BD ADD A,C       ; }
 $B7BE PUSH AF       ; stash variant byte for blit_sprite_fast
 $B7BF CALL $B61B    ; Get sprite def

; Blit sprite fast
;
; .
;
; .
;
; Fast masked sprite blit using the LD SP,screen / PUSH stack-write trick
; (saves the real SP to #R$6000, DI, treats the screen as a "stack" so each
; POP+merge writes one masked byte pair).
; .
; Entered by fallthrough from draw_actor_sprite's GET_SPRITE_DEF/RET (POP AF
; recovers the sprite-variant byte pushed before that call): height B is 8 rows
; normally, or 4 rows when that byte is >=$4E (used for the fixed $BC80
; runtime-table sprites, which pre-set C=3/B=8 explicitly and skip this test).
; .
; C selects the row width variant: 1-cell-wide ($B7DD, 2 mask/data pairs per
; row), 2-cell-wide ($B7FD, 4 pairs), or 3-cell-wide ($B82B, 6 pairs) each
; variant does the same AND/OR merge-and-advance idiom (INC H each row,
; wrapping L by +$20/-8 on the char-cell boundary every 8 rows -- the standard
; ZX scan-order step), looping B times via DJNZ.
; .
; Data is consumed via POP off the (redirected) stack: each row pops a
; mask/value pair per cell, ANDs the mask into the destination screen byte, ORs
; in the value.
; .
; Restores the real SP from #R$6000 and EI before returning.
; .
; Clobbers: A,BC,DE,HL.
@label=blit_sprite_fast
c$B7C2 POP AF        ; recover sprite-variant byte pushed before GET_SPRITE_DEF
 $B7C3 LD B,$08      ; {height = 4 rows if variant >= $4E, else 8
 $B7C5 CP $4E        ;
 $B7C7 JR NC,$B7CB   ;
 $B7C9 LD B,$04      ; }
; This entry point is used by the routine at #R$B74D.
*$B7CB POP DE        ; DE = mask/value source pointer
 $B7CC LD ($6000),SP ; set Temporary place for SP
 $B7D0 DI            ;
 $B7D1 LD SP,HL      ; {SP=HL (write-via-POP trick); HL=mask/value ptr
 $B7D2 EX DE,HL      ; }
 $B7D3 DEC C         ; {C selects row-width variant: 1/2/3-cell
 $B7D4 JR Z,$B7DD    ;
 $B7D6 DEC C         ;
 $B7D7 JP Z,$B7FD    ;
 $B7DA JP $B82B      ; }
*$B7DD POP DE        ; --- 1-cell-wide variant ---
 $B7DE LD A,(HL)     ;
 $B7DF AND E         ;
 $B7E0 OR D          ;
 $B7E1 LD (HL),A     ;
 $B7E2 INC H         ;
 $B7E3 POP DE        ;
 $B7E4 LD A,(HL)     ;
 $B7E5 AND E         ;
 $B7E6 OR D          ;
 $B7E7 LD (HL),A     ;
 $B7E8 INC H         ;
 $B7E9 LD A,H        ; {wrap to next screen row (char-cell boundary step)
 $B7EA AND $07       ;
 $B7EC JR NZ,$B7F8   ;
 $B7EE LD A,L        ;
 $B7EF ADD A,$20     ;
 $B7F1 LD L,A        ;
 $B7F2 JR C,$B7F8    ;
 $B7F4 LD A,H        ;
 $B7F5 SUB $08       ;
 $B7F7 LD H,A        ; }
*$B7F8 DJNZ $B7DD    ; loop B rows
 $B7FA JP $B863      ; done -> restore SP
*$B7FD POP DE        ; --- 2-cell-wide variant ---
 $B7FE LD A,(HL)     ;
 $B7FF AND E         ;
 $B800 OR D          ;
 $B801 LD (HL),A     ;
 $B802 INC L         ;
 $B803 POP DE        ;
 $B804 LD A,(HL)     ;
 $B805 AND E         ;
 $B806 OR D          ;
 $B807 LD (HL),A     ;
 $B808 DEC L         ;
 $B809 INC H         ;
 $B80A POP DE        ;
 $B80B LD A,(HL)     ;
 $B80C AND E         ;
 $B80D OR D          ;
 $B80E LD (HL),A     ;
 $B80F INC L         ;
 $B810 POP DE        ;
 $B811 LD A,(HL)     ;
 $B812 AND E         ;
 $B813 OR D          ;
 $B814 LD (HL),A     ;
 $B815 DEC L         ;
 $B816 INC H         ;
 $B817 LD A,H        ; {wrap to next screen row
 $B818 AND $07       ;
 $B81A JR NZ,$B826   ;
 $B81C LD A,L        ;
 $B81D ADD A,$20     ;
 $B81F LD L,A        ;
 $B820 JR C,$B826    ;
 $B822 LD A,H        ;
 $B823 SUB $08       ;
 $B825 LD H,A        ; }
*$B826 DJNZ $B7FD    ; loop B rows
 $B828 JP $B863      ;
*$B82B POP DE        ; --- 3-cell-wide variant ---
 $B82C LD C,L        ;
 $B82D LD A,(HL)     ;
 $B82E AND E         ;
 $B82F OR D          ;
 $B830 LD (HL),A     ;
 $B831 INC L         ;
 $B832 POP DE        ;
 $B833 LD A,(HL)     ;
 $B834 AND E         ;
 $B835 OR D          ;
 $B836 LD (HL),A     ;
 $B837 INC L         ;
 $B838 POP DE        ;
 $B839 LD A,(HL)     ;
 $B83A AND E         ;
 $B83B OR D          ;
 $B83C LD (HL),A     ;
 $B83D LD L,C        ;
 $B83E INC H         ;
 $B83F POP DE        ;
 $B840 LD A,(HL)     ;
 $B841 AND E         ;
 $B842 OR D          ;
 $B843 LD (HL),A     ;
 $B844 INC L         ;
 $B845 POP DE        ;
 $B846 LD A,(HL)     ;
 $B847 AND E         ;
 $B848 OR D          ;
 $B849 LD (HL),A     ;
 $B84A INC L         ;
 $B84B POP DE        ;
 $B84C LD A,(HL)     ;
 $B84D AND E         ;
 $B84E OR D          ;
 $B84F LD (HL),A     ;
 $B850 LD L,C        ;
 $B851 INC H         ;
 $B852 LD A,H        ; {wrap to next screen row
 $B853 AND $07       ;
 $B855 JR NZ,$B861   ;
 $B857 LD A,L        ;
 $B858 ADD A,$20     ;
 $B85A LD L,A        ;
 $B85B JR C,$B861    ;
 $B85D LD A,H        ;
 $B85E SUB $08       ;
 $B860 LD H,A        ; }
*$B861 DJNZ $B82B    ; loop B rows
*$B863 LD SP,($6000) ; get Temporary place for SP
 $B867 EI            ; {EI; RET
 $B868 RET           ; }

; Actor screen y
;
; Used by the routines at #R$A700 and #R$B74D.
;
; .
;
; Object-table counterpart of col_screen_y: map an actor's angular column
; (IX+0)+$20, minus tower_height rotation, wrapped (AND $7F), through
; col_y_table to a screen row also derives the object index ((IX low)-$5B).
; .
; Clobbers: A,DE,HL.
@label=actor_screen_y
c$B869 LD A,(IX+$00) ; {angular column + $20, minus tower rotation, wrapped
 $B86C ADD A,$20     ;
 $B86E LD HL,$60B9   ;
 $B871 SUB (HL)      ;
 $B872 AND $7F       ; }
 $B874 LD E,A        ;
 $B875 LD D,$00      ;
 $B877 LD HL,$6380   ; {HL -> col_y_table[rel]
 $B87A ADD HL,DE     ; }
 $B87B PUSH IX       ; {object index = (IX low) - $5B
 $B87D POP DE        ;
 $B87E LD A,E        ;
 $B87F SUB $5B       ;
 $B881 LD E,A        ; }
 $B882 CP $04        ;
 $B884 LD A,(HL)     ;
 $B885 JR NZ,$B889   ;
 $B887 ADD A,$02     ;
*$B889 ADD A,A       ; {scale/bias -> store projected value ($60A6)
 $B88A ADD A,$78     ;
 $B88C LD ($60A6),A  ; }
 $B88F LD A,(IX+$06) ;
 $B892 LD HL,$6030   ;
 $B895 SUB (HL)      ;
 $B896 ADD A,A       ;
 $B897 LD C,A        ;
 $B898 LD A,$A8      ;
 $B89A SUB C         ;
 $B89B LD C,A        ;
 $B89C LD A,E        ;
 $B89D CP $04        ;
 $B89F LD A,C        ;
 $B8A0 JR NZ,$B8A4   ;
 $B8A2 ADD A,$08     ;
*$B8A4 LD ($60A8),A  ;
 $B8A7 RET           ;

; Draw pending sprite
;
; Used by the routine at #R$A700.
;
; .
;
; If flag_b5cb is set, consume it and draw the one-shot sprite queued at
; #R$B5CC (pos) / #R$B5CE (id), with on-screen bounds checks.
; .
; RET immediately when nothing queued.
; .
; Clobbers: A,BC,HL.
@label=draw_pending_sprite
c$B8A8 LD A,($B5CB)  ; {flag_b5cb set? consume it, else RET
 $B8AB OR A          ;
 $B8AC RET Z         ; }
 $B8AD XOR A         ;
 $B8AE LD ($B5CB),A  ;
 $B8B1 LD HL,($B5CC) ; {HL = queued pos, B = queued sprite id
 $B8B4 LD A,($B5CE)  ;
 $B8B7 LD B,A        ; }
 $B8B8 LD A,L        ; {bounds check: column edge cases (row 7..$17 skip)
 $B8B9 CP $07        ;
 $B8BB JR C,$B8C0    ;
 $B8BD CP $17        ;
 $B8BF RET C         ; }
*$B8C0 CP $1E        ; {bounds check: row < $1E
 $B8C2 RET NC        ; }
 $B8C3 LD C,$02      ; {C=2 (default cell count); row<5 -> $B8DE
 $B8C5 CP $05        ;
 $B8C7 JR C,$B8DE    ; }
 $B8C9 JR Z,$B8E3    ; {row==6 or edge cases -> adjust C (1 or 3 cells)
 $B8CB DEC C         ;
 $B8CC CP $06        ;
 $B8CE JR Z,$B8E3    ;
 $B8D0 CP $17        ;
 $B8D2 JR NZ,$B8D7   ;
 $B8D4 LD A,B        ;
 $B8D5 OR A          ;
 $B8D6 RET Z         ; }
*$B8D7 INC C         ; {adjust cell count near right/bottom edge
 $B8D8 CP $19        ;
 $B8DA JR NC,$B8DE   ;
 $B8DC INC L         ;
 $B8DD DEC C         ; }
*$B8DE LD A,B        ; {sprite id (B)!=0? bump C for extra cell
 $B8DF OR A          ;
 $B8E0 JR Z,$B8E3    ;
 $B8E2 INC C         ; }
*$B8E3 CALL $B5D9    ; Get screen addr
 $B8E6 LD B,$08      ; {B=8 rows, D=0 (erase byte)
 $B8E8 LD D,$00      ; }
 $B8EA DEC C         ; {C selects erase width: 1/2/3-cell
 $B8EB JR Z,$B8F3    ;
 $B8ED DEC C         ;
 $B8EE JR Z,$B909    ;
 $B8F0 JP $B923      ; }
*$B8F3 LD (HL),D     ; {--- 1-cell erase: write+wrap to next row ---
 $B8F4 INC H         ;
 $B8F5 LD (HL),D     ;
 $B8F6 INC H         ;
 $B8F7 LD A,H        ;
 $B8F8 AND $07       ;
 $B8FA JR NZ,$B906   ;
 $B8FC LD A,L        ;
 $B8FD ADD A,$20     ;
 $B8FF LD L,A        ;
 $B900 JR C,$B906    ;
 $B902 LD A,H        ;
 $B903 SUB $08       ;
 $B905 LD H,A        ;
*$B906 DJNZ $B8F3    ;
 $B908 RET           ; }
*$B909 LD (HL),D     ; {--- 2-cell erase: write+wrap to next row ---
 $B90A INC L         ;
 $B90B LD (HL),D     ;
 $B90C INC H         ;
 $B90D LD (HL),D     ;
 $B90E DEC L         ;
 $B90F LD (HL),D     ;
 $B910 INC H         ;
 $B911 LD A,H        ;
 $B912 AND $07       ;
 $B914 JR NZ,$B920   ;
 $B916 LD A,L        ;
 $B917 ADD A,$20     ;
 $B919 LD L,A        ;
 $B91A JR C,$B920    ;
 $B91C LD A,H        ;
 $B91D SUB $08       ;
 $B91F LD H,A        ;
*$B920 DJNZ $B909    ;
 $B922 RET           ; }
*$B923 LD (HL),D     ; {--- 3-cell erase: write+wrap to next row ---
 $B924 INC L         ;
 $B925 LD (HL),D     ;
 $B926 INC L         ;
 $B927 LD (HL),D     ;
 $B928 INC H         ;
 $B929 LD (HL),D     ;
 $B92A DEC L         ;
 $B92B LD (HL),D     ;
 $B92C DEC L         ;
 $B92D LD (HL),D     ;
 $B92E INC H         ;
 $B92F LD A,H        ;
 $B930 AND $07       ;
 $B932 JR NZ,$B93E   ;
 $B934 LD A,L        ;
 $B935 ADD A,$20     ;
 $B937 LD L,A        ;
 $B938 JR C,$B93E    ;
 $B93A LD A,H        ;
 $B93B SUB $08       ;
 $B93D LD H,A        ;
*$B93E DJNZ $B923    ;
 $B940 RET           ; }

; Data block at B941
@label=strip_params
b$B941 DEFB $00,$00,$00,$00,$00,$0F,$17,$2F
 $B949 DEFB $09
 $B94A DEFM "8 >"

; Data block at B94D
b$B94D DEFB $12,$29,$16,$08,$1B,$10,$3F,$2A
 $B955 DEFB $00,$0F,$17,$2F,$09
 $B95A DEFM "8 >"

