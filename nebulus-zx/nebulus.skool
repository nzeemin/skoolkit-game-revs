 $A9C0 LD A,($6040)  ;
 $A9C3 OR A          ;
 $A9C4 JR Z,$A9C9    ;
 $A9C6 LD DE,$6047   ;
*$A9C9 LD A,(DE)     ;
 $A9CA ADD A,L       ;
 $A9CB DAA           ;
 $A9CC LD (DE),A     ;
 $A9CD INC DE        ;
 $A9CE LD A,(DE)     ;
 $A9CF LD B,A        ;
 $A9D0 ADC A,H       ;
 $A9D1 DAA           ;
 $A9D2 LD (DE),A     ;
 $A9D3 LD C,A        ;
 $A9D4 INC DE        ;
 $A9D5 LD A,(DE)     ;
 $A9D6 ADC A,$00     ;
 $A9D8 LD (DE),A     ;
 $A9D9 INC DE        ;
 $A9DA LD A,(DE)     ;
 $A9DB ADC A,$00     ;
 $A9DD LD (DE),A     ;
 $A9DE LD A,B        ;
 $A9DF AND $F0       ;
 $A9E1 CP $40        ;
 $A9E3 JR NZ,$A9EC   ;
 $A9E5 LD A,C        ;
 $A9E6 AND $F0       ;
 $A9E8 CP $50        ;
 $A9EA JR Z,$A9F6    ;
*$A9EC LD A,B        ;
 $A9ED AND $F0       ;
 $A9EF CP $90        ;
 $A9F1 RET NZ        ;
 $A9F2 LD A,C        ;
 $A9F3 AND $F0       ;
 $A9F5 RET NZ        ;
*$A9F6 LD HL,$6041   ;
 $A9F9 LD A,($6040)  ;
 $A9FC OR A          ;
 $A9FD JR Z,$AA00    ;
 $A9FF INC HL        ;
*$AA00 INC (HL)      ;
 $AA01 LD A,(HL)     ;
 $AA02 CP $08        ;
 $AA04 RET C         ;
 $AA05 LD (HL),$08   ;
 $AA07 RET           ;

; INIT_BONUS -- seed the active player's (lives_p1 index) bonus/ accumulator
