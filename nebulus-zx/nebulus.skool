 $AA4B DAA           ;
 $AA4C LD (HL),A     ;
 $AA4D INC HL        ;
 $AA4E LD A,(HL)     ;
 $AA4F ADC A,$00     ;
 $AA51 LD (HL),A     ;
 $AA52 CP $06        ;
 $AA54 RET C         ;
 $AA55 LD (HL),$05   ;
 $AA57 DEC HL        ;
