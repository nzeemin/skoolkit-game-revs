*$831F LD (HL),A     ;
 $8320 LD HL,$8302   ;
 $8323 OR A          ;
 $8324 JR Z,$8328    ;
 $8326 INC HL        ;
 $8327 INC HL        ;
*$8328 LD A,(HL)     ;
 $8329 OR A          ;
 $832A JR NZ,$8346   ;
 $832C LD A,($603F)  ;
 $832F CP $01        ;
 $8331 JR Z,$835E    ;
 $8333 LD A,$01      ;
 $8335 LD HL,$6040   ;
 $8338 SUB (HL)      ;
 $8339 LD (HL),A     ;
 $833A LD HL,$8302   ;
 $833D OR A          ;
 $833E JR Z,$8342    ;
 $8340 INC HL        ;
 $8341 INC HL        ;
*$8342 LD A,(HL)     ;
 $8343 OR A          ;
 $8344 JR Z,$835E    ;
*$8346 DEC HL        ;
 $8347 LD A,(HL)     ;
 $8348 LD ($6039),A  ;
 $834B INC HL        ;
 $834C LD C,(HL)     ;
 $834D LD HL,$60CB   ;
 $8350 LD B,$08      ;
*$8352 XOR A         ;
 $8353 RR C          ;
 $8355 JR NC,$8358   ;
 $8357 INC A         ;
*$8358 LD (HL),A     ;
 $8359 INC HL        ;
 $835A DJNZ $8352    ;
 $835C SCF           ;
 $835D RET           ;
*$835E OR A          ;
 $835F RET           ;

