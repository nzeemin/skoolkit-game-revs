 $FCCA LD A,B        ;
 $FCCB CP $D4        ;
 $FCCD JR NC,$FCC3   ;
 $FCCF CALL $FD20    ; Tape get edge
 $FCD2 RET NC        ;
 $FCD3 EXX           ;
 $FCD4 LD A,($FC1A)  ;
 $FCD7 LD C,A        ;
 $FCD8 LD ($FC1F),A  ;
 $FCDB EXX           ;
 $FCDC LD H,$00      ;
 $FCDE LD B,$B0      ;
 $FCE0 JR $FD01      ;
