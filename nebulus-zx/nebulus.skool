; PLAY_SOUND -- trigger sound effect A (id < $0D).
;
; Used by the routines at #R$8240, #R$84B9, #R$85DB, #R$8656, #R$868D, #R$8724,
; #R$8736, #R$8831, #R$88BD, #R$8A4A, #R$8A71, #R$90DA, #R$9372, #R$955B,
; #R$96E9, #R$9F33 and #R$A113.
;
; .
;
; Saves all regs, looks up the effect via lookup_sound, and (subject to a
; priority check against the currently playing effect at $A368/$A369) latches
; its data pointer at $A36A for sound_tick to play out.
; .
; In: A=effect id.
; .
; Preserves all registers.
; .
; Most-called audio API.
@label=play_sound
c$A3DE PUSH AF       ;
 $A3DF PUSH BC       ;
 $A3E0 PUSH DE       ;
 $A3E1 PUSH HL       ;
 $A3E2 CP $0D        ;
 $A3E4 JR NC,$A406   ;
 $A3E6 CALL $A40B    ;
 $A3E9 LD D,A        ;
 $A3EA LD A,($A368)  ;
 $A3ED CP $FF        ;
 $A3EF JR Z,$A3F7    ;
 $A3F1 LD A,($A369)  ;
 $A3F4 CP B          ;
 $A3F5 JR C,$A406    ;
*$A3F7 LD ($A36A),HL ;
 $A3FA LD A,C        ;
 $A3FB LD ($A36C),A  ;
 $A3FE LD A,D        ;
 $A3FF LD ($A368),A  ;
 $A402 LD A,B        ;
 $A403 LD ($A369),A  ;
*$A406 POP HL        ;
 $A407 POP DE        ;
 $A408 POP BC        ;
 $A409 POP AF        ;
 $A40A RET           ;

; Routine at A40B
;
; Used by the routine at #R$A3DE.
@label=lookup_sound
c$A40B LD L,A        ;
 $A40C LD H,$00      ;
 $A40E LD DE,$A373   ;
 $A411 ADD HL,HL     ;
 $A412 ADD HL,DE     ;
 $A413 LD E,(HL)     ;
 $A414 INC HL        ;
 $A415 LD D,(HL)     ;
 $A416 EX DE,HL      ;
 $A417 LD B,(HL)     ;
 $A418 INC HL        ;
 $A419 LD C,(HL)     ;
 $A41A INC HL        ;
 $A41B RET           ;

; SOUND_TICK -- per-frame SFX engine step.
;
; Used by the routines at #R$8240 and #R$A02A.
;
; .
;
; Gated by the sound-enable flag ($6056) and the active marker ($A368).
; .
; Reads the next byte of the current effect (pointer $A36A), interpreting
; commands (>=$80) vs tone/length data, and emits to the speaker.
; .
; i8080: speaker via OUT ($FE) bit4 (ULA).
; .
; The Specialist has a 1-bit beeper too -- retarget the port and retune the
; delay loops.
@label=sound_tick
c$A41C LD A,($6056)  ;
 $A41F OR A          ;
 $A420 JP Z,$A50E    ;
 $A423 LD A,($A368)  ;
 $A426 CP $FF        ;
 $A428 JP Z,$A50E    ;
 $A42B LD HL,($A36A) ;
 $A42E LD A,(HL)     ;
 $A42F INC HL        ;
 $A430 LD ($A36A),HL ;
 $A433 CP $80        ;
 $A435 JR C,$A462    ;
 $A437 CALL Z,$A48A  ;
 $A43A JR Z,$A465    ;
 $A43C CP $81        ;
 $A43E CALL Z,$A470  ;
 $A441 JR Z,$A465    ;
 $A443 CP $C8        ;
 $A445 CALL Z,$A4BF  ;
 $A448 JR Z,$A465    ;
 $A44A CP $C9        ;
 $A44C CALL Z,$A52E  ;
 $A44F JR Z,$A465    ;
 $A451 CP $CA        ;
 $A453 CALL Z,$A4F2  ;
 $A456 JR Z,$A465    ;
 $A458 CP $82        ;
 $A45A CALL NC,$A493 ;
 $A45D JR NC,$A465   ;
 $A45F JP $A46A      ;
*$A462 CALL $A539    ;
*$A465 LD HL,$A36C   ;
 $A468 DEC (HL)      ;
 $A469 RET NZ        ;
*$A46A LD A,$FF      ;
 $A46C LD ($A368),A  ;
 $A46F RET           ;

; Routine at A470
;
; Used by the routine at #R$A41C.
c$A470 PUSH AF       ;
 $A471 LD E,$10      ;
 $A473 LD C,$12      ;
 $A475 LD D,$80      ;
*$A477 LD A,E        ;
 $A478 OUT ($FE),A   ;
 $A47A XOR $10       ;
 $A47C LD E,A        ;
 $A47D LD B,D        ;
*$A47E DJNZ $A47E    ;
 $A480 LD A,D        ;
 $A481 SUB $03       ;
 $A483 LD D,A        ;
 $A484 DEC C         ;
 $A485 JP NZ,$A477   ;
 $A488 POP AF        ;
 $A489 RET           ;

; Routine at A48A
;
; Used by the routine at #R$A41C.
c$A48A PUSH AF       ;
 $A48B LD DE,$0143   ;
 $A48E CALL $A4AD    ;
 $A491 POP AF        ;
 $A492 RET           ;

; Routine at A493
;
; Used by the routine at #R$A41C.
c$A493 PUSH AF       ;
 $A494 LD B,$10      ;
 $A496 ADD A,$A3     ;
 $A498 LD H,A        ;
 $A499 LD L,$6D      ;
 $A49B LD DE,$0143   ;
*$A49E LD A,(HL)     ;
 $A49F AND B         ;
 $A4A0 OUT ($FE),A   ;
 $A4A2 INC HL        ;
 $A4A3 DEC DE        ;
 $A4A4 LD A,D        ;
 $A4A5 OR E          ;
 $A4A6 NOP           ;
 $A4A7 NOP           ;
 $A4A8 JP NZ,$A49E   ;
 $A4AB POP AF        ;
 $A4AC RET           ;

; SFX_NOISE -- white-noise burst: XORs the refresh register R into the speaker
; bit and toggles OUT ($FE) for DE iterations.
;
; Used by the routine at #R$A48A.
