 $AA2F DAA           ;
 $AA30 LD (HL),A     ;
 $AA31 INC HL        ;
 $AA32 LD A,(HL)     ;
 $AA33 SBC A,$00     ;
 $AA35 DAA           ;
 $AA36 LD (HL),A     ;
 $AA37 RET NC        ;
 $AA38 XOR A         ;
 $AA39 LD (HL),A     ;
