;
; One-instruction wrapper around jp_anim_bg ($A778) -- ticks the title
; background animation.
@label=title_anim_tick
c$9CEB CALL $A778    ;
 $9CEE RET           ;

; Unused
s$9CEF DEFS $01

; Wait frames
;
; Used by the routines at #R$99A1, #R$99CE, #R$99F0 and #R$9A23.
;
; .
;
; Pause for A frames (HALT-synced), running the attract animation (proc_table)
; meanwhile returns early if input (input_x) arrives.
; .
; #R$9CEF = frame counter.
; .
; Clobbers: A,HL.
@label=wait_frames
c$9CF0 HALT          ;
; This entry point is used by the routine at #R$9963.
*$9CF1 LD ($9CEF),A  ;
 $9CF4 CALL $9D07    ;
*$9CF7 HALT          ;
 $9CF8 LD HL,$9CEF   ;
 $9CFB DEC (HL)      ;
 $9CFC JR Z,$9D10    ;
 $9CFE CALL $A700    ; Proc table
 $9D01 LD A,($601C)  ; get Signed input
 $9D04 OR A          ;
 $9D05 JR Z,$9CF7    ;
; This entry point is used by the routine at #R$9BA5.
@label=menu_wait_release
*$9D07 CALL $A700    ; Proc table
 $9D0A LD A,($601C)  ; get Signed input
 $9D0D OR A          ;
 $9D0E JR NZ,$9D07   ;
*$9D10 RET           ;

; Print PLAYER label
;
; Used by the routines at #R$9963, #R$99A1, #R$99CE and #R$99F0.
;
; .
;
; Prints "PLAYER 1" or "PLAYER 2" (strings at #R$977F/#R$978B) depending on
; lives_p1 (#R$6040).
@label=print_player_label
c$9D11 LD A,($6040)  ; A = lives_p1 (active player index)
 $9D14 LD HL,$977F   ;
 $9D17 OR A          ; {==0? player 1
 $9D18 JR Z,$9D1D    ; }
 $9D1A LD HL,$978B   ; else HL -> "PLAYER 2" string
*$9D1D CALL $A745    ; jp_print_centered
 $9D20 RET           ;

; Print string at
;
; Used by the routines at #R$9963, #R$99A1, #R$99CE, #R$99F0, #R$9AD7, #R$9BA5,
; #R$9CC7, #R$9D4C and #R$9D80.
;
; .
;
; Set the print row (A) then print the string at HL, centered. Thin wrapper
; combining set_print_row + jp_print_centered.
@label=print_string_at
c$9D21 CALL $9D27    ; set_print_row
 $9D24 JP $A745      ; jp_print_centered (tail call)

; Set print row
;
; Used by the routines at #R$9963, #R$99A1, #R$99CE, #R$99F0 and #R$9D21.
;
; .
;
; Set print_cursor's row to A and column to 0.
@label=set_print_row
c$9D27 LD ($60C6),A  ; store row into print_cursor high byte
 $9D2A XOR A         ; A = 0
 $9D2B LD ($60C7),A  ; store column = 0
 $9D2E RET           ;

; Data block at 9D2F
;
; .
;
; .
;
; Default hiscore table, 4 entries x 7 bytes (4 BCD score bytes + 3-char ASCII
; name). All 4 ship with the same "JMP" initials (programmer's easter egg) and
; descending round scores (#R$9D2F highest). Live-updated in place by
; check_hiscore (#R$9E6D) as real scores qualify -- not reloaded from tape, so
; scores reset each time the game is loaded.
@label=hiscore_entry_1
b$9D2F DEFB $40,$26,$04,$00
 $9D33 DEFM "JMP"

; Data block at 9D36
@label=hiscore_entry_2
b$9D36 DEFB $00,$50,$00,$00
 $9D3A DEFM "JMP"

; Data block at 9D3D
@label=hiscore_entry_3
b$9D3D DEFB $00,$30,$00,$00
 $9D41 DEFM "JMP"

; Data block at 9D44
@label=hiscore_entry_4
b$9D44 DEFB $00,$10,$00,$00
 $9D48 DEFM "JMP"

; Unused
s$9D4B DEFS $01

; Draw hiscore screen
;
; Used by the routines at #R$9BA5 and #R$9D80.
;
; .
;
; Render the high-score table (the alternate title page): header string #R$9927
; plus each score entry printed via print_score_entry.
; .
; Clobbers: most.
@label=draw_hiscore_screen
c$9D4C LD A,$06      ; A = row $06 (header)
 $9D4E LD HL,$9927   ; HL -> header string (#R$9927)
 $9D51 CALL $9D21    ; Print string at
 $9D54 LD HL,$9D2F   ; HL -> hiscore_entry_1
 $9D57 LD C,$47      ; C = colour $47
 $9D59 LD A,$0A      ; A = row $0A
 $9D5B CALL $9E0F    ; Print score entry
 $9D5E LD HL,$9D36   ; HL -> hiscore_entry_2
 $9D61 LD C,$46      ; C = colour $46
 $9D63 LD A,$0C      ; A = row $0C
 $9D65 CALL $9E0F    ; Print score entry
 $9D68 LD HL,$9D3D   ; HL -> hiscore_entry_3
 $9D6B LD C,$45      ; C = colour $45
 $9D6D LD A,$0E      ; A = row $0E
 $9D6F CALL $9E0F    ; Print score entry
 $9D72 LD HL,$9D44   ; HL -> hiscore_entry_4
 $9D75 LD C,$44      ; C = colour $44
 $9D77 LD A,$10      ; A = row $10
 $9D79 CALL $9E0F    ; Print score entry
 $9D7C RET           ;

; Unused
s$9D7D DEFS $03

; Enter HiScore name
;
; Used by the routines at #R$99A1 and #R$99F0.
;
; .
;
; "Type your initials" screen, entered from the time-up/bonus screens
; (#R$99A1/#R$99F0) after a level. Checks check_hiscore first RET NC
; immediately if the active player's score didn't qualify.
; .
; On a qualifying score: seeds the new table row's 3-char name with "A  "
; (IX+4/5/6), stashes the row pointer at $9D7E and the letter-position counter
; (4/5/6, one per char) at #R$9D7D=4, then redraws the hiscore screen with
; prompt text and enters an input loop.
; .
; Per letter: waits for horizontal input release, then a fire/movement poll.
; Vertical/horizontal movement (input_x, added to the current letter) cycles
; the letter A-Z (wrapping $40/$5B boundaries) fire or continued input confirms
; the letter and advances the position counter, defaulting the next letter to
; the same value as the one just confirmed. After all 3 letters (counter
; reaches 7), pauses ~25 frames and returns.
; .
; Clobbers: most.
@label=enter_hiscore_name
c$9D80 CALL $9E6D      ; check_hiscore
 $9D83 RET NC          ; not a qualifying score -> RET
 $9D84 LD (IX+$04),$41 ; default letter 1 = 'A'
 $9D88 LD (IX+$05),$20 ; default letter 2 = ' '
 $9D8C LD (IX+$06),$20 ; default letter 3 = ' '
 $9D90 LD ($9D7E),IX   ; stash row pointer ($9D7E)
 $9D94 LD A,$04        ; A = 4 (first letter-position value)
 $9D96 LD ($9D7D),A    ; stash letter-position counter (#R$9D7D)
 $9D99 CALL $9CEB      ; Title anim tick
*$9D9C CALL $9D4C      ; Draw hiscore screen
 $9D9F LD A,$15        ; A = row $15 (prompt line 1)
 $9DA1 LD HL,$9935     ; HL -> prompt string
 $9DA4 CALL $9D21      ; Print string at
 $9DA7 LD A,$17        ; A = row $17 (prompt line 2)
 $9DA9 LD HL,$9943     ; HL -> prompt string
 $9DAC CALL $9D21      ; Print string at
 $9DAF HALT            ; HALT (sync)
*$9DB0 CALL $A700      ; Proc table
 $9DB3 LD A,($601C)    ; get Signed input
 $9DB6 OR A            ;
 $9DB7 JR NZ,$9DB0     ; horizontal input still held -> wait for release
*$9DB9 LD B,$06        ; B = 6 (debounce frames)
*$9DBB HALT            ;
 $9DBC DJNZ $9DBB      ; loop 6 HALTs
 $9DBE CALL $A700      ; Proc table
 $9DC1 LD A,($601E)    ; get Signed input
 $9DC4 LD HL,$601C     ;
 $9DC7 OR (HL)         ; {fire or horizontal input? else keep waiting
 $9DC8 JR Z,$9DB9      ; }
 $9DCA LD A,($601E)    ; get Signed input
 $9DCD OR A            ;
 $9DCE JR Z,$9DEB      ; no vertical input -> confirm letter ($9DEB)
 $9DD0 LD IX,($9D7E)   ; IX -> current letter slot
 $9DD4 ADD A,(IX+$04)  ; A = input_y + current letter
 $9DD7 CP $40          ; wrapped below 'A'? -> wrap to 'Z'
 $9DD9 JR NZ,$9DDF     ;
 $9DDB LD A,$5A        ; A = 'Z'
 $9DDD JR $9DE5        ;
*$9DDF CP $5B          ; wrapped past 'Z'? -> wrap to 'A'
 $9DE1 JR NZ,$9DE5     ;
 $9DE3 LD A,$41        ; A = 'A'
*$9DE5 LD (IX+$04),A   ; store adjusted letter
 $9DE8 JP $9D9C        ; loop (redraw with new letter)
*$9DEB LD IX,($9D7E)   ; IX -> current letter slot
 $9DEF INC IX          ; IX += 1 (advance to next letter)
 $9DF1 LD ($9D7E),IX   ; store advanced pointer
 $9DF5 LD A,($9D7D)    ; A = letter-position counter
 $9DF8 INC A           ;
 $9DF9 LD ($9D7D),A    ; store advanced counter
 $9DFC CP $07          ; all 3 letters entered (counter==7)?
 $9DFE JR Z,$9E09      ;
 $9E00 LD A,(IX+$03)   ; else: A = previous letter's final value
 $9E03 LD (IX+$04),A   ; seed next letter with the same value
 $9E06 JP $9D9C        ; loop (redraw for next letter)
*$9E09 LD B,$19        ; B = $19 (pause frames)
*$9E0B HALT            ; HALT
 $9E0C DJNZ $9E0B      ; loop pause frames
 $9E0E RET             ;

; Print score entry
;
; Used by the routine at #R$9D4C.
;
; .
;
; Print one high-score row: cursor row A, colour C, entry record at HL (IX)
; formats the BCD score bytes via print_score_byte.
; .
; Clobbers: A,IX,...
@label=print_score_entry
c$9E0F LD ($60C6),A  ;
 $9E12 LD A,C        ;
 $9E13 LD ($60C8),A  ; set Current text colour/attribute
 $9E16 LD A,$09      ;
 $9E18 LD ($60C7),A  ;
 $9E1B PUSH HL       ;
 $9E1C POP IX        ;
 $9E1E LD A,(IX+$03) ;
 $9E21 CALL $9E58    ;
 $9E24 LD A,(IX+$02) ;
 $9E27 CALL $9E58    ;
 $9E2A LD A,(IX+$01) ;
 $9E2D CALL $9E58    ;
 $9E30 LD A,(IX+$00) ;
 $9E33 CALL $9E58    ;
 $9E36 LD A,$20      ;
 $9E38 CALL $A73F    ;
 $9E3B LD A,$20      ;
 $9E3D CALL $A73F    ;
 $9E40 LD A,$20      ;
 $9E42 CALL $A73F    ;
 $9E45 LD A,(IX+$04) ;
 $9E48 CALL $A73F    ;
 $9E4B LD A,(IX+$05) ;
 $9E4E CALL $A73F    ;
 $9E51 LD A,(IX+$06) ;
 $9E54 CALL $A73F    ;
 $9E57 RET           ;

; Routine at 9E58
;
; Used by the routine at #R$9E0F.
@label=print_score_byte
c$9E58 PUSH AF       ;
 $9E59 SRL A         ;
 $9E5B SRL A         ;
 $9E5D SRL A         ;
 $9E5F SRL A         ;
 $9E61 CALL $9E65    ;
 $9E64 POP AF        ;
@label=print_score_nibble
*$9E65 AND $0F       ;
 $9E67 ADD A,$30     ;
 $9E69 JP $A73F      ;

; Unused
s$9E6C DEFS $01

; Check hiscore
;
; Used by the routine at #R$9D80.
;
; .
;
; Compare the active player's 4-byte BCD score ($6043 / $6047 by lives_p1)
; against the high-score table and insert it in rank order if it qualifies.
; .
; Runs with IRQs off.
; .
; Clobbers: A,IX,IY,...
@label=check_hiscore
c$9E6D DI             ; DI
 $9E6E PUSH IY        ;
 $9E70 LD A,($6040)   ; get Lives
 $9E73 LD IX,$6043    ;
 $9E77 OR A           ; player index==0? select score buffer
 $9E78 JR Z,$9E7E     ;
 $9E7A LD IX,$6047    ; else IX -> P2 score ($6047)
*$9E7E LD IY,$9D2F    ; IY -> hiscore table (#R$9D2F)
 $9E82 LD B,$04       ; B = 4 (BCD score bytes)
*$9E84 LD A,(IY+$00)  ; A = table entry byte
 $9E87 SUB (IX+$00)   ; subtract score byte (with carry chain)
 $9E8A LD A,(IY+$01)  ;
 $9E8D SBC A,(IX+$01) ;
 $9E90 LD A,(IY+$02)  ;
 $9E93 SBC A,(IX+$02) ;
 $9E96 LD A,(IY+$03)  ;
 $9E99 SBC A,(IX+$03) ;
 $9E9C JR C,$9EAA     ; table entry >= score? -> next entry
 $9E9E LD DE,$0007    ;
 $9EA1 ADD IY,DE      ; IY += 7 (next table row)
 $9EA3 DJNZ $9E84     ; loop 4 bytes; no qualifying row -> fall through
 $9EA5 POP IY         ; restore IY
 $9EA7 EI             ; EI
 $9EA8 OR A           ;
 $9EA9 RET            ; RET (no new high score)
*$9EAA PUSH IY        ; save insertion point (IY) into DE
 $9EAC POP DE         ;
 $9EAD LD IY,$9D44    ; IY -> end of hiscore table (#R$9D44)
*$9EB1 PUSH IY        ;
 $9EB3 POP HL         ;
 $9EB4 LD A,L         ; A = low byte of IY
 $9EB5 CP E           ;
 $9EB6 JR NZ,$9EBC    ; not yet at insertion point? keep shifting
 $9EB8 LD A,H         ;
 $9EB9 CP D           ;
 $9EBA JR Z,$9ECF     ; reached insertion point -> store new score
*$9EBC LD B,$07       ; B = 7 (bytes per table row)
*$9EBE DEC IY         ; shift row down: IY -= 1
 $9EC0 LD A,(IY+$00)  ; A = byte to shift
 $9EC3 INC IY         ;
 $9EC5 LD (IY+$06),A  ; store into next row (+6)
 $9EC8 DEC IY         ;
 $9ECA DJNZ $9EBE     ; loop 7 bytes; then next row down
 $9ECC JP $9EB1       ;
*$9ECF LD A,(IX+$00)  ; A = new score byte (IX)
 $9ED2 LD (IY+$00),A  ; store into table row (IY)
 $9ED5 LD A,(IX+$01)  ;
 $9ED8 LD (IY+$01),A  ;
 $9EDB LD A,(IX+$02)  ;
 $9EDE LD (IY+$02),A  ;
 $9EE1 LD A,(IX+$03)  ;
 $9EE4 LD (IY+$03),A  ;
 $9EE7 PUSH IY        ; IY -> IX (restore active player's score ptr)
 $9EE9 POP IX         ;
 $9EEB POP IY         ; restore IY
 $9EED EI             ; EI
 $9EEE SCF            ; SCF (new high score inserted)
 $9EEF RET            ;

; Unused
s$9EF0 DEFS $01
 $9EF1 DEFM "yvwxpxhx"

; Data block at 9EF9
b$9EF9 DEFB $88,$00,$00,$00,$00,$00,$68,$7C
 $9F01 DEFB $90,$90,$90
 $9F04 DEFM "xpphhyzyzy"

; Unused
s$9F0E DEFS $03

