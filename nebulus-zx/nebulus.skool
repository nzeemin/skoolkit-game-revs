 $B73B SUB $08       ;
 $B73D LD H,A        ;

; PLOT_MASKED_ROW -- plot a 3-cell sprite slice at HL: AND the left edge cell
; with mask D, write the two middle cells = B, AND the right edge with mask E
; restores L and bumps H.
;
; Used by the routines at #R$B636 and #R$B72F.
;
; .
;
; In: HL,B,D,E.
