*$B0BE LD A,($6021)  ; A = sub-column phase ($6021)
 $B0C1 OR A          ;
 $B0C2 JR Z,$B0D1    ; phase 0 -> straight into the strip blit below
 $B0C4 CP $02        ; {phase 2 -> variant at $B126
 $B0C6 JP Z,$B126    ; }
