 $B5D8 RET           ;

; GET_SCREEN_ADDR -- pixel address for (row=H, col-in-row=L).
;
; Used by the routines at #R$A781, #R$AC5E, #R$B636, #R$B74D, #R$B8A8, #R$B965
; and #R$B9D6.
;
; .
;
; Indexes scr_row_addr_tbl ($5D00, 2 bytes/row) at 2*H to fetch the row base,
; then adds L to get the final byte address in HL.
; .
; In: H=row 0..191, L=byte offset within row.
; .
; Out: HL=screen addr.
; .
; Clobbers A preserves DE.
; .
; i8080 PORT: replace table lookup with row*32 + col on a linear framebuffer
; (no scan-order table needed).
@label=get_screen_addr
c$B5D9 PUSH DE       ;
 $B5DA LD D,L        ;
 $B5DB LD A,H        ;
 $B5DC ADD A,A       ; L = 2*H = table index
 $B5DD LD L,A        ;
 $B5DE LD A,$5D      ; H = $5D + carry -> HL -> scr_row_addr_tbl[H]
 $B5E0 ADC A,$00     ;
 $B5E2 LD H,A        ;
 $B5E3 LD A,D        ;
 $B5E4 ADD A,(HL)    ; A = row base low + col offset
 $B5E5 INC L         ;
 $B5E6 LD H,(HL)     ; H = row base high
 $B5E7 LD L,A        ;
 $B5E8 POP DE        ;
 $B5E9 RET           ;

; BUILD_ROW_ADDR_TABLE -- precompute 192 screen-row addresses into
; scr_row_addr_tbl ($5D00, little-endian words).
;
; Used by the routine at #R$B546.
;
; .
;
; For each row y in 0..191 it builds the ZX pixel address:
; .
; high = $40 | (y&7) | ((y>>3)&$18)
; .
; low  = (y&$38)<<2 i.e.
; .
; the famous ZX scan-order layout (Y bits split across the address).
; .
; get_screen_addr then just indexes this table.
; .
; i8080 PORT: on a linear framebuffer this table is row*width -- trivial this
; builder can be dropped.
@label=build_row_addr_table
c$B5EA LD DE,$5D00   ; DE -> $5D00 table base
 $B5ED LD HL,$0000   ; HL: H = row counter y, builds address in HL
*$B5F0 PUSH HL       ;
 $B5F1 PUSH DE       ;
 $B5F2 LD A,H        ; (y>>3)&$18  -> D (the y bits 3..5 region)
 $B5F3 RRCA          ;
 $B5F4 RRCA          ;
 $B5F5 RRCA          ;
 $B5F6 AND $18       ;
 $B5F8 LD D,A        ;
 $B5F9 LD A,H        ;
 $B5FA AND $07       ;
 $B5FC ADD A,D       ; + (y&7) + $40 -> high byte
 $B5FD ADD A,$40     ;
 $B5FF LD D,A        ;
 $B600 LD A,H        ;
 $B601 RLC A         ; (y<<2)&$E0 -> low byte (E)
 $B603 RLC A         ;
 $B605 AND $E0       ;
 $B607 LD E,A        ;
 $B608 LD H,$00      ;
 $B60A ADD HL,DE     ; HL = full row-0 screen address
 $B60B POP DE        ;
 $B60C LD A,L        ;
 $B60D LD (DE),A     ; store LE word into table[y]
 $B60E INC DE        ;
 $B60F LD A,H        ;
 $B610 LD (DE),A     ;
 $B611 INC DE        ;
 $B612 POP HL        ;
 $B613 INC H         ;
 $B614 LD A,H        ;
 $B615 CP $C0        ; stop after row $BF (192 rows)
 $B617 JP NZ,$B5F0   ;
 $B61A RET           ;

; GET_SPRITE_DEF -- look up sprite/graphic descriptor A in the gfx_c101 table
; (A*2): unpack the frame count (top 2 bits, 0->4) into C and the bitmap
; pointer (low 6 bits + $C1xx base) into HL.
;
; Used by the routines at #R$A784, #R$B636 and #R$B74D.
;
; .
;
; In: A=sprite id.
; .
; Out: HL=bitmap, C=frames.
; .
; Clobbers: A,HL.
@label=get_sprite_def
c$B61B ADD A,A       ;
 $B61C LD L,A        ;
 $B61D LD H,$00      ;
 $B61F LD DE,$C101   ;
 $B622 ADD HL,DE     ;
 $B623 LD A,(HL)     ;
 $B624 RLCA          ;
 $B625 RLCA          ;
 $B626 AND $03       ;
 $B628 LD C,A        ;
 $B629 JR NZ,$B62D   ;
 $B62B LD C,$04      ;
*$B62D LD A,(HL)     ;
 $B62E AND $3F       ;
 $B630 ADD A,$C1     ;
 $B632 DEC HL        ;
 $B633 LD L,(HL)     ;
 $B634 LD H,A        ;
 $B635 RET           ;

; SELECT_PLAYER_SPRITE -- pick the player's current sprite frame from $60C1
; plus facing ($60BE bit7) and player_state, applying frame-base offsets ($1F
; walking-left / $44 walking-right).
;
; Used by the routine at #R$A787.
;
; .
;
; RET early if $60C2==0 (nothing to draw).
; .
; Clobbers: A,H,L.
@label=select_player_sprite
c$B636 LD A,($60C2)  ;
 $B639 OR A          ;
 $B63A RET Z         ;
 $B63B LD A,($60C0)  ;
 $B63E CP $08        ;
 $B640 LD A,($60C1)  ;
 $B643 JR NZ,$B654   ;
 $B645 LD HL,$60BE   ;
 $B648 BIT 7,(HL)    ;
 $B64A JR Z,$B650    ;
 $B64C ADD A,$1F     ;
 $B64E JR $B661      ;
*$B650 ADD A,$44     ;
 $B652 JR $B661      ;
*$B654 LD H,A        ;
 $B655 AND $7F       ;
 $B657 BIT 7,H       ;
 $B659 JR NZ,$B65F   ;
 $B65B ADD A,$25     ;
 $B65D JR $B661      ;
*$B65F ADD A,$00     ;
*$B661 CALL $B61B    ;
 $B664 PUSH HL       ;
 $B665 PUSH BC       ;
 $B666 LD A,($60BA)  ;
 $B669 LD HL,$6030   ;
 $B66C SUB (HL)      ;
 $B66D ADD A,A       ;
 $B66E LD C,A        ;
 $B66F LD A,$A4      ;
 $B671 SUB C         ;
 $B672 LD H,A        ;
 $B673 LD L,$0E      ;
 $B675 LD ($B5C9),HL ;
 $B678 CALL $B5D9    ;
 $B67B EX DE,HL      ;
 $B67C POP BC        ;
 $B67D POP HL        ;
 $B67E LD ($6000),SP ;
 $B682 DI            ;
 $B683 LD SP,HL      ;
 $B684 EX DE,HL      ;
 $B685 LD B,$0A      ;
 $B687 BIT 2,C       ;
 $B689 JP NZ,$B6BC   ;
 $B68C INC L         ;
*$B68D POP DE        ;
 $B68E LD A,(HL)     ;
 $B68F AND E         ;
 $B690 OR D          ;
 $B691 LD (HL),A     ;
 $B692 INC L         ;
 $B693 POP DE        ;
 $B694 LD A,(HL)     ;
 $B695 AND E         ;
 $B696 OR D          ;
 $B697 LD (HL),A     ;
 $B698 DEC L         ;
 $B699 INC H         ;
 $B69A POP DE        ;
 $B69B LD A,(HL)     ;
 $B69C AND E         ;
 $B69D OR D          ;
