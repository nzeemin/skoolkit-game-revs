; Title menu
;
; Used by the routine at #R$802B.
;
; .
;
; Title screen, option menu and attract/demo loop.
; .
; (TASK.md guessed 'init level data' here -- WRONG verified to be the
; front-end.) Blits the 24-row NEBULUS logo bitmap from rt_be00 ($BE00) into
; the screen, paints attribute rows, and prints the option lines (1/2 PLAYER
; etc.) via draw_menu_text.
; .
; Runs proc_table as an attract demo until input, then polls the keyboard ($FE)
; and Kempston ($1F) for select/start.
; .
; Entry: ticks the background animation once, starts music 0, resets the
; page/timeout/active flags (#R$9B87=0 main menu page, $9B88=$C0 attract
; timeout, $9B89=0 not-yet-active), falls into #R$9BA5.
; .
; menu_page
@label=title_menu
c$9B8A CALL $9CEB    ; tick background animation once
 $9B8D LD A,$00      ; A = tune 0
 $9B8F CALL $A197    ; Start music
 $9B92 XOR A         ; {clear menu_page (#R$9B87=0, main menu)
 $9B93 LD ($9B87),A  ; }
 $9B96 LD A,$C0      ; {attract_timer = $C0
 $9B98 LD ($9B88),A  ; }
 $9B9B XOR A         ; {menu_active = 0
 $9B9C LD ($9B89),A  ; }
 $9B9F JP $9BA5      ;

; Title menu redraw anim
;
; Used by the routine at #R$9BA5.
;
; .
;
; Re-ticks the background animation (falls straight into #R$9BA5) -- the
; re-entry point used when the attract timer flips between the menu page and
; the hiscore page.
@label=title_menu_redraw_anim
c$9BA2 CALL $A778    ;

; Title menu draw
;
; Used by the routine at #R$9B8A.
;
; .
;
; Draws the current page: if menu_page (#R$9B87)!=0, shows the hiscore table
; (draw_hiscore_screen + draw_menu_text for the CONTROLS/SOUND lines) and skips
; straight to the input poll ($9C23).
; .
; Otherwise draws the main menu: blits the 24-row NEBULUS logo from $BE00 in 3
; vertical thirds (A=0/8/16), each blitting 16 columns x 7 source bytes/column
; via jp_get_screen_addr paints 3 header attribute rows ($58C8/$58E8/$5908,
; colours $47/$46/$45) via fill_attr_row prints the 3 option lines ("1 PLAYER"
; etc, strings at #R$98C8/#R$98D4/#R$98E2) at rows $0C/$0E/$10 then
; draw_menu_text for the CONTROLS/SOUND state lines.
@label=title_menu_draw
