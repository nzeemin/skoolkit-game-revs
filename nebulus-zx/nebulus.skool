 $BB45 DEFB $BA,$BA,$BA,$BA,$BA,$BA,$BA,$BA
 $BB4D DEFB $BA,$BA,$BA,$BA,$BA,$BA,$BA,$BA
 $BB55 DEFB $BA,$BA,$BA,$BA,$BA,$BA,$BA,$BA
 $BB5D DEFB $BA,$BA,$BA,$BA,$BA,$BA,$BA,$BA
 $BB65 DEFB $BA,$BA,$BA,$BA,$BA,$BA,$BA,$BA
