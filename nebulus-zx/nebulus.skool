; ROTATE_TOWER -- rotate the tower by signed B: tower_height = (tower_height +
; B) AND $7F (128-column wrap), saving the old value in $6033.
;
; Used by the routines at #R$8460, #R$84B9, #R$85DB, #R$868D and #R$8736.
;
; .
;
; Tests the new position for a wall/collision ($9330) on collision (NC) it
; reverts tower_height.
; .
; In: B=delta.
; .
; Out: CY=moved.
; .
; Clobbers: A,B,HL.
@label=rotate_tower
c$8411 LD B,A        ;
 $8412 LD A,($60B9)  ;
 $8415 LD ($6033),A  ;
 $8418 ADD A,B       ;
 $8419 AND $7F       ;
 $841B LD ($60B9),A  ;
 $841E LD HL,($60BA) ;
 $8421 CALL $9330    ;
 $8424 JR NC,$842E   ;
 $8426 LD A,($6033)  ;
 $8429 LD ($60B9),A  ;
 $842C SCF           ;
 $842D RET           ;
*$842E OR A          ;
 $842F RET           ;

