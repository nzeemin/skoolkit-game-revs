 $AB87 XOR A         ;
*$AB88 LD (HL),A     ;
 $AB89 INC HL        ;
 $AB8A LD (HL),A     ;
 $AB8B INC HL        ;
 $AB8C LD (HL),A     ;
 $AB8D ADD HL,DE     ;
 $AB8E LD (HL),A     ;
 $AB8F INC HL        ;
 $AB90 LD (HL),A     ;
 $AB91 INC HL        ;
 $AB92 LD (HL),A     ;
 $AB93 INC HL        ;
 $AB94 DJNZ $AB88    ;
 $AB96 RET           ;

