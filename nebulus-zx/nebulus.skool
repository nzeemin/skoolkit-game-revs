 $B39E CP $FF          ;
 $B3A0 JR NZ,$B3B9     ;
 $B3A2 LD A,(HL)       ;
 $B3A3 AND $0C         ;
 $B3A5 CP $04          ;
 $B3A7 JR Z,$B3BD      ;
 $B3A9 LD A,(HL)       ;
 $B3AA LD (IX+$0C),A   ;
 $B3AD LD (IX+$04),L   ;
 $B3B0 LD (IX+$08),H   ;
 $B3B3 LD (IX+$00),$7D ;
 $B3B7 SCF             ;
 $B3B8 RET             ;
*$B3B9 INC IX          ;
 $B3BB DJNZ $B39B      ;
*$B3BD OR A            ;
 $B3BE RET             ;

