; SETUP_IM2 -- install the Z80 mode-2 interrupt vector.
;
; Used by the routine at #R$8000.
;
; .
;
; Builds a 257-byte page of identical bytes at $BB00..$BC00 so that, whatever
; the data-bus byte is at IRQ time, the Z80 reads the 16-bit vector $BABA from
; table[$FF]/table[$100].
; .
; At $BABA it plants 'JP $83CA' -- the actual interrupt service routine.
; .
; In:  nothing.
; .
; Out: IM 2 active, IFF1=1 (interrupts enabled).
; .
; Clobbers: A, B, HL, I.
; .
; i8080 PORT: the 8080 has no IM 2.
; .
; The porter must emulate this
@label=setup_im2
c$83AD DI            ; no IRQs while we build the vector table (i8080: DI)
 $83AE LD HL,$BB00   ; HL -> vector-table page base $BB00
 $83B1 LD A,H        ; A = $BB = high byte of the table page
 $83B2 LD I,A        ; I = $BB: IM2 reads vectors from page I (Z80-only)
 $83B4 DEC A         ; A = $BA = the byte we flood the table with
 $83B5 LD B,$00      ; B = 0 -> DJNZ loops 256 times (Z80 DJNZ: dec B, jump nz)
*$83B7 LD (HL),A     ; table[i] = $BA
 $83B8 INC HL        ; next table slot
 $83B9 DJNZ $83B7    ; fill all 256 bytes of $BB00..$BBFF (i8080: DCR B/JNZ
                     ; loop)
 $83BB LD (HL),A     ; +1 byte at $BC00 = $BA: covers the table[$100]
                     ; off-by-one
 $83BC LD H,A        ; H = $BA
 $83BD LD L,A        ; L = $BA  -> HL = $BABA (the vector the IRQ will fetch)
 $83BE LD (HL),$C3   ; plant C3 = JP opcode at $BABA
 $83C0 INC L         ;
 $83C1 LD (HL),$CA   ; low byte of JP target -> $CA
 $83C3 INC L         ;
 $83C4 LD (HL),$83   ; high byte -> $83, so vector = 'JP $83CA' = irq_handler
 $83C6 IM 2          ; switch CPU to interrupt mode 2 (Z80-only)
 $83C8 EI            ; interrupts on

; Routine at 83C9
;
; Used by the routine at #R$83CA.
@label=im2_noop_ret
c$83C9 RET           ; return to game_entry

; IRQ_HANDLER -- IM 2 interrupt service routine (50 Hz vblank).
;
; Used by the routine at #R$BABA.
;
; .
;
; Reached via the planted vector at $BABA -> JP here.
; .
; It is a deliberate NEAR-NO-OP: 'CALL $83C9' targets the bare RET at the end
; of setup_im2, so the call does nothing.
; .
; The point is to REPLACE the 48K ROM's own interrupt routine (which scans the
; keyboard and bumps the FRAMES sysvar) with a handler that has no side
; effects, while still letting interrupts fire.
; .
; Verified: no code anywhere
@label=irq_handler
c$83CA CALL $83C9    ; CALL $83C9 = the RET in setup_im2: a no-op (neutralized
                     ; ISR)
 $83CD EI            ; re-enable interrupts
 $83CE RETI          ; RETI: return from maskable interrupt (Z80-only

