; .
; Clobbers: A,B,C,H
@label=restore_col_state
c$8311 LD A,($603F)  ;
 $8314 CP $01        ;
 $8316 LD A,$00      ;
 $8318 LD HL,$6040   ;
 $831B JR Z,$831F    ;
 $831D INC A         ;
