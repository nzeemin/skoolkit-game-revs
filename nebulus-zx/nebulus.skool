; INIT_COL_STATE -- seed BOTH players' saved column-mask words.
;
; Used by the routine at #R$802B.
;
; .
;
; HL = (pad_var_8005) [low=0 at level start], then H forced to $FF (all 8
; columns present) the same $FF00|sel is written to the P1 ($8301) and P2
; ($8303) slots.
; .
; Called once per level build.
; .
; In: pad_var_8005.
; .
; Out: ($8301),($8303).
; .
; Clobbers: A,HL.
@label=init_col_state
c$8305 LD HL,($8005) ;
 $8308 LD H,$FF      ;
 $830A LD ($8301),HL ;
 $830D LD ($8303),HL ;
 $8310 RET           ;

; RESTORE_COL_STATE -- expand a player's saved column bitmask into the 8-byte
; col_flags[] array ($60CB) and mirror its counter into $6039.
;
; Used by the routine at #R$802B.
;
; .
;
; lives_p1 ($6040) selects the slot (0=P1 word $8301, else P2 word $8303) --
; here $6040 doubles as an ACTIVE-PLAYER INDEX, not a life count.
; .
; running_flag gates an alternate (re)init path.
; .
; Unpacks via RR through col_flags[] returns CY=1 on success.
; .
